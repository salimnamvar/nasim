#!/usr/bin/env bash
# nasim — thin launcher for the Python implementation (src/nasim).
#
# Resolves the package: prefer an installed `nasim` console script / importable
# module; otherwise fall back to the in-repo src/ tree so the tool runs straight
# from a checkout without installation.
#
# All real logic lives in src/nasim/ (see nasim.cli). This shim only locates the
# package and hands off argv.
set -euo pipefail

PY="${NASIM_PYTHON:-python3}"

# Repo layout: this file is <repo>/bin/nasim ; package is <repo>/src/nasim.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_SRC="$SCRIPT_DIR/../src"

if "$PY" -c 'import nasim' >/dev/null 2>&1; then
    # Installed (pip) or already importable.
    exec "$PY" -m nasim "$@"
elif [[ -d "$REPO_SRC/nasim" ]]; then
    # Run from the checkout without installation.
    exec env PYTHONPATH="$REPO_SRC${PYTHONPATH:+:$PYTHONPATH}" "$PY" -m nasim "$@"
else
    echo "nasim: cannot locate the nasim Python package (install with 'pip install -e .' or run from the repo)" >&2
    exit 1
fi
