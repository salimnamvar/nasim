# nasim environment example
# Copy to .env and edit as needed.

# Current PoC uses CLI flags. Future layered config will read these.

# NASIM_MODEL=qwen2.5-coder:14b
# NASIM_OLLAMA_URL=http://localhost:11434
# NASIM_SAFETY_MODE=ask          # ask | auto | off
# NASIM_SESSION_DIR=~/.nasim/sessions
# NASIM_LOG_LEVEL=INFO
