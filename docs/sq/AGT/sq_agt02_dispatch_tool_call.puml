@startuml sq_agt02_dispatch_tool_call
' ============================================================
' Title:     AGT-02 — DISPATCH Tool Call
' Boundary:  nasim code agent CLI
' Purpose:   Single tool dispatch with permission check
' Milestone: v1.0
' Version:   2.0.0
' Source:    docs/audit/audit_2026-06-20_capability-and-architecture.md
' Review:    —
' ============================================================

participant "AgentOrchestrator" as agent
participant "PermissionGate" as gate
participant "ToolRegistry" as registry

box "Agent Layer" #E3F2FD
end box
box "Tool Layer" #F3E5F5
end box

note over agent
  Scope:          Single tool call dispatch with safety check
  Preconditions:  LLM returned tool_calls
  Excludes:       LLM call, conversation management
  Contexts:       Called by AGT-01 (PROCESS User Task)
  Rollback:       Tool error -> error ToolResult
  Design:         Permission gate before every tool execution
end note

agent -> gate : check(tool_name, config.safety_mode)
ref over gate
  SAF-01: CHECK Tool Permission
end ref

alt permission rejected
    gate --> agent : rejected
    agent -> agent : skip tool, append "Tool skipped: permission denied"
else permission approved
    gate --> agent : approved
    agent -> registry : execute(tool_name, args)
    registry -> registry : lookup tool handler
    registry -> registry : handler(**args)
    
    break Tool execution fails
        registry --> agent : ToolResult(success=False, error="...")
    end
    
    registry --> agent : ToolResult(success=True, content="...")
end

agent -> agent : append tool result to messages

note over agent
  Flow:    tool call -> permission check -> execute -> ToolResult
  State:   THINKING -> TOOL_EXEC -> THINKING (or AWAITING_APPROVAL)
  Failure: Permission denied or tool error -> error ToolResult
  Success: ToolResult appended to messages
end note

@enduml
