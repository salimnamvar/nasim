@startuml cl_runtime_model
' @cl-type runtime
' ============================================================
' Title:     nasim — Runtime Model
' Boundary:  NASIM Application (C4 container)
' Purpose:   Core runtime classes mapped to C4 components
' Milestone: v1.0
' Version:   6.0.0
' Source:    docs/C4/c4_nasim_component.puml (v11.3.0)
' Review:    —
' Note:      Runtime structure diagram. All classes are owned by a C4
'            component (controller, service, or repository). Classes
'            without a C4 prefix are value types or events internal to
'            their owning component.
' ============================================================

skinparam classAttributeIconSize 0

package "Controller Layer" #E8EAF6 {
    class CLI Adapter {
        + process_input(raw_input) : AgentEvent
        + parse_args(argv) : Namespace
        + dispatch_slash_command(cmd) : Response
        + stream_output(events) : None
        + request_approval(action) : bool
    }

    class MCP Adapter {
        + expose_tools(registry) : list[ToolDef]
        + handle_call(tool_name, args) : ToolResult
        + start_transport(transport_type) : None
        + discover_tools() : list[MCPToolDef]
    }

    class Agent Controller {
        - adapters : dict[str, Adapter]
        - services : dict[str, Service]
        + handle_input(source, input) : Iterator[AgentEvent]
        + delegate_to_service(service, operation, payload) : Result
        + route_to_adapter(adapter_id) : None
        + register_adapter(source, adapter)
    }
}

package "Service Layer" #E8F5E9 {
    class Session Service {
        + create_session() : Session
        + load_session(session_id) : Session
        + save_session(session)
        + snapshot_session(session_id) : str
        + revert_session(session_id, snapshot_id)
        + list_sessions() : list[SessionSummary]
    }
}

package "Provider Layer" #FFF3E0 {
    interface Provider {
        + model_name : str
        + capabilities : ProviderCapabilities
        + chat(messages, tools) : LLMResponse
        + chat_stream(messages, tools) : Iterator[str | ToolCall]
    }

    class LiteLLMProxy {
        + model_name : str
        + capabilities : ProviderCapabilities
        + chat(messages, tools) : LLMResponse
        + chat_stream(messages, tools) : Iterator
    }

    class ProviderCapabilities {
        + supports_tools : bool
        + supports_vision : bool
        + supports_streaming : bool
        + max_context : int
        + supports_prompt_caching : bool
    }

    class ProviderFactory {
        + create_provider(config) : Provider
        + select_backend(name) : type
    }

    class ModelRouter {
        + select_model(task_type) : str
        + apply_fallback(model) : str
        + classify_task(input) : str
    }

    class LLMResponse {
        + content : str
        + tool_calls : list[ToolCall]
        + done : bool
        + total_duration_ms : float
        + eval_count : int
    }

    class ToolCall {
        + name : str
        + arguments : dict
        + id : str
    }

    abstract class RoutingStrategy {
        + {abstract} route(task, providers) : str
    }

    class TaskClassifierStrategy {
        + route(task, providers) : str
    }

    class CapabilityMatchStrategy {
        + route(task, providers) : str
    }

    class CostOptimizationStrategy {
        + route(task, providers) : str
    }

    class RoleStrategy {
        + route(role, providers) : str
    }

    class ModelRoleRegistry {
        + get_preferred_model(role) : str
    }
}

package "Agent Layer" #E3F2FD {
    class AgentOrchestrator {
        - provider : Provider
        - tool_registry : ToolRegistry
        - history : ConversationHistory
        - perm_gate : PermissionGate
        - plan : PlanSession
        - hooks : list[Hook]
        - router : ModelRouter
        + PROCESS(user_input) : Iterator[AgentEvent]
        + reset()
    }

    class ConversationHistory {
        - messages : list[dict]
        - token_count : int
        - context_budget : int
        + add_message(msg)
        + get_messages() : list[dict]
        + reset()
        + check_budget() : bool
    }

    class ContextCompactor {
        + compact(messages, budget) : list[dict]
        - summarize_old_exchanges(messages) : str
        - extract_oldest(messages, count) : list[dict]
    }

    class PermissionGate {
        - mode : str
        + check(tool_name, safety_mode) : bool
        + apply_mode(mode)
    }

    class PlanSession {
        - pending_calls : list[tuple]
        + queue_tool_call(name, args)
        + approve_plan() : list[ToolResult]
        + display_plan() : str
        + is_active() : bool
    }

    abstract class AgentEvent
    class TextChunk {
        + text : str
    }
    class ToolStart {
        + name : str
        + args : dict
    }
    class ToolResultEvent {
        + name : str
        + success : bool
        + content : str
        + error : str | None
    }
    class Error {
        + message : str
    }
    class Done {
        + final_text : str
    }
}

package "Tool Layer" #F3E5F5 {
    abstract class Tool {
        + name : str
        + description : str
        + parameters : dict
        + safe : bool
        + execute(**args) : ToolResult
    }

    class ToolRegistry {
        - tools : dict[str, Tool]
        + register(tool)
        + execute(name, args) : ToolResult
        + get_tool(name) : Tool
        + get_definitions() : list[dict]
    }

    class ReadFileTool {
        + execute(path, offset, limit) : ToolResult
    }
    class WriteFileTool {
        + execute(path, content) : ToolResult
    }
    class EditFileTool {
        + execute(path, old_string, new_string) : ToolResult
    }
    class GrepTool {
        + execute(pattern, path, case_sensitive, include_glob) : ToolResult
    }
    class GlobTool {
        + execute(pattern, base_path) : ToolResult
    }
    class FindFileTool {
        + execute(name_pattern, path, max_depth) : ToolResult
    }
    class ShellTool {
        + execute(command, timeout) : ToolResult
    }
    class DirTool {
        + execute(path) : ToolResult
    }
    class WebFetchTool {
        + execute(url, timeout) : ToolResult
    }
    class WebSearchTool {
        + execute(query, num_results) : ToolResult
    }
    class GitTool {
        + execute(action, args) : ToolResult
    }
    class LspTool {
        + execute(operation, file, position) : ToolResult
    }

    class MCPToolAdapter {
        + execute(tool_name, args) : ToolResult
        + list_tools() : list[MCPToolDef]
    }

}

package "Config Layer" #E0F7FA {
    class Config {
        + provider : str
        + model : str
        + server_url : str
        + safety_mode : str
        + context_budget : int
        + timeout : int
        + max_iterations : int
        + mcp_servers : list[dict]
        + server_port : int
        + hooks : list[dict]
    }

    class ConfigLoader {
        + load(cli_args) : Config
        - read_global_yaml() : dict
        - read_project_yaml() : dict
        - read_env_vars() : dict
        - merge(layers) : Config
        - validate(config)
    }
}

package "Session Layer" #F1F8E9 {
    class Session {
        + id : str
        + created_at : datetime
        + messages : list[dict]
        + metadata : dict
    }

    class SessionStore {
        + save(session_id, messages)
        + load(session_id) : Session
        + load_latest() : Session
        + list_sessions() : list[tuple]
    }

    class History Repository {
        + save_snapshot(session_id, turn) : str
        + load_snapshot(snapshot_id) : Session
        + search_sessions(query) : list[SearchResult]
        + revert_to(session_id, snapshot_id)
        + list_snapshots(session_id) : list[SnapshotSummary]
    }
}

package "Server Layer" #E0F2F1 {
    class ServerApp {
        + create_app(config, agent) : ASGIApp
        + add_routes(router)
    }

    class ServerRouter {
        + create_session(request) : Response
        + send_message(session_id, message) : Response
        + stream_response(session_id) : EventSource
        + get_messages(session_id) : Response
        + list_tools() : Response
        + get_config() : Response
    }

    class SSEHandler {
        + stream_events(events) : EventSourceResponse
    }

}

package "Hook Layer" #E8EAF6 {
    class Hook {
        + name : str
        + event : str
        + handler : Callable
    }

    class HookResult {
        + allow : bool
        + modified_input : dict | None
        + message : str | None
    }
}

package "Plugin Layer" #FFF3E0 {
    class PluginLoader {
        + discover(plugin_dir) : list[PluginManifest]
        + load(manifest) : Plugin
        + register_tools(plugin, registry)
        + register_hooks(plugin, hook_manager)
    }

    class PluginManifest {
        + name : str
        + version : str
        + description : str
        + tools : list[str]
        + hooks : list[str]
    }

    class Plugin {
        + manifest : PluginManifest
        + get_tools() : list[Tool]
        + get_hooks() : list[Hook]
    }
}

package "Repo Intelligence Layer" #FBE9E7 {
    class SymbolGraph {
        + add_node(symbol)
        + add_edge(source, target, type)
        + pagerank(personalization) : dict
    }

    class RankingService {
        + rank(graph, chat_files, budget) : list[RankedSymbol]
    }

    class SemanticSearchService {
        + search(query_embedding, top_k) : list[SearchResult]
    }

    class RepoMapBuilder {
        + build(ranked_symbols, token_budget) : str
    }
}

package "Edit Strategy Layer" #FFF8E1 {
    abstract class EditStrategyManager {
        + {abstract} select(model_caps) : EditStrategy
        + {abstract} apply(strategy, original, instructions) : EditResult
    }

    class SearchReplaceCoder {
        + apply(original, instructions) : EditResult
    }

    class WholeFileCoder {
        + apply(original, instructions) : EditResult
    }

    class UnifiedDiffCoder {
        + apply(original, instructions) : EditResult
    }

    class FencedBlockCoder {
        + apply(original, instructions) : EditResult
    }

    class FunctionLevelCoder {
        + apply(original, instructions) : EditResult
    }

    class DiffSandboxCoder {
        + apply(original, instructions) : EditResult
    }

    class ArchitectCoder {
        + apply(original, instructions) : EditResult
    }

    class InlinePatchCoder {
        + apply(original, instructions) : EditResult
    }

    class StrategySelector {
        + select(caps) : EditStrategy
    }
}

package "Evaluation Layer" #E8F5E9 {
    class EvaluationEngine {
        + evaluate(task_result) : QualitySignal
        + should_retry(signal) : bool
    }

    class SuccessCheckRunner {
        + run(checks) : bool
    }

    class LLMReviewer {
        + review(submission) : QualitySignal
    }

    class RetryCoordinator {
        + retry(task, feedback)
        + on_failure(task)
    }

    class RepetitionDetector {
        + detect(tool_calls) : bool
    }

    class TurnBudgetInjector {
        + inject(turn_num, max_turns) : str
    }
}

package "Wire Log Layer" #E3F2FD {
    class WireLog {
        + append(event)
        + read() : Iterator[WireEvent]
        + seek(turn) : WireEvent
    }

    class WireAppender {
        + write(event)
    }

    class WireReader {
        + scan() : Iterator[WireEvent]
        + seek(turn_number) : WireEvent
    }

    class TurnIndex {
        + get_offset(turn) : int
        + add_turn(turn, offset)
    }


}

package "Context Graph Layer" #F3E5F5 {
    class ContextGraph {
        + add_node(node)
        + add_edge(source, target, type)
        + get_messages() : list[dict]
    }

    class ContextNode {
        + type : NodeType
        + content : str
        + token_count : int
    }

    class ContextEdge {
        + type : EdgeType
        + source : ContextNode
        + target : ContextNode
    }

    class PipelineOrchestrator {
        + process(graph) : ContextGraph
    }

    class TruncationProcessor {
        + process(graph) : ContextGraph
    }

    class DistillationProcessor {
        + process(graph) : ContextGraph
    }

    class InjectionProcessor {
        + process(graph) : ContextGraph
    }

    class CompactionProcessor {
        + process(graph) : ContextGraph
    }

    class TokenBudgetTracker {
        + count(graph) : int
        + check_budget(graph) : bool
    }
}

package "Memory Layer" #F1F8E9 {
    class MemoryRetriever {
        + retrieve(query, scope) : list
        + hybrid_search(query) : list
    }

    class MemoryIndexer {
        + index(entry)
        + reindex()
    }

    class MemoryStore {
        + save(entry)
        + load(key) : KnowledgeEntry
        + search(query, top_k) : list[SearchResult]
        + scope(session_id) : list
    }
}

package "Data Store Layer" #FCE4EC {
    class WireLogStore {
        + append(event)
        + read(from_turn, to_turn) : list[WireEvent]
        + seek(turn) : WireEvent
        + checkpoint(session_id)
        + fork(session_id, from_turn) : str
    }

    class ConfigStore {
        + load() : Config
        + save(config)
        + list_profiles() : list[str]
        + switch_profile(name)
    }
}

package "Sandbox Layer" #FFF8E1 {
    class EditStagingArea {
        + stage(file_path, content)
        + get_original(file_path) : str
    }

    class DiffComputer {
        + compute(original, staged) : str
    }

    class DiffPresenter {
        + render(diff) : str
    }

    class StagedApplicator {
        + apply_all(staging_area)
    }
}

' Relationships
Provider <|.. LiteLLMProxy
ProviderFactory --> Provider : creates
Provider --> LLMResponse : returns
Provider --> ProviderCapabilities : declares
LLMResponse --> ToolCall : contains
ModelRouter --> Provider : selects
ModelRouter --> ProviderCapabilities : queries
RoutingStrategy <|.. TaskClassifierStrategy
RoutingStrategy <|.. CapabilityMatchStrategy
RoutingStrategy <|.. CostOptimizationStrategy
RoleStrategy --> ModelRoleRegistry : uses

AgentOrchestrator --> Provider : uses
AgentOrchestrator --> ToolRegistry : dispatches to
AgentOrchestrator --> ConversationHistory : owns
AgentOrchestrator --> PermissionGate : checks
AgentOrchestrator --> PlanSession : uses
AgentOrchestrator --> AgentEvent : yields
AgentOrchestrator --> SessionStore : loads/saves
AgentOrchestrator --> ModelRouter : routes models
AgentOrchestrator --> EditStrategyManager : selects strategy
AgentOrchestrator --> EvaluationEngine : evaluates tasks
AgentOrchestrator --> WireLog : appends events
AgentOrchestrator --> ContextGraph : processes context

ConversationHistory --> ContextCompactor : triggers
ContextCompactor --> Provider : secondary call

AgentEvent <|-- TextChunk
AgentEvent <|-- ToolStart
AgentEvent <|-- ToolResultEvent
AgentEvent <|-- Error
AgentEvent <|-- Done

ToolRegistry --> Tool : manages
Tool <|.. ReadFileTool
Tool <|.. WriteFileTool
Tool <|.. EditFileTool
Tool <|.. GrepTool
Tool <|.. GlobTool
Tool <|.. FindFileTool
Tool <|.. ShellTool
Tool <|.. DirTool
Tool <|.. WebFetchTool
Tool <|.. WebSearchTool
Tool <|.. GitTool
Tool <|.. LspTool
Tool <|.. MCPToolAdapter

ConfigLoader --> Config : produces
SessionStore --> Session : manages

ServerApp --> ServerRouter : uses
ServerRouter --> SSEHandler : streams via
ServerRouter --> AgentOrchestrator : delegates to
ServerRouter --> SessionStore : manages sessions
ServerRouter --> ToolRegistry : lists tools

PluginLoader --> PluginManifest : reads
PluginLoader --> Plugin : creates
Plugin --> PluginManifest : references

SymbolGraph --> RepoMapBuilder : ranked symbols

EditStrategyManager <|.. SearchReplaceCoder
EditStrategyManager <|.. WholeFileCoder
EditStrategyManager <|.. UnifiedDiffCoder
EditStrategyManager <|.. FencedBlockCoder
EditStrategyManager <|.. FunctionLevelCoder
EditStrategyManager <|.. DiffSandboxCoder
EditStrategyManager <|.. ArchitectCoder
EditStrategyManager <|.. InlinePatchCoder
StrategySelector --> EditStrategyManager : selects

EvaluationEngine --> SuccessCheckRunner : uses
EvaluationEngine --> LLMReviewer : uses
RetryCoordinator --> EvaluationEngine : triggers
RepetitionDetector --> RetryCoordinator : alerts
TurnBudgetInjector --> RetryCoordinator : injects budget

WireLog --> WireAppender : appends via
WireLog --> WireReader : reads via
WireReader --> TurnIndex : uses

ContextGraph --> ContextNode : contains
ContextGraph --> ContextEdge : contains
PipelineOrchestrator --> ContextGraph : processes
TruncationProcessor --> ContextGraph : truncates
DistillationProcessor --> ContextGraph : distills
InjectionProcessor --> ContextGraph : injects
CompactionProcessor --> ContextGraph : compacts
TokenBudgetTracker --> ContextGraph : tracks
ContextGraph --> MemoryRetriever : injects memory

' Controller & Service relationships
CLI Adapter --> Agent Controller : delegates input
MCP Adapter --> Agent Controller : delegates calls
Agent Controller --> Session Service : manages sessions
Agent Controller --> AgentOrchestrator : dispatches tasks
Agent Controller --> PermissionGate : enforces gates
Session Service --> SessionStore : persists
Session Service --> History Repository : snapshots
History Repository --> SessionStore : reads from

' Data Store relationships
MemoryStore --> MemoryRetriever : backs
WireLogStore --> WireAppender : writes via
WireLogStore --> WireReader : reads via
ConfigStore --> ConfigLoader : sources from

@enduml
