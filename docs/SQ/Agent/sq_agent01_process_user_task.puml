@startuml sq_agent01_process_user_task
' ============================================================
' Title:     AGT-01 — PROCESS User Task
' Boundary:  nasim code agent
' Purpose:   Primary orchestrator — core agentic loop
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> AgentOrchestrator
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-01 PROCESS User Task

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "AgentOrchestrator" as orchestrator
end box

== AGT-01 PROCESS User Task ==

user -> iface : POST /v1/agents/{agent_id}:process
activate iface
iface -> router : POST /v1/agents/{agent_id}:process
activate router
router -> orchestrator : AGT-01 PROCESS Task({session_id, message})
' --- Internal processing ---
activate orchestrator
orchestrator -> orchestrator : PROCESS Task
' orchestrator interacts with sub-components
activate orchestrator

alt task accepted
  ref over orchestrator : AGT-01 PROCESS Task
    ' State: <back:#43A047>RUNNING</back>
    ' Owned by: AGT-01 (SM/README.md)
  orchestrator --> router : 200 OK
  deactivate orchestrator
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  orchestrator --> router : 422 Unprocessable
  deactivate orchestrator
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
