@startuml sq_agent01_process_user_task
' ============================================================
' Title:     AGT-01 — PROCESS User Task
' Boundary:  nasim code agent
' Purpose:   Primary orchestrator — core agentic loop
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> AgentManager -> AgentStore -> AgentDirectory -> FileSystem
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-01 PROCESS User Task

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group (Service)" #FFF3E0
  participant "AgentManager" as mgr
end box
box "Agent Group (Repository)" #E8F5E9
  participant "AgentStore" as store
end box
database "AgentDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== AGT-01 PROCESS User Task ==

user -> iface : POST /v1/agents/{agent_id}:process
activate iface
iface -> router : POST /v1/agents/{agent_id}:process
activate router
router -> mgr : AGT-01 PROCESS Task({session_id, message})
activate mgr

alt task accepted
  hnote over mgr : RUNNING (#43A047)
  mgr -> store : AGT-01 PROCESS Task({session_id, message})
  activate store
  store -> dir : AGT-01 PROCESS Task({session_id, message})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
