@startuml sq_agent10_collect_subagent_result
' ============================================================
' Title:     AGENT-10 — COLLECT Subagent Result
' Boundary:  nasim code agent
' Purpose:   Gather results from child agent process
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> SubagentService -> SubagentRegistry
' SM States: COMPLETED (#2E7D32)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGENT-10 COLLECT Subagent Result

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "TaskService" as subagent
end box

box "Repository" REPOSITORY_COLOR
  participant "TaskService" as subagentRegistry
end box

== AGENT-10 COLLECT Subagent Result ==

user -> iface : POST /v1/agents/{agent_id}:collect-subagent
activate iface
iface -> router : POST /v1/agents/{agent_id}:collect-subagent
activate router
router -> subagent : AGENT-10 COLLECT Subagent Result({child_id, timeout})
activate subagent

alt result available without error
  ref over subagent : AGENT-10 COLLECT SubagentResult({child_id, timeout}) <back:#2E7D32>COMPLETED</back>
  subagent -> subagentRegistry : AGENT-10 READ SubagentResult({child_id})
  activate subagentRegistry
  subagentRegistry --> subagent : 200 OK
  deactivate subagentRegistry
  subagent --> router : 200 OK
  deactivate subagent
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else child not found
  subagent --> router : 404 NOT_FOUND\n{error: {code: "AGENT-10_NOT_FOUND", message: "Child agent not found", status: 404}}
  deactivate subagent
  router --> iface : 404 NOT_FOUND\n{error: {code: "AGENT-10_NOT_FOUND", message: "Child agent not found", status: 404}}
  iface --> user : 404 NOT_FOUND\n{error: {code: "AGENT-10_NOT_FOUND", message: "Child agent not found", status: 404}}
  deactivate router
  deactivate iface
end

@enduml
