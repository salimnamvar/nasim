@startuml sq_agent10_collect_subagent_result
' ============================================================
' Title:     AGT-10 — COLLECT Subagent Result
' Boundary:  nasim code agent
' Purpose:   Gather results from child agent process
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SubagentCoordinator
' SM States: COMPLETED (#2E7D32)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-10 COLLECT Subagent Result

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "SubagentCoordinator" as subagent
end box

== AGT-10 COLLECT Subagent Result ==

user -> iface : POST /v1/agents/{agent_id}:collect-subagent
activate iface
iface -> router : POST /v1/agents/{agent_id}:collect-subagent
activate router
router -> subagent : AGT-10 COLLECT Subagent Result({child_id, timeout})
activate subagent

alt result available
  ref over subagent : AGT-10 COLLECT Subagent Result
    ' State: <back:#2E7D32>COMPLETED</back>
    ' Owned by: AGT-10 (SM/README.md)
  subagent --> router : 200 OK
  deactivate subagent
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else child not found
  subagent --> router : 404 Not Found
  deactivate subagent
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
