@startuml sq_agent10_collect_subagent_result
' ============================================================
' Title:     AGT-10 — COLLECT Subagent Result
' Boundary:  nasim code agent
' Purpose:   Gather results from child agent process
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> AgentAPI -> AgentManager -> AgentStore -> AgentDirectory
' SM States: COMPLETED (#2E7D32)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-10 COLLECT Subagent Result

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "AgentAPI" as api
end box
box "Agent Group (Service)" #FFF3E0
  participant "AgentManager" as mgr
end box
box "Agent Group (Repository)" #E8F5E9
  participant "AgentStore" as store
end box
database "AgentDirectory" as dir

== AGT-10 COLLECT Subagent Result ==

user -> router : POST /v1/agents/{agent_id}:collect-subagent
activate router
router -> api : AGT-10 COLLECT Subagent Result({child_id, timeout})
activate api
api -> mgr : AGT-10 COLLECT Subagent Result({child_id, timeout})
activate mgr

alt result available
  hnote over mgr : COMPLETED (#2E7D32)
  mgr -> store : AGT-10 COLLECT Subagent Result({child_id, timeout})
  activate store
  store -> dir : AGT-10 COLLECT Subagent Result({child_id, timeout})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else child not found
  mgr --> api : 404 Not Found
  deactivate mgr
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end

@enduml
