@startuml sq_agent08_approve_plan
' ============================================================
' Title:     AGT-08 — APPROVE Plan
' Boundary:  nasim code agent
' Purpose:   Execute queued tool calls after user approval
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> AgentAPI -> AgentManager -> AgentStore -> AgentDirectory
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-08 APPROVE Plan

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "AgentAPI" as api
end box
box "Agent Group (Service)" #FFF3E0
  participant "AgentManager" as mgr
end box
box "Agent Group (Repository)" #E8F5E9
  participant "AgentStore" as store
end box
database "AgentDirectory" as dir

== AGT-08 APPROVE Plan ==

user -> router : POST /v1/agents/{agent_id}:approve-plan
activate router
router -> api : AGT-08 APPROVE Plan({agent_id})
activate api
api -> mgr : AGT-08 APPROVE Plan({agent_id})
activate mgr

alt plan approved
  hnote over mgr : RUNNING (#43A047)
  mgr -> store : AGT-08 APPROVE Plan({agent_id})
  activate store
  store -> dir : AGT-08 APPROVE Plan({agent_id})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else plan empty
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
