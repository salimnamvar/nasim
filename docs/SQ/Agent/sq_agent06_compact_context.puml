@startuml sq_agent06_compact_context
' ============================================================
' Title:     AGT-06 — COMPACT Context
' Boundary:  nasim code agent
' Purpose:   Summarize old exchanges when token budget exceeded
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ContextCompactor
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-06 COMPACT Context

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Agent Group (Service)" #FFF3E0
  participant "ContextCompactor" as compactor
end box

== AGT-06 COMPACT Context ==

user -> iface : POST /v1/agents/{agent_id}:compact
activate iface
iface -> router : POST /v1/agents/{agent_id}:compact
activate router
router -> compactor : AGT-06 COMPACT Context({agent_id, budget})
' --- Internal processing ---
activate compactor
compactor -> compactor : COMPACT Context
' compactor interacts with sub-components
activate compactor

alt compaction succeeds
  ref over compactor : AGT-06 COMPACT Context
    ' State: <back:#43A047>RUNNING</back>
    ' Owned by: AGT-06 (SM/README.md)
  compactor --> router : 200 OK
  deactivate compactor
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else compaction fails
  compactor --> router : 422 Unprocessable
  deactivate compactor
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
