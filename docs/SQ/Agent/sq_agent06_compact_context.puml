@startuml sq_agent06_compact_context
' ============================================================
' Title:     AGENT-06 — COMPACT Context
' Boundary:  nasim code agent
' Purpose:   Summarize old exchanges when token budget exceeded
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> ContextCompactionService -> SessionService -> SessionStore
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGENT-06 COMPACT Context

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "ContextService" as compactor
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionService" as store
end box

database "SessionStore" as storage

== AGENT-06 COMPACT Context ==

user -> iface : AGENT-06 COMPACT Context({agent_id, budget})
activate iface
iface -> router : AGENT-06 COMPACT Context({agent_id, budget})
activate router
router -> compactor : AGENT-06 COMPACT Context({agent_id, budget})
activate compactor

alt summary_quality acceptable
  ref over compactor : AGENT-06 COMPACT Context({agent_id, budget}) <back:#43A047>RUNNING</back>
  compactor -> store : AGENT-06 PERSIST Compacted({session_id, compacted_context})
  activate store
  store -> storage : AGENT-06 PERSIST Compacted({session_id, compacted_context})
  activate storage
  storage --> store : 200 OK
  deactivate storage
  store --> compactor : 200 OK
  deactivate store
  compactor --> router : 200 OK
  deactivate compactor
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else compaction fails
  compactor --> router : 500 INTERNAL\n{error: {code: "AGENT-06_COMPACT_FAILED", message: "Context compaction failed", status: 500}}
  deactivate compactor
  router --> iface : 500 INTERNAL\n{error: {code: "AGENT-06_COMPACT_FAILED", message: "Context compaction failed", status: 500}}
  iface --> user : 500 INTERNAL\n{error: {code: "AGENT-06_COMPACT_FAILED", message: "Context compaction failed", status: 500}}
  deactivate router
  deactivate iface
end

@enduml
