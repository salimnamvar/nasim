@startuml sq_agent06_compact_context
' ============================================================
' Title:     AGT-06 — COMPACT Context
' Boundary:  nasim code agent
' Purpose:   Summarize old exchanges when token budget exceeded
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> AgentAPI -> AgentManager -> AgentStore -> AgentDirectory
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-06 COMPACT Context

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "AgentAPI" as api
end box
box "Agent Group (Service)" #FFF3E0
  participant "AgentManager" as mgr
end box
box "Agent Group (Repository)" #E8F5E9
  participant "AgentStore" as store
end box
database "AgentDirectory" as dir

== AGT-06 COMPACT Context ==

user -> router : POST /v1/agents/{agent_id}:compact
activate router
router -> api : AGT-06 COMPACT Context({agent_id, budget})
activate api
api -> mgr : AGT-06 COMPACT Context({agent_id, budget})
activate mgr

alt compaction succeeds
  hnote over mgr : RUNNING (#43A047)
  mgr -> store : AGT-06 COMPACT Context({agent_id, budget})
  activate store
  store -> dir : AGT-06 COMPACT Context({agent_id, budget})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else compaction fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
