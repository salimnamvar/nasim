@startuml sq_agent06_compact_context
' ============================================================
' Title:     AGT-06 — COMPACT Context
' Boundary:  nasim code agent
' Purpose:   Summarize old exchanges when token budget exceeded
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ContextCompactor
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-06 COMPACT Context

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "ContextCompactor" as compactor
end box

== AGT-06 COMPACT Context ==

user -> iface : AGT-06 COMPACT Context({agent_id, budget})
activate iface
iface -> router : AGT-06 COMPACT Context({agent_id, budget})
activate router
router -> compactor : AGT-06 COMPACT Context({agent_id, budget})
activate compactor

alt summary_quality acceptable
  ref over compactor : AGT-06 COMPACT Context({agent_id, budget}) <back:#43A047>RUNNING</back>
  compactor --> router : 200 OK
  deactivate compactor
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else compaction fails
  compactor --> router : 500 INTERNAL\n{error: {code: "AGT-06_COMPACT_FAILED", message: "Context compaction failed", status: 500}}
  deactivate compactor
  router --> iface : 500 INTERNAL
  iface --> user : 500 INTERNAL
  deactivate router
  deactivate iface
end

@enduml
