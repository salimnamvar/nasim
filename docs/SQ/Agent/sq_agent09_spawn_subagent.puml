@startuml sq_agent09_spawn_subagent
' ============================================================
' Title:     AGT-09 — SPAWN Subagent
' Boundary:  nasim code agent
' Purpose:   Create child agent process with restricted tools
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SubagentCoordinator
' SM States: WAITING (#CE93D8)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-09 SPAWN Subagent

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Agent Group (Service)" #FFF3E0
  participant "SubagentCoordinator" as subagent
end box

== AGT-09 SPAWN Subagent ==

user -> iface : POST /v1/agents/{agent_id}:spawn-subagent
activate iface
iface -> router : POST /v1/agents/{agent_id}:spawn-subagent
activate router
router -> subagent : AGT-09 SPAWN Subagent({task_prompt, parent_id})
activate subagent

alt spawn succeeds
  ref over subagent : AGT-09 SPAWN Subagent
    ' State: <back:#CE93D8>WAITING</back>
    ' Owned by: AGT-09 (SM/README.md)
  subagent --> router : 200 OK
  deactivate subagent
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else spawn fails
  subagent --> router : 422 Unprocessable
  deactivate subagent
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
