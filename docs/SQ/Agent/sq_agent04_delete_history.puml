@startuml sq_agent04_delete_history
' ============================================================
' Title:     AGT-04 — DELETE History
' Boundary:  nasim code agent
' Purpose:   Reset conversation history to initial state
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ConversationHistory
' SM States: CREATED (#BBDEFB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-04 DELETE History

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Agent Group (Service)" #FFF3E0
  participant "ConversationHistory" as history
end box

== AGT-04 DELETE History ==

user -> iface : DELETE /v1/agents/{agent_id}/history
activate iface
iface -> router : DELETE /v1/agents/{agent_id}/history
activate router
router -> history : AGT-04 DELETE History({agent_id})
' --- Internal processing ---
activate history
history -> history : DELETE History
' history interacts with sub-components
activate history

alt delete succeeds
  ref over history : AGT-04 DELETE History
    ' State: <back:#BBDEFB>CREATED</back>
    ' Owned by: AGT-04 (SM/README.md)
  history --> router : 200 OK
  deactivate history
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else history not found
  history --> router : 404 Not Found
  deactivate history
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
