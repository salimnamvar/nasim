@startuml sq_agent04_delete_history
' ============================================================
' Title:     AGT-04 — DELETE History
' Boundary:  nasim code agent
' Purpose:   Reset conversation history to initial state
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> AgentManager -> AgentStore -> AgentDirectory -> FileSystem
' SM States: CREATED (#BBDEFB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-04 DELETE History

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group (Service)" #FFF3E0
  participant "AgentManager" as mgr
end box
box "Agent Group (Repository)" #E8F5E9
  participant "AgentStore" as store
end box
database "AgentDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== AGT-04 DELETE History ==

user -> iface : DELETE /v1/agents/{agent_id}/history
activate iface
iface -> router : DELETE /v1/agents/{agent_id}/history
activate router
router -> mgr : AGT-04 DELETE History({agent_id})
activate mgr

alt delete succeeds
      mgr -> mgr : TRANSITION State(<back:#BBDEFB>CREATED</back>)
  mgr -> store : AGT-04 DELETE History({agent_id})
  activate store
  store -> dir : AGT-04 DELETE History({agent_id})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else history not found
  mgr --> router : 404 Not Found
  deactivate mgr
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
