@startuml sq_agent04_delete_history
' ============================================================
' Title:     AGT-04 — DELETE History
' Boundary:  nasim code agent
' Purpose:   Reset conversation history to initial state
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> AgentAPI -> AgentManager -> AgentStore -> AgentDirectory
' SM States: CREATED (#BBDEFB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-04 DELETE History

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "AgentAPI" as api
end box
box "Agent Group (Service)" #FFF3E0
  participant "AgentManager" as mgr
end box
box "Agent Group (Repository)" #E8F5E9
  participant "AgentStore" as store
end box
database "AgentDirectory" as dir

== AGT-04 DELETE History ==

user -> router : DELETE /v1/agents/{agent_id}/history
activate router
router -> api : AGT-04 DELETE History({agent_id})
activate api
api -> mgr : AGT-04 DELETE History({agent_id})
activate mgr

alt delete succeeds
  hnote over mgr : CREATED (#BBDEFB)
  mgr -> store : AGT-04 DELETE History({agent_id})
  activate store
  store -> dir : AGT-04 DELETE History({agent_id})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else history not found
  mgr --> api : 404 Not Found
  deactivate mgr
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end

@enduml
