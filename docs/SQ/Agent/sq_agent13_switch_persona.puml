@startuml sq_agent13_switch_persona
' ============================================================
' Title:     AGT-13 — SWITCH Persona
' Boundary:  nasim code agent
' Purpose:   Unload current persona and activate a new one
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> AgentAPI -> AgentManager -> AgentStore -> AgentDirectory
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-13 SWITCH Persona

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "AgentAPI" as api
end box
box "Agent Group (Service)" #FFF3E0
  participant "AgentManager" as mgr
end box
box "Agent Group (Repository)" #E8F5E9
  participant "AgentStore" as store
end box
database "AgentDirectory" as dir

== AGT-13 SWITCH Persona ==

user -> router : POST /v1/agents/{agent_id}:switch-persona
activate router
router -> api : AGT-13 SWITCH Persona({new_persona_name})
activate api
api -> mgr : AGT-13 SWITCH Persona({new_persona_name})
activate mgr

alt switch succeeds
  hnote over mgr : RUNNING (#43A047)
  mgr -> store : AGT-13 SWITCH Persona({new_persona_name})
  activate store
  store -> dir : AGT-13 SWITCH Persona({new_persona_name})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else switch fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
