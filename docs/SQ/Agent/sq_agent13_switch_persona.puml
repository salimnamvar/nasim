@startuml sq_agent13_switch_persona
' ============================================================
' Title:     AGT-13 — SWITCH Persona
' Boundary:  nasim code agent
' Purpose:   Unload current persona and activate a new one
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PersonaManager
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-13 SWITCH Persona

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Agent Group (Service)" #FFF3E0
  participant "PersonaManager" as persona
end box

== AGT-13 SWITCH Persona ==

user -> iface : POST /v1/agents/{agent_id}:switch-persona
activate iface
iface -> router : POST /v1/agents/{agent_id}:switch-persona
activate router
router -> persona : AGT-13 SWITCH Persona({new_persona_name})
activate persona

alt switch succeeds
  ref over persona : AGT-13 SWITCH Persona
    ' State: <back:#43A047>RUNNING</back>
    ' Owned by: AGT-13 (SM/README.md)
  persona --> router : 200 OK
  deactivate persona
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else switch fails
  persona --> router : 422 Unprocessable
  deactivate persona
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
