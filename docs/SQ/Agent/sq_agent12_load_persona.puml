@startuml sq_agent12_load_persona
' ============================================================
' Title:     AGT-12 — LOAD Persona
' Boundary:  nasim code agent
' Purpose:   Load persona configuration and apply system prompt
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PersonaManager
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-12 LOAD Persona

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "PersonaManager" as persona
end box

== AGT-12 LOAD Persona ==

user -> iface : POST /v1/agents/{agent_id}:load-persona
activate iface
iface -> router : POST /v1/agents/{agent_id}:load-persona
activate router
router -> persona : AGT-12 LOAD Persona({persona_name})
activate persona

alt load succeeds
  ref over persona : AGT-12 LOAD Persona
    ' State: <back:#43A047>RUNNING</back>
    ' Owned by: AGT-12 (SM/README.md)
  persona --> router : 200 OK
  deactivate persona
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else config invalid
  persona --> router : 422 Unprocessable
  deactivate persona
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
