@startuml sq_agent12_load_persona
' ============================================================
' Title:     AGT-12 — LOAD Persona
' Boundary:  nasim code agent
' Purpose:   Load persona configuration and apply system prompt
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> AgentAPI -> AgentManager -> AgentStore -> AgentDirectory
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-12 LOAD Persona

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "AgentAPI" as api
end box
box "Agent Group (Service)" #FFF3E0
  participant "AgentManager" as mgr
end box
box "Agent Group (Repository)" #E8F5E9
  participant "AgentStore" as store
end box
database "AgentDirectory" as dir

== AGT-12 LOAD Persona ==

user -> router : POST /v1/agents/{agent_id}:load-persona
activate router
router -> api : AGT-12 LOAD Persona({persona_name})
activate api
api -> mgr : AGT-12 LOAD Persona({persona_name})
activate mgr

alt load succeeds
  hnote over mgr : RUNNING (#43A047)
  mgr -> store : AGT-12 LOAD Persona({persona_name})
  activate store
  store -> dir : AGT-12 LOAD Persona({persona_name})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else config invalid
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
