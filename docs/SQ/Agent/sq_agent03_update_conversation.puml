@startuml sq_agent03_update_conversation
' ============================================================
' Title:     AGT-03 — UPDATE Conversation
' Boundary:  nasim code agent
' Purpose:   Append messages and track token count
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ConversationHistory -> SessionStore -> SessionStorage
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-03 UPDATE Conversation

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "ConversationHistory" as history
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionStore" as store
end box

database "SessionStorage" as storage

== AGT-03 UPDATE Conversation ==

user -> iface : AGT-03 UPDATE Conversation({msg, updateMask})
activate iface
iface -> router : AGT-03 UPDATE Conversation({msg, updateMask})
activate router
router -> history : AGT-03 UPDATE Conversation({msg, updateMask})
activate history

alt token_count <= budget
  ref over history : AGT-03 UPDATE Conversation({msg, updateMask}) <back:#43A047>RUNNING</back>
  history -> store : AGT-03 PERSIST History({session_id, messages})
  activate store
  store -> storage : AGT-03 PERSIST History({session_id, messages})
  activate storage
  storage --> store : 200 OK
  deactivate storage
  store --> history : 200 OK
  deactivate store
  history --> router : 200 OK
  deactivate history
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else budget exceeded
  history --> router : 409 FAILED_PRECONDITION\n{error: {code: "AGT-03_BUDGET_EXCEEDED", message: "Token budget exceeded", status: 409}}
  deactivate history
  router --> iface : 409 FAILED_PRECONDITION
  iface --> user : 409 FAILED_PRECONDITION
  deactivate router
  deactivate iface
end

@enduml
