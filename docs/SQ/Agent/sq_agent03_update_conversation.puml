@startuml sq_agent03_update_conversation
' ============================================================
' Title:     AGT-03 — UPDATE Conversation
' Boundary:  nasim code agent
' Purpose:   Append messages and track token count
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ConversationHistory
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-03 UPDATE Conversation

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "ConversationHistory" as history
end box

== AGT-03 UPDATE Conversation ==

user -> iface : PATCH /v1/agents/{agent_id}/conversation
activate iface
iface -> router : PATCH /v1/agents/{agent_id}/conversation
activate router
router -> history : AGT-03 UPDATE Conversation({msg, updateMask})
' --- Internal processing ---
activate history
history -> history : UPDATE Conversation
' history interacts with sub-components
activate history

alt token within budget
  ref over history : AGT-03 UPDATE Conversation
    ' State: <back:#43A047>RUNNING</back>
    ' Owned by: AGT-03 (SM/README.md)
  history --> router : 200 OK
  deactivate history
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else budget exceeded
  history --> router : 422 Unprocessable
  deactivate history
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
