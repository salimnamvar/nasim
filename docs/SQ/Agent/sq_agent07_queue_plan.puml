@startuml sq_agent07_queue_plan
' ============================================================
' Title:     AGENT-07 — QUEUE Plan
' Boundary:  nasim code agent
' Purpose:   Queue tool calls in plan mode without executing
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> PlanService -> PlanStore
' SM States: WAITING (#CE93D8)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGENT-07 QUEUE Plan

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "TaskService" as plan
end box

box "Repository" REPOSITORY_COLOR
  participant "TaskService" as planStore
end box

== AGENT-07 QUEUE Plan ==

user -> iface : POST /v1/agents/{agent_id}:queue-plan
activate iface
iface -> router : POST /v1/agents/{agent_id}:queue-plan
activate router
router -> plan : AGENT-07 QUEUE Plan({tool_name, args})
activate plan

alt plan queued without error
  ref over plan : AGENT-07 QUEUE Plan({tool_name, args}) <back:#CE93D8>WAITING</back>
  plan -> planStore : AGENT-07 PERSIST Plan({agent_id, tool_name, args})
  activate planStore
  planStore --> plan : 200 OK
  deactivate planStore
  plan --> router : 200 OK
  deactivate plan
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else queue full
  plan --> router : 409 FAILED_PRECONDITION\n{error: {code: "AGENT-07_QUEUE_FULL", message: "Plan queue capacity exceeded", status: 409}}
  deactivate plan
  router --> iface : 409 FAILED_PRECONDITION\n{error: {code: "AGENT-07_QUEUE_FULL", message: "Plan queue capacity exceeded", status: 409}}
  iface --> user : 409 FAILED_PRECONDITION\n{error: {code: "AGENT-07_QUEUE_FULL", message: "Plan queue capacity exceeded", status: 409}}
  deactivate router
  deactivate iface
end

@enduml
