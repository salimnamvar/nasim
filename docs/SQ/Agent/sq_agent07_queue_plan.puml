@startuml sq_agent07_queue_plan
' ============================================================
' Title:     AGT-07 — QUEUE Plan
' Boundary:  nasim code agent
' Purpose:   Queue tool calls in plan mode without executing
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PlanSession
' SM States: WAITING (#CE93D8)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-07 QUEUE Plan

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "PlanSession" as plan
end box

== AGT-07 QUEUE Plan ==

user -> iface : POST /v1/agents/{agent_id}:queue-plan
activate iface
iface -> router : POST /v1/agents/{agent_id}:queue-plan
activate router
router -> plan : AGT-07 QUEUE Plan({tool_name, args})
activate plan

alt plan queued without error
  ref over plan : AGT-07 QUEUE Plan({tool_name, args}) <back:#CE93D8>WAITING</back>
  plan --> router : 200 OK
  deactivate plan
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else queue full
  plan --> router : 409 FAILED_PRECONDITION\n{error: {code: "AGT-07_QUEUE_FULL", message: "Plan queue capacity exceeded", status: 409}}
  deactivate plan
  router --> iface : 409 FAILED_PRECONDITION
  iface --> user : 409 FAILED_PRECONDITION
  deactivate router
  deactivate iface
end

@enduml
