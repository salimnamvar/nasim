@startuml sq_agent11_delegate_to_persona
' ============================================================
' Title:     AGT-11 — DELEGATE to Persona
' Boundary:  nasim code agent
' Purpose:   Assign task execution to a specialized persona role
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> AgentManager -> AgentStore -> AgentDirectory -> FileSystem
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-11 DELEGATE to Persona

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group (Service)" #FFF3E0
  participant "AgentManager" as mgr
end box
box "Agent Group (Repository)" #E8F5E9
  participant "AgentStore" as store
end box
database "AgentDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== AGT-11 DELEGATE to Persona ==

user -> iface : POST /v1/agents/{agent_id}:delegate-persona
activate iface
iface -> router : POST /v1/agents/{agent_id}:delegate-persona
activate router
router -> mgr : AGT-11 DELEGATE to Persona({task, persona_hint})
activate mgr

alt delegation succeeds
      mgr -> mgr : TRANSITION State(<back:#43A047>RUNNING</back>)
  mgr -> store : AGT-11 DELEGATE to Persona({task, persona_hint})
  activate store
  store -> dir : AGT-11 DELEGATE to Persona({task, persona_hint})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else persona not found
  mgr --> router : 404 Not Found
  deactivate mgr
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
