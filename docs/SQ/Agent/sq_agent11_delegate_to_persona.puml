@startuml sq_agent11_delegate_to_persona
' ============================================================
' Title:     AGENT-11 — DELEGATE to Persona
' Boundary:  nasim code agent
' Purpose:   Assign task execution to a specialized persona role
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> PersonaService -> PersonaRepository
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGENT-11 DELEGATE to Persona

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "TaskService" as persona
end box

box "Repository" REPOSITORY_COLOR
  participant "TaskService" as personaRepo
end box

== AGENT-11 DELEGATE to Persona ==

user -> iface : POST /v1/agents/{agent_id}:delegate-persona
activate iface
iface -> router : POST /v1/agents/{agent_id}:delegate-persona
activate router
router -> persona : AGENT-11 DELEGATE to Persona({task, persona_hint})
activate persona

alt delegation succeeds without error
  ref over persona : AGENT-11 DELEGATE Persona({task, persona_hint}) <back:#43A047>RUNNING</back>
  persona -> personaRepo : AGENT-11 READ Persona({persona_hint})
  activate personaRepo
  personaRepo --> persona : 200 OK
  deactivate personaRepo
  persona --> router : 200 OK
  deactivate persona
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else persona not found
  persona --> router : 404 NOT_FOUND\n{error: {code: "AGENT-11_NOT_FOUND", message: "Persona not found", status: 404}}
  deactivate persona
  router --> iface : 404 NOT_FOUND\n{error: {code: "AGENT-11_NOT_FOUND", message: "Persona not found", status: 404}}
  iface --> user : 404 NOT_FOUND\n{error: {code: "AGENT-11_NOT_FOUND", message: "Persona not found", status: 404}}
  deactivate router
  deactivate iface
end

@enduml
