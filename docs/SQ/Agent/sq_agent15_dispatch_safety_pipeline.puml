@startuml sq_agent15_dispatch_safety_pipeline
' ============================================================
' Title:     AGT-15 — DISPATCH Safety Pipeline
' Boundary:  nasim code agent
' Purpose:   Run injection scan, egress inspect, and permission check
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> AgentAPI -> AgentManager -> AgentStore -> AgentDirectory
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-15 DISPATCH Safety Pipeline

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "AgentAPI" as api
end box
box "Agent Group (Service)" #FFF3E0
  participant "AgentManager" as mgr
end box
box "Agent Group (Repository)" #E8F5E9
  participant "AgentStore" as store
end box
database "AgentDirectory" as dir

== AGT-15 DISPATCH Safety Pipeline ==

user -> router : POST /v1/agents/{agent_id}:dispatch-safety
activate router
router -> api : AGT-15 DISPATCH Safety Pipeline({tool_call})
activate api
api -> mgr : AGT-15 DISPATCH Safety Pipeline({tool_call})
activate mgr

alt all checks pass
  hnote over mgr : RUNNING (#43A047)
  mgr -> store : AGT-15 DISPATCH Safety Pipeline({tool_call})
  activate store
  store -> dir : AGT-15 DISPATCH Safety Pipeline({tool_call})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else safety violation
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
