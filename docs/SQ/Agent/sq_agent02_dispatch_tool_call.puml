@startuml sq_agent02_dispatch_tool_call
' ============================================================
' Title:     AGT-02 — DISPATCH Tool Call
' Boundary:  nasim code agent
' Purpose:   Route tool call to ToolRegistry via safety pipeline
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> AgentOrchestrator -> SafetyCoordinator
' SM States: RUNNING (#43A047), WAITING (#CE93D8)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-02 DISPATCH Tool Call

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Agent Group (Service)" #FFF3E0
  participant "AgentOrchestrator" as orchestrator
  participant "SafetyCoordinator" as safety
end box

== AGT-02 DISPATCH Tool Call ==

user -> iface : POST /v1/agents/{agent_id}:dispatch-tool
activate iface
iface -> router : POST /v1/agents/{agent_id}:dispatch-tool
activate router
router -> orchestrator : AGT-02 DISPATCH Tool Call({tool_name, args})
activate orchestrator
orchestrator -> safety : AGT-02 DISPATCH Safety Check({tool_name, args})
activate safety

alt safety approved
  ref over orchestrator : AGT-02 DISPATCH Tool Call
    ' State: <back:#43A047>RUNNING</back>
    ' Owned by: AGT-02 (SM/README.md)
  safety --> orchestrator : 200 OK Approved
  deactivate safety
  orchestrator --> router : 200 OK
  deactivate orchestrator
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else safety violation
  ref over orchestrator : AGT-02 DISPATCH Tool Call
    ' State: <back:#CE93D8>WAITING</back>
    ' Owned by: AGT-02 (SM/README.md)
  safety --> orchestrator : 422 Unprocessable
  deactivate safety
  orchestrator --> router : 422 Unprocessable
  deactivate orchestrator
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
