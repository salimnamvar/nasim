@startuml sq_agent02_dispatch_tool_call
' ============================================================
' Title:     AGT-02 — DISPATCH Tool Call
' Boundary:  nasim code agent
' Purpose:   Route tool call to ToolRegistry via safety pipeline
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> AgentOrchestrator -> SafetyCoordinator
' SM States: RUNNING (#43A047), WAITING (#CE93D8)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-02 DISPATCH Tool Call

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "AgentOrchestrator" as orchestrator
  participant "SafetyCoordinator" as safety
end box

== AGT-02 DISPATCH Tool Call ==

user -> iface : AGT-02 DISPATCH Tool Call({tool_name, args})
activate iface
iface -> router : AGT-02 DISPATCH Tool Call({tool_name, args})
activate router
router -> orchestrator : AGT-02 DISPATCH Tool Call({tool_name, args})
activate orchestrator
orchestrator -> safety : AGT-02 DISPATCH Safety Check({tool_name, args})
activate safety

alt safety_approved
  ref over orchestrator : AGT-02 DISPATCH ToolCall({tool_name, args}) <back:#43A047>RUNNING</back>
  safety --> orchestrator : 200 OK Approved
  deactivate safety
  orchestrator --> router : 200 OK
  deactivate orchestrator
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else safety_violation
  ref over orchestrator : AGT-02 DISPATCH ToolCall({tool_name, args}) <back:#CE93D8>WAITING</back>
  safety --> orchestrator : 403 PERMISSION_DENIED\n{error: {code: "AGT-02_SAFETY_VIOLATION", message: "Tool call blocked by safety policy", status: 403}}
  deactivate safety
  orchestrator --> router : 403 PERMISSION_DENIED\n{error: {code: "AGT-02_SAFETY_VIOLATION", message: "Tool call blocked by safety policy", status: 403}}
  deactivate orchestrator
  router --> iface : 403 PERMISSION_DENIED\n{error: {code: "AGT-02_SAFETY_VIOLATION", message: "Tool call blocked by safety policy", status: 403}}
  iface --> user : 403 PERMISSION_DENIED\n{error: {code: "AGT-02_SAFETY_VIOLATION", message: "Tool call blocked by safety policy", status: 403}}
  deactivate router
  deactivate iface
end

@enduml
