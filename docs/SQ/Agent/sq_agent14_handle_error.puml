@startuml sq_agent14_handle_error
' ============================================================
' Title:     AGT-14 — HANDLE Error
' Boundary:  nasim code agent
' Purpose:   Classify errors and determine recovery action
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> AgentAPI -> AgentManager -> AgentStore -> AgentDirectory
' SM States: FAILED (#EF5350)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-14 HANDLE Error

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "AgentAPI" as api
end box
box "Agent Group (Service)" #FFF3E0
  participant "AgentManager" as mgr
end box
box "Agent Group (Repository)" #E8F5E9
  participant "AgentStore" as store
end box
database "AgentDirectory" as dir

== AGT-14 HANDLE Error ==

user -> router : POST /v1/agents/{agent_id}:handle-error
activate router
router -> api : AGT-14 HANDLE Error({error})
activate api
api -> mgr : AGT-14 HANDLE Error({error})
activate mgr

alt retryable error
  hnote over mgr : FAILED (#EF5350)
  mgr -> store : AGT-14 HANDLE Error({error})
  activate store
  store -> dir : AGT-14 HANDLE Error({error})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else unrecoverable
  mgr --> api : 500 Server Error
  deactivate mgr
  api --> router : 500 Server Error
  deactivate api
  router --> user : 500 Server Error
  deactivate router
end

@enduml
