@startuml sq_agent14_handle_error
' ============================================================
' Title:     AGT-14 — HANDLE Error
' Boundary:  nasim code agent
' Purpose:   Classify errors and determine recovery action
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ErrorBoundary
' SM States: FAILED (#EF5350)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-14 HANDLE Error

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "ErrorBoundary" as boundary
end box

== AGT-14 HANDLE Error ==

user -> iface : POST /v1/agents/{agent_id}:handle-error
activate iface
iface -> router : POST /v1/agents/{agent_id}:handle-error
activate router
router -> boundary : AGT-14 HANDLE Error({error})
activate boundary

alt retryable error
  ref over boundary : AGT-14 HANDLE Error({error}) <back:#EF5350>FAILED</back>
  boundary --> router : 200 OK
  deactivate boundary
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else unrecoverable error
  boundary --> router : 500 INTERNAL\n{error: {code: "AGT-14_UNRECOVERABLE", message: "Unrecoverable error", status: 500}}
  deactivate boundary
  router --> iface : 500 INTERNAL
  iface --> user : 500 INTERNAL
  deactivate router
  deactivate iface
end

@enduml
