@startuml sq_agent14_handle_error
' ============================================================
' Title:     AGT-14 — HANDLE Error
' Boundary:  nasim code agent
' Purpose:   Classify errors and determine recovery action
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ErrorBoundary
' SM States: FAILED (#EF5350)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGT-14 HANDLE Error

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Agent Group (Service)" #FFF3E0
  participant "ErrorBoundary" as boundary
end box

== AGT-14 HANDLE Error ==

user -> iface : POST /v1/agents/{agent_id}:handle-error
activate iface
iface -> router : POST /v1/agents/{agent_id}:handle-error
activate router
router -> boundary : AGT-14 HANDLE Error({error})
activate boundary

alt retryable error
  ref over boundary : AGT-14 HANDLE Error
    ' State: <back:#EF5350>FAILED</back>
    ' Owned by: AGT-14 (SM/README.md)
  boundary --> router : 200 OK
  deactivate boundary
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else unrecoverable
  boundary --> router : 500 Server Error
  deactivate boundary
  router --> iface : 500 Server Error
  iface --> user : 500 Server Error
  deactivate router
  deactivate iface
end

@enduml
