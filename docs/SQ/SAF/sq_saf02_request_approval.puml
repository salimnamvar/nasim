@startuml sq_saf02_request_approval
!include ../common/sq_styles.puml
' ============================================================
' Title:     SAF-02 — REQUEST Approval
' Boundary:  nasim code agent CLI
' Purpose:   Display approval prompt for unsafe tool execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

title nasim — SAF-02 PROMPT User Approval

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
  participant "Renderer" as renderer
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
  participant "PermissionGate" as gate
end box

note over user
  Scope:          SAF-02 Request Approval — Display approval prompt for unsafe tool execution
  Preconditions:  SAF-01 returned SafetyViolation with safety_mode="ask"
  Contexts:       Called by SAF-01 when tool is unsafe and mode is "ask"
  Excludes:       Permission check (SAF-01), safety mode config (SAF-03)
  Rollback:       User rejection → tool execution blocked
  Design:         Interactive y/N prompt; user choice respected immediately
  Returns:
    - Success: approved (y)
    - Failure: rejected (N)
end note

== SAF-02 Prompt User Approval ==

user -> router : types input
router -> agent : SAF-02 PROCESS(user_input)

agent -> gate : SAF-02 PROMPT UserApproval(tool_name, args)
activate gate

gate -> renderer : SAF-02 DISPLAY Approval(tool_name, args)
activate renderer
renderer --> user : "Allow <tool_name>(<args>)? [y/N]"

user -> renderer : y or N
renderer --> gate : choice (bool)

alt user = y
    renderer --> gate : approved
    gate --> agent : approved
    agent --> router : AgentEvent(Done)
else user = N
    renderer --> gate : rejected
    gate --> agent : rejected
    agent --> router : AgentEvent(Done)
end

deactivate gate
deactivate renderer

note over user
  Flow:    SAF-02 → display prompt → user choice → approved or rejected
  State:   No state change
  Success: approved — tool execution proceeds
  Failure: rejected (N) — tool execution blocked
end note


@enduml
