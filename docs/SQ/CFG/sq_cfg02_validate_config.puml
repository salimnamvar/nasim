@startuml sq_cfg02_validate_config
!include ../common/sq_styles.puml
' ============================================================
' Title:     CFG-02 — VALIDATE Config
' Boundary:  nasim code agent CLI
' Purpose:   Config field validation
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — CFG-02 VALIDATE Config

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Config Group" #E8F5E9
  participant "ConfigLoader" as cfg
end box
box "Repository Group" #E8F5E9
  participant "ConfigRepository" as cfg_repo
end box


note over user
  Scope:          CFG-02 Validate Config — Validate config fields against allowed values
  Preconditions:  Config object exists and has been loaded via CFG-01
  Contexts:       Called by CFG-01 after merge; can also be invoked independently
  Excludes:       Config loading (CFG-01), config merging (CFG-03), persistence
  Rollback:       ConfigError returned with field-specific message on any validation failure
  Design:         Independent field checks: provider whitelist, safety mode enum, positive integers
  Returns:
    - Success: 200 Config valid
    - Failure: ConfigError
end note

== CFG-02 VALIDATE Config ==

user -> router : invoke agent
activate router
router -> agent : cfg02 VALIDATE Config(config)
activate agent
agent -> cfg : cfg02 VALIDATE Config(config)
activate cfg
cfg -> cfg : cfg02 CHECK Provider(provider in ["ollama", "openai", "anthropic"])
cfg -> cfg : cfg02 CHECK SafetyMode(safety_mode in ["ask", "auto", "off"])
cfg -> cfg : cfg02 CHECK ContextBudget(context_budget > 0)
cfg -> cfg : cfg02 CHECK Timeout(timeout > 0)

break Validation fails
    cfg --> agent : ConfigError("field: message")
    agent --> router : ConfigError
end

cfg --> agent : Config valid
agent --> router : Config valid
deactivate agent
deactivate router


note over user
  Flow:    CFG-02 → check provider → check safety mode → check context budget → check timeout → return
  State:   No state change
  Success: 200 Config valid
  Failure: ConfigError — field validation failure
end note

@enduml
