@startuml sq_edt02_apply_search_replace
!include ../common/sq_styles.puml
' ============================================================
' Title:     EDT-02 — APPLY Search-Replace
' Boundary:  nasim code agent
' Purpose:   Execute edit via search-replace strategy
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    CAR audit 2026-06-26 (removed EditApplier phantom, fixed box naming)
' ============================================================

title nasim — EDT-02 APPLY Search-Replace

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Edit Strategy Group" #FFF3E0
  participant "SearchReplaceCoder" as strategy
end box
participant "Host Filesystem" as fs


note over user
  Scope:          EDT-02 APPLY Search-Replace — Execute edit via search-replace strategy
  Preconditions:  EditStrategy from EDT-01 selected search-replace format; target file exists
  Contexts:       Invoked via dynamic dispatch from EDT-01
  Excludes:       Strategy selection (EDT-01); sandbox validation (EDT-07); linter checks
  Rollback:       Backup restored from backup_path on failure
  Design:         Creates backup before write; computes diff after apply
  Returns:
    - Success: 200 OK — AgentEvent(Done)
    - Failure: 500 INTERNAL: file write or apply failure
end note


== EDT-02 APPLY Search-Replace ==

user -> router : types input
router -> agent : PROCESS(user_input)

agent -> fs : read_file(file_path)
activate fs
fs --> agent : original_content
deactivate fs

agent -> fs : create_backup(file_path)
activate fs
fs --> agent : backup_path
deactivate fs

agent -> strategy : apply(original_content)
activate strategy
strategy --> agent : modified_content
deactivate strategy

agent -> fs : write_file(file_path, modified_content)
activate fs
fs --> agent : write_success
deactivate fs

agent -> agent : compute_diff(original_content, modified_content)

agent --> router : AgentEvent(Done)


note over user
  Flow:    EDT-02 → user input → router → agent → fs(read) → fs(backup) → strategy(apply) → fs(write) → compute_diff → Done
  State:   No state change
  Success: 200 OK — AgentEvent(Done)
  Failure: 500 INTERNAL: apply or write failure — backup restored
end note

@enduml
