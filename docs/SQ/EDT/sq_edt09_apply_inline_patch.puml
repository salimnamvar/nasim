@startuml sq_edt09_apply_inline_patch
!include ../common/sq_styles.puml
' ============================================================
' Title:     EDT-09 — APPLY Inline Patch
' Boundary:  nasim code agent
' Purpose:   Apply inline patch with line-level precision
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — EDT-09 UPDATE Inline Patch

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Edit Strategy Group" #FFF3E0
  participant "EditStrategyManager" as esm
  participant "InlinePatchCoder" as ipc
end box
box "FileSystem Group" #E8F5E9
  participant "FileSystem" as fs
end box


note over user
  Scope:          EDT-09 APPLY Inline Patch — Apply inline patch with line-level precision
  Preconditions:  EditStrategy from EDT-01 selected inline patch format; target file exists
  Contexts:       Invoked via dynamic dispatch from EDT-01
  Excludes:       Whole-file replacement; AST-based editing; sandbox validation
  Rollback:       Patch rejected; original file preserved on context mismatch
  Design:         Context-line validation prevents applying patches to wrong locations
  Returns:
    - Success: 200 OK — EditResult(success, file_path, lines_changed)
    - Failure: 400 BAD_REQUEST: context mismatch
end note


== EDT-09 APPLY Inline Patch ==

user -> router : types input
router -> agent : PROCESS(user_input)

agent -> esm : EDT-09 APPLY_INLINE_PATCH(file_path, patch, updateMask)
activate esm

esm -> ipc : code_inline_patch(file_path, patch)
activate ipc

ipc -> ipc : parse_patch(patch)

ipc -> fs : read_file(file_path)
activate fs
fs --> ipc : source_lines
deactivate fs

ipc -> ipc : validate_context_lines(source_lines, patch.context_lines)

alt context validation passes
    ipc -> ipc : apply_hunks(source_lines, patch.hunks)

    ipc -> fs : write_file(file_path, patched_source)
    activate fs
    fs --> ipc : write_result
    deactivate fs

    ipc -> ipc : validate_no_conflicts(patched_source)
else context mismatch
    ipc -> ipc : reject_patch(reason="context mismatch")
end

ipc --> esm : EditResult(success, file_path, lines_changed)
deactivate ipc

esm --> agent : EditResult
deactivate esm

agent --> router : AgentEvent(Done)


note over user
  Flow:    EDT-09 → user input → router → agent → esm → ipc(parse → fs(read) → validate_context → apply_hunks → fs(write) → validate) → Done
  State:   No state change
  Success: 200 OK — EditResult(success, file_path, lines_changed)
  Failure: 400 BAD_REQUEST: context mismatch — patch rejected, file unchanged
end note

@enduml
