@startuml sq_edt10_stage_diff
!include ../common/sq_styles.puml
' ============================================================
' Title:     EDT-10 — STAGE Diff
' Boundary:  nasim code agent
' Purpose:   Stage edit in DiffSandboxManager for review before sandbox-validated apply
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    Meta-Software Designer audit 2026-06-21
' Note:      Process decomposition — internal step of edit flow. Actor required per updated sq.md rules.
' ============================================================

title nasim — EDT-10 STAGE Diff

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Sandbox Group" #F3E5F5
  participant "DiffSandboxManager" as diff_mgr
  participant "EditStagingArea" as staging
  participant "DiffComputer" as diff_comp
end box


note over user
  Scope:          EDT-10 STAGE Diff — Stage edit for review before sandbox-validated apply
  Preconditions:  Edit result available from EDT-02..09; staging area has capacity
  Contexts:       Internal step of edit flow; called before EDT-07
  Excludes:       Actual file modification; sandbox validation; strategy selection
  Rollback:       No staging slot allocated; edit not staged
  Design:         Process decomposition; stages edits for later validation with diff summary
  Returns:
    - Success: 200 OK — StagedEdit(edit_id, diff_summary)
    - Failure: 400 BAD_REQUEST: staging slot allocation failure
end note


== EDT-10 STAGE Diff ==

user -> router : types input
router -> agent : PROCESS(user_input)

agent -> diff_mgr : EDT-10 STAGE_DIFF(edit_result)
activate diff_mgr

diff_mgr -> staging : allocate_edit_slot()
activate staging

staging -> staging : store_edit(edit_result)

staging -> diff_comp : compute_staged_diff(original, staged)
activate diff_comp
diff_comp --> staging : diff_summary
deactivate diff_comp

staging --> diff_mgr : StagedEdit(edit_id, diff_summary, timestamp)
deactivate staging

diff_mgr --> agent : StagedEdit(edit_id, diff_summary)
deactivate diff_mgr

agent --> router : AgentEvent(Done)


note over user
  Flow:    EDT-10 → user input → router → agent → diff_mgr → staging(allocate → store → compute diff) → Done
  State:   No state change
  Success: 200 OK — StagedEdit(edit_id, diff_summary)
  Failure: 400 BAD_REQUEST: slot allocation failure — edit not staged
end note

@enduml
