@startuml sq_edt05_review_diff
' ============================================================
' Title:     EDT-05 — REVIEW Diff
' Boundary:  nasim code agent CLI
' Purpose:   Present diff for user approval
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/audit/audit.2026.06.20.deep.domain.audit.md
' Review:    —
' ============================================================

actor "Developer" as user

box "Agent Layer" #E3F2FD
  participant "AgentOrchestrator" as agent
end box
box "Edit Layer" #FFF3E0
  participant "DiffSandbox" as sandbox
  participant "DiffRenderer" as renderer
end box
box "CLI Layer" #E8F5E9
  participant "REPLSession" as repl
end box

note over user, repl
  Scope:
    - edt05 REVIEW Diff — present diff for user approval

  Preconditions:
    - EDT-04 completed (edit staged in DiffSandbox)
    - REPLSession available for user interaction

  Contexts:
    - Called after EDT-04 (Stage Edit)
    - Final step before applying edits to file system

  Excludes:
    - Edit execution (handled by EDT-02)
    - Staging (handled by EDT-04)
    - Validation (handled by EDT-03)

  Rollback:
    - User rejects → discard staged edit from sandbox

  Design:
    - DiffRenderer formats staged diff for terminal display
    - Color-coded additions/deletions
    - User approves or rejects via REPL input
    - Approved edits applied atomically

  Returns:
    - Success: ReviewResult with user decision
    - Failure: User rejection or timeout
end note

== edt05 REVIEW Diff ==

agent -> sandbox : GET_STAGED_DIFF(edit_id)
activate sandbox
sandbox --> agent : staged_diff
deactivate sandbox

agent -> renderer : RENDER_DIFF(staged_diff)
activate renderer
renderer --> agent : formatted_diff
deactivate renderer

agent -> repl : DISPLAY_DIFF(formatted_diff)
activate repl
repl --> user : shows diff to user
deactivate repl

repl -> user : prompt approval (y/n)
user --> repl : decision

alt user approves
    repl --> agent : APPROVED
    agent -> sandbox : APPLY_STAGED(edit_id)
    activate sandbox
    sandbox --> agent : apply_success
    deactivate sandbox
else user rejects
    repl --> agent : REJECTED
    agent -> sandbox : DISCARD_STAGED(edit_id)
    activate sandbox
    sandbox --> agent : discard_success
    deactivate sandbox
end

agent --> repl : ReviewResult(decision, edit_id)
deactivate agent

note over user, repl
  Flow:
    - AgentOrchestrator → DiffSandbox + DiffRenderer → REPLSession → User → Decision

  State:
    - IDLE → RENDERING → DISPLAYING → AWAITING → DECIDED

  Failure:
    - User rejection → discard staged edit

  Success:
    - User approval → edits applied atomically

  Key invariants:
    - Diff always rendered before user decision
    - User always has opportunity to reject
    - Rejection triggers immediate discard
end note

@enduml
