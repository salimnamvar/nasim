@startuml sq_edt04_apply_unified_diff
!include ../common/sq_styles.puml
' ============================================================
' Title:     EDT-04 — APPLY Unified Diff
' Boundary:  nasim code agent
' Purpose:   Apply unified diff format edit to file
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — EDT-04 UPDATE Unified Diff

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Edit Strategy Group" #FFF3E0
  participant "EditStrategyManager" as mgr
  participant "UnifiedDiffCoder" as coder
end box
box "Repository Group" #E8F5E9
  participant "FileSystem" as fs
end box


note over user
  Scope:          EDT-04 APPLY Unified Diff — Apply unified diff format edit to file
  Preconditions:  EditStrategy from EDT-01 selected unified diff format; target file exists
  Contexts:       Invoked via dynamic dispatch from EDT-01
  Excludes:       Strategy selection (EDT-01); sandbox validation (EDT-07); linter checks
  Rollback:       File unchanged if hunk application fails
  Design:         Applies hunks sequentially; breaks on first mismatch
  Returns:
    - Success: 200 OK — ToolResult(success=True)
    - Failure: 400 BAD_REQUEST: DiffError(hunk_mismatch)
end note


== EDT-04 APPLY Unified Diff ==

user -> router : types input
router -> agent : PROCESS(user_input)
agent -> mgr : EDT-04 APPLY_UNIFIED_DIFF(file, diff, updateMask)
activate mgr

mgr -> coder : apply(diff, file_content)
activate coder

coder -> coder : parse diff hunks
coder -> coder : apply each hunk

break Hunk application fails
  coder --> mgr : DiffError(hunk_mismatch)
end

coder -> fs : write modified content
fs --> coder : written
coder --> mgr : ModifiedContent
deactivate coder

mgr --> agent : ToolResult(success=True)
deactivate mgr

agent --> router : AgentEvent(Done)


note over user
  Flow:    EDT-04 → user input → router → agent → mgr → coder(parse hunks, apply) → fs(write) → Done
  State:   No state change
  Success: 200 OK — ToolResult(success=True)
  Failure: 400 BAD_REQUEST: hunk_mismatch — file unchanged
end note

@enduml
