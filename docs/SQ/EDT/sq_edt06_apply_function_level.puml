@startuml sq_edt06_apply_function_level
!include ../common/sq_styles.puml
' ============================================================
' Title:     EDT-06 — APPLY Function-Level
' Boundary:  nasim code agent
' Purpose:   Edit a single function via AST-aware replace
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — EDT-06 UPDATE Function-Level

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Edit Strategy Group" #FFF3E0
  participant "EditStrategyManager" as esm
  participant "FunctionLevelCoder" as flc
end box
box "Tool Group" #E8F5E9
  participant "ASTParser" as ast
end box
box "FileSystem Group" #E8F5E9
  participant "FileSystem" as fs
end box


note over user
  Scope:          EDT-06 APPLY Function-Level — Edit a single function via AST-aware replace
  Preconditions:  EditStrategy from EDT-01 selected function-level format; target file exists
  Contexts:       Invoked via dynamic dispatch from EDT-01
  Excludes:       Multi-file edits; diff-based editing; sandbox validation
  Rollback:       File unchanged if AST validation fails
  Design:         AST-aware replacement preserves surrounding code; validates AST integrity after edit
  Returns:
    - Success: 200 OK — EditResult(success, file_path, function_name)
    - Failure: 400 BAD_REQUEST: AST validation failure or function not found
end note


== EDT-06 APPLY Function-Level ==

user -> router : types input
router -> agent : PROCESS(user_input)
agent -> esm : EDT-06 APPLY_FUNCTION_LEVEL(file_path, function_name, new_body, updateMask)
activate esm

esm -> flc : code_function_edit(file_path, function_name, new_body)
activate flc

flc -> fs : read_file(file_path)
activate fs
fs --> flc : source_content
deactivate fs

flc -> ast : parse(source_content)
activate ast
ast --> flc : ast_root
deactivate ast

flc -> flc : locate_function_node(ast_root, function_name)

flc -> flc : replace_function_body(node, new_body)

flc -> flc : validate_ast_integrity(ast_root)

flc -> fs : write_file(file_path, modified_source)
activate fs
fs --> flc : write_result
deactivate fs

flc --> esm : EditResult(success, file_path, function_name)
deactivate flc

esm --> agent : EditResult
deactivate esm

agent --> router : AgentEvent(Done)


note over user
  Flow:    EDT-06 → user input → router → agent → esm → flc → fs(read) → ast(parse) → locate_function → replace_body → validate_ast → fs(write) → Done
  State:   No state change
  Success: 200 OK — EditResult(success, file_path, function_name)
  Failure: 400 BAD_REQUEST: function not found or AST invalid — file unchanged
end note

@enduml
