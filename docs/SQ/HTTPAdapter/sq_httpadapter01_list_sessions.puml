@startuml sq_api01_list_sessions
' ============================================================
' Title:     HTTPADAPTER-01 — LIST Sessions
' Boundary:  nasim code agent
' Purpose:   List all sessions with pagination
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> Session Service -> SessionStore
' @csr-exempt service
' SM States: (no state change — read-only)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- HTTPADAPTER-01 LIST Sessions

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "Session Service" as store
end box

database "SessionStore" as storage

== HTTPADAPTER-01 LIST Sessions ==

user -> iface : HTTPADAPTER-01 LIST Sessions({pageSize, pageToken})
activate iface
iface -> router : HTTPADAPTER-01 LIST Sessions({pageSize, pageToken})
activate router

router -> store : HTTPADAPTER-01 LIST Sessions({pageSize, pageToken})
activate store

alt validation fails
    store --> router : 422 INVALID_ARGUMENT\n{error: {code: "HTTPADAPTER-01_VALIDATION_ERROR", message: "Invalid pagination parameters", status: 422}}
    router --> iface : 422 INVALID_ARGUMENT
    iface --> user : 422 INVALID_ARGUMENT
    deactivate store
    deactivate router
    deactivate iface
end

store -> storage : HTTPADAPTER-01 LIST Sessions({pageSize, pageToken})
activate storage

alt directory not found
    storage --> store : FileNotFoundError
    deactivate storage
    store --> router : 200 OK — [] (empty list)
    router --> iface : 200 OK — [] (empty list)
    iface --> user : 200 OK — [] (empty list)
    deactivate store
    deactivate router
    deactivate iface
end

storage --> store : 200 OK — [{session_id, created_at, message_count}]
deactivate storage

store --> router : 200 OK — [{session_id, created_at, message_count}]
deactivate store
router --> iface : 200 OK — [{session_id, created_at, message_count}]
iface --> user : 200 OK — [{session_id, created_at, message_count}]
deactivate router
deactivate iface

@enduml
