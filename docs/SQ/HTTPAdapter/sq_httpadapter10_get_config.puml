@startuml sq_api10_get_config
' ============================================================
' Title:     HTTPADAPTER-10 — GET Config
' Boundary:  nasim code agent
' Purpose:   Read current agent configuration
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> HTTPAdapter -> AgentController -> ConfigService -> ConfigRepository
' SM States: (no state change — read-only)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- HTTPADAPTER-10 GET Config

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "HTTPAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "ConfigService" as cfg_svc
end box

box "Repository" REPOSITORY_COLOR
  participant "ConfigRepository" as repo
end box

database "ConfigStore" as storage

== HTTPADAPTER-10 GET Config ==

user -> iface : HTTPADAPTER-10 GET Config({})
activate iface
iface -> router : HTTPADAPTER-10 GET Config({})
activate router

router -> cfg_svc : HTTPADAPTER-10 GET Config({})
activate cfg_svc

cfg_svc -> repo : HTTPADAPTER-10 GET Config({})
activate repo

repo -> storage : HTTPADAPTER-10 GET Config({})
activate storage

alt config not found
    storage --> repo : 404 NOT_FOUND\n{error: {code: "HTTPADAPTER-10_CONFIG_NOT_FOUND", message: "Configuration not found", status: 404}}
    deactivate storage
    repo --> cfg_svc : 404 NOT_FOUND
    deactivate repo
    cfg_svc --> router : 404 NOT_FOUND
    deactivate cfg_svc
    router --> iface : 404 NOT_FOUND
    deactivate router
    iface --> user : 404 NOT_FOUND
    deactivate iface
end

storage --> repo : 200 OK — {config}
deactivate storage

repo --> cfg_svc : 200 OK — {config}
deactivate repo

cfg_svc --> router : 200 OK — {config}
deactivate cfg_svc

router --> iface : 200 OK — {config}
iface --> user : 200 OK — {config}
deactivate router
deactivate iface

@enduml
