@startuml sq_api11_update_config
' ============================================================
' Title:     HTTPADAPTER-11 — UPDATE Config
' Boundary:  nasim code agent
' Purpose:   Update agent configuration at runtime
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> ConfigLoader -> ConfigStore
' SM States: (no state change — config is not an entity lifecycle)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- HTTPADAPTER-11 UPDATE Config

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "ConfigRepository" as loader
end box

database "ConfigStore" as storage

== HTTPADAPTER-11 UPDATE Config ==

user -> iface : HTTPADAPTER-11 UPDATE Config({patchData, updateMask})
activate iface
iface -> router : HTTPADAPTER-11 UPDATE Config({patchData, updateMask})
activate router

router -> loader : HTTPADAPTER-11 UPDATE Config({patchData, updateMask})
activate loader

alt validation fails
    loader --> router : 422 INVALID_ARGUMENT\n{error: {code: "HTTPADAPTER-11_VALIDATION_ERROR", message: "Invalid config update data", status: 422}}
    deactivate loader
    router --> iface : 422 INVALID_ARGUMENT
    iface --> user : 422 INVALID_ARGUMENT
    deactivate router
    deactivate iface
end

loader -> storage : HTTPADAPTER-11 UPDATE Config({patchData})
activate storage

alt disk write error
    storage --> loader : 500 INTERNAL\n{error: {code: "HTTPADAPTER-11_DISK_WRITE_ERROR", message: "Failed to persist config update", status: 500}}
    deactivate storage
    loader --> router : 500 INTERNAL
    router --> iface : 500 INTERNAL
    iface --> user : 500 INTERNAL
    deactivate loader
    deactivate router
    deactivate iface
end

storage --> loader : 200 OK
deactivate storage

loader --> router : 200 OK
deactivate loader
router --> iface : 200 OK
iface --> user : 200 OK
deactivate router
deactivate iface

@enduml
