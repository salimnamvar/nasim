@startuml sq_httpadapter06_dispatch_message
' ============================================================
' Title:     HTTPADP-06 — dispatchMessage
' Boundary:  NASIM Application — Controller Layer
' Purpose:   HTTP/SSE entry gate for user messages — sole API-first entry
'            for agent processing (sm_task_svc_agent: IDLE → RECEIVING).
' Intro:     POST /v1/sessions/{id}:dispatch converges at agent_ctrl before
'             reaching task_svc. No adapter bypasses the convergence point.
' Summary:   Successful dispatch streams AgentEvents via SSE; validation and
'             session errors break early with HTTP error codes.
' Milestone: v1.0
' Version:   10.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0), docs/UC/uc_http_adp.puml
' Review:    SQ Architect extraction 2026-07-01
' CSR Chain: User → HTTP Adapter → Agent Controller → Task Service
' SM States: IDLE → RECEIVING → THINKING → RESPONDING → IDLE
' ============================================================

!include ../common/sq_styles.puml

title nasim — HTTPADP-06 dispatchMessage

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "HTTP Adapter" as httpAdp
end box

box "API" API_COLOR
  participant "Agent Controller" as agentCtrl
end box

box "Service" SERVICE_COLOR
  participant "Task Service" as taskSvc
end box

== HTTPADP-06 dispatchMessage — entry ==

user -> httpAdp : POST /v1/sessions/{id}:dispatch\n{message}
activate httpAdp

httpAdp -> agentCtrl : AGENTCTRL-01 processRequest({sessionId, message})
activate agentCtrl

ref over agentCtrl
  AGENTCTRL-02 validateRequest
  AGENTCTRL-03 adaptProtocol
end ref

break validation_failed
  agentCtrl --> httpAdp : 422 UNPROCESSABLE\n{error: {code: "AGENTCTRL-02_VALIDATION_ERROR"}}
  httpAdp --> user : 422 UNPROCESSABLE
  deactivate agentCtrl
  deactivate httpAdp
end

agentCtrl -> taskSvc : AGENTCTRL-04 dispatchToServices → TASKSVC-01 processUserTask({sessionId, message})
activate taskSvc

ref over taskSvc : HTTPADP-06 dispatchMessage\nState: <back:#ECEFF1>IDLE</back> → <back:#E8EAF6>RECEIVING</back>

ref over taskSvc
  sq_taskservice01_process_user_task
end ref

taskSvc --> agentCtrl : 200 OK — {events}
deactivate taskSvc

agentCtrl --> httpAdp : 200 OK — {events}
deactivate agentCtrl

httpAdp --> user : 200 OK — SSE stream {events}
deactivate httpAdp

ref over taskSvc : HTTPADP-06 dispatchMessage\nState: <back:#D1C4E9>RESPONDING</back> → <back:#ECEFF1>IDLE</back>

== Summary ==
' HTTPADP-06 is the canonical entry gate for all interface containers per
' sm_task_svc_agent. Agent Controller is the single convergence point.

@enduml