@startuml sq_taskservice02_dispatch_tool_call
' ============================================================
' Title:     TASKSVC-02 — dispatchToolCall
' Boundary:  NASIM Application — Service Layer
' Purpose:   Route an LLM tool call through safety pipeline and Tool Service.
' Intro:     Invoked from TASKSVC-01 during TOOL_EXEC state. Never called
'             directly from agent_ctrl — task_svc mediates all tool dispatch.
' Summary:   Safety pipeline (TASKSVC-15) gates execution; hooks (TOOLSVC-HK02)
'             may run pre-dispatch; failures return to TASKSVC-14 recovery.
' Milestone: v1.0
' Version:   10.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0), docs/UC/uc_task_svc.puml
' Review:    SQ Architect extraction 2026-07-01
' CSR Chain: Task Service → Safety Service → Tool Service → Repositories
' SM States: TOOL_EXEC, AWAITING_APPROVAL, HOOK_RUNNING (sm_task_svc_agent.puml)
' ============================================================

!include ../common/sq_styles.puml

title nasim — TASKSVC-02 dispatchToolCall

box "Service" SERVICE_COLOR
  participant "Task Service" as taskSvc
  participant "Safety Service" as safetySvc
  participant "Tool Service" as toolSvc
end box

box "Repository" REPOSITORY_COLOR
  participant "Sandbox Repository" as sandboxRepo
  participant "Filesystem Repository" as fsRepo
end box

actor "User" as user
participant "CLI Adapter" as iface

== TASKSVC-02 dispatchToolCall — entry ==

taskSvc -> taskSvc : TASKSVC-02 dispatchToolCall({toolName, args})
activate taskSvc

ref over taskSvc, safetySvc, iface, user
  sq_ref_dispatch_safety_pipeline
end ref

break safety_denied
  ref over taskSvc : SAFETYSVC-02 requestApproval\nState: <back:#FFF9C4>AWAITING_APPROVAL</back> → <back:#ECEFF1>IDLE</back>
  taskSvc --> taskSvc : 403 PERMISSION_DENIED
  deactivate taskSvc
end

opt hooks_configured
  taskSvc -> toolSvc : TOOLSVC-HK02 dispatchPreToolHook({toolName, args})
  activate toolSvc
  ref over taskSvc, toolSvc : TOOLSVC-HK02 dispatchPreToolHook\nState: <back:#FFFDE7>HOOK_RUNNING</back>
  toolSvc --> taskSvc : 200 OK — {hookResult}
  deactivate toolSvc
end

taskSvc -> toolSvc : TOOLSVC-01 readFile / TOOLSVC-05 dispatchShellCommand / ...
activate toolSvc

alt shell_command
  toolSvc -> sandboxRepo : SANDBOXREPO-01 isolateCommand({cmd})
  activate sandboxRepo
  sandboxRepo --> toolSvc : 200 OK — {stdout, stderr, exitCode}
  deactivate sandboxRepo
else file_operation
  toolSvc -> fsRepo : FSREPO-01 readFile({path})
  activate fsRepo
  fsRepo --> toolSvc : 200 OK — {content}
  deactivate fsRepo
end

toolSvc --> taskSvc : 200 OK — {toolResult}
deactivate toolSvc

opt hooks_configured
  taskSvc -> toolSvc : TOOLSVC-HK03 dispatchPostToolHook({toolResult})
  activate toolSvc
  toolSvc --> taskSvc : 200 OK
  deactivate toolSvc
end

ref over taskSvc
  sq_ref_persist_conversation
end ref

ref over taskSvc : TASKSVC-02 dispatchToolCall\nState: <back:#B2DFDB>TOOL_EXEC</back> → <back:#D7CCC8>THINKING</back>

taskSvc --> taskSvc : 200 OK — {toolResult}
deactivate taskSvc

== Summary ==
' TASKSVC-02 encapsulates tool routing. Safety mode guards (ASK/BLOCK) from
' sm_safety_svc_safety determine whether execution proceeds or awaits approval.

@enduml