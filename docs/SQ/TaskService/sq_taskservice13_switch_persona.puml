@startuml sq_agent13_switch_persona
' ============================================================
' Title:     TASKSERVICE-13 — SWITCH Persona
' Boundary:  nasim code agent
' Purpose:   Unload current persona and activate a new one
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> PersonaService -> PersonaRepository
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TASKSERVICE-13 SWITCH Persona

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Task Service" as persona
end box

box "Repository" REPOSITORY_COLOR
  participant "Task Service" as personaRepo
end box

== TASKSERVICE-13 SWITCH Persona ==

user -> iface : POST /v1/agents/{agent_id}:switch-persona
activate iface
iface -> router : POST /v1/agents/{agent_id}:switch-persona
activate router
router -> persona : TASKSERVICE-13 SWITCH Persona({new_persona_name})
activate persona

alt switch succeeds without error
  ref over persona : TASKSERVICE-13 SWITCH Persona({new_persona_name}) <back:#43A047>RUNNING</back>
  persona -> personaRepo : TASKSERVICE-13 READ Persona({new_persona_name})
  activate personaRepo
  personaRepo --> persona : 200 OK
  deactivate personaRepo
  persona --> router : 200 OK
  deactivate persona
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else switch fails
  persona --> router : 404 NOT_FOUND\n{error: {code: "TASKSERVICE-13_NOT_FOUND", message: "Target persona not found", status: 404}}
  deactivate persona
  router --> iface : 404 NOT_FOUND\n{error: {code: "TASKSERVICE-13_NOT_FOUND", message: "Target persona not found", status: 404}}
  iface --> user : 404 NOT_FOUND\n{error: {code: "TASKSERVICE-13_NOT_FOUND", message: "Target persona not found", status: 404}}
  deactivate router
  deactivate iface
end

@enduml
