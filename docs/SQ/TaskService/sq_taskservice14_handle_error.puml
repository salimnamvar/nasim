@startuml sq_agent14_handle_error
' ============================================================
' Title:     TASKSERVICE-14 — HANDLE Error
' Boundary:  nasim code agent
' Purpose:   Classify errors and determine recovery action
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> ErrorService -> ErrorBoundary
' SM States: FAILED (#EF5350)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TASKSERVICE-14 HANDLE Error

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "TaskService" as errorService
end box

box "Repository" REPOSITORY_COLOR
  participant "TaskService" as boundary
end box

== TASKSERVICE-14 HANDLE Error ==

user -> iface : POST /v1/agents/{agent_id}:handle-error
activate iface
iface -> router : POST /v1/agents/{agent_id}:handle-error
activate router
router -> errorService : TASKSERVICE-14 HANDLE Error({error})
activate errorService

alt retryable error
  ref over errorService : TASKSERVICE-14 HANDLE Error({error}) <back:#EF5350>FAILED</back>
  errorService -> boundary : TASKSERVICE-14 PERSIST Error({error, recovery_action})
  activate boundary
  boundary --> errorService : 200 OK
  deactivate boundary
  errorService --> router : 200 OK
  deactivate errorService
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else unrecoverable error
  errorService --> router : 500 INTERNAL\n{error: {code: "TASKSERVICE-14_UNRECOVERABLE", message: "Unrecoverable error", status: 500}}
  deactivate errorService
  router --> iface : 500 INTERNAL\n{error: {code: "TASKSERVICE-14_UNRECOVERABLE", message: "Unrecoverable error", status: 500}}
  iface --> user : 500 INTERNAL\n{error: {code: "TASKSERVICE-14_UNRECOVERABLE", message: "Unrecoverable error", status: 500}}
  deactivate router
  deactivate iface
end

@enduml
