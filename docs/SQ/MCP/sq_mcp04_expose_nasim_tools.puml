@startuml sq_mcp04_expose_nasim_tools
' ============================================================
' Title:     MCP-04 — EXPOSE nasim Tools
' Boundary:  nasim code agent
' Purpose:   Expose nasim tools to external MCP clients
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> MCPServerRuntime
' SM States: STARTING (#FFA726), RUNNING (#66BB6A), ERROR (#FFCDD2)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MCP-04 EXPOSE nasim Tools

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "MCPServerRuntime" as mgr
end box

== MCP-04 EXPOSE nasim Tools ==

user -> iface : POST /mcp/server:start
activate iface
iface -> router : POST /mcp/server:start
activate router
router -> mgr : MCP-04 EXPOSE nasim Tools({})
activate mgr

alt validation succeeds
  ref over mgr : MCP-04 TRANSITION State
    ' SM States: STARTING (#FFA726), RUNNING (#66BB6A)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
