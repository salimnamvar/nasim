@startuml sq_mcp04_expose_nasim_tools
' ============================================================
' Title:     MCP-04 — EXPOSE nasim Tools
' Boundary:  nasim code agent
' Purpose:   Expose nasim tools to external MCP clients
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> MCPServerRuntime
' SM States: STARTING (#FFA726), RUNNING (#66BB6A), ERROR (#FFCDD2)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MCP-04 EXPOSE nasim Tools

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "MCPServerRuntime" as mgr
end box

== MCP-04 EXPOSE nasim Tools ==

user -> iface : MCP-04 EXPOSE nasim Tools({})
activate iface
iface -> router : MCP-04 EXPOSE nasim Tools({})
activate router
router -> mgr : MCP-04 EXPOSE nasim Tools({})
activate mgr

alt server_started
  ref over mgr : MCP-04 EXPOSE nasim Tools
    <back:#FFA726>STARTING</back> → <back:#66BB6A>RUNNING</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else server_failed
  mgr --> router : 500 INTERNAL\n{error: {code: "MCP-04_SERVER_START_FAILED", message: "MCP server runtime failed to start", status: 500}}
  deactivate mgr
  router --> iface : 500 INTERNAL
  iface --> user : 500 INTERNAL
  deactivate router
  deactivate iface
end

@enduml
