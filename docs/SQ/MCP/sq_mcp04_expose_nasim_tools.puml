@startuml sq_mcp04_expose_nasim_tools
' ============================================================
' Title:     MCP-04 — EXPOSE nasim Tools
' Boundary:  nasim code agent
' Purpose:   Expose nasim tools to external MCP clients
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> MCPAPI -> MCPManager -> MCPStore -> MCPDirectory
' SM States: STARTING (#FFA726), RUNNING (#66BB6A), ERROR (#FFCDD2)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MCP-04 EXPOSE nasim Tools

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "MCPAPI" as api
end box
box "MCP Group (Service)" #FFF3E0
  participant "MCPManager" as mgr
end box
box "MCP Group (Repository)" #E8F5E9
  participant "MCPStore" as store
end box
database "MCPDirectory" as dir

== MCP-04 EXPOSE nasim Tools ==

user -> router : POST /mcp/server:start
activate router
router -> api : MCP-04 EXPOSE nasim Tools({})
activate api
api -> mgr : MCP-04 EXPOSE nasim Tools({})
activate mgr

alt validation succeeds
  mgr -> store : MCP-04 EXPOSE nasim Tools({})
  activate store
  store -> dir : MCP-04 EXPOSE nasim Tools({})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : STARTING (#FFA726) -> RUNNING (#66BB6A)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
