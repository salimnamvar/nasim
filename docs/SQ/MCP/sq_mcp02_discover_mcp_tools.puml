@startuml sq_mcp02_discover_mcp_tools
' ============================================================
' Title:     MCP-02 — DISCOVER MCP Tools
' Boundary:  nasim code agent
' Purpose:   Discover and register tools from connected MCP server
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> McpManager -> McpStore -> McpDirectory -> MCPServer
' SM States: DISCOVERING (#A1887F), CONNECTED (#00BCD4), ERROR (#E57373)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MCP-02 DISCOVER MCP Tools

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "MCP Group (Service)" #FFF3E0
  participant "MCPManager" as mgr
end box
box "MCP Group (Repository)" #E8F5E9
  participant "MCPStore" as store
end box
database "MCPDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "MCPServer" as MCPServer
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "MCPServer" as MCPServer
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "MCPServer" as MCPServer
end box

== MCP-02 DISCOVER MCP Tools ==

user -> iface : GET /mcp/servers/{id}:discover
activate iface
iface -> router : GET /mcp/servers/{id}:discover
activate router
router -> mgr : MCP-02 DISCOVER MCP Tools({connection})
activate mgr

alt validation succeeds
  mgr -> store : MCP-02 DISCOVER MCP Tools({connection})
  activate store
  store -> dir : MCP-02 DISCOVER MCP Tools({connection})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : DISCOVERING (#A1887F) -> CONNECTED (#00BCD4)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
