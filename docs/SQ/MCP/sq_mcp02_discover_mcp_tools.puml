@startuml sq_mcp02_discover_mcp_tools
' ============================================================
' Title:     MCP-02 — DISCOVER MCP Tools
' Boundary:  nasim code agent
' Purpose:   Discover and register tools from connected MCP server
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> MCPDiscovery
' SM States: DISCOVERING (#A1887F), CONNECTED (#00BCD4), ERROR (#E57373)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MCP-02 DISCOVER MCP Tools

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "MCPDiscovery" as mgr
end box

== MCP-02 DISCOVER MCP Tools ==

user -> iface : GET /mcp/servers/{id}:discover
activate iface
iface -> router : GET /mcp/servers/{id}:discover
activate router
router -> mgr : MCP-02 DISCOVER MCP Tools({connection})
activate mgr

alt validation succeeds
  ref over mgr : MCP-02 TRANSITION State
    ' SM States: DISCOVERING (#A1887F), CONNECTED (#00BCD4)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
