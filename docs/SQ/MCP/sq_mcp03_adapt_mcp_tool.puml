@startuml sq_mcp03_adapt_mcp_tool
' ============================================================
' Title:     MCP-03 — ADAPT MCP Tool
' Boundary:  nasim code agent
' Purpose:   Wrap MCP server tool into nasim Tool format
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> MCPToolAdapter -> MCPClientRuntime
' SM States: CONNECTED (#00BCD4)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MCP-03 ADAPT MCP Tool

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "MCPToolAdapter" as svc
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "MCPClientRuntime" as mgr
end box

== MCP-03 ADAPT MCP Tool ==

user -> iface : MCP-03 ADAPT MCP Tool({tool_definition})
activate iface
iface -> router : MCP-03 ADAPT MCP Tool({tool_definition})
activate router
router -> svc : MCP-03 ADAPT MCP Tool({tool_definition})
activate svc
svc -> mgr : MCP-03 ADAPT MCP Tool({tool_definition})
activate mgr

alt tool_compatible
  ref over svc : MCP-03 ADAPT MCP Tool({tool_definition}) <back:#00BCD4>CONNECTED</back>
  mgr --> svc : 200 OK
  deactivate mgr
  svc --> router : 200 OK
  deactivate svc
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else tool_incompatible
  mgr --> svc : 422 UNPROCESSABLE\n{error: {code: "MCP-03_ADAPTATION_FAILED", message: "MCP tool adaptation failed", status: 422}}
  deactivate mgr
  svc --> router : 422 UNPROCESSABLE
  deactivate svc
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
