@startuml sq_mcp03_adapt_mcp_tool
' ============================================================
' Title:     MCP-03 — ADAPT MCP Tool
' Boundary:  nasim code agent
' Purpose:   Wrap MCP server tool into nasim Tool format
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> MCPToolAdapter
' SM States: CONNECTED (#00BCD4)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MCP-03 ADAPT MCP Tool

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "MCPToolAdapter" as mgr
end box

== MCP-03 ADAPT MCP Tool ==

user -> iface : POST /mcp/tools:adapt
activate iface
iface -> router : POST /mcp/tools:adapt
activate router
router -> mgr : MCP-03 ADAPT MCP Tool({tool_definition})
activate mgr

alt validation succeeds
  ref over mgr : MCP-03 TRANSITION State
    ' SM States: CONNECTED (#00BCD4)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
