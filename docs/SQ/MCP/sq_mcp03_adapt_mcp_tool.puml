@startuml sq_mcp03_adapt_mcp_tool
' ============================================================
' Title:     MCP-03 — ADAPT MCP Tool
' Boundary:  nasim code agent
' Purpose:   Wrap MCP server tool into nasim Tool format
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> McpManager -> McpStore -> McpDirectory -> MCPServer
' SM States: CONNECTED (#00BCD4)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MCP-03 ADAPT MCP Tool

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "MCP Group (Service)" #FFF3E0
  participant "MCPManager" as mgr
end box
box "MCP Group (Repository)" #E8F5E9
  participant "MCPStore" as store
end box
database "MCPDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "MCPServer" as MCPServer
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "MCPServer" as MCPServer
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "MCPServer" as MCPServer
end box

== MCP-03 ADAPT MCP Tool ==

user -> iface : POST /mcp/tools:adapt
activate iface
iface -> router : POST /mcp/tools:adapt
activate router
router -> mgr : MCP-03 ADAPT MCP Tool({tool_definition})
activate mgr

alt validation succeeds
  mgr -> store : MCP-03 ADAPT MCP Tool({tool_definition})
  activate store
  store -> dir : MCP-03 ADAPT MCP Tool({tool_definition})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : CONNECTED (#00BCD4)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
