@startuml sq_mcp01_connect_mcp_server
' ============================================================
' Title:     MCP-01 — CONNECT MCP Server
' Boundary:  nasim code agent
' Purpose:   Connect to external MCP server via stdio/SSE
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> MCPClientRuntime
' SM States: CONNECTING (#FFCA28), CONNECTED (#00BCD4), ERROR (#E57373)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MCP-01 CONNECT MCP Server

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "MCPClientRuntime" as mgr
end box

== MCP-01 CONNECT MCP Server ==

user -> iface : MCP-01 CONNECT MCP Server({endpoint, transport})
activate iface
iface -> router : MCP-01 CONNECT MCP Server({endpoint, transport})
activate router
router -> mgr : MCP-01 CONNECT MCP Server({endpoint, transport})
activate mgr

alt connection_established
  ref over mgr : MCP-01 CONNECT MCP Server
    <back:#FFCA28>CONNECTING</back> → <back:#00BCD4>CONNECTED</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else connection_failed
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "MCP-01_CONNECTION_FAILED", message: "MCP server connection failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
