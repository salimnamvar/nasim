@startuml sq_mcp01_connect_mcp_server
' ============================================================
' Title:     MCP-01 — CONNECT MCP Server
' Boundary:  nasim code agent
' Purpose:   Connect to external MCP server via stdio/SSE
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> MCPAPI -> MCPManager -> MCPStore -> MCPDirectory
' SM States: CONNECTING (#FFCA28), CONNECTED (#00BCD4), ERROR (#E57373)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MCP-01 CONNECT MCP Server

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "MCPAPI" as api
end box
box "MCP Group (Service)" #FFF3E0
  participant "MCPManager" as mgr
end box
box "MCP Group (Repository)" #E8F5E9
  participant "MCPStore" as store
end box
database "MCPDirectory" as dir

== MCP-01 CONNECT MCP Server ==

user -> router : POST /mcp/servers/{id}:connect
activate router
router -> api : MCP-01 CONNECT MCP Server({endpoint, transport})
activate api
api -> mgr : MCP-01 CONNECT MCP Server({endpoint, transport})
activate mgr

alt validation succeeds
  mgr -> store : MCP-01 CONNECT MCP Server({endpoint, transport})
  activate store
  store -> dir : MCP-01 CONNECT MCP Server({endpoint, transport})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : CONNECTING (#FFCA28) -> CONNECTED (#00BCD4)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
