@startuml sq_mcp01_connect_mcp_server
' ============================================================
' Title:     MCP-01 — CONNECT MCP Server
' Boundary:  nasim code agent
' Purpose:   Connect to external MCP server via stdio/SSE
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> McpManager -> McpStore -> McpDirectory -> MCPServer
' SM States: CONNECTING (#FFCA28), CONNECTED (#00BCD4), ERROR (#E57373)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MCP-01 CONNECT MCP Server

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "MCP Group (Service)" #FFF3E0
  participant "MCPManager" as mgr
end box
box "MCP Group (Repository)" #E8F5E9
  participant "MCPStore" as store
end box
database "MCPDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "MCPServer" as MCPServer
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "MCPServer" as MCPServer
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "MCPServer" as MCPServer
end box

== MCP-01 CONNECT MCP Server ==

user -> iface : POST /mcp/servers/{id}:connect
activate iface
iface -> router : POST /mcp/servers/{id}:connect
activate router
router -> mgr : MCP-01 CONNECT MCP Server({endpoint, transport})
activate mgr

alt validation succeeds
  mgr -> store : MCP-01 CONNECT MCP Server({endpoint, transport})
  activate store
  store -> dir : MCP-01 CONNECT MCP Server({endpoint, transport})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : CONNECTING (#FFCA28) -> CONNECTED (#00BCD4)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
