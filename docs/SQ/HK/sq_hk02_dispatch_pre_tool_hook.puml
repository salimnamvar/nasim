@startuml sq_hk02_dispatch_pre_tool_hook
' ============================================================
' Title:     nasim — SQ: Dispatch Pre-Tool Hook
' Boundary:  nasim code agent CLI + HTTP API
' Purpose:   Execute hooks before tool execution
' Milestone: v1.0
' Version:   3.0.0
' Source:    docs/audit/nasim-car-improvement-plan.md CAR-18
' Review:    —
' ============================================================

title nasim — SQ: Pre-Tool Hook (HK-02)

participant "AgentOrchestrator" as agent
participant "HookManager" as hooks
participant "Hook" as hook
participant "ToolRegistry" as tools

== Pre-Tool Hook ==

agent -> hooks : execute_pre_tool(tool_name, args)
activate hooks

loop for each registered hook
    hooks -> hook : handler(tool_name, args)
    activate hook
    hook --> hooks : HookResult(allow=true/false, modified_input=...)
    deactivate hook
end

alt any hook denies
    hooks --> agent : HookResult(allow=false, message="blocked")
    note right : Tool execution stopped
else all hooks allow
    hooks --> agent : HookResult(allow=true)
    deactivate hooks

    agent -> tools : execute(tool_name, args)
    activate tools
    tools --> agent : ToolResult
    deactivate tools
end

@enduml
