@startuml sq_hk02_dispatch_pre_tool_hook
!include ../common/sq_styles.puml
' ============================================================
' Title:     HK-02 — DISPATCH Pre-Tool Hook
' Boundary:  nasim code agent
' Purpose:   Execute hooks before tool execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — HK-02 DISPATCH Pre-Tool Hook

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Hooks Group" #F3E5F5
  participant "HookManager" as hooks
  participant "Hook" as hook
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as tools
end box
box "Repository Group" #E8F5E9
  participant "HookRepository" as hook_repo
end box

note over user
  Scope:          HK-02 Dispatch Pre-Tool Hook — Execute hooks before tool execution
  Preconditions:  Hooks registered for PreToolCall event; tool_name and args are valid
  Contexts:       Called by AgentOrchestrator before tool execution
  Excludes:       Hook registration (HK-01), Post-tool dispatch (HK-03), LLM hooks (HK-04, HK-05)
  Rollback:       DENY action → tool execution aborted, HookResult returned immediately
  Design:         Hooks execute in priority order; DENY action breaks the loop early
  Returns:
    - Success: 200 HookResult(action=ALLOW, modified_args?)
    - Failure: 200 HookResult(action=DENY, reason)
end note

== HK-02 DISPATCH Pre-Tool Hook ==

user -> router : invoke agent
activate router
router -> agent : hk02 DISPATCH Pre-Tool Hook(tool_name, args)
activate agent
agent -> hooks : hk02 DISPATCH Pre-Tool Hook(tool_name, args)
activate hooks
hooks -> hooks : hk02 FIND Hooks For Event(PreToolCall)

loop for each hook in priority order
    hooks -> hook : hk02 EXECUTE Hook(tool_name, args)
    activate hook
    hook --> hooks : HookResult(action, data?)
    deactivate hook

    break action == DENY
        hooks --> agent : HookResult(action=DENY, reason)
        agent --> router : HookResult(action=DENY)
    end
end

hooks --> agent : HookResult(action=ALLOW, modified_args?)
deactivate hooks
agent --> router : HookResult(action=ALLOW)
deactivate agent
deactivate router

note over user
  Flow:    HK-02 → invoke agent → find hooks → loop priority → execute hook → DENY or continue
  State:   No state change
  Success: 200 HookResult(action=ALLOW, modified_args?)
  Failure: 200: DENY action — tool execution aborted, reason returned
end note

@enduml
