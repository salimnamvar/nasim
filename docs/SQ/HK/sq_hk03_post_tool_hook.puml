@startuml sq_hk03_post_tool_hook
' ============================================================
' Title:     nasim — SQ: Execute Post-Tool Hook
' Boundary:  nasim code agent CLI + HTTP API
' Purpose:   Execute hooks after tool execution
' Milestone: v1.0
' Version:   3.0.0
' Source:    docs/audit/nasim-car-improvement-plan.md CAR-18
' Review:    —
' ============================================================

title nasim — SQ: Post-Tool Hook (HK-03)

participant "AgentOrchestrator" as agent
participant "ToolRegistry" as tools
participant "HookManager" as hooks
participant "Hook" as hook

== Post-Tool Hook ==

agent -> tools : execute(tool_name, args)
activate tools
tools --> agent : ToolResult
deactivate tools

agent -> hooks : execute_post_tool(tool_name, result)
activate hooks

loop for each registered hook
    hooks -> hook : handler(tool_name, result)
    activate hook
    hook --> hooks : HookResult(allow=true, modified_result=...)
    deactivate hook
end

hooks --> agent : HookResult
deactivate hooks

@enduml
