@startuml sq_mem02_recall_knowledge
!include ../common/sq_styles.puml
' ============================================================
' Title:     MEM-02 — RECALL Knowledge
' Boundary:  nasim code agent
' Purpose:   Retrieve previously stored knowledge
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — MEM-02 RECALL Knowledge

actor "User" as user

box "Controller Group" #E3F2FD
  participant "ServerRouter" as router
end box
box "Service Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Repository Group" #E8F5E9
  participant "MemoryStore" as store
  participant "MemoryScope" as scope
  participant "MemoryIndex" as index
end box

note over user
  Scope:          MEM-02 RECALL Knowledge
  Preconditions:  MemoryStore accessible
  Contexts:       Called by AgentOrchestrator during task processing
  Excludes:       Knowledge persist, search, scope filtering
  Rollback:       Key not found returns null
  Design:         Scope-filtered lookup via index
  Returns:
    - Success: recalled_entry
    - Failure: null (key not found)
end note


user -> router : types input
router -> agent : PROCESS(user_input)

== MEM-02 RECALL Knowledge ==

agent -> store : MEM-02 RECALL(key, scope)
activate store

store -> scope : filter_by_scope(key, scope)
activate scope
scope --> store : scoped_results
deactivate scope

store -> index : lookup(key)
activate index
index --> store : entry_data
deactivate index

break Key not found
    store --> agent : null
end

store --> agent : recalled_entry
deactivate store

agent --> router : AgentEvent(Done)

note over user
  Flow:    MEM-02 → agent → store → scope → store → index → store → agent
  State:   No state change
  Success: recalled_entry
  Failure: null — key not found in scope
end note


@enduml
