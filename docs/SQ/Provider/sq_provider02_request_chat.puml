@startuml sq_provider02_request_chat
' ============================================================
' Title:     PRV-02 — REQUEST Chat
' Boundary:  nasim code agent
' Purpose:   Synchronous LLM chat completion via provider abstraction
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> Provider
' SM States: THINKING (#D7CCC8), ERROR (#FFEBEE)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PRV-02 REQUEST Chat

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "LLMRepository" as mgr
end box

== PRV-02 REQUEST Chat ==

user -> iface : POST /providers/{id}:chat
activate iface
iface -> router : POST /providers/{id}:chat
activate router
router -> mgr : PRV-02 REQUEST Chat({messages, tools})
activate mgr

alt validation succeeds
  ref over mgr : PRV-02 REQUEST Chat({messages, tools}) <back:#D7CCC8>THINKING</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
