@startuml sq_provider02_request_chat
' ============================================================
' Title:     PRV-02 — REQUEST Chat
' Boundary:  nasim code agent
' Purpose:   Synchronous LLM chat completion via provider abstraction
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ProviderManager -> ProviderStore -> ProviderDirectory -> LLMBackend
' SM States: THINKING (#D7CCC8), ERROR (#FFEBEE)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PRV-02 REQUEST Chat

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Provider Group (Service)" #FFF3E0
  participant "ProviderManager" as mgr
end box
box "Provider Group (Repository)" #E8F5E9
  participant "ProviderStore" as store
end box
database "ProviderDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "LLMBackend" as LLMBackend
end box



== PRV-02 REQUEST Chat ==

user -> iface : POST /providers/{id}:chat
activate iface
iface -> router : POST /providers/{id}:chat
activate router
router -> mgr : PRV-02 REQUEST Chat({messages, tools})
activate mgr

alt validation succeeds
  mgr -> store : PRV-02 REQUEST Chat({messages, tools})
  activate store
  store -> dir : PRV-02 REQUEST Chat({messages, tools})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#D7CCC8>THINKING</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
