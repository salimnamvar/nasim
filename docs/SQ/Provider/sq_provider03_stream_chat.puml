@startuml sq_provider03_stream_chat
' ============================================================
' Title:     PRV-03 — STREAM Chat
' Boundary:  nasim code agent
' Purpose:   Streaming LLM chat completion via provider abstraction
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ProviderAPI -> ProviderManager -> ProviderStore -> ProviderDirectory
' SM States: THINKING (#D7CCC8), RESPONDING (#D1C4E9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PRV-03 STREAM Chat

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ProviderAPI" as api
end box
box "Provider Group (Service)" #FFF3E0
  participant "ProviderManager" as mgr
end box
box "Provider Group (Repository)" #E8F5E9
  participant "ProviderStore" as store
end box
database "ProviderDirectory" as dir

== PRV-03 STREAM Chat ==

user -> router : POST /providers/{id}:chat/stream
activate router
router -> api : PRV-03 STREAM Chat({messages, tools})
activate api
api -> mgr : PRV-03 STREAM Chat({messages, tools})
activate mgr

alt validation succeeds
  mgr -> store : PRV-03 STREAM Chat({messages, tools})
  activate store
  store -> dir : PRV-03 STREAM Chat({messages, tools})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : THINKING (#D7CCC8) -> RESPONDING (#D1C4E9)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
