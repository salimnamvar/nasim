@startuml sq_provider04_select_provider_backend
' ============================================================
' Title:     PRV-04 — SELECT Provider Backend
' Boundary:  nasim code agent
' Purpose:   Map config.provider string to provider class
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ProviderAPI -> ProviderManager -> ProviderStore -> ProviderDirectory
' SM States: SELECTING (#FBC02D), ERROR (#E64A19)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PRV-04 SELECT Provider Backend

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ProviderAPI" as api
end box
box "Provider Group (Service)" #FFF3E0
  participant "ProviderManager" as mgr
end box
box "Provider Group (Repository)" #E8F5E9
  participant "ProviderStore" as store
end box
database "ProviderDirectory" as dir

== PRV-04 SELECT Provider Backend ==

user -> router : POST /providers:select
activate router
router -> api : PRV-04 SELECT Provider Backend({provider_name})
activate api
api -> mgr : PRV-04 SELECT Provider Backend({provider_name})
activate mgr

alt validation succeeds
  mgr -> store : PRV-04 SELECT Provider Backend({provider_name})
  activate store
  store -> dir : PRV-04 SELECT Provider Backend({provider_name})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : SELECTING (#FBC02D)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else provider not found
  mgr --> api : 404 Not Found
  deactivate mgr
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end

@enduml
