@startuml sq_provider04_select_provider_backend
' ============================================================
' Title:     PRV-04 — SELECT Provider Backend
' Boundary:  nasim code agent
' Purpose:   Map config.provider string to provider class
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ProviderManager -> ProviderStore -> ProviderDirectory -> LLMBackend
' SM States: SELECTING (#FBC02D), ERROR (#E64A19)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PRV-04 SELECT Provider Backend

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Provider Group (Service)" #FFF3E0
  participant "ProviderManager" as mgr
end box
box "Provider Group (Repository)" #E8F5E9
  participant "ProviderStore" as store
end box
database "ProviderDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "LLMBackend" as LLMBackend
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "LLMBackend" as LLMBackend
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "LLMBackend" as LLMBackend
end box

== PRV-04 SELECT Provider Backend ==

user -> iface : POST /providers:select
activate iface
iface -> router : POST /providers:select
activate router
router -> mgr : PRV-04 SELECT Provider Backend({provider_name})
activate mgr

alt validation succeeds
  mgr -> store : PRV-04 SELECT Provider Backend({provider_name})
  activate store
  store -> dir : PRV-04 SELECT Provider Backend({provider_name})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : SELECTING (#FBC02D)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else provider not found
  mgr --> router : 404 Not Found
  deactivate mgr
  router --> iface : 404 Not Found
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
