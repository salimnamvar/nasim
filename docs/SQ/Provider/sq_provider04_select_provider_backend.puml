@startuml sq_provider04_select_provider_backend
' ============================================================
' Title:     PRV-04 — SELECT Provider Backend
' Boundary:  nasim code agent
' Purpose:   Map config.provider string to provider class
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> Provider
' SM States: SELECTING (#FBC02D), ERROR (#E64A19)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PRV-04 SELECT Provider Backend

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "Provider" as mgr
end box

== PRV-04 SELECT Provider Backend ==

user -> iface : POST /providers:select
activate iface
iface -> router : POST /providers:select
activate router
router -> mgr : PRV-04 SELECT Provider Backend({provider_name})
activate mgr

alt validation succeeds
  ref over mgr : PRV-04 SELECT Provider Backend({provider_name}) <back:#FBC02D>SELECTING</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else provider not found
  mgr --> router : 404 Not Found
  deactivate mgr
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
