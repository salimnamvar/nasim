@startuml sq_provider01_register_provider
' ============================================================
' Title:     PRV-01 — REGISTER Provider
' Boundary:  nasim code agent
' Purpose:   Provider instantiation from config
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ProviderAPI -> ProviderManager -> ProviderStore -> ProviderDirectory
' SM States: REGISTERING (#29B6F6), ACTIVE (#03A9F4), ERROR (#E64A19)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PRV-01 REGISTER Provider

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ProviderAPI" as api
end box
box "Provider Group (Service)" #FFF3E0
  participant "ProviderManager" as mgr
end box
box "Provider Group (Repository)" #E8F5E9
  participant "ProviderStore" as store
end box
database "ProviderDirectory" as dir

== PRV-01 REGISTER Provider ==

user -> router : POST /providers:register
activate router
router -> api : PRV-01 REGISTER Provider({config})
activate api
api -> mgr : PRV-01 REGISTER Provider({config})
activate mgr

alt validation succeeds
  mgr -> store : PRV-01 REGISTER Provider({config})
  activate store
  store -> dir : PRV-01 REGISTER Provider({config})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : REGISTERING (#29B6F6) -> ACTIVE (#03A9F4)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
