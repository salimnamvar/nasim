@startuml sq_agt01_execute_user_task
' ============================================================
' Title:     AGT-01 — Execute User Task
' Boundary:  nasim code agent CLI
' Purpose:   Core agentic loop: LLM call -> tool dispatch -> repeat
' Milestone: v0.1
' Version:   1.0.0
' Source:    —
' Review:    —
' ============================================================

actor "Developer" as user
participant "REPL" as repl
participant "AgentLoop" as agent
participant "ContextManager" as ctx
participant "OllamaClient" as llm
participant "ToolExecutor" as tool

note over repl
  Scope:          Single user task execution
  Preconditions:  Agent initialized, Ollama reachable
  Excludes:       Slash commands, streaming display
  Contexts:       Called by CLI-01 (Process User Input)
  Rollback:       Error state -> IDLE
  Design:         Max 20 iterations to prevent infinite loops
end note

user -> repl : types input
repl -> agent : run(user_input)
agent -> ctx : append user message
agent -> ctx : get messages list
agent -> llm : chat(messages, tools)

alt LLM returns text only
    llm --> agent : LLMResponse(content)
    agent -> ctx : append assistant message
    agent --> repl : final text
    repl --> user : display response
else LLM returns tool calls
    llm --> agent : LLMResponse(tool_calls)
    agent -> ctx : append assistant message with tool_calls
    loop for each tool_call
        agent -> tool : execute_tool(name, args)
        tool --> agent : result string
        agent -> ctx : append tool result message
    end
    agent -> llm : chat(messages, tools)  [recurse]
    note right of agent : Max 20 iterations
    llm --> agent : LLMResponse(content)
    agent -> ctx : append assistant message
    agent --> repl : final text
    repl --> user : display response
end

note over repl
  Flow:    User -> Agent -> LLM -> (tool loop) -> response
  State:   IDLE -> LISTENING -> THINKING -> [TOOL_EXEC]* -> RESPONDING -> IDLE
  Failure: LLM error or tool error -> ERROR -> IDLE
  Success: Final text displayed to user
end note

@enduml
