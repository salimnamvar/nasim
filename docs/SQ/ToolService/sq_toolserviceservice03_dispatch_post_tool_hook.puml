@startuml sq_hooks03_dispatch_post_tool_hook
' ============================================================
' Title:     TOOLSERVICE-03 — DISPATCH Post-Tool Hook
' Boundary:  nasim code agent
' Purpose:   Execute hooks after tool execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> HookManager
' SM States: HOOK_RUNNING (#FFFDE7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TOOLSERVICE-03 DISPATCH Post-Tool Hook

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "ToolService" as mgr
end box

== TOOLSERVICE-03 DISPATCH Post-Tool Hook ==

user -> iface : POST /hooks/{id}:dispatch
activate iface
iface -> router : POST /hooks/{id}:dispatch
activate router
router -> mgr : TOOLSERVICE-03 DISPATCH Post-Tool Hook({tool_name, result})
activate mgr

alt validation succeeds
  ref over mgr : TOOLSERVICE-03 DISPATCH Post-Tool Hook({tool_name, result}) <back:#FFFDE7>HOOK_RUNNING</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "TOOLSERVICE-03_POST_TOOL_FAILED", message: "Post-tool hook dispatch failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "TOOLSERVICE-03_POST_TOOL_FAILED", message: "Post-tool hook dispatch failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "TOOLSERVICE-03_POST_TOOL_FAILED", message: "Post-tool hook dispatch failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
