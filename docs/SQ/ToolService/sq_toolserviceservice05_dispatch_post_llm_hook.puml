@startuml sq_hooks05_dispatch_post_llm_hook
' ============================================================
' Title:     TOOLSERVICE-05 — DISPATCH Post-LLM Hook
' Boundary:  nasim code agent
' Purpose:   Execute hooks after LLM call completes
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> HookManager
' SM States: HOOK_RUNNING (#FFFDE7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TOOLSERVICE-05 DISPATCH Post-LLM Hook

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "ToolService" as mgr
end box

== TOOLSERVICE-05 DISPATCH Post-LLM Hook ==

user -> iface : POST /hooks/{id}:dispatch
activate iface
iface -> router : POST /hooks/{id}:dispatch
activate router
router -> mgr : TOOLSERVICE-05 DISPATCH Post-LLM Hook({llm_result})
activate mgr

alt validation succeeds
  ref over mgr : TOOLSERVICE-05 DISPATCH Post-LLM Hook({llm_result}) <back:#FFFDE7>HOOK_RUNNING</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "TOOLSERVICE-05_POST_LLM_FAILED", message: "Post-LLM hook dispatch failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "TOOLSERVICE-05_POST_LLM_FAILED", message: "Post-LLM hook dispatch failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "TOOLSERVICE-05_POST_LLM_FAILED", message: "Post-LLM hook dispatch failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
