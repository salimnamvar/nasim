@startuml sq_wirelog02_read_log
' ============================================================
' Title:     WRL-02 — READ Log
' Boundary:  nasim code agent
' Purpose:   Sequential scan for replay
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> WireLogAPI -> WireLogManager -> WireLogStore -> WireLogDirectory
' SM States: ACTIVE (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- WRL-02 READ Log

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "WireLogAPI" as api
end box
box "WireLog Group (Service)" #FFF3E0
  participant "WireLogManager" as mgr
end box
box "WireLog Group (Repository)" #E8F5E9
  participant "WireLogStore" as store
end box
database "WireLogDirectory" as dir

== WRL-02 READ Log ==

user -> router : GET /wirelog/events
activate router
router -> api : wrl02 READ Log(session_id, filter)
activate api
api -> mgr : wrl02 READ Log(session_id, filter)
activate mgr

alt read succeeds
  mgr -> store : wrl02 READ Log(session_id, filter)
  activate store
  store -> dir : wrl02 READ Log(session_id, filter)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : ACTIVE (#43A047)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else no events found
  mgr --> api : 404 Not Found
  deactivate mgr
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end

@enduml
