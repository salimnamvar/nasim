@startuml sq_wirelog01_append_event
' ============================================================
' Title:     WRL-01 — APPEND Event
' Boundary:  nasim code agent
' Purpose:   Append event to wire log
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> WireLog -> WireAppender -> FileSystem
' SM States: (no session state change — append-only log)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- WRL-01 APPEND Event

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "WireLogRepository" as wl
  participant "WireLogRepository" as appender
end box

database "WireLogStorage" as storage

== WRL-01 APPEND Event ==

user -> iface : POST /wirelog/events
activate iface
iface -> router : POST /wirelog/events
activate router
router -> wl : WRL-01 APPEND Event(event_data)
activate wl

alt append succeeds
  wl -> appender : WRL-01 APPEND Event(event_data)
  activate appender
  appender -> storage : WRL-01 APPEND Event(event_data)
  activate storage
  storage --> appender : 200 OK
  deactivate storage
  appender --> wl : 200 OK
  deactivate appender
  wl --> router : 200 OK
  deactivate wl
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else write failure
  wl --> router : 422 Unprocessable
  deactivate wl
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
