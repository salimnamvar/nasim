@startuml sq_wirelog01_append_event
' ============================================================
' Title:     WRL-01 — APPEND Event
' Boundary:  nasim code agent
' Purpose:   Append event to wire log
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> WireLogAPI -> WireLogManager -> WireLogStore -> WireLogDirectory
' SM States: ACTIVE (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- WRL-01 APPEND Event

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "WireLogAPI" as api
end box
box "WireLog Group (Service)" #FFF3E0
  participant "WireLogManager" as mgr
end box
box "WireLog Group (Repository)" #E8F5E9
  participant "WireLogStore" as store
end box
database "WireLogDirectory" as dir

== WRL-01 APPEND Event ==

user -> router : POST /wirelog/events
activate router
router -> api : wrl01 APPEND Event(event_data)
activate api
api -> mgr : wrl01 APPEND Event(event_data)
activate mgr

alt append succeeds
  mgr -> store : wrl01 APPEND Event(event_data)
  activate store
  store -> dir : wrl01 APPEND Event(event_data)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : ACTIVE (#43A047)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else write failure
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
