@startuml sq_wirelog01_append_event
' ============================================================
' Title:     WRL-01 — APPEND Event
' Boundary:  nasim code agent
' Purpose:   Append event to wire log
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> WirelogManager -> WirelogStore -> WirelogDirectory -> FileSystem
' SM States: ACTIVE (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- WRL-01 APPEND Event

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "WireLog Group (Service)" #FFF3E0
  participant "WireLogManager" as mgr
end box
box "WireLog Group (Repository)" #E8F5E9
  participant "WireLogStore" as store
end box
database "WireLogDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== WRL-01 APPEND Event ==

user -> iface : POST /wirelog/events
activate iface
iface -> router : POST /wirelog/events
activate router
router -> mgr : wrl01 APPEND Event(event_data)
activate mgr

alt append succeeds
  mgr -> store : wrl01 APPEND Event(event_data)
  activate store
  store -> dir : wrl01 APPEND Event(event_data)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#43A047>ACTIVE</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else write failure
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
