@startuml sq_wirelog04_fork_session
' ============================================================
' Title:     WRL-04 — FORK Session
' Boundary:  nasim code agent
' Purpose:   Fork session at any turn
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> WireLogAPI -> WireLogManager -> WireLogStore -> WireLogDirectory
' SM States: BRANCHED (#7B1FA2)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- WRL-04 FORK Session

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "WireLogAPI" as api
end box
box "WireLog Group (Service)" #FFF3E0
  participant "WireLogManager" as mgr
end box
box "WireLog Group (Repository)" #E8F5E9
  participant "WireLogStore" as store
end box
database "WireLogDirectory" as dir

== WRL-04 FORK Session ==

user -> router : POST /wirelog/fork
activate router
router -> api : wrl04 FORK Session(source_session_id, fork_turn)
activate api
api -> mgr : wrl04 FORK Session(source_session_id, fork_turn)
activate mgr

alt fork succeeds
  mgr -> store : wrl04 FORK Session(source_session_id, fork_turn)
  activate store
  store -> dir : wrl04 FORK Session(source_session_id, fork_turn)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : BRANCHED (#7B1FA2)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else source not found
  mgr --> api : 404 Not Found
  deactivate mgr
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end

@enduml
