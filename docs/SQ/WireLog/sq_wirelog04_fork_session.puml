@startuml sq_wirelog04_fork_session
' ============================================================
' Title:     WRL-04 — FORK Session
' Boundary:  nasim code agent
' Purpose:   Fork session at any turn
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> WirelogManager -> WirelogStore -> WirelogDirectory -> FileSystem
' SM States: BRANCHED (#7B1FA2)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- WRL-04 FORK Session

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "WireLog Group (Service)" #FFF3E0
  participant "WireLogManager" as mgr
end box
box "WireLog Group (Repository)" #E8F5E9
  participant "WireLogStore" as store
end box
database "WireLogDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== WRL-04 FORK Session ==

user -> iface : POST /wirelog/fork
activate iface
iface -> router : POST /wirelog/fork
activate router
router -> mgr : wrl04 FORK Session(source_session_id, fork_turn)
activate mgr

alt fork succeeds
  mgr -> store : wrl04 FORK Session(source_session_id, fork_turn)
  activate store
  store -> dir : wrl04 FORK Session(source_session_id, fork_turn)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : BRANCHED (#7B1FA2)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else source not found
  mgr --> router : 404 Not Found
  deactivate mgr
  router --> iface : 404 Not Found
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
