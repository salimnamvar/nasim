@startuml sq_wirelog03_seek_turn
' ============================================================
' Title:     WRL-03 — SEEK Turn
' Boundary:  nasim code agent
' Purpose:   Seek to a specific turn in the wire log
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> WireLog -> WireReader -> FileSystem
' SM States: (no session state change — seek is read-only)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- WRL-03 SEEK Turn

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "WireLog" as wl
  participant "WireReader" as reader
end box

database "WireLogStorage" as storage

== WRL-03 SEEK Turn ==

user -> iface : GET /wirelog/turns/{turn}
activate iface
iface -> router : GET /wirelog/turns/{turn}
activate router
router -> wl : WRL-03 SEEK Turn(target_turn_number)
activate wl

alt turn found
  wl -> reader : WRL-03 SEEK Turn(target_turn_number)
  activate reader
  reader -> storage : WRL-03 SEEK Turn(target_turn_number)
  activate storage
  storage --> reader : 200 OK
  deactivate storage
  reader --> wl : 200 OK
  deactivate reader
  wl --> router : 200 OK
  deactivate wl
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else turn not found
  wl --> router : 404 Not Found
  deactivate wl
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
