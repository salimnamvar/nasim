@startuml sq_wirelog03_seek_turn
' ============================================================
' Title:     WRL-03 — SEEK Turn
' Boundary:  nasim code agent
' Purpose:   Seek to a specific turn in the wire log
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> WireLogAPI -> WireLogManager -> WireLogStore -> WireLogDirectory
' SM States: RESTORED (#1E88E5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- WRL-03 SEEK Turn

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "WireLogAPI" as api
end box
box "WireLog Group (Service)" #FFF3E0
  participant "WireLogManager" as mgr
end box
box "WireLog Group (Repository)" #E8F5E9
  participant "WireLogStore" as store
end box
database "WireLogDirectory" as dir

== WRL-03 SEEK Turn ==

user -> router : GET /wirelog/turns/{turn}
activate router
router -> api : wrl03 SEEK Turn(target_turn_number)
activate api
api -> mgr : wrl03 SEEK Turn(target_turn_number)
activate mgr

alt turn found
  mgr -> store : wrl03 SEEK Turn(target_turn_number)
  activate store
  store -> dir : wrl03 SEEK Turn(target_turn_number)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : RESTORED (#1E88E5)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else turn not found
  mgr --> api : 404 Not Found
  deactivate mgr
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end

@enduml
