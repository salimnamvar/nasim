@startuml sq_wirelog05_checkpoint_turn
' ============================================================
' Title:     WRL-05 — CHECKPOINT Turn
' Boundary:  nasim code agent
' Purpose:   Index current turn and persist checkpoint for resumption
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> WireLogAPI -> WireLogManager -> WireLogStore -> WireLogDirectory
' SM States: SAVED (#1565C0)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- WRL-05 CHECKPOINT Turn

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "WireLogAPI" as api
end box
box "WireLog Group (Service)" #FFF3E0
  participant "WireLogManager" as mgr
end box
box "WireLog Group (Repository)" #E8F5E9
  participant "WireLogStore" as store
end box
database "WireLogDirectory" as dir

== WRL-05 CHECKPOINT Turn ==

user -> router : POST /wirelog/checkpoint
activate router
router -> api : wrl05 CHECKPOINT Turn(turn_data)
activate api
api -> mgr : wrl05 CHECKPOINT Turn(turn_data)
activate mgr

alt checkpoint succeeds
  mgr -> store : wrl05 CHECKPOINT Turn(turn_data)
  activate store
  store -> dir : wrl05 CHECKPOINT Turn(turn_data)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : SAVED (#1565C0)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else persist failure
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
