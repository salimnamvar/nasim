@startuml sq_wirelog05_checkpoint_turn
' ============================================================
' Title:     WRL-05 — CHECKPOINT Turn
' Boundary:  nasim code agent
' Purpose:   Index current turn and persist checkpoint for resumption
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> WireLog -> WireAppender -> FileSystem
' SM States: (no session state change — wire log checkpoint)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- WRL-05 CHECKPOINT Turn

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "WireLog Group (Infrastructure)" #F3E5F5
  participant "WireLog" as wl
  participant "WireAppender" as appender
end box

database "WireLogStorage" as storage

== WRL-05 CHECKPOINT Turn ==

user -> iface : POST /wirelog/checkpoint
activate iface
iface -> router : POST /wirelog/checkpoint
activate router
router -> wl : WRL-05 CHECKPOINT Turn(turn_data)
activate wl

alt checkpoint succeeds
  wl -> appender : WRL-05 CHECKPOINT Turn(turn_data)
  activate appender
  appender -> storage : WRL-05 CHECKPOINT Turn(turn_data)
  activate storage
  storage --> appender : 200 OK
  deactivate storage
  appender --> wl : 200 OK
  deactivate appender
  wl --> router : 200 OK
  deactivate wl
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else persist failure
  wl --> router : 422 Unprocessable
  deactivate wl
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
