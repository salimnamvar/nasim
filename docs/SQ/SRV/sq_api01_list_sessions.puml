@startuml sq_srv01_list_sessions
!include ../common/sq_styles.puml
' ============================================================
' Title:     API-01 — LIST Sessions
' Boundary:  nasim code agent HTTP API
' Purpose:   List all sessions with pagination
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    Prompt audit 2026-06-21 (cop.md: AIP-193 error path added)
' ============================================================

title nasim — API-01 LIST Sessions

actor "User" as user

box "Controller Group" #E3F2FD
  participant "ServerRouter" as router
end box
box "Service Group" #FFF3E0
  participant "SessionService" as svc
end box
box "Repository Group" #E8F5E9
  participant "SessionStore" as store
end box

note over user
  Scope:          API-01 LIST Sessions
  Preconditions:  None
  Contexts:       Parent: HTTP Client request
  Excludes:       Session creation, message history
  Rollback:       No state change on failure
  Design:         Paginated collection read via Service layer
  Returns:
    - Success: 200 OK — {sessions: [...], next_page_token: string}
    - Failure: 500 INTERNAL — store read failure
end note


== API-01 LIST Sessions ==

user -> router : GET /v1/sessions?page_size=10&page_token=abc
activate router

router -> svc : API-01 LIST Sessions(pageSize=10, pageToken="abc")
activate svc

svc -> store : API-01 LIST Sessions(pageSize=10, pageToken="abc")
activate store

break Store read failure [500]
    store --> svc : 500 INTERNAL
    deactivate store
    svc --> router : 500 INTERNAL
    router --> user : 500 INTERNAL {error: {code: "INTERNAL", message: "Failed to list sessions", status: "INTERNAL"}}
end

alt Sessions exist
    store --> svc : 200 OK {sessions, nextPageToken}
    deactivate store
    svc --> router : 200 OK {sessions, nextPageToken}
    router --> user : 200 OK {sessions: [...], next_page_token: "def"}
else No sessions
    store --> svc : 200 OK {sessions: [], nextPageToken: ""}
    deactivate store
    svc --> router : 200 OK {sessions: [], nextPageToken: ""}
    router --> user : 200 OK {sessions: [], next_page_token: null}
end

deactivate svc
deactivate router

note over user
  Flow:    API-01 → router → svc → store → svc → router → user
  State:   No state change
  Success: 200 OK — {sessions: [...], next_page_token: string}
  Failure: 500 INTERNAL: store read failure — retry later
end note


@enduml
