@startuml sq_srv02_create_session
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Sequence.puml
!theme plain

' ============================================================
' Title:     nasim — SQ: Create Session
' UC:        SRV-02
' Purpose:   ROD-compliant Create operation for sessions
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/audit/audit.2026.06.20.car-framework-csr-rod.md
' Review:    —
' ============================================================

title nasim — SQ: Create Session (SRV-02)

actor "HTTP Client" as client
participant "ServerRouter" as router
participant "SessionStore" as store

== Request ==

client -> router : POST /sessions
activate router

router -> router : Validate request (SessionCreate)
router -> router : Generate session UUID

router -> store : save_session(session_id, config)
activate store

alt Success
    store --> router : session
    deactivate store
    
    router --> client : 201 Created
    note right of client
        {
            "id": "uuid-...",
            "created_at": "2026-06-20T...",
            "model": "qwen2.5-coder:14b",
            "state": "IDLE"
        }
    end note
else Error
    store --> router : error
    deactivate store
    
    router --> client : 500 INTERNAL
end

deactivate router

@enduml
