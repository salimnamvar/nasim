@startuml sq_srv09_read_tool
!include ../common/sq_styles.puml
' ============================================================
' Title:     API-09 — GET Tool
' Boundary:  nasim code agent HTTP API
' Purpose:   Read details of a specific registered tool
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — API-09 GET Tool

actor "User" as user

box "Controller Group" #E3F2FD
  participant "ServerRouter" as router
end box
box "Service Group" #FFF3E0
  participant "ToolService" as svc
end box
box "Repository Group" #E8F5E9
  participant "ToolRegistry" as registry
end box

note over user
  Scope:          API-09 READ Tool
  Preconditions:  Tool must be registered
  Contexts:       Parent: HTTP Client request
  Excludes:       Tool listing, tool execution
  Rollback:       No state change on failure
  Design:         Read-only tool metadata fetch; 404 if tool not registered
  Returns:
    - Success: 200 OK — {tool: {name, description, safe, parameters}}
    - Failure: 404 NOT_FOUND — tool does not exist
end note


== API-09 READ Tool ==

user -> router : GET /v1/tools/{name}
activate router

router -> svc : API-09 READ Tool(name)
activate svc

svc -> registry : readTool(name)
activate registry

break Tool not found [404]
  registry --> svc : NotFound
  deactivate registry
  svc --> router : 404 NOT_FOUND
  router --> user : 404 NOT_FOUND {error: {code: "NOT_FOUND", message: "Tool not found", status: "NOT_FOUND"}}
end

registry --> svc : ToolMetadata
deactivate registry

svc --> router : ToolResponseDTO
deactivate svc
router --> user : 200 OK {tool: {name, description, safe, parameters}}
deactivate router

note over user
  Flow:    API-09 → router → svc → registry → svc → router → user
  State:   No state change
  Success: 200 OK — {tool: {name, description, safe, parameters}}
  Failure: 404 NOT_FOUND: tool does not exist — verify tool name
end note


@enduml
