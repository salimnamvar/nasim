@startuml sq_api05_delete_session
!include ../common/sq_styles.puml
' ============================================================
' Title:     API-05 — DELETE Session
' Boundary:  nasim code agent HTTP API
' Purpose:   Delete a session (hard delete)
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — API-05 DELETE Session

actor "User" as user

box "Controller Group" #E3F2FD
  participant "ServerRouter" as router
end box
box "Service Group" #FFF3E0
  participant "SessionService" as svc
end box
box "Repository Group" #E8F5E9
  participant "SessionStore" as store
end box

note over user
  Scope:          API-05 DELETE Session
  Preconditions:  Session must exist
  Contexts:       Parent: HTTP Client request
  Excludes:       Session creation, update, message dispatch
  Rollback:       Delete is not reversible; state guard prevents invalid transitions
  Design:         Service validates state transition (ACTIVE → CLOSED) before delete
  Returns:
    - Success: 200 OK — {retired: true}
    - Failure: 404 NOT_FOUND — session does not exist
    - Failure: 409 FAILED_PRECONDITION — invalid state transition
end note


== API-05 DELETE Session ==

user -> router : DELETE /v1/sessions/{id}
activate router

router -> svc : API-05 DELETE Session(sessionId)
activate svc

svc -> store : API-05 READ Session(sessionId)
activate store

break Session not found [404]
  store --> svc : 404 NOT_FOUND
  deactivate store
  svc --> router : 404 NOT_FOUND
  router --> user : 404 NOT_FOUND {error: {code: "NOT_FOUND", message: "Session not found", status: "NOT_FOUND"}}
end

store --> svc : SessionEntity
deactivate store

svc -> svc : validateStateTransition(ACTIVE → CLOSED)

svc -> store : API-05 DELETE Session(sessionId)
activate store
store --> svc : deleted
deactivate store

svc --> router : 200 OK {retired: true}
deactivate svc
router --> user : 200 OK {retired: true}
deactivate router

note over user
  Flow:    API-05 → router → svc → store(read) → svc → store(delete) → router → user
  State:   ACTIVE → CLOSED
  Success: 200 OK — {retired: true}
  Failure: 404 NOT_FOUND: session does not exist — verify session ID
  Failure: 409 FAILED_PRECONDITION: invalid state transition — check session state
end note


@enduml
