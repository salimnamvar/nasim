@startuml sq_srv05_get_message_history
' ============================================================
' Title:     nasim — SQ: Get Message History (API)
' Boundary:  nasim code agent CLI + HTTP API
' Purpose:   Retrieve message history for a session via HTTP
' Milestone: v1.0
' Version:   3.0.0
' Source:    docs/audit/nasim-car-improvement-plan.md CAR-11
' Review:    —
' ============================================================

title nasim — SQ: Get Message History (SRV-05)

participant "HTTP Client" as client
participant "ServerRouter" as router
participant "SessionStore" as store

== Get Messages ==

client -> router : GET /v1/sessions/{id}/messages
activate router
router -> store : load(session_id)
activate store
store --> router : Session(messages=[...])
deactivate store

router --> client : 200 {messages: [...]}
deactivate router

@enduml
