@startuml sq_srv06_send_message
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Sequence.puml
!theme plain

' ============================================================
' Title:     nasim — SQ: Send Message (Custom Method)
' UC:        SRV-06
' Purpose:   ROD-compliant custom method :send for message submission
'            Returns SSE stream of AgentEvents
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/audit/audit.2026.06.20.car-framework-csr-rod.md
' Review:    —
' ============================================================

title nasim — SQ: Send Message (SRV-06)

actor "HTTP Client" as client
participant "ServerRouter" as router
participant "SSEHandler" as sse
participant "AgentOrchestrator" as agent
participant "SessionStore" as store

== Request ==

client -> router : POST /sessions/{session}:send
activate router

router -> router : Validate request (MessageCreate)
router -> store : load_session(session_id)
activate store

alt Session not found
    store --> router : null
    deactivate store
    router --> client : 404 NOT_FOUND
    note right of client
        {
            "error": {
                "code": 404,
                "message": "Session not found",
                "status": "NOT_FOUND"
            }
        }
    end note
else Session found
    store --> router : session
    deactivate store
    
    router -> agent : PROCESS(user_input)
    activate agent
    
    agent -> agent : LLM call + tool execution loop
    
    loop AgentEvent stream
        agent --> sse : yield AgentEvent
        activate sse
        sse --> client : SSE event
        note right of client
            data: {"type": "text", "text": "..."}
            data: {"type": "tool_start", "name": "..."}
            data: {"type": "tool_result", ...}
            data: {"type": "done"}
        end note
        deactivate sse
    end
    
    agent --> router : final response
    deactivate agent
    
    router -> store : save_session(session_id, messages)
    activate store
    store --> router : ok
    deactivate store
    
    router --> client : 200 OK (SSE stream complete)
end

deactivate router

@enduml
