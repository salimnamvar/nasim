@startuml sq_rim04_inject_repo_map
!include ../common/sq_styles.puml
' ============================================================
' Title:     RIM-04 — INJECT RepoMap
' Boundary:  nasim code agent CLI
' Purpose:   Token-budgeted repo-map injection into LLM context
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — RIM-04 INJECT RepoMap

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Repo Intelligence Group" #E8F5E9
  participant "RepoMapInjector" as injector
  participant "SymbolRanker" as ranker
end box
box "Context Group" #FFF3E0
  participant "TokenBudget" as budget
  participant "ConversationHistory" as history
end box


note over user
  Scope:          RIM-04 INJECT RepoMap — token-budgeted repo-map injection into LLM context
  Preconditions:  Ranked symbols available from RIM-03; token budget specified
  Contexts:       Called by AgentOrchestrator before LLM inference to provide codebase context
  Excludes:       Codebase indexing, embedding, semantic search, symbol ranking
  Rollback:       (No explicit failure path — always produces repo map within budget)
  Design:         Splits budget [60% structure, 25% snippets, 15% reserve]; truncates to max_tokens; prepends to conversation
  Returns:
    - Success: 200 OK — RepoMapContext(text, token_count)
    - Failure: (none — always returns within budget)
end note

== RIM-04 INJECT RepoMap ==

user -> router : RIM-04 INJECT RepoMap(budget_tokens, ranked_symbols)
activate router
router -> agent : RIM-04 INJECT RepoMap(budget_tokens, ranked_symbols)
activate agent

agent -> injector : RIM-04 INJECT RepoMap(budget_tokens, ranked_symbols)
activate injector

injector -> budget : budget.get_available_budget()
activate budget
budget --> injector : available_tokens
deactivate budget

injector -> injector : split_budget(available_tokens, ratios=[0.6, 0.25, 0.15])

injector -> ranker : ranker.get_top_symbols(structure_budget)
activate ranker
ranker --> injector : structure_symbols[]
deactivate ranker

injector -> ranker : ranker.get_relevant_snippets(snippet_budget)
activate ranker
ranker --> injector : snippet_symbols[]
deactivate ranker

injector -> injector : format_repo_map(structure_symbols, snippet_symbols)

injector -> injector : truncate_to_budget(formatted_map, max_tokens)

injector -> history : history.prepend_context(repo_map_text)
activate history
history --> injector : context_injected
deactivate history

injector --> agent : RepoMapContext(text, token_count)
deactivate injector

agent --> router : RepoMapContext(text, token_count)
deactivate agent
deactivate router

note over user
  Flow:    User → ServerRouter → AgentOrchestrator → RepoMapInjector → get budget → split budget → get top symbols → get snippets → format → truncate → prepend context → Result
  State:   No state change (mutates conversation history with injected context)
  Success: 200 OK — RepoMapContext(text, token_count)
  Failure: (none — always returns within token budget)
end note

@enduml
