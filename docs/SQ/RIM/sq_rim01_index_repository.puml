@startuml sq_rim01_index_repository
' ============================================================
' Title:     RIM-01 — INDEX Repository (AST + Symbol Graph)
' Boundary:  nasim code agent CLI
' Purpose:   Build AST index and symbol graph from project source
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/audit/audit.2026.06.20.deep.domain.audit.md
' Review:    —
' ============================================================

actor "Developer" as user

box "CLI Layer" #E8F5E9
  participant "REPLSession" as repl
end box
box "Agent Layer" #E3F2FD
  participant "AgentOrchestrator" as agent
end box
box "Repo Index Layer" #FFF3E0
  participant "RepoIndexer" as indexer
  participant "ASTParser" as ast
  participant "SymbolGraph" as graph
end box
box "FileSystem Layer" #F3E5F5
  participant "FileSystem" as fs
end box

note over user, fs
  Scope:
    - rim01 INDEX Repository — parse project files into AST index and symbol graph

  Preconditions:
    - Project root directory is accessible
    - Supported source files present (Python, JS, TS, etc.)
    - FileSystem permissions allow read traversal

  Contexts:
    - Called by AgentOrchestrator at session start or on-demand
    - Prerequisite for RIM-02 (Rank Symbols) and RIM-03 (Search Semantic)

  Excludes:
    - File watching / incremental updates
    - Embedding generation (handled by RIM-03)

  Rollback:
    - Parse error on file → skip file, log warning, continue
    - Permission denied → skip directory, log warning
    - Complete failure → return empty index with error summary

  Design:
    - RepoIndexer orchestrates the full indexing pipeline
    - ASTParser extracts function, class, method definitions
    - SymbolGraph builds call/inheritance/import relationships
    - Results stored in-memory for session lifetime
    - Progress reported via AgentEvent(Progress)

  Returns:
    - Success: IndexStats with file count, symbol count, graph edges
    - Failure: Error event with partial stats
end note

== rim01 INDEX Repository ==

agent -> indexer : INDEX(project_root)
activate indexer

indexer -> fs : list_source_files(project_root)
activate fs
fs --> indexer : source_files[]
deactivate fs

loop for each source_file
    indexer -> ast : parse(source_file)
    activate ast
    alt parse succeeds
        ast --> indexer : ASTNode[]
    else parse error
        ast --> indexer : ParseError(file, reason)
        note right: Skip file, log warning
    end
    deactivate ast

    indexer -> graph : extract_symbols(ast_nodes)
    activate graph
    graph --> indexer : symbols[]
    deactivate graph

    indexer -> graph : link_relationships(symbols)
    activate graph
    graph --> indexer : edges[]
    deactivate graph
end

indexer -> graph : build_adjacency_index()
activate graph
graph --> indexer : adjacency_map
deactivate graph

indexer --> agent : IndexStats(files, symbols, edges)
deactivate indexer

note over user, fs
  Flow:
    - AgentOrchestrator → RepoIndexer → [FileSystem → ASTParser → SymbolGraph]* → IndexStats

  State:
    - IDLE → SCANNING → PARSING → GRAPH_BUILDING → READY

  Failure:
    - Parse error → skip file, continue
    - Complete failure → empty index + error

  Success:
    - IndexStats with file count, symbol count, edge count

  Key invariants:
    - Each source file parsed exactly once per index run
    - SymbolGraph maintains referential integrity
    - Index is immutable after build (read-only for consumers)
end note

@enduml
