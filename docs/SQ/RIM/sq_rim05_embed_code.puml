@startuml sq_rim05_embed_code
!include ../common/sq_styles.puml
' ============================================================
' Title:     RIM-05 — EMBED Code
' Boundary:  nasim code agent
' Purpose:   Generate vector embeddings for code fragments
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — RIM-05 EMBED Code

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Repo Intelligence Group" #E8F5E9
  participant "RepoIntelligenceManager" as rim
  participant "EmbeddingAdapter" as embed
end box
box "External" #F5F5F5
  participant "EmbeddingProvider" as provider
end box
box "Storage Group" #E8F5E9
  participant "VectorStore" as vstore
end box


note over user
  Scope:          RIM-05 EMBED Code — generate vector embeddings for code fragments
  Preconditions:  Code fragments extracted; embedding provider configured and available
  Contexts:       Called by AgentOrchestrator to build searchable vector index for semantic search
  Excludes:       Codebase indexing, symbol ranking, repo-map injection, semantic search queries
  Rollback:       Provider failure → error propagated per batch; partial embedding on partial success
  Design:         Batch embedding with dimension validation; stores in VectorStore for downstream search
  Returns:
    - Success: 200 OK — EmbeddingResult(count, dimensions)
    - Failure: 500 INTERNAL — embedding provider error
end note

== RIM-05 EMBED Code ==

user -> router : RIM-05 EMBED Code(code_fragments)
activate router
router -> agent : RIM-05 EMBED Code(code_fragments)
activate agent

agent -> rim : RIM-05 EMBED Code(code_fragments)
activate rim

rim -> embed : RIM-05 EMBED Code(code_fragments)
activate embed

loop for each batch of fragments
    embed -> provider : provider.embed(batch)
    activate provider
    provider --> embed : vectors[]
    deactivate provider

    embed -> embed : validate_dimensions(vectors)
end

embed -> vstore : vstore.store_vectors(code_fragments, vectors)
activate vstore
vstore --> embed : store_result
deactivate vstore

embed --> rim : EmbeddingResult(count, dimensions)
deactivate embed

rim --> agent : EmbeddingResult(count, dimensions)
deactivate rim

agent --> router : EmbeddingResult(count, dimensions)
deactivate agent
deactivate router

note over user
  Flow:    User → ServerRouter → AgentOrchestrator → RepoIntelligenceManager → EmbeddingAdapter → batch embed → validate → store vectors → Result
  State:   No state change (populates VectorStore)
  Success: 200 OK — EmbeddingResult(count, dimensions)
  Failure: 500 INTERNAL: embedding provider error — propagate error to caller
end note

@enduml
