@startuml sq_tl01_read_file
' ============================================================
' Title:     TL-01 — Read File
' Boundary:  nasim code agent CLI
' Purpose:   File read tool execution
' Milestone: v0.1
' Version:   1.0.0
' Source:    —
' Review:    —
' ============================================================

participant "ToolExecutor" as executor
participant "FileTools" as ft
participant "Host Filesystem" as fs

note over ft
  Scope:          Read file contents with line numbers
  Preconditions:  File path provided by LLM
  Excludes:       Write, edit, directory listing
  Contexts:       Called by AGT-02 (Invoke Tool)
  Rollback:       Error string returned to LLM
  Design:         Supports offset/limit for large files
end note

executor -> ft : read_file(path, offset, limit)
ft -> fs : Path(path).read_text()
alt File exists
    fs --> ft : file content
    ft -> ft : add line numbers
    ft --> executor : numbered content string
else File not found
    fs --> ft : FileNotFoundError
    ft --> executor : "Error: file not found"
end

note over ft
  Flow:    Path -> read_text -> line numbers -> string
  State:   No state change
  Failure: File not found or read error -> error string
  Success: File content with line numbers
end note

@enduml
