@startuml sq_sandbox01_isolate_command
' ============================================================
' Title:     SANDBOXREPOSITORY-01 — ISOLATE Command
' Boundary:  nasim code agent
' Purpose:   Execute command in OS-level sandbox
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> SandboxExecutor
' SM States: EXECUTING (#2196F3)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SANDBOXREPOSITORY-01 ISOLATE Command

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "SandboxRepository" as mgr
end box

== SANDBOXREPOSITORY-01 ISOLATE Command ==

user -> iface : POST /sandbox/isolate
activate iface
iface -> router : POST /sandbox/isolate
activate router
router -> mgr : SANDBOXREPOSITORY-01 ISOLATE Command({command, policy})
activate mgr

alt execution succeeds
  ref over mgr : SANDBOXREPOSITORY-01 ISOLATE Command({command, policy}) <back:#2196F3>EXECUTING</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else timeout or violation
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "SANDBOXREPOSITORY-01_ISOLATION_FAILED", message: "Command isolation failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "SANDBOXREPOSITORY-01_ISOLATION_FAILED", message: "Command isolation failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "SANDBOXREPOSITORY-01_ISOLATION_FAILED", message: "Command isolation failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
