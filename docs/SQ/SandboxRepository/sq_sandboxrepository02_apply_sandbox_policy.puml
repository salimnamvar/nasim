@startuml sq_sandbox02_apply_sandbox_policy
' ============================================================
' Title:     SANDBOXREPOSITORY-02 — APPLY Sandbox Policy
' Boundary:  nasim code agent
' Purpose:   Load and apply sandbox security policy
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> SandboxPolicy
' SM States: IDLE (#78909C)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SANDBOXREPOSITORY-02 APPLY Sandbox Policy

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "SandboxRepository" as mgr
end box

== SANDBOXREPOSITORY-02 APPLY Sandbox Policy ==

user -> iface : PATCH /sandbox/policy
activate iface
iface -> router : PATCH /sandbox/policy
activate router
router -> mgr : SANDBOXREPOSITORY-02 APPLY Sandbox Policy({policy_path})
activate mgr

alt policy applied
  ref over mgr : SANDBOXREPOSITORY-02 APPLY Sandbox Policy({policy_path}) <back:#78909C>IDLE</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else invalid policy
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "SANDBOXREPOSITORY-02_POLICY_APPLY_FAILED", message: "Sandbox policy application failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "SANDBOXREPOSITORY-02_POLICY_APPLY_FAILED", message: "Sandbox policy application failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "SANDBOXREPOSITORY-02_POLICY_APPLY_FAILED", message: "Sandbox policy application failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
