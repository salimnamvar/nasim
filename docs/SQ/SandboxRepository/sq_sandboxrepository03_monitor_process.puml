@startuml sq_sandbox03_monitor_process
' ============================================================
' Title:     SANDBOXREPOSITORY-03 — MONITOR Process
' Boundary:  nasim code agent
' Purpose:   Monitor sandboxed process for timeout and resource usage
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> SandboxMonitor
' SM States: MONITORING (#64B5F6)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SANDBOXREPOSITORY-03 MONITOR Process

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "Sandbox Repository" as mgr
end box

== SANDBOXREPOSITORY-03 MONITOR Process ==

user -> iface : GET /sandbox/monitor/{process}
activate iface
iface -> router : GET /sandbox/monitor/{process}
activate router
router -> mgr : SANDBOXREPOSITORY-03 MONITOR Process({process_id, limits})
activate mgr

alt normal completion
  ref over mgr : SANDBOXREPOSITORY-03 MONITOR Process({process_id, limits}) <back:#64B5F6>MONITORING</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else timeout or resource exceeded
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "SANDBOXREPOSITORY-03_MONITOR_FAILED", message: "Process monitoring failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "SANDBOXREPOSITORY-03_MONITOR_FAILED", message: "Process monitoring failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "SANDBOXREPOSITORY-03_MONITOR_FAILED", message: "Process monitoring failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
