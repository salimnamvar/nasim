@startuml sq_evl06_coordinate_retry
' ============================================================
' Title:     EVL-06 — COORDINATE Retry
' Boundary:  nasim code agent
' Purpose:   Coordinate task retry with backoff and escalation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> RetryCoordinator
' SM States: RETRYING (#C62828)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-06 COORDINATE Retry

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Evaluation Group" #FFF3E0
  participant "RetryCoordinator" as coord
end box

== EVL-06 COORDINATE Retry ==

user -> iface : POST /evaluation/retry
activate iface
iface -> router : POST /evaluation/retry
activate router
router -> coord : EVL-06 COORDINATE Retry({task_id, attempt})
activate coord

alt retry succeeds
  ref over coord : TRANSITION State(<back:#C62828>RETRYING</back>)
  coord --> router : 200 OK
  deactivate coord
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else retry exhausted
  coord --> router : 422 Unprocessable
  deactivate coord
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
