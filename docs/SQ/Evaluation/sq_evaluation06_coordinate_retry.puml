@startuml sq_evl06_coordinate_retry
' ============================================================
' Title:     EVL-06 — COORDINATE Retry
' Boundary:  nasim code agent
' Purpose:   Coordinate task retry with backoff and escalation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EvaluationManager -> EvaluationStore -> EvaluationDirectory -> TestSuite
' SM States: RETRYING (#C62828)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-06 COORDINATE Retry

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TestSuite" as TestSuite
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TestSuite" as TestSuite
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TestSuite" as TestSuite
end box

== EVL-06 COORDINATE Retry ==

user -> iface : POST /evaluation/retry
activate iface
iface -> router : POST /evaluation/retry
activate router
router -> mgr : EVL-06 COORDINATE Retry({task_id, attempt})
activate mgr

alt retry succeeds
  mgr -> store : EVL-06 COORDINATE Retry({task_id, attempt})
  activate store
  store -> dir : EVL-06 COORDINATE Retry({task_id, attempt})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : RETRYING (#C62828) ...
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else retry exhausted
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
