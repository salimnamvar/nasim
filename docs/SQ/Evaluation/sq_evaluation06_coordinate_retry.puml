@startuml sq_evl06_coordinate_retry
' ============================================================
' Title:     EVL-06 — COORDINATE Retry
' Boundary:  nasim code agent
' Purpose:   Coordinate task retry with backoff and escalation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> EvaluationAPI -> EvaluationManager -> EvaluationStore -> EvaluationDirectory
' SM States: RETRYING (#C62828)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-06 COORDINATE Retry

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "EvaluationAPI" as api
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

== EVL-06 COORDINATE Retry ==

user -> router : POST /evaluation/retry
activate router
router -> api : EVL-06 COORDINATE Retry({task_id, attempt})
activate api
api -> mgr : EVL-06 COORDINATE Retry({task_id, attempt})
activate mgr

alt retry succeeds
  mgr -> store : EVL-06 COORDINATE Retry({task_id, attempt})
  activate store
  store -> dir : EVL-06 COORDINATE Retry({task_id, attempt})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : RETRYING (#C62828) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else retry exhausted
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
