@startuml sq_evaluation03_check_success
' ============================================================
' Title:     EVL-03 — CHECK Success
' Boundary:  nasim code agent
' Purpose:   Execute success checks and aggregate results
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SuccessCheckRunner
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-03 CHECK Success

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "SuccessCheckRunner" as runner
end box

== EVL-03 CHECK Success ==

user -> iface : GET /evaluation/success
activate iface
iface -> router : GET /evaluation/success
activate router
router -> runner : EVL-03 CHECK Success({task_id, check_criteria})
activate runner

alt all checks pass
  ref over runner : TRANSITION State(<back:#C5CAE9>CHECKING</back>)
  runner --> router : 200 OK
  deactivate runner
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else checks fail
  runner --> router : 422 Unprocessable
  deactivate runner
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
