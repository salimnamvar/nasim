@startuml sq_evaluation03_check_success
' ============================================================
' Title:     EVALUATION-03 — CHECK Success
' Boundary:  nasim code agent
' Purpose:   Execute success checks and aggregate results
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> SuccessCheckRunner
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVALUATION-03 CHECK Success

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "EvaluationService" as runner
end box

== EVALUATION-03 CHECK Success ==

user -> iface : EVALUATION-03 CHECK Success({task_id, check_criteria})
activate iface
iface -> router : EVALUATION-03 CHECK Success({task_id, check_criteria})
activate router
router -> runner : EVALUATION-03 CHECK Success({task_id, check_criteria})
activate runner

alt all_checks_pass
  ref over runner : EVALUATION-03 CHECK Success({task_id}) <back:#C5CAE9>CHECKING</back>
  runner --> router : 200 OK
  deactivate runner
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else checks_fail
  runner --> router : 422 UNPROCESSABLE\n{error: {code: "EVALUATION-03_CHECKS_FAILED", message: "Success checks failed", status: 422}}
  deactivate runner
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
