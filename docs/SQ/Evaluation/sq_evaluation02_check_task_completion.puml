@startuml sq_evl02_check_task_completion
' ============================================================
' Title:     EVL-02 — CHECK Task Completion
' Boundary:  nasim code agent
' Purpose:   Check whether the task's criteria are met
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EvaluationManager -> EvaluationStore -> EvaluationDirectory -> TestSuite
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-02 CHECK Task Completion

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "TestSuite" as TestSuite
end box



== EVL-02 CHECK Task Completion ==

user -> iface : GET /evaluation/completion
activate iface
iface -> router : GET /evaluation/completion
activate router
router -> mgr : EVL-02 CHECK Task Completion({task_id})
activate mgr

alt task complete
  mgr -> store : EVL-02 CHECK Task Completion({task_id})
  activate store
  store -> dir : EVL-02 CHECK Task Completion({task_id})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#C5CAE9>CHECKING</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else task incomplete
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
