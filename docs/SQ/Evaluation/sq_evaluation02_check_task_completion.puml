@startuml sq_evl02_check_task_completion
' ============================================================
' Title:     EVL-02 — CHECK Task Completion
' Boundary:  nasim code agent
' Purpose:   Check whether the task's criteria are met
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> EvaluationAPI -> EvaluationManager -> EvaluationStore -> EvaluationDirectory
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-02 CHECK Task Completion

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "EvaluationAPI" as api
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

== EVL-02 CHECK Task Completion ==

user -> router : GET /evaluation/completion
activate router
router -> api : EVL-02 CHECK Task Completion({task_id})
activate api
api -> mgr : EVL-02 CHECK Task Completion({task_id})
activate mgr

alt task complete
  mgr -> store : EVL-02 CHECK Task Completion({task_id})
  activate store
  store -> dir : EVL-02 CHECK Task Completion({task_id})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : CHECKING (#C5CAE9) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else task incomplete
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
