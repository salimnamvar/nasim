@startuml sq_evaluation01_evaluate_task
' ============================================================
' Title:     EVL-01 — EVALUATE Task
' Boundary:  nasim code agent
' Purpose:   Evaluate task completion via success checks and quality signals
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> EvaluationEngine
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-01 EVALUATE Task

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "EvaluationService" as eng
end box

== EVL-01 EVALUATE Task ==

user -> iface : EVL-01 EVALUATE Task({task_id, check_commands})
activate iface
iface -> router : EVL-01 EVALUATE Task({task_id, check_commands})
activate router
router -> eng : EVL-01 EVALUATE Task({task_id, check_commands})
activate eng

alt all_checks_pass
  ref over eng : EVL-01 EVALUATE Task({task_id, check_commands}) <back:#C5CAE9>CHECKING</back>
  eng --> router : 200 OK
  deactivate eng
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else check_fails
  eng --> router : 422 UNPROCESSABLE\n{error: {code: "EVL-01_CHECK_FAILED", message: "Task evaluation check failed", status: 422}}
  deactivate eng
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
