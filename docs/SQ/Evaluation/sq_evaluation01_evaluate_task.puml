@startuml sq_evaluation01_evaluate_task
' ============================================================
' Title:     EVL-01 — EVALUATE Task
' Boundary:  nasim code agent
' Purpose:   Evaluate task completion via success checks and quality signals
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EvaluationEngine
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-01 EVALUATE Task

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "EvaluationEngine" as eng
end box

== EVL-01 EVALUATE Task ==

user -> iface : POST /evaluation/evaluate
activate iface
iface -> router : POST /evaluation/evaluate
activate router
router -> eng : EVL-01 EVALUATE Task({task_id, check_commands})
activate eng

alt evaluation succeeds
  ref over eng : TRANSITION State(<back:#C5CAE9>CHECKING</back>)
  eng --> router : 200 OK
  deactivate eng
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else evaluation fails
  eng --> router : 422 Unprocessable
  deactivate eng
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
