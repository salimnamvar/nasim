@startuml sq_evl01_evaluate_task
' ============================================================
' Title:     EVL-01 — EVALUATE Task
' Boundary:  nasim code agent
' Purpose:   Evaluate task completion via success checks and quality signals
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EvaluationManager -> EvaluationStore -> EvaluationDirectory -> TestSuite
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-01 EVALUATE Task

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TestSuite" as TestSuite
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TestSuite" as TestSuite
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TestSuite" as TestSuite
end box

== EVL-01 EVALUATE Task ==

user -> iface : POST /evaluation/evaluate
activate iface
iface -> router : POST /evaluation/evaluate
activate router
router -> mgr : EVL-01 EVALUATE Task({task_id, check_commands})
activate mgr

alt evaluation succeeds
  mgr -> store : EVL-01 EVALUATE Task({task_id, check_commands})
  activate store
  store -> dir : EVL-01 EVALUATE Task({task_id, check_commands})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : CHECKING (#C5CAE9) ...
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else evaluation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
