@startuml sq_evl01_evaluate_task
' ============================================================
' Title:     EVL-01 — EVALUATE Task
' Boundary:  nasim code agent
' Purpose:   Evaluate task completion via success checks and quality signals
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> EvaluationAPI -> EvaluationManager -> EvaluationStore -> EvaluationDirectory
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-01 EVALUATE Task

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "EvaluationAPI" as api
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

== EVL-01 EVALUATE Task ==

user -> router : POST /evaluation/evaluate
activate router
router -> api : EVL-01 EVALUATE Task({task_id, check_commands})
activate api
api -> mgr : EVL-01 EVALUATE Task({task_id, check_commands})
activate mgr

alt evaluation succeeds
  mgr -> store : EVL-01 EVALUATE Task({task_id, check_commands})
  activate store
  store -> dir : EVL-01 EVALUATE Task({task_id, check_commands})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : CHECKING (#C5CAE9) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else evaluation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
