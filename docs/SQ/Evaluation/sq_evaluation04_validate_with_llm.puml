@startuml sq_evl04_validate_with_llm
' ============================================================
' Title:     EVL-04 — VALIDATE With LLM
' Boundary:  nasim code agent
' Purpose:   Validate task results using an LLM reviewer
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> EvaluationAPI -> EvaluationManager -> EvaluationStore -> EvaluationDirectory
' SM States: REVIEWING (#AB47BC)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-04 VALIDATE With LLM

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "EvaluationAPI" as api
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

== EVL-04 VALIDATE With LLM ==

user -> router : POST /evaluation/llm-review
activate router
router -> api : EVL-04 VALIDATE With LLM({task_id, artifact})
activate api
api -> mgr : EVL-04 VALIDATE With LLM({task_id, artifact})
activate mgr

alt review passes
  mgr -> store : EVL-04 VALIDATE With LLM({task_id, artifact})
  activate store
  store -> dir : EVL-04 VALIDATE With LLM({task_id, artifact})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : REVIEWING (#AB47BC) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else review fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
