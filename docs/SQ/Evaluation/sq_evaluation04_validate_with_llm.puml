@startuml sq_evl04_validate_with_llm
' ============================================================
' Title:     EVL-04 — VALIDATE With LLM
' Boundary:  nasim code agent
' Purpose:   Validate task results using an LLM reviewer
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EvaluationManager -> EvaluationStore -> EvaluationDirectory -> TestSuite
' SM States: REVIEWING (#AB47BC)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-04 VALIDATE With LLM

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "TestSuite" as TestSuite
end box



== EVL-04 VALIDATE With LLM ==

user -> iface : POST /evaluation/llm-review
activate iface
iface -> router : POST /evaluation/llm-review
activate router
router -> mgr : EVL-04 VALIDATE With LLM({task_id, artifact})
activate mgr

alt review passes
  mgr -> store : EVL-04 VALIDATE With LLM({task_id, artifact})
  activate store
  store -> dir : EVL-04 VALIDATE With LLM({task_id, artifact})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#AB47BC>REVIEWING</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else review fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
