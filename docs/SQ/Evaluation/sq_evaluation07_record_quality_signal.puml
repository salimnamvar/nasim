@startuml sq_evl07_record_quality_signal
' ============================================================
' Title:     EVL-07 — RECORD Quality Signal
' Boundary:  nasim code agent
' Purpose:   Record and persist quality signals for scoring
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EvaluationManager -> EvaluationStore -> EvaluationDirectory -> TestSuite
' SM States: SCORING (#FF8A65)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-07 RECORD Quality Signal

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "TestSuite" as TestSuite
end box



== EVL-07 RECORD Quality Signal ==

user -> iface : POST /evaluation/quality-signal
activate iface
iface -> router : POST /evaluation/quality-signal
activate router
router -> mgr : EVL-07 RECORD Quality Signal({task_id, score, signals})
activate mgr

alt recording succeeds
  mgr -> store : EVL-07 RECORD Quality Signal({task_id, score, signals})
  activate store
  store -> dir : EVL-07 RECORD Quality Signal({task_id, score, signals})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#FF8A65>SCORING</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else recording fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
