@startuml sq_evl07_record_quality_signal
' ============================================================
' Title:     EVL-07 — RECORD Quality Signal
' Boundary:  nasim code agent
' Purpose:   Record and persist quality signals for scoring
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> EvaluationAPI -> EvaluationManager -> EvaluationStore -> EvaluationDirectory
' SM States: SCORING (#FF8A65)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-07 RECORD Quality Signal

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "EvaluationAPI" as api
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

== EVL-07 RECORD Quality Signal ==

user -> router : POST /evaluation/quality-signal
activate router
router -> api : EVL-07 RECORD Quality Signal({task_id, score, signals})
activate api
api -> mgr : EVL-07 RECORD Quality Signal({task_id, score, signals})
activate mgr

alt recording succeeds
  mgr -> store : EVL-07 RECORD Quality Signal({task_id, score, signals})
  activate store
  store -> dir : EVL-07 RECORD Quality Signal({task_id, score, signals})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : SCORING (#FF8A65) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else recording fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
