@startuml sq_evaluation05_validate_test_suite
' ============================================================
' Title:     EVL-05 — VALIDATE Test Suite
' Boundary:  nasim code agent
' Purpose:   Run the project test suite for validation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> TestRunner
' SM States: TESTING (#D4E157)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-05 VALIDATE Test Suite

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Evaluation Group" #FFF3E0
  participant "TestRunner" as runner
end box

== EVL-05 VALIDATE Test Suite ==

user -> iface : POST /evaluation/test-suite
activate iface
iface -> router : POST /evaluation/test-suite
activate router
router -> runner : EVL-05 VALIDATE Test Suite({task_id, test_commands})
activate runner

alt tests pass
  ref over runner : TRANSITION State(<back:#D4E157>TESTING</back>)
  runner --> router : 200 OK
  deactivate runner
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else tests fail
  runner --> router : 422 Unprocessable
  deactivate runner
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
