@startuml sq_evaluation05_validate_test_suite
' ============================================================
' Title:     EVL-05 — VALIDATE Test Suite
' Boundary:  nasim code agent
' Purpose:   Run the project test suite for validation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> TestRunner
' SM States: TESTING (#D4E157)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-05 VALIDATE Test Suite

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "EvaluationService" as runner
end box

== EVL-05 VALIDATE Test Suite ==

user -> iface : EVL-05 VALIDATE Test Suite({task_id, test_commands})
activate iface
iface -> router : EVL-05 VALIDATE Test Suite({task_id, test_commands})
activate router
router -> runner : EVL-05 VALIDATE Test Suite({task_id, test_commands})
activate runner

alt tests_pass
  ref over runner : EVL-05 VALIDATE Test Suite({task_id, test_commands}) <back:#D4E157>TESTING</back>
  runner --> router : 200 OK
  deactivate runner
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else tests_fail
  runner --> router : 422 UNPROCESSABLE\n{error: {code: "EVL-05_TESTS_FAILED", message: "Test suite failed", status: 422}}
  deactivate runner
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
