@startuml sq_evl05_validate_test_suite
' ============================================================
' Title:     EVL-05 — VALIDATE Test Suite
' Boundary:  nasim code agent
' Purpose:   Run the project test suite for validation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> EvaluationAPI -> EvaluationManager -> EvaluationStore -> EvaluationDirectory
' SM States: TESTING (#D4E157)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-05 VALIDATE Test Suite

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "EvaluationAPI" as api
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

== EVL-05 VALIDATE Test Suite ==

user -> router : POST /evaluation/test-suite
activate router
router -> api : EVL-05 VALIDATE Test Suite({task_id, test_commands})
activate api
api -> mgr : EVL-05 VALIDATE Test Suite({task_id, test_commands})
activate mgr

alt tests pass
  mgr -> store : EVL-05 VALIDATE Test Suite({task_id, test_commands})
  activate store
  store -> dir : EVL-05 VALIDATE Test Suite({task_id, test_commands})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : TESTING (#D4E157) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else tests fail
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
