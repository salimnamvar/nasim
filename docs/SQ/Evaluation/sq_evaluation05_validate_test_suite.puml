@startuml sq_evl05_validate_test_suite
' ============================================================
' Title:     EVL-05 — VALIDATE Test Suite
' Boundary:  nasim code agent
' Purpose:   Run the project test suite for validation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EvaluationManager -> EvaluationStore -> EvaluationDirectory -> TestSuite
' SM States: TESTING (#D4E157)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-05 VALIDATE Test Suite

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TestSuite" as TestSuite
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TestSuite" as TestSuite
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TestSuite" as TestSuite
end box

== EVL-05 VALIDATE Test Suite ==

user -> iface : POST /evaluation/test-suite
activate iface
iface -> router : POST /evaluation/test-suite
activate router
router -> mgr : EVL-05 VALIDATE Test Suite({task_id, test_commands})
activate mgr

alt tests pass
  mgr -> store : EVL-05 VALIDATE Test Suite({task_id, test_commands})
  activate store
  store -> dir : EVL-05 VALIDATE Test Suite({task_id, test_commands})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : TESTING (#D4E157) ...
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else tests fail
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
