@startuml sq_evl08_detect_repetition
' ============================================================
' Title:     EVL-08 — DETECT Repetition
' Boundary:  nasim code agent
' Purpose:   Detect repetitive tool call or response patterns
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> EvaluationAPI -> EvaluationManager -> EvaluationStore -> EvaluationDirectory
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-08 DETECT Repetition

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "EvaluationAPI" as api
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

== EVL-08 DETECT Repetition ==

user -> router : GET /evaluation/repetition
activate router
router -> api : EVL-08 DETECT Repetition({task_id, recent_calls})
activate api
api -> mgr : EVL-08 DETECT Repetition({task_id, recent_calls})
activate mgr

alt no repetition
  mgr -> store : EVL-08 DETECT Repetition({task_id, recent_calls})
  activate store
  store -> dir : EVL-08 DETECT Repetition({task_id, recent_calls})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : CHECKING (#C5CAE9) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else repetition detected
  mgr --> api : 409 Conflict
  deactivate mgr
  api --> router : 409 Conflict
  deactivate api
  router --> user : 409 Conflict
  deactivate router
end

@enduml
