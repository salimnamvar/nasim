@startuml sq_evl09_inject_turn_budget
' ============================================================
' Title:     EVL-09 — INJECT Turn Budget
' Boundary:  nasim code agent
' Purpose:   Inject remaining turn budget into the conversation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EvaluationManager -> EvaluationStore -> EvaluationDirectory -> TestSuite
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-09 INJECT Turn Budget

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TestSuite" as TestSuite
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TestSuite" as TestSuite
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TestSuite" as TestSuite
end box

== EVL-09 INJECT Turn Budget ==

user -> iface : POST /evaluation/turn-budget
activate iface
iface -> router : POST /evaluation/turn-budget
activate router
router -> mgr : EVL-09 INJECT Turn Budget({task_id, remaining_turns, max_turns})
activate mgr

alt injection succeeds
  mgr -> store : EVL-09 INJECT Turn Budget({task_id, remaining_turns, max_turns})
  activate store
  store -> dir : EVL-09 INJECT Turn Budget({task_id, remaining_turns, max_turns})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : CHECKING (#C5CAE9) ...
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else budget exceeded
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
