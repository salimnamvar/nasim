@startuml sq_evl09_inject_turn_budget
' ============================================================
' Title:     EVL-09 — INJECT Turn Budget
' Boundary:  nasim code agent
' Purpose:   Inject remaining turn budget into the conversation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> EvaluationAPI -> EvaluationManager -> EvaluationStore -> EvaluationDirectory
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-09 INJECT Turn Budget

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "EvaluationAPI" as api
end box
box "Evaluation Group (Service)" #FFF3E0
  participant "EvaluationManager" as mgr
end box
box "Evaluation Group (Repository)" #E8F5E9
  participant "EvaluationStore" as store
end box
database "EvaluationDirectory" as dir

== EVL-09 INJECT Turn Budget ==

user -> router : POST /evaluation/turn-budget
activate router
router -> api : EVL-09 INJECT Turn Budget({task_id, remaining_turns, max_turns})
activate api
api -> mgr : EVL-09 INJECT Turn Budget({task_id, remaining_turns, max_turns})
activate mgr

alt injection succeeds
  mgr -> store : EVL-09 INJECT Turn Budget({task_id, remaining_turns, max_turns})
  activate store
  store -> dir : EVL-09 INJECT Turn Budget({task_id, remaining_turns, max_turns})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : CHECKING (#C5CAE9) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else budget exceeded
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
