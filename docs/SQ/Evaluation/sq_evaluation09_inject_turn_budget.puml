@startuml sq_evaluation09_inject_turn_budget
' ============================================================
' Title:     EVL-09 — INJECT Turn Budget
' Boundary:  nasim code agent
' Purpose:   Inject remaining turn budget into the conversation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> TurnBudgetInjector
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVL-09 INJECT Turn Budget

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Evaluation Group" #FFF3E0
  participant "TurnBudgetInjector" as injector
end box

== EVL-09 INJECT Turn Budget ==

user -> iface : POST /evaluation/turn-budget
activate iface
iface -> router : POST /evaluation/turn-budget
activate router
router -> injector : EVL-09 INJECT Turn Budget({task_id, remaining_turns, max_turns})
activate injector

alt injection succeeds
  ref over injector : TRANSITION State(<back:#C5CAE9>CHECKING</back>)
  injector --> router : 200 OK
  deactivate injector
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else budget exceeded
  injector --> router : 422 Unprocessable
  deactivate injector
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
