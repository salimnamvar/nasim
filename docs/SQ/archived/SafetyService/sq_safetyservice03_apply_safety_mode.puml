@startuml sq_safety03_apply_safety_mode
' ============================================================
' Title:     SAFETYSERVICE-03 — APPLY Safety Mode
' Boundary:  nasim code agent
' Purpose:   Configure safety mode from config
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> Safety Service
' SM States: ASK (#FDD835), PERMISSIVE (#9CCC65), BLOCK (#E91E63)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SAFETYSERVICE-03 APPLY Safety Mode

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Safety Service" as mgr
end box

== SAFETYSERVICE-03 APPLY Safety Mode ==

user -> iface : SAFETYSERVICE-03 APPLY Safety Mode({safety_mode})
activate iface
iface -> router : SAFETYSERVICE-03 APPLY Safety Mode({safety_mode})
activate router
router -> mgr : SAFETYSERVICE-03 APPLY Safety Mode(safety_mode)
activate mgr

alt mode applied
  ref over mgr : SAFETYSERVICE-03 APPLY Safety Mode(safety_mode) <back:#FDD835>ASK</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else invalid mode
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "SAFETYSERVICE-03_INVALID_MODE", message: "Invalid safety mode", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
