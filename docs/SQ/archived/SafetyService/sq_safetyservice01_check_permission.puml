@startuml sq_safety01_check_permission
' ============================================================
' Title:     SAFETYSERVICE-01 — CHECK Permission
' Boundary:  nasim code agent
' Purpose:   Per-tool safety check before execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> Safety Service
' SM States: PERMISSIVE (#9CCC65), ERROR (#F4511E)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SAFETYSERVICE-01 CHECK Permission

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Safety Service" as mgr
end box

== SAFETYSERVICE-01 CHECK Permission ==

user -> iface : SAFETYSERVICE-01 CHECK Permission({tool_name, safety_mode})
activate iface
iface -> router : SAFETYSERVICE-01 CHECK Permission({tool_name, safety_mode})
activate router
router -> mgr : SAFETYSERVICE-01 CHECK Permission(tool_name, safety_mode)
activate mgr

alt permission allowed
  ref over mgr : SAFETYSERVICE-01 CHECK Permission(tool_name, safety_mode) <back:#9CCC65>PERMISSIVE</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else permission denied
  mgr --> router : 403 FORBIDDEN\n{error: {code: "SAFETYSERVICE-01_PERMISSION_DENIED", message: "Tool blocked by safety policy", status: 403}}
  deactivate mgr
  router --> iface : 403 FORBIDDEN
  iface --> user : 403 FORBIDDEN
  deactivate router
  deactivate iface
end

@enduml
