@startuml sq_config02_validate_config
' ============================================================
' Title:     CONFIGREPOSITORY-02 — VALIDATE Config
' Boundary:  nasim code agent
' Purpose:   Validate configuration field types and values
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> ConfigLoader
' SM States: SERVING (#E0F7FA)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CONFIGREPOSITORY-02 VALIDATE Config

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Config Service" as cfg_svc
end box

box "Repository" REPOSITORY_COLOR
  participant "Config Repository" as mgr
end box

== CONFIGREPOSITORY-02 VALIDATE Config ==

user -> iface : CONFIGREPOSITORY-02 VALIDATE Config({config_object})
activate iface
iface -> router : CONFIGREPOSITORY-02 VALIDATE Config({config_object})
activate router
router -> cfg_svc : CONFIGREPOSITORY-02 VALIDATE Config({config_object})
activate cfg_svc
cfg_svc -> mgr : CONFIGREPOSITORY-02 VALIDATE Config({config_object})
activate mgr

alt validation passes
  ref over mgr : CONFIGREPOSITORY-02 VALIDATE Config <back:#E0F7FA>SERVING</back>
  mgr --> cfg_svc : 200 OK
  deactivate mgr
  cfg_svc --> router : 200 OK
  deactivate cfg_svc
  router --> iface : 200 OK
  deactivate router
  iface --> user : 200 OK
  deactivate iface
else validation fails
  mgr --> cfg_svc : 422 UNPROCESSABLE\n{error: {code: "CONFIGREPOSITORY-02_VALIDATION_ERROR", message: "Config validation failed", status: 422}}
  deactivate mgr
  cfg_svc --> router : 422 UNPROCESSABLE
  deactivate cfg_svc
  router --> iface : 422 UNPROCESSABLE
  deactivate router
  iface --> user : 422 UNPROCESSABLE
  deactivate iface
end

@enduml
