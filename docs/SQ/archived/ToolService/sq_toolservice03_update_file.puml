@startuml sq_tool03_update_file
' ============================================================
' Title:     TOOLSERVICE-03 — UPDATE File
' Boundary:  nasim code agent
' Purpose:   Replace an exact string in a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> EditFileTool
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TOOLSERVICE-03 UPDATE File

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "Tool Service" as tool
end box

== TOOLSERVICE-03 UPDATE File ==

user -> iface : POST /tools/update_file:execute
activate iface
iface -> router : POST /tools/update_file:execute
activate router

router -> tool : TOOLSERVICE-03 UPDATE File(path, oldString, newString)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TOOLSERVICE-03 UPDATE File
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TOOLSERVICE-03 UPDATE File (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else string not found
  tool --> router : 404 Not Found
  deactivate tool
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
else ambiguous match
  tool --> router : 422 Unprocessable
  deactivate tool
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end
@enduml
