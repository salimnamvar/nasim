@startuml sq_git01_read_git_status
' ============================================================
' Title:     GITREPOSITORY-01 — READ Git Status
' Boundary:  nasim code agent
' Purpose:   Read working tree status and staged changes
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> GitIntegration
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- GITREPOSITORY-01 READ Git Status

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "Git Repository" as mgr
end box

== GITREPOSITORY-01 READ Git Status ==

user -> iface : GET /git/status
activate iface
iface -> router : GET /git/status
activate router
router -> mgr : GITREPOSITORY-01 READ Git Status({repo_path})
activate mgr

alt validation succeeds
  ref over mgr : GITREPOSITORY-01 READ Git Status({repo_path}) <back:#B2DFDB>TOOL_EXEC</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "GITREPOSITORY-01_VALIDATION_ERROR", message: "Git status read failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "GITREPOSITORY-01_VALIDATION_ERROR", message: "Git status read failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "GITREPOSITORY-01_VALIDATION_ERROR", message: "Git status read failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
