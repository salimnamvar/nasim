@startuml sq_repointelligence06_search_semantic
' ============================================================
' Title:     REPOINTELLIGENCEREPOSITORY-06 — SEARCH Semantic
' Boundary:  nasim code agent
' Purpose:   Embedding-based code similarity search across repository
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> SemanticSearchService -> EmbeddingRepository
' SM States: INDEXED (#7CB342)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- REPOINTELLIGENCEREPOSITORY-06 SEARCH Semantic

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Repo Intelligence Repository" as mgr
end box

box "Repository" REPOSITORY_COLOR
  participant "Repo Intelligence Repository" as embeddingRepo
end box

== REPOINTELLIGENCEREPOSITORY-06 SEARCH Semantic ==

user -> iface : REPOINTELLIGENCEREPOSITORY-06 SEARCH Semantic({query, top_k})
activate iface
iface -> router : REPOINTELLIGENCEREPOSITORY-06 SEARCH Semantic({query, top_k})
activate router
router -> mgr : REPOINTELLIGENCEREPOSITORY-06 SEARCH Semantic({query, top_k})
activate mgr

alt embeddings_indexed and search completes
  ref over mgr : REPOINTELLIGENCEREPOSITORY-06 SEARCH Semantic({query, top_k}) <back:#7CB342>INDEXED</back>
  mgr -> embeddingRepo : REPOINTELLIGENCEREPOSITORY-06 SEARCH Embedding({query, top_k})
  activate embeddingRepo
  embeddingRepo --> mgr : 200 OK
  deactivate embeddingRepo
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else no results
  mgr --> router : 404 NOT_FOUND\n{error: {code: "REPOINTELLIGENCEREPOSITORY-06_NO_RESULTS", message: "No matching results found", status: 404}}
  deactivate mgr
  router --> iface : 404 NOT_FOUND\n{error: {code: "REPOINTELLIGENCEREPOSITORY-06_NO_RESULTS", message: "No matching results found", status: 404}}
  iface --> user : 404 NOT_FOUND\n{error: {code: "REPOINTELLIGENCEREPOSITORY-06_NO_RESULTS", message: "No matching results found", status: 404}}
  deactivate router
  deactivate iface
end

@enduml
