@startuml sq_agent03_update_conversation
' ============================================================
' Title:     TASKSERVICE-03 — UPDATE Conversation
' Boundary:  nasim code agent
' Purpose:   Append messages and track token count
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> ConversationService -> Session Service -> SessionStore
' SM States: RUNNING (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TASKSERVICE-03 UPDATE Conversation

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Task Service" as history
end box

box "Repository" REPOSITORY_COLOR
  participant "Session Service" as store
end box

database "SessionStore" as storage

== TASKSERVICE-03 UPDATE Conversation ==

user -> iface : TASKSERVICE-03 UPDATE Conversation({msg, updateMask})
activate iface
iface -> router : TASKSERVICE-03 UPDATE Conversation({msg, updateMask})
activate router
router -> history : TASKSERVICE-03 UPDATE Conversation({msg, updateMask})
activate history

alt token_count <= budget
  ref over history : TASKSERVICE-03 UPDATE Conversation({msg, updateMask}) <back:#43A047>RUNNING</back>
  history -> store : TASKSERVICE-03 PERSIST History({session_id, messages})
  activate store
  store -> storage : TASKSERVICE-03 PERSIST History({session_id, messages})
  activate storage
  storage --> store : 200 OK
  deactivate storage
  store --> history : 200 OK
  deactivate store
  history --> router : 200 OK
  deactivate history
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else budget exceeded
  history --> router : 409 FAILED_PRECONDITION\n{error: {code: "TASKSERVICE-03_BUDGET_EXCEEDED", message: "Token budget exceeded", status: 409}}
  deactivate history
  router --> iface : 409 FAILED_PRECONDITION\n{error: {code: "TASKSERVICE-03_BUDGET_EXCEEDED", message: "Token budget exceeded", status: 409}}
  iface --> user : 409 FAILED_PRECONDITION\n{error: {code: "TASKSERVICE-03_BUDGET_EXCEEDED", message: "Token budget exceeded", status: 409}}
  deactivate router
  deactivate iface
end

@enduml
