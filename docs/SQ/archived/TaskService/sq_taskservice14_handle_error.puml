@startuml sq_taskservice14_handle_error
' ============================================================
' Title:     TASKSVC-14 — handleError
' Boundary:  NASIM Application — Service Layer
' Purpose:   Classify errors and determine recovery action for the
'             agentic loop (retry, fallback, or terminal failure).
' Intro:     Invoked by TASKSVC-01 when LLM call or tool execution
'             fails. Entry: task_svc self-invocation during error handling.
' Summary:   Recoverable errors retry with feedback; unrecoverable errors
'             transition to ERROR state and return to caller.
' Milestone: v1.0
' Version:   10.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0), docs/UC/uc_task_svc.puml
' Review:    SQ Architect extraction 2026-07-01
' CSR Chain: Task Service (internal orchestration)
' SM States: sm_task_svc_agent.puml — ERROR, IDLE
' ============================================================

!include ../common/sq_styles.puml

title nasim — TASKSVC-14 handleError

box "Service" SERVICE_COLOR
  participant "Task Service" as taskSvc
end box

== TASKSVC-14 handleError — entry ==

taskSvc -> taskSvc : TASKSVC-14 handleError({error, context})
activate taskSvc

ref over taskSvc : TASKSVC-14 handleError\nState: <back:#FFEBEE>ERROR</back>

alt recoverable_error
  taskSvc -> taskSvc : classifyError({error}) → RETRYABLE
  ref over taskSvc : TASKSVC-14 handleError\nState: <back:#FFEBEE>ERROR</back> → <back:#ECEFF1>IDLE</back>
  taskSvc --> taskSvc : 200 OK — {recovered: true, retryHint}

else provider_unavailable
  taskSvc -> taskSvc : classifyError({error}) → PROVIDER_DOWN
  ref over taskSvc : TASKSVC-14 handleError\nState: <back:#FFEBEE>ERROR</back> → <back:#ECEFF1>IDLE</back>
  taskSvc --> taskSvc : 200 OK — {recovered: true, fallbackModel}

else tool_execution_failed
  taskSvc -> taskSvc : classifyError({error}) → TOOL_ERROR
  ref over taskSvc : TASKSVC-14 handleError\nState: <back:#FFEBEE>ERROR</back> → <back:#ECEFF1>IDLE</back>
  taskSvc --> taskSvc : 200 OK — {recovered: true, retryHint}

else unrecoverable_error
  taskSvc -> taskSvc : classifyError({error}) → FATAL
  ref over taskSvc : TASKSVC-14 handleError\nState: <back:#FFEBEE>ERROR</back> (terminal)
  taskSvc --> taskSvc : 500 INTERNAL\n{error: {code: "TASKSVC-14_UNRECOVERABLE"}}

end

deactivate taskSvc

== Summary ==
' TASKSVC-14 is the error recovery hub for the agentic loop. Error
' classification determines whether to retry, fallback, or terminate.
' State transitions follow sm_task_svc_agent ERROR → IDLE pattern.

@enduml
