@startuml sq_taskservice07_queue_plan
' ============================================================
' Title:     TASKSVC-07 — queuePlan
' Boundary:  NASIM Application — Service Layer
' Purpose:   Hold queued tool calls in plan mode without executing them.
' Intro:     Triggered by CLIADP-05 /plan or TASKSVC-01 when plan_mode active.
'             Entry: User → CLI Adapter → agent_ctrl → task_svc.
' Summary:   Plan entity transitions EMPTY → BUILDING → QUEUED per sm_task_svc_plan;
'             tool calls are stored in-memory until TASKSVC-08 approval.
' Milestone: v1.0
' Version:   10.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0), docs/UC/uc_task_svc.puml
' Review:    SQ Architect extraction 2026-07-01
' CSR Chain: User → CLI Adapter → Agent Controller → Task Service
' SM States: sm_task_svc_plan.puml — EMPTY, BUILDING, QUEUED; sm_task_svc_agent PLANNING
' ============================================================

!include ../common/sq_styles.puml

title nasim — TASKSVC-07 queuePlan

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as cliAdp
end box

box "API" API_COLOR
  participant "Agent Controller" as agentCtrl
end box

box "Service" SERVICE_COLOR
  participant "Task Service" as taskSvc
end box

== TASKSVC-07 queuePlan — entry ==

user -> cliAdp : CLIADP-05 enablePlanMode()
activate cliAdp
cliAdp -> agentCtrl : AGENTCTRL-01 processRequest({planMode: true})
activate agentCtrl
agentCtrl -> taskSvc : TASKSVC-07 queuePlan({toolCall})
activate taskSvc

ref over taskSvc : TASKSVC-07 queuePlan\nState: <back:#ECEFF1>IDLE</back> → <back:#FFCCBC>PLANNING</back>

alt plan_state == EMPTY
  ref over taskSvc : TASKSVC-07 queuePlan\nPlan: <back:#F5F5F5>EMPTY</back> → <back:#FFE0B2>BUILDING</back>
  taskSvc -> taskSvc : TASKSVC-07 queuePlan({toolCall})
else plan_state == BUILDING
  taskSvc -> taskSvc : TASKSVC-07 queuePlan({toolCall})
  ref over taskSvc : TASKSVC-07 queuePlan\nPlan: <back:#FFE0B2>BUILDING</back> → <back:#E3F2FD>QUEUED</back>
else plan_cancelled
  ref over taskSvc : TASKSVC-07 queuePlan\nPlan: <back:#FFE0B2>BUILDING</back> → <back:#F5F5F5>EMPTY</back>
  taskSvc --> agentCtrl : 200 OK — {cancelled: true}
  deactivate taskSvc
  agentCtrl --> cliAdp : 200 OK
  cliAdp --> user : 200 OK
  deactivate agentCtrl
  deactivate cliAdp
end

break queue_full
  taskSvc --> agentCtrl : 409 FAILED_PRECONDITION\n{error: {code: "TASKSVC-07_QUEUE_FULL"}}
  agentCtrl --> cliAdp : 409 FAILED_PRECONDITION
  cliAdp --> user : 409 FAILED_PRECONDITION
  deactivate taskSvc
  deactivate agentCtrl
  deactivate cliAdp
end

taskSvc --> agentCtrl : 200 OK — {queued: true, planId}
deactivate taskSvc
agentCtrl --> cliAdp : 200 OK
cliAdp --> user : 200 OK — plan queued
deactivate agentCtrl
deactivate cliAdp

== Summary ==
' In PLANNING agent state, TASKSVC-02 tool dispatch is suppressed; calls accumulate
' in the plan queue until TASKSVC-08 approvePlan drains them.

@enduml