@startuml sq_ac03_adapt_protocol
' ============================================================
' Title:     AGENTCONTROLLER-03 — ADAPT Protocol
' Boundary:  nasim code agent
' Purpose:   Adapt between interface protocols (CLI, HTTP, MCP)
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> InterfaceAdapter -> Agent Controller
' SM States: LISTENING (#E8EAF6), IDLE (#ECEFF1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AGENTCONTROLLER-03 ADAPT Protocol

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
  participant "HTTP Adapter" as http
  participant "MCP Adapter" as mcp
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

== AGENTCONTROLLER-03 ADAPT Protocol ==

user -> iface : AGENTCONTROLLER-03 ADAPT Protocol({payload, protocol})
activate iface

iface -> router : AGENTCONTROLLER-03 ADAPT Protocol({payload, protocol})
activate router

alt protocol is CLI
  router -> iface : AGENTCONTROLLER-03 ADAPT Protocol({payload, "cli"})
  iface --> router : 200 OK — {adapted_payload}
  deactivate iface
  router --> user : 200 OK — {adapted_payload}
  deactivate router

else protocol is HTTP
  router -> http : AGENTCONTROLLER-03 ADAPT Protocol({payload, "http"})
  activate http
  http --> router : 200 OK — {adapted_payload}
  deactivate http
  router --> iface : 200 OK — {adapted_payload}
  deactivate router
  iface --> user : 200 OK — {adapted_payload}
  deactivate iface

else protocol is MCP
  router -> mcp : AGENTCONTROLLER-03 ADAPT Protocol({payload, "mcp"})
  activate mcp
  mcp --> router : 200 OK — {adapted_payload}
  deactivate mcp
  router --> iface : 200 OK — {adapted_payload}
  deactivate router
  iface --> user : 200 OK — {adapted_payload}
  deactivate iface

else unsupported protocol
  router --> iface : 501 NOT_IMPLEMENTED\n{error: {code: "AGENTCONTROLLER-03_PROTOCOL_ERROR", message: "Unsupported protocol", status: 501}}
  deactivate router
  iface --> user : 501 NOT_IMPLEMENTED
  deactivate iface
end

@enduml
