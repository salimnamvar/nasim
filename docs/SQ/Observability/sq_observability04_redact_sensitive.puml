@startuml sq_observability04_redact_sensitive
' ============================================================
' Title:     OBS-04 — REDACT Sensitive Data
' Boundary:  nasim code agent
' Purpose:   Strip secrets before emission to structured logs or wire
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> LogRedactor
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- OBS-04 REDACT Sensitive Data

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "WireLogRepository" as mgr
end box

== OBS-04 REDACT Sensitive Data ==

user -> iface : POST /redact
activate iface
iface -> router : POST /redact
activate router
router -> mgr : OBS-04 REDACT Sensitive Data({record})
activate mgr

alt validation succeeds
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
