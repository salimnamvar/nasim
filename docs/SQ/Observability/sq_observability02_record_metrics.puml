@startuml sq_observability02_record_metrics
' ============================================================
' Title:     OBS-02 — RECORD Metrics
' Boundary:  nasim code agent
' Purpose:   Record metric points for token usage, latency, tool calls
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ObservabilityManager -> ObservabilityStore -> ObservabilityDirectory -> MetricsBackend
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- OBS-02 RECORD Metrics

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Observability Group (Service)" #FFF3E0
  participant "ObservabilityManager" as mgr
end box
box "Observability Group (Repository)" #E8F5E9
  participant "ObservabilityStore" as store
end box
database "ObservabilityDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "MetricsBackend" as MetricsBackend
end box



== OBS-02 RECORD Metrics ==

user -> iface : POST /metrics
activate iface
iface -> router : POST /metrics
activate router
router -> mgr : OBS-02 RECORD Metrics({metric_data})
activate mgr

alt validation succeeds
  mgr -> store : OBS-02 RECORD Metrics({metric_data})
  activate store
  store -> dir : OBS-02 RECORD Metrics({metric_data})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
