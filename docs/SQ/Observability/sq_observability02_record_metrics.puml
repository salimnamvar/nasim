@startuml sq_observability02_record_metrics
' ============================================================
' Title:     OBS-02 — RECORD Metrics
' Boundary:  nasim code agent
' Purpose:   Record metric points for token usage, latency, tool calls
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> MetricsCollector
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- OBS-02 RECORD Metrics

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Observability Group (Infrastructure)" #F3E5F5
  participant "MetricsCollector" as mgr
end box


== OBS-02 RECORD Metrics ==

user -> iface : POST /metrics
activate iface
iface -> router : POST /metrics
activate router
router -> mgr : OBS-02 RECORD Metrics({metric_data})
activate mgr

alt validation succeeds
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
