@startuml sq_observability01_stream_log
' ============================================================
' Title:     OBS-01 — STREAM Structured Log
' Boundary:  nasim code agent
' Purpose:   Emit structured JSON log record to stdout
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> StructuredLogger
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- OBS-01 STREAM Structured Log

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Observability Group (Infrastructure)" #F3E5F5
  participant "StructuredLogger" as mgr
end box


== OBS-01 STREAM Structured Log ==

user -> iface : POST /logs
activate iface
iface -> router : POST /logs
activate router
router -> mgr : OBS-01 STREAM Structured Log({msg, level, extra})
activate mgr

alt validation succeeds
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
