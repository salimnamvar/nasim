@startuml sq_observability01_stream_log
' ============================================================
' Title:     OBS-01 — STREAM Structured Log
' Boundary:  nasim code agent
' Purpose:   Emit structured JSON log record to stdout
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ObservabilityAPI -> ObservabilityManager -> ObservabilityStore -> ObservabilityDirectory
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- OBS-01 STREAM Structured Log

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ObservabilityAPI" as api
end box
box "Observability Group (Service)" #FFF3E0
  participant "ObservabilityManager" as mgr
end box
box "Observability Group (Repository)" #E8F5E9
  participant "ObservabilityStore" as store
end box
database "ObservabilityDirectory" as dir

== OBS-01 STREAM Structured Log ==

user -> router : POST /logs
activate router
router -> api : OBS-01 STREAM Structured Log({msg, level, extra})
activate api
api -> mgr : OBS-01 STREAM Structured Log({msg, level, extra})
activate mgr

alt validation succeeds
  mgr -> store : OBS-01 STREAM Structured Log({msg, level, extra})
  activate store
  store -> dir : OBS-01 STREAM Structured Log({msg, level, extra})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
