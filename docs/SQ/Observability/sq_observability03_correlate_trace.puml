@startuml sq_observability03_correlate_trace
' ============================================================
' Title:     OBS-03 — CORRELATE Trace
' Boundary:  nasim code agent
' Purpose:   Generate and propagate trace context across nasim surfaces
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> TraceCorrelator
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- OBS-03 CORRELATE Trace

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Observability Group (Infrastructure)" #F3E5F5
  participant "TraceCorrelator" as mgr
end box


== OBS-03 CORRELATE Trace ==

user -> iface : POST /traces
activate iface
iface -> router : POST /traces
activate router
router -> mgr : OBS-03 CORRELATE Trace({trace_event})
activate mgr

alt validation succeeds
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
