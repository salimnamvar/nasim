@startuml sq_observability05_expose_metrics
' ============================================================
' Title:     OBS-05 — EXPOSE /metrics
' Boundary:  nasim code agent
' Purpose:   Serve /metrics endpoint for Prometheus pull scrape
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ObservabilityAPI -> ObservabilityManager -> ObservabilityStore -> ObservabilityDirectory
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- OBS-05 EXPOSE /metrics

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ObservabilityAPI" as api
end box
box "Observability Group (Service)" #FFF3E0
  participant "ObservabilityManager" as mgr
end box
box "Observability Group (Repository)" #E8F5E9
  participant "ObservabilityStore" as store
end box
database "ObservabilityDirectory" as dir

== OBS-05 EXPOSE /metrics ==

user -> router : GET /metrics
activate router
router -> api : OBS-05 EXPOSE Metrics({})
activate api
api -> mgr : OBS-05 EXPOSE Metrics({})
activate mgr

alt collection succeeds
  mgr -> store : OBS-05 EXPOSE Metrics({})
  activate store
  store -> dir : OBS-05 EXPOSE Metrics({})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else collection fails
  mgr --> api : 500 Internal Server Error
  deactivate mgr
  api --> router : 500 Internal Server Error
  deactivate api
  router --> user : 500 Internal Server Error
  deactivate router
end

@enduml
