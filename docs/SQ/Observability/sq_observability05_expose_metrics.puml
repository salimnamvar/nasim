@startuml sq_observability05_expose_metrics
' ============================================================
' Title:     OBS-05 — EXPOSE /metrics
' Boundary:  nasim code agent
' Purpose:   Serve /metrics endpoint for Prometheus pull scrape
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ObservabilityManager -> ObservabilityStore -> ObservabilityDirectory -> MetricsBackend
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- OBS-05 EXPOSE /metrics

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Observability Group (Service)" #FFF3E0
  participant "ObservabilityManager" as mgr
end box
box "Observability Group (Repository)" #E8F5E9
  participant "ObservabilityStore" as store
end box
database "ObservabilityDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "MetricsBackend" as MetricsBackend
end box



== OBS-05 EXPOSE /metrics ==

user -> iface : GET /metrics
activate iface
iface -> router : GET /metrics
activate router
router -> mgr : OBS-05 EXPOSE Metrics({})
activate mgr

alt collection succeeds
  mgr -> store : OBS-05 EXPOSE Metrics({})
  activate store
  store -> dir : OBS-05 EXPOSE Metrics({})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else collection fails
  mgr --> router : 500 Internal Server Error
  deactivate mgr
  router --> iface : 500 Internal Server Error
  iface --> user : 500 Internal Server Error
  deactivate router
  deactivate iface
end

@enduml
