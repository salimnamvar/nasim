@startuml sq_observability05_expose_metrics
' ============================================================
' Title:     OBS-05 — EXPOSE /metrics
' Boundary:  nasim code agent
' Purpose:   Serve /metrics endpoint for Prometheus pull scrape
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> MetricsCollector
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- OBS-05 EXPOSE /metrics

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "MetricsCollector" as mgr
end box

== OBS-05 EXPOSE /metrics ==

user -> iface : GET /metrics
activate iface
iface -> router : GET /metrics
activate router
router -> mgr : OBS-05 EXPOSE Metrics({})
activate mgr

alt collection succeeds
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else collection fails
  mgr --> router : 500 Internal Server Error
  deactivate mgr
  router --> iface : 500 Internal Server Error
  iface --> user : 500 Internal Server Error
  deactivate router
  deactivate iface
end

@enduml
