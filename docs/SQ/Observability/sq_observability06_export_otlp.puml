@startuml sq_observability06_export_otlp
' ============================================================
' Title:     OBS-06 — EXPORT OTLP
' Boundary:  nasim code agent
' Purpose:   Export traces and metrics to OTel-compatible backend
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ObservabilityAPI -> ObservabilityManager -> ObservabilityStore -> ObservabilityDirectory
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- OBS-06 EXPORT OTLP

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ObservabilityAPI" as api
end box
box "Observability Group (Service)" #FFF3E0
  participant "ObservabilityManager" as mgr
end box
box "Observability Group (Repository)" #E8F5E9
  participant "ObservabilityStore" as store
end box
database "ObservabilityDirectory" as dir

== OBS-06 EXPORT OTLP ==

user -> router : POST /export
activate router
router -> api : OBS-06 EXPORT OTLP({})
activate api
api -> mgr : OBS-06 EXPORT OTLP({})
activate mgr

alt validation succeeds
  mgr -> store : OBS-06 EXPORT OTLP({})
  activate store
  store -> dir : OBS-06 EXPORT OTLP({})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
