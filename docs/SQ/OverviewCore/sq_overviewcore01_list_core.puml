@startuml sq_overviewcore01_list_core
' ============================================================
' Title:     OVC-01 — LIST Core Components
' Boundary:  nasim code server
' Purpose:   High-level overview of core system components.
'            References subsystem diagrams for details.
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/C4/c4_nasim_component_overview_core.puml
' Review:    Cross-layer naming alignment
' CSR Chain: User -> CLI Process -> CoreSystem
' SM States: — (stateless overview)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- OVC-01 LIST Core Components

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Service" SERVICE_COLOR
  participant "CoreSystem" as core
end box

user -> iface : OVC-01 LIST Core()
iface -> core : OVC-01 LIST Core()
activate core

alt components loaded
  core --> iface : 200 CoreComponent[]
  deactivate core
else system unavailable
  core --> iface : 503 {error: {code: "OVC-01_SYSTEM_ERROR", message: "Core system unavailable", status: 503}}
  deactivate core
end

@enduml