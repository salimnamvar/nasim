@startuml sq_mcp02_discover_mcp_tools
' ============================================================
' Title:     MCPREPOSITORY-02 — DISCOVER MCP Tools
' Boundary:  nasim code agent
' Purpose:   Discover and register tools from connected MCP server
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> MCP Repository -> MCP Repository
' SM States: DISCOVERING (#A1887F), CONNECTED (#00BCD4), ERROR (#E57373)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MCPREPOSITORY-02 DISCOVER MCP Tools

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "MCP Repository" as svc
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "MCP Repository" as mgr
end box

== MCPREPOSITORY-02 DISCOVER MCP Tools ==

user -> iface : MCPREPOSITORY-02 DISCOVER MCP Tools({connection})
activate iface
iface -> router : MCPREPOSITORY-02 DISCOVER MCP Tools({connection})
activate router
router -> svc : MCPREPOSITORY-02 DISCOVER MCP Tools({connection})
activate svc
svc -> mgr : MCPREPOSITORY-02 DISCOVER MCP Tools({connection})
activate mgr

alt tools_discovered
  ref over mgr : MCPREPOSITORY-02 DISCOVER MCP Tools({connection}) <back:#00BCD4>CONNECTED</back>
  mgr --> svc : 200 OK
  deactivate mgr
  svc --> router : 200 OK
  deactivate svc
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else discovery_failed
  mgr --> svc : 422 UNPROCESSABLE\n{error: {code: "MCPREPOSITORY-02_DISCOVERY_FAILED", message: "MCP tool discovery failed", status: 422}}
  deactivate mgr
  svc --> router : 422 UNPROCESSABLE
  deactivate svc
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
