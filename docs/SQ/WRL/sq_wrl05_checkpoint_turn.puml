@startuml sq_wrl05_checkpoint_turn
!include ../common/sq_styles.puml
' ============================================================
' Title:     WRL-05 — CHECKPOINT Turn
' Boundary:  nasim code agent
' Purpose:   Index current turn and persist checkpoint for resumption
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — WRL-05 INSERT Turn

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Wire Log Group" #F3E5F5
  participant "WireLog" as wl
  participant "TurnIndex" as ti
end box
box "FileSystem Group" #E8F5E9
  participant "FileSystem" as fs
end box


note over user
  Scope:          WRL-05 CHECKPOINT Turn — index current turn and persist checkpoint for resumption
  Preconditions:  Turn data available; wire log session active
  Contexts:       Called by AgentOrchestrator at end of each turn for persistence
  Excludes:       Event appending, log reading, seeking, session forking
  Rollback:       (No explicit failure path in diagram — assumes filesystem persistence succeeds)
  Design:         Extracts turn metadata, builds checkpoint index, persists to filesystem
  Returns:
    - Success: 200 OK — CheckpointResult(turn_id, offset)
    - Failure: (implicit — returns error if filesystem write fails)
end note

== WRL-05 CHECKPOINT Turn ==

user -> router : types input
router -> agent : PROCESS(user_input)

agent -> wl : wrl05 CHECKPOINT Turn(turn_data)
activate wl

wl -> ti : index_turn(turn_data)
activate ti

ti -> ti : extract_turn_metadata(turn_data)

ti -> ti : build_checkpoint_index(metadata)

ti -> fs : persist_checkpoint(checkpoint_index)
activate fs
fs --> ti : persist_result
deactivate fs

ti --> wl : CheckpointResult(turn_id, offset)
deactivate ti

wl --> agent : 200 OK — CheckpointResult
deactivate wl

agent --> router : AgentEvent(Done)

note over user
  Flow:    User → ServerRouter → AgentOrchestrator → WireLog → TurnIndex → extract metadata → build index → persist → Result
  State:   No state change (checkpoint persistence; turn indexed for future resume)
  Success: 200 OK — AgentEvent(Done) with CheckpointResult(turn_id, offset)
  Failure: (implicit) filesystem write fails — propagate error to caller
end note

@enduml
