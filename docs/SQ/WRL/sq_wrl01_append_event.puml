@startuml sq_wrl01_append_event
!include ../common/sq_styles.puml
' ============================================================
' Title:     WRL-01 — APPEND Event
' Boundary:  nasim code agent
' Purpose:   Append event to wire log
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — WRL-01 INSERT Event

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Wire Log Group" #F3E5F5
  participant "WireLog" as wirelog
  participant "WireAppender" as appender
end box
box "External" #F5F5F5
  participant "Host Filesystem" as fs
end box


note over user
  Scope:          WRL-01 APPEND Event — append event to wire log
  Preconditions:  Wire log session initialized; event payload valid
  Contexts:       Called by AgentOrchestrator for every user/agent interaction turn
  Excludes:       Log reading, seeking, forking, checkpointing
  Rollback:       Write failure (IOError) → 500 INTERNAL — AppendError("write failed")
  Design:         Append-only log; metadata (session_id, timestamp) auto-injected; sequential offset tracking
  Returns:
    - Success: 200 OK — AppendResult(event_id, offset)
    - Failure: 500 INTERNAL — AppendError("write failed")
end note

== WRL-01 APPEND Event ==

user -> router : types input
router -> agent : PROCESS(user_input)

agent -> wirelog : wrl01 APPEND Event(event)
activate wirelog

wirelog -> appender : serialize(event)
activate appender
appender --> wirelog : serialized_event
deactivate appender

wirelog -> wirelog : add_metadata(serialized_event, session_id, timestamp)

wirelog -> fs : append_file(log_path, serialized_event)
activate fs

break Write failure
    fs --> wirelog : IOError
    wirelog --> agent : 500 INTERNAL — AppendError("write failed")
    agent --> router : AgentEvent(Error)
end

fs --> wirelog : 200 OK — write_result
deactivate fs

wirelog --> agent : 200 OK — AppendResult(event_id, offset)
deactivate wirelog

agent --> router : AgentEvent(Done)

note over user
  Flow:    User → ServerRouter → AgentOrchestrator → WireLog → serialize → add metadata → fs append → Result
  State:   No state change (append-only log mutation)
  Success: 200 OK — AgentEvent(Done) with AppendResult(event_id, offset)
  Failure: 500 INTERNAL: write failed — propagate error to caller; no retry
end note

@enduml
