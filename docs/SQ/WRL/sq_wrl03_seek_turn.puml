@startuml sq_wrl03_seek_turn
!include ../common/sq_styles.puml
' ============================================================
' Title:     WRL-03 — SEEK Turn
' Boundary:  nasim code agent
' Purpose:   Seek to a specific turn in the wire log
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — WRL-03 READ Turn

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Wire Log Group" #F3E5F5
  participant "TurnIndex" as idx
  participant "WireReader" as reader
end box
box "Repository Group" #E8F5E9
  participant "WireLogStore" as wrl
end box


note over user
  Scope:          WRL-03 SEEK Turn — seek to a specific turn in the wire log
  Preconditions:  Wire log indexed; valid turn_number requested
  Contexts:       Called by AgentOrchestrator for time-travel debugging or replay from specific turn
  Excludes:       Full log scan, event appending, session forking
  Rollback:       Turn not found → 404 NOT_FOUND — turn not in index
  Design:         Uses TurnIndex for O(1) lookup; WireReader fetches events at offset
  Returns:
    - Success: 200 OK — WireEvents[turn]
    - Failure: 404 NOT_FOUND — turn not in index
end note

== WRL-03 SEEK Turn ==

user -> router : types input
router -> agent : PROCESS(user_input)

agent -> idx : wrl03 SEEK Turn(turn_number)

idx -> idx : LOOKUP turn_number
idx -> reader : wrl03 READ Wire Events(offset)
activate reader
reader -> wrl : read events from store
wrl --> reader : events

break Turn not found
  reader --> idx : 404 NOT_FOUND
  idx --> agent : 404 NOT_FOUND — turn not in index
  agent --> router : AgentEvent(Error)
end

reader --> idx : 200 OK — WireEvents[turn]
deactivate reader

idx --> agent : 200 OK — WireEvents[turn]

agent --> router : AgentEvent(Done)

note over user
  Flow:    User → ServerRouter → AgentOrchestrator → TurnIndex → lookup → WireReader → read from store → Result
  State:   No state change (read-only)
  Success: 200 OK — AgentEvent(Done) with WireEvents[turn]
  Failure: 404 NOT_FOUND: turn not in index — propagate error to user
end note

@enduml
