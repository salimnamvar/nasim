@startuml sq_wrl04_replay_session
' ============================================================
' Title:     WRL-04 — REPLAY Session
' Boundary:  nasim code agent CLI
' Purpose:   Replay session from wire log
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/audit/audit.2026.06.20.deep.domain.audit.md
' Review:    —
' ============================================================

actor "Developer" as user

box "Agent Layer" #E3F2FD
  participant "AgentOrchestrator" as agent
end box
box "Wire Log Layer" #FFF3E0
  participant "WireLogger" as logger
  participant "SessionReplayer" as replayer
end box
box "Session Layer" #E8F5E9
  participant "SessionManager" as session
  participant "ConversationHistory" as history
end box

note over user, history
  Scope:
    - wrl04 REPLAY Session — replay session from wire log

  Preconditions:
    - Wire log has events for target session
    - SessionManager available for session access

  Contexts:
    - Called to restore session state from wire log
    - Uses WRL-02 (Read Log) to get events for replay

  Excludes:
    - Log reading (handled by WRL-02)
    - Session forking (handled by WRL-03)
    - Event writing (handled by WRL-01)

  Rollback:
    - Replay failure → session state partially restored

  Design:
    - SessionReplayer reads events from wire log
    - Reconstructs ConversationHistory from events
    - Validates event integrity during replay
    - Supports partial replay (up to specific turn)

  Returns:
    - Success: ReplayResult with session state and event count
    - Failure: ReplayError with partial state
end note

== wrl04 REPLAY Session ==

agent -> replayer : REPLAY_SESSION(session_id, up_to_turn=MAX)
activate replayer

replayer -> logger : READ_LOG(session_id, up_to_turn)
activate logger
logger --> replayer : events[]
deactivate logger

replayer -> session : GET_OR_CREATE_SESSION(session_id)
activate session
session --> replayer : session
deactivate session

loop for each event in events
    replayer -> history : apply_event(event)
    activate history
    history --> replayer : applied
    deactivate history

    replayer -> replayer : validate_event_integrity(event)
end

replayer --> agent : ReplayResult(session_id, event_count, final_state)
deactivate replayer

note over user, history
  Flow:
    - AgentOrchestrator → SessionReplayer → WireLogger + SessionManager + ConversationHistory → ReplayResult

  State:
    - IDLE → READING → RECONSTRUCTING → VALIDATING → DONE

  Failure:
    - Replay failure → partial state restored

  Success:
    - ReplayResult with reconstructed session

  Key invariants:
    - Events applied in order
    - Integrity validated each step
    - Partial replay supported (up_to_turn)
end note

@enduml
