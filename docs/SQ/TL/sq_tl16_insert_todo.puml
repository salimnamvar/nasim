@startuml sq_tl16_insert_todo
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-16 — Insert Todo
' Boundary:  nasim code agent
' Purpose:   Add a new todo item via TodoTool
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "TodoTool" as tool
end box


note over user
  Scope:          TL-16 INSERT Todo — Add a new todo item via TodoTool
  Preconditions:  TodoTool initialized; title provided
  Contexts:       Called by task tracking, work item creation, backlog management
  Excludes:       Todo updates, deletions, bulk operations
  Rollback:       No failure path in diagram (assumed always succeeds)
  Design:         Generates unique ID; sets initial status to OPEN
  Returns:
    - Success: ToolResult(success=True, todo_id)
    - Failure: N/A — no failure path in diagram
end note

== TL-16 Insert Todo ==

user -> router : types input
activate router
router -> agent : TL-16 PROCESS(user_input)
activate agent
agent -> registry : TL-16 Insert Todo(title, description)
activate registry
registry -> tool : TL-16 Insert Todo(title, description)
activate tool
tool -> tool : generate ID, set status OPEN
tool --> registry : ToolResult(success=True, todo_id)
deactivate tool
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-16 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → TodoTool (generate ID, set OPEN)
  State:   No state change
  Success: 200 + ToolResult(success=True, todo_id)
  Failure: N/A — no failure path
end note

@enduml
