@startuml sq_tl19_persist_memory
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-19 — Persist Memory
' Boundary:  nasim code agent
' Purpose:   Persist knowledge to memory via MemoryTool
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "MemoryTool" as tool
end box
participant "MemoryStore" as mem


note over user
  Scope:          TL-19 PERSIST Memory — Persist knowledge to memory via MemoryTool
  Preconditions:  MemoryTool initialized; key, value, and scope provided
  Contexts:       Called by knowledge preservation, learning capture, project memory
  Excludes:       Memory recall, deletion, scope migration
  Rollback:       Storage failure → ToolResult(success=False); no partial state
  Design:         Delegates to MEM-01 persist operation; scoped storage
  Returns:
    - Success: ToolResult(success=True)
    - Failure: ToolResult(success=False) — persist failed
end note

== TL-19 Persist Memory ==

user -> router : types input
activate router
router -> agent : TL-19 PROCESS(user_input)
activate agent
agent -> registry : TL-19 Persist Memory(key, value, scope)
activate registry
registry -> tool : TL-19 Persist Memory(key, value, scope)
activate tool
tool -> mem : MEM-01 persist(key, value, scope)
activate mem

break Storage failure
    mem --> tool : StorageError
    deactivate mem
    tool --> registry : ToolResult(success=False, error="persist failed")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

mem --> tool : persisted
deactivate mem
tool --> registry : ToolResult(success=True)
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate tool
deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-19 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → MemoryTool → MemoryStore (MEM-01 persist)
  State:   No state change
  Success: 200 + ToolResult(success=True)
  Failure: ToolResult(success=False): persist failed
end note

@enduml
