@startuml sq_tl08_search_find
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-08 — SEARCH Find
' Boundary:  nasim code agent CLI
' Purpose:   Find files by name pattern with depth limit
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "FindFileTool" as find
end box


note over user
  Scope:          TL-08 SEARCH Find — Find files by name pattern with depth limit
  Preconditions:  Name pattern and path provided by user; path exists
  Contexts:       Called by file discovery, project structure exploration
  Excludes:       Content search, glob patterns, binary file filtering
  Rollback:       Path not found → ToolResult(success=False); no state change
  Design:         Uses os.walk with depth tracking; fnmatch for pattern matching; respects max_depth
  Returns:
    - Success: ToolResult(success=True, content=matching_paths)
    - Failure: ToolResult(success=False) — path not found
end note

== TL-08 FIND Files ==

user -> router : types input
activate router
router -> agent : TL-08 PROCESS(user_input)
activate agent
agent -> registry : TL-08 FIND Files(name_pattern, path, max_depth)
activate registry
registry -> find : TL-08 FIND Files(name_pattern, path, max_depth)
activate find
find -> find : os.walk(path) with depth tracking
find -> find : fnmatch.fnmatch(filename, pattern)

break Path not found
    find --> registry : ToolResult(success=False, error="Error: path not found: path")
    deactivate find
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

find --> registry : ToolResult(success=True, content=matching_paths)
deactivate find
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-08 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → FindFileTool → os.walk() + fnmatch
  State:   No state change
  Success: 200 + ToolResult(success=True, content=matching_paths)
  Failure: ToolResult(success=False): path not found
end note

@enduml
