@startuml sq_tl01_read_file
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-01 — Read File
' Boundary:  nasim code agent CLI
' Purpose:   File read tool execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "ReadFileTool" as ft
end box
participant "Host Filesystem" as fs


note over user
  Scope:          TL-01 READ File — File read tool execution
  Preconditions:  File path provided by user; host filesystem accessible
  Contexts:       Called by any UC requiring file content (e.g., TL-03 EDIT File pre-read, agent exploration)
  Excludes:       File writing, directory listing, file metadata operations
  Rollback:       FileNotFoundError → ToolResult(success=False); PermissionError/UnicodeDecodeError → ToolResult(success=False); no partial state changes
  Design:         Reads file with line numbers; supports offset/limit pagination; single atomic read operation
  Returns:
    - Success: ToolResult(success=True, content=numbered_content)
    - Failure: ToolResult(success=False) — FileNotFoundError, PermissionError, UnicodeDecodeError
end note

== TL-01 READ File ==

user -> router : types input
activate router
router -> agent : TL-01 PROCESS(user_input)
activate agent
agent -> registry : TL-01 READ File(path, offset, limit)
activate registry
registry -> ft : TL-01 READ File(path, offset, limit)
activate ft
ft -> fs : Path(path).read_text()
activate fs

break File not found or not a file
    fs --> ft : FileNotFoundError / IsADirectoryError
    deactivate fs
    ft --> registry : ToolResult(success=False, error="file not found")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

break Read error (encoding, permissions)
    fs --> ft : PermissionError / UnicodeDecodeError
    deactivate fs
    ft --> registry : ToolResult(success=False, error="Error reading path")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

fs --> ft : file content
deactivate fs
ft -> ft : add line numbers, apply offset/limit
ft --> registry : ToolResult(success=True, content=numbered_content)
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate ft
deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-01 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → ReadFileTool → Host Filesystem.read_text()
  State:   No state change
  Success: 200 + ToolResult(success=True, content=numbered_content)
  Failure: ToolResult(success=False): FileNotFoundError — file not found | PermissionError/UnicodeDecodeError — Error reading path
end note

@enduml
