@startuml sq_tl12_dispatch_mcp_extension
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-12 — Dispatch MCP Extension
' Boundary:  nasim code agent CLI
' Purpose:   Invoke tools from MCP server extensions
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "MCPToolAdapter" as mcp
end box
participant "MCP Server" as server


note over user
  Scope:          TL-12 DISPATCH MCP Extension — Invoke tools from MCP server extensions
  Preconditions:  MCP server configured and running; tool name registered
  Contexts:       Called by any UC requiring MCP-provided capabilities
  Excludes:       Direct tool invocation, MCP server management, tool registration
  Rollback:       Server not running → ToolResult(success=False); Tool not found → ToolResult(success=False); no state change
  Design:         Communicates via stdio/SSE; wraps results in ToolResult; delegates to MCP server
  Returns:
    - Success: ToolResult(success=True, content=mcp_result)
    - Failure: ToolResult(success=False) — server unreachable, tool not found
end note

== TL-12 Dispatch MCP Extension ==

user -> router : types input
activate router
router -> agent : TL-12 PROCESS(user_input)
activate agent
agent -> registry : TL-12 Dispatch MCP Extension(tool_name, args)
activate registry
registry -> mcp : TL-12 Dispatch MCP Extension(tool_name, args)
activate mcp
mcp -> server : MCP call(tool_name, args) via stdio/SSE
activate server

break MCP server not running
    server --> mcp : ConnectionRefused
    deactivate server
    mcp --> registry : ToolResult(success=False, error="Error: MCP server not reachable")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

break Tool not found on server
    server --> mcp : UnknownTool error
    deactivate server
    mcp --> registry : ToolResult(success=False, error="Error: tool not found on MCP server")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

server --> mcp : result
deactivate server
mcp -> mcp : wrap in ToolResult(success=True, content=result)
mcp --> registry : ToolResult
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate mcp
deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-12 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → MCPToolAdapter → MCP Server
  State:   No state change
  Success: 200 + ToolResult(success=True, content=result)
  Failure: ToolResult(success=False): MCP server not reachable | tool not found on MCP server
end note

@enduml
