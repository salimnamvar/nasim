@startuml sq_tl09_fetch_web_content
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-09 — FETCH Web Content
' Boundary:  nasim code agent CLI
' Purpose:   Fetch URL content and convert to markdown
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "WebFetchTool" as fetch
end box
participant "Web" as web


note over user
  Scope:          TL-09 FETCH Web Content — Fetch URL content and convert to markdown
  Preconditions:  Valid URL provided by user; network access available
  Contexts:       Called by documentation lookup, reference gathering, web research
  Excludes:       Web search, multi-page crawling, authentication-required pages
  Rollback:       HTTP error (4xx/5xx) → ToolResult(success=False); Timeout → ToolResult(success=False); no partial state
  Design:         Uses httpx for HTTP; html2text for conversion; configurable timeout
  Returns:
    - Success: ToolResult(success=True, content=markdown)
    - Failure: ToolResult(success=False) — HTTP error, timeout
end note

== TL-09 FETCH Web Content ==

user -> router : types input
activate router
router -> agent : TL-09 PROCESS(user_input)
activate agent
agent -> registry : TL-09 FETCH Web Content(url, timeout)
activate registry
registry -> fetch : TL-09 FETCH Web Content(url, timeout)
activate fetch
fetch -> web : httpx GET url (timeout=timeout)
activate web

break HTTP error (4xx, 5xx)
    web --> fetch : HTTPError
    deactivate web
    fetch --> registry : ToolResult(success=False, error="Error: HTTP {status_code} for {url}")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

break Timeout
    web --> fetch : TimeoutException
    deactivate web
    fetch --> registry : ToolResult(success=False, error="Error: timeout fetching {url}")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

web --> fetch : HTML content
deactivate web
fetch -> fetch : html2text.convert(html) -> markdown
fetch --> registry : ToolResult(success=True, content=markdown)
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate fetch
deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-09 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → WebFetchTool → httpx GET → html2text.convert()
  State:   No state change
  Success: 200 + ToolResult(success=True, content=markdown)
  Failure: ToolResult(success=False): HTTP {status_code} for {url} | timeout fetching {url}
end note

@enduml
