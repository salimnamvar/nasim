@startuml sq_tl14_list_registered_tools
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-14 — List Registered Tools
' Boundary:  nasim code agent
' Purpose:   Return list of all tools registered in the ToolRegistry
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — TL-14 LIST Registered Tools

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
end box


note over user
  Scope:          TL-14 LIST Registered Tools — Return list of all tools registered in the ToolRegistry
  Preconditions:  ToolRegistry initialized; at least one tool registered
  Contexts:       Called by tool discovery, capability listing, debugging
  Excludes:       Tool invocation, tool registration, tool configuration
  Rollback:       No failure path; always succeeds (may return empty list)
  Design:         Paginated enumeration (default 100); returns tool names and metadata
  Returns:
    - Success: ToolResult(success=True, tools=[...], nextPageToken)
    - Failure: N/A — no failure path in diagram
end note

== TL-14 List Registered Tools ==

user -> router : types input
activate router
router -> agent : TL-14 PROCESS(user_input)
activate agent
agent -> registry : TL-14 List Registered Tools(pageSize=100, pageToken="abc")
activate registry
registry -> registry : enumerate registered tools (limit=100, offset=0)
registry --> agent : ToolResult(success=True, tools=[...], nextPageToken)
deactivate registry
agent --> router : AgentEvent(Done)

deactivate agent
deactivate router

note over user
  Flow:    TL-14 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry (self-enumeration)
  State:   No state change
  Success: 200 + ToolResult(success=True, tools=[...], nextPageToken)
  Failure: N/A — no failure path
end note

@enduml
