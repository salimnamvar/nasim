@startuml sq_tl06_search_grep
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-06 — SEARCH Grep
' Boundary:  nasim code agent CLI
' Purpose:   Search file contents by regex pattern
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "GrepTool" as grep
  participant "ShellTool" as shell
end box


note over user
  Scope:          TL-06 SEARCH Grep — Search file contents by regex pattern
  Preconditions:  Pattern and optional path provided by user; search path exists
  Contexts:       Called by code exploration, bug investigation, feature search
  Excludes:       Binary file search, file name search, content modification
  Rollback:       No matches found → ToolResult(success=False); Permission denied / path error → ToolResult(success=False); no state change
  Design:         Prefers ripgrep (rg) for performance; falls back to Python os.walk + re.search; formats as file:line:content
  Returns:
    - Success: ToolResult(success=True, content=formatted_matches)
    - Failure: ToolResult(success=False) — no matches, permission denied
end note

== TL-06 GREP Search ==

user -> router : types input
activate router
router -> agent : TL-06 PROCESS(user_input)
activate agent
agent -> registry : TL-06 GREP Search(pattern, path, case_sensitive, include_glob)
activate registry
registry -> grep : TL-06 GREP Search(pattern, path, case_sensitive, include_glob)
activate grep

alt ripgrep available
    grep -> shell : subprocess: rg --json pattern path
    activate shell
    shell --> grep : JSON output
    deactivate shell
    grep -> grep : parse matches -> file:line:content format
else ripgrep not found
    grep -> grep : Python os.walk + re.search fallback
end

break No matches found
    grep --> registry : ToolResult(success=False, error="No matches found for pattern")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

break Permission denied / path error
    grep --> registry : ToolResult(success=False, error="Error: permission denied / path not found")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

grep --> registry : ToolResult(success=True, content=formatted_matches)
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate grep
deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-06 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → GrepTool → ShellTool (ripgrep) or Python fallback
  State:   No state change
  Success: 200 + ToolResult(success=True, content=formatted_matches)
  Failure: ToolResult(success=False): No matches found for pattern | permission denied / path not found
end note

@enduml
