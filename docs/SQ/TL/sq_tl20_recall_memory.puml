@startuml sq_tl20_recall_memory
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-20 — Recall Memory
' Boundary:  nasim code agent
' Purpose:   Recall knowledge from memory via MemoryTool
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "MemoryTool" as tool
end box
participant "MemoryStore" as mem


note over user
  Scope:          TL-20 RECALL Memory — Recall knowledge from memory via MemoryTool
  Preconditions:  MemoryTool initialized; query provided
  Contexts:       Called by knowledge retrieval, context loading, learning application
  Excludes:       Memory persistence, deletion, scope management
  Rollback:       No matching knowledge → ToolResult(success=False); no state change
  Design:         Delegates to MEM-02 recall; optional scope filter
  Returns:
    - Success: ToolResult(success=True, knowledge)
    - Failure: ToolResult(success=False) — no match
end note

== TL-20 Recall Memory ==

user -> router : types input
activate router
router -> agent : TL-20 PROCESS(user_input)
activate agent
agent -> registry : TL-20 Recall Memory(query, scope?)
activate registry
registry -> tool : TL-20 Recall Memory(query, scope)
activate tool
tool -> mem : MEM-02 recall(query, scope)
activate mem

break No matching knowledge
    mem --> tool : empty result
    deactivate mem
    tool --> registry : ToolResult(success=False, error="no match")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

mem --> tool : matching knowledge
deactivate mem
tool --> registry : ToolResult(success=True, knowledge)
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate tool
deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-20 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → MemoryTool → MemoryStore (MEM-02 recall)
  State:   No state change
  Success: 200 + ToolResult(success=True, knowledge)
  Failure: ToolResult(success=False): no match
end note

@enduml
