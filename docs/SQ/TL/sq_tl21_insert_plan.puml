@startuml sq_tl21_insert_plan
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-21 — Insert Plan
' Boundary:  nasim code agent
' Purpose:   Add a new plan step via PlanTool
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "PlanTool" as tool
end box


note over user
  Scope:          TL-21 INSERT Plan — Add a new plan step via PlanTool
  Preconditions:  PlanTool initialized; description provided
  Contexts:       Called by task planning, workflow creation, step definition
  Excludes:       Plan execution, deletion, bulk operations
  Rollback:       No failure path in diagram
  Design:         Generates unique step ID; sets initial status to PENDING; optional dependencies
  Returns:
    - Success: ToolResult(success=True, step_id)
    - Failure: N/A — no failure path in diagram
end note

== TL-21 Insert Plan ==

user -> router : types input
activate router
router -> agent : TL-21 PROCESS(user_input)
activate agent
agent -> registry : TL-21 Insert Plan(description, dependencies?)
activate registry
registry -> tool : TL-21 Insert Plan(description, dependencies)
activate tool
tool -> tool : generate step ID, set status PENDING
tool --> registry : ToolResult(success=True, step_id)
deactivate tool
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-21 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → PlanTool (generate ID, set PENDING)
  State:   No state change
  Success: 200 + ToolResult(success=True, step_id)
  Failure: N/A — no failure path
end note

@enduml
