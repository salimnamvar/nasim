@startuml sq_tl07_search_glob
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-07 — SEARCH Glob
' Boundary:  nasim code agent CLI
' Purpose:   Find files by glob pattern
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "GlobTool" as glob
end box


note over user
  Scope:          TL-07 SEARCH Glob — Find files by glob pattern
  Preconditions:  Glob pattern and base path provided by user; base path accessible
  Contexts:       Called by file discovery, project structure exploration, config file lookup
  Excludes:       Content search, regex search, binary file filtering
  Rollback:       Permission denied → ToolResult(success=False); no state change
  Design:         Uses pathlib.Path.glob(); returns sorted matching paths; no depth limit
  Returns:
    - Success: ToolResult(success=True, content=sorted_paths)
    - Failure: ToolResult(success=False) — permission denied
end note

== TL-07 GLOB Files ==

user -> router : types input
activate router
router -> agent : TL-07 PROCESS(user_input)
activate agent
agent -> registry : TL-07 GLOB Files(pattern, base_path)
activate registry
registry -> glob : TL-07 GLOB Files(pattern, base_path)
activate glob
glob -> glob : Path(base_path).glob(pattern)
glob -> glob : collect and sort matching paths

break Permission denied
    glob --> registry : ToolResult(success=False, error="Error: permission denied: path")
    deactivate glob
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

glob --> registry : ToolResult(success=True, content=sorted_paths)
deactivate glob
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-07 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → GlobTool → Path.glob()
  State:   No state change
  Success: 200 + ToolResult(success=True, content=sorted_paths)
  Failure: ToolResult(success=False): permission denied: path
end note

@enduml
