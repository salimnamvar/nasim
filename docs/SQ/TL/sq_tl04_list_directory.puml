@startuml sq_tl04_list_directory
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-04 — List Directory
' Boundary:  nasim code agent CLI
' Purpose:   List files and directories at a path
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "DirTool" as dt
end box
participant "Host Filesystem" as fs


note over user
  Scope:          TL-04 LIST Directory — List files and directories at a path
  Preconditions:  Directory path provided by user; directory exists
  Contexts:       Called by agent exploration, file browsing, project navigation
  Excludes:       File content reading, recursive directory traversal, file metadata
  Rollback:       FileNotFoundError → ToolResult(success=False); not a directory → ToolResult(success=False); no partial state
  Design:         Paginated results (default 100 entries); formats dirs with d/ prefix; sorted output
  Returns:
    - Success: ToolResult(success=True, content=formatted_listing, nextPageToken)
    - Failure: ToolResult(success=False) — FileNotFoundError, not a directory
end note

== TL-04 LIST Directory ==

user -> router : types input
activate router
router -> agent : TL-04 PROCESS(user_input)
activate agent
agent -> registry : TL-04 LIST Directory(path, pageSize=100, pageToken="abc")
activate registry
registry -> dt : TL-04 LIST Directory(path, pageSize=100, pageToken="abc")
activate dt
dt -> fs : Path(path).resolve()
activate fs

break Path not found
    fs --> dt : FileNotFoundError
    deactivate fs
    dt --> registry : ToolResult(success=False, error="path not found")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

break Not a directory
    dt --> registry : ToolResult(success=False, error="not a directory")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

dt -> fs : sorted(p.iterdir())
activate fs
fs --> dt : entries, next_page_token
deactivate fs
dt -> dt : format with d/ prefix for dirs
dt --> registry : ToolResult(success=True, content=formatted_listing, nextPageToken)
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate dt
deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-04 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → DirTool → Host Filesystem.iterdir()
  State:   No state change
  Success: 200 + ToolResult(success=True, content=formatted_listing, nextPageToken)
  Failure: ToolResult(success=False): FileNotFoundError — path not found | not a directory — not a directory
end note

@enduml
