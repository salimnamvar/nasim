@startuml sq_tl03_update_file
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-03 — UPDATE File
' Boundary:  nasim code agent CLI
' Purpose:   Replace an exact string in a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "EditFileTool" as ft
end box
participant "Host Filesystem" as fs


note over user
  Scope:          TL-03 UPDATE File — Replace an exact string in a file
  Preconditions:  File path, old_string, and new_string provided; file must exist
  Contexts:       Called by any UC requiring precise text replacement (code editing, refactoring)
  Excludes:       Regex replacement, multi-file edits, binary file editing
  Rollback:       FileNotFoundError → ToolResult(success=False); old_string not found → ToolResult(success=False); old_string found N times → ToolResult(success=False); no partial writes on failure
  Design:         Requires exact single match; reads full file, replaces, writes back; uses updateMask for field selection
  Returns:
    - Success: ToolResult(success=True, content='Edited: replaced 1 occurrence')
    - Failure: ToolResult(success=False) — FileNotFoundError, ambiguous/missing match
end note

== TL-03 EDIT File ==

user -> router : types input
activate router
router -> agent : TL-03 PROCESS(user_input)
activate agent
agent -> registry : TL-03 EDIT File(path, old_string, new_string, updateMask)
activate registry
registry -> ft : TL-03 EDIT File(path, old_string, new_string)
activate ft
ft -> fs : Path(path).read_text()
activate fs

break File not found
    fs --> ft : FileNotFoundError
    deactivate fs
    ft --> registry : ToolResult(success=False, error="Error: file not found")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

ft -> ft : content.count(old_string)

alt count == 0
    ft --> registry : ToolResult(success=False, error="old_string not found")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
else count > 1
    ft --> registry : ToolResult(success=False, error="old_string found N times (ambiguous)")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
else count == 1
    ft -> ft : content.replace(old_string, new_string, 1)
    ft -> fs : Path(path).write_text(new_content)
    activate fs
    ft --> registry : ToolResult(success=True, content="Edited: replaced 1 occurrence")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Done)
end

    deactivate ft
    deactivate registry
    deactivate agent
deactivate router

note over user
  Flow:    TL-03 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → EditFileTool → Host Filesystem.read_text() + write_text()
  State:   No state change
  Success: 200 + ToolResult(success=True, content='Edited: replaced 1 occurrence')
  Failure: ToolResult(success=False): FileNotFoundError — file not found | count==0 — old_string not found | count>1 — old_string found N times (ambiguous)
end note

@enduml
