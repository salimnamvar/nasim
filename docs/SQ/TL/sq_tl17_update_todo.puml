@startuml sq_tl17_update_todo
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-17 — Update Todo
' Boundary:  nasim code agent
' Purpose:   Update status or content of an existing todo item
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "TodoTool" as tool
end box


note over user
  Scope:          TL-17 UPDATE Todo — Update status or content of an existing todo item
  Preconditions:  Todo item exists with given todo_id
  Contexts:       Called by task status tracking, work completion, backlog grooming
  Excludes:       Todo creation, deletion, bulk updates
  Rollback:       Todo not found → ToolResult(success=False); Invalid status transition → ToolResult(success=False); no partial state
  Design:         Uses updateMask for partial updates; enforces valid state transitions
  Returns:
    - Success: ToolResult(success=True, todo)
    - Failure: ToolResult(success=False) — not found, invalid transition
end note

== TL-17 Update Todo ==

user -> router : types input
activate router
router -> agent : TL-17 PROCESS(user_input)
activate agent
agent -> registry : TL-17 Update Todo(todo_id, status, description, updateMask)
activate registry
registry -> tool : TL-17 Update Todo(todo_id, status, description, updateMask)
activate tool

break Todo not found
    tool --> registry : ToolResult(success=False, error="todo not found")
    deactivate tool
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

break Invalid status transition
    tool --> registry : ToolResult(success=False, error="invalid transition")
    deactivate tool
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

tool -> tool : update fields
tool --> registry : ToolResult(success=True, todo)
deactivate tool
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-17 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → TodoTool (update fields)
  State:   No state change
  Success: 200 + ToolResult(success=True, todo)
  Failure: ToolResult(success=False): todo not found | invalid transition
end note

@enduml
