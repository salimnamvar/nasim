@startuml sq_tl22_update_plan
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-22 — Update Plan
' Boundary:  nasim code agent
' Purpose:   Update status or content of an existing plan step
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "PlanTool" as tool
end box


note over user
  Scope:          TL-22 UPDATE Plan — Update status or content of an existing plan step
  Preconditions:  Plan step exists with given step_id
  Contexts:       Called by plan progress tracking, step completion, workflow management
  Excludes:       Plan step creation, deletion, bulk updates
  Rollback:       Step not found → ToolResult(success=False); Invalid status transition → ToolResult(success=False); no partial state
  Design:         Uses updateMask for partial updates; enforces valid state transitions
  Returns:
    - Success: ToolResult(success=True, step)
    - Failure: ToolResult(success=False) — not found, invalid transition
end note

== TL-22 Update Plan ==

user -> router : types input
activate router
router -> agent : TL-22 PROCESS(user_input)
activate agent
agent -> registry : TL-22 Update Plan(step_id, status, description, updateMask)
activate registry
registry -> tool : TL-22 Update Plan(step_id, status, description, updateMask)
activate tool

break Step not found
    tool --> registry : ToolResult(success=False, error="step not found")
    deactivate tool
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

break Invalid status transition
    tool --> registry : ToolResult(success=False, error="invalid transition")
    deactivate tool
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

tool -> tool : update fields
tool --> registry : ToolResult(success=True, step)
deactivate tool
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-22 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → PlanTool (update fields)
  State:   No state change
  Success: 200 + ToolResult(success=True, step)
  Failure: ToolResult(success=False): step not found | invalid transition
end note

@enduml
