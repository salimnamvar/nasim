@startuml sq_tl05_dispatch_shell_command
!include ../common/sq_styles.puml
' ============================================================
' Title:     TL-05 — Dispatch Shell Command
' Boundary:  nasim code agent CLI
' Purpose:   Shell command execution with timeout
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
  participant "ShellTool" as st
end box
participant "Host Shell" as shell


note over user
  Scope:          TL-05 DISPATCH Shell Command — Shell command execution with timeout
  Preconditions:  Command string provided by user; host shell accessible
  Contexts:       Called by any UC requiring shell execution (build, test, git, npm, etc.)
  Excludes:       Interactive shell sessions, persistent processes, shell environment setup
  Rollback:       TimeoutExpired → ToolResult(success=False); Execution error → ToolResult(success=False); no cleanup of started processes
  Design:         Enforced timeout via subprocess.run; captures stdout + stderr + exit code; single execution
  Returns:
    - Success: ToolResult(success=True, content=command_output)
    - Failure: ToolResult(success=False) — TimeoutExpired, execution Exception
end note

== TL-05 EXECUTE Shell Command ==

user -> router : types input
activate router
router -> agent : TL-05 PROCESS(user_input)
activate agent
agent -> registry : TL-05 EXECUTE Shell Command(command, timeout)
activate registry
registry -> st : TL-05 EXECUTE Shell Command(command, timeout)
activate st
st -> shell : subprocess.run(command, shell=True, timeout=timeout)
activate shell

break Timeout
    shell --> st : TimeoutExpired
    deactivate shell
    st --> registry : ToolResult(success=False, error="command timed out after Ns")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

break Execution error
    shell --> st : Exception
    deactivate shell
    st --> registry : ToolResult(success=False, error="Error executing command")
    registry --> agent : ToolResult
    agent --> router : AgentEvent(Error)
end

shell --> st : CompletedProcess(stdout, stderr, returncode)
deactivate shell
st -> st : format output (stdout + stderr + exit code)
st --> registry : ToolResult(success=True, content=command_output)
registry --> agent : ToolResult
agent --> router : AgentEvent(Done)

deactivate st
deactivate registry
deactivate agent
deactivate router

note over user
  Flow:    TL-05 → User types input → ServerRouter → AgentOrchestrator → ToolRegistry → ShellTool → Host Shell subprocess.run()
  State:   No state change
  Success: 200 + ToolResult(success=True, content=command_output)
  Failure: ToolResult(success=False): TimeoutExpired — command timed out after Ns | Exception — Error executing command
end note

@enduml
