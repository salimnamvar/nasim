@startuml sq_wirelog04_fork_session
' ============================================================
' Title:     WIRELOGREPOSITORY-04 — FORK Session
' Boundary:  nasim code agent
' Purpose:   Fork session at any turn
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> WireLog -> SessionServiceManager -> FileSystem
' SM States: BRANCHED (#7B1FA2)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- WIRELOGREPOSITORY-04 FORK Session

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "WireLogRepository" as wl
  participant "WireLogRepository" as fork_mgr
end box

database "WireLogStore" as storage

== WIRELOGREPOSITORY-04 FORK Session ==

user -> iface : POST /wirelog/fork
activate iface
iface -> router : POST /wirelog/fork
activate router
router -> wl : WIRELOGREPOSITORY-04 FORK Session(source_session_id, fork_turn)
activate wl

alt fork succeeds
  wl -> fork_mgr : WIRELOGREPOSITORY-04 FORK Session(source_session_id, fork_turn)
  activate fork_mgr
  fork_mgr -> storage : WIRELOGREPOSITORY-04 FORK Session(source_session_id, fork_turn)
  activate storage
  storage --> fork_mgr : 200 OK
  deactivate storage
  fork_mgr --> wl : 200 OK
  deactivate fork_mgr

  ref over fork_mgr : WIRELOGREPOSITORY-04 FORK Session({source_session_id, fork_turn}) <back:#7B1FA2>BRANCHED</back>

  wl --> router : 200 OK
  deactivate wl
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else source not found
  wl --> router : 404 Not Found
  deactivate wl
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
