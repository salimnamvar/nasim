@startuml sq_router01_select_model
' ============================================================
' Title:     RTG-01 — SELECT Model
' Boundary:  nasim code agent
' Purpose:   Model selection and fallback routing
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ModelRouter
' SM States: SELECTING (#3F51B5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RTG-01 SELECT Model

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "ModelRouter" as mgr
end box

== RTG-01 SELECT Model ==

user -> iface : RTG-01 SELECT Model({task_type})
activate iface
iface -> router : RTG-01 SELECT Model({task_type})
activate router
router -> mgr : RTG-01 SELECT Model(task_classification)
activate mgr

alt model found
  ref over mgr : RTG-01 SELECT Model <back:#3F51B5>SELECTING</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else no supported model
  mgr --> router : 404 NOT_FOUND\n{error: {code: "RTG-01_MODEL_NOT_FOUND", message: "No supported model for task", status: 404}}
  deactivate mgr
  router --> iface : 404 NOT_FOUND
  iface --> user : 404 NOT_FOUND
  deactivate router
  deactivate iface
end

@enduml
