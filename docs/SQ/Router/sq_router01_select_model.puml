@startuml sq_router01_select_model
' ============================================================
' Title:     RTG-01 — SELECT Model
' Boundary:  nasim code agent
' Purpose:   Model selection and fallback routing
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> RouterAPI -> RouterManager -> RouterStore -> RouterDirectory
' SM States: SELECTING (#3F51B5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RTG-01 SELECT Model

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "RouterAPI" as api
end box
box "Router Group (Service)" #FFF3E0
  participant "RouterManager" as mgr
end box
box "Router Group (Repository)" #E8F5E9
  participant "RouterStore" as store
end box
database "RouterDirectory" as dir

== RTG-01 SELECT Model ==

user -> router : GET /models/select?task={task_type}
activate router
router -> api : rtg01 SELECT Model(task_classification)
activate api
api -> mgr : rtg01 SELECT Model(task_classification)
activate mgr

alt model found
  mgr -> store : rtg01 SELECT Model(task_classification)
  activate store
  store -> dir : rtg01 SELECT Model(task_classification)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : SELECTING (#3F51B5)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else no supported model
  mgr --> api : 404 Not Found
  deactivate mgr
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end

@enduml
