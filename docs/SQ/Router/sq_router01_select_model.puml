@startuml sq_router01_select_model
' ============================================================
' Title:     RTG-01 — SELECT Model
' Boundary:  nasim code agent
' Purpose:   Model selection and fallback routing
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> RouterManager -> RouterStore -> RouterDirectory -> ModelBackend
' SM States: SELECTING (#3F51B5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RTG-01 SELECT Model

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Router Group (Service)" #FFF3E0
  participant "RouterManager" as mgr
end box
box "Router Group (Repository)" #E8F5E9
  participant "RouterStore" as store
end box
database "RouterDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "ModelBackend" as ModelBackend
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "ModelBackend" as ModelBackend
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "ModelBackend" as ModelBackend
end box

== RTG-01 SELECT Model ==

user -> iface : GET /models/select?task={task_type}
activate iface
iface -> router : GET /models/select?task={task_type}
activate router
router -> mgr : rtg01 SELECT Model(task_classification)
activate mgr

alt model found
  mgr -> store : rtg01 SELECT Model(task_classification)
  activate store
  store -> dir : rtg01 SELECT Model(task_classification)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : SELECTING (#3F51B5)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else no supported model
  mgr --> router : 404 Not Found
  deactivate mgr
  router --> iface : 404 Not Found
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
