@startuml sq_router04_switch_model
' ============================================================
' Title:     RTG-04 — SWITCH Model
' Boundary:  nasim code agent
' Purpose:   Change the active model at runtime
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> RouterAPI -> RouterManager -> RouterStore -> RouterDirectory
' SM States: SWITCHING (#FF8F00)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RTG-04 SWITCH Model

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "RouterAPI" as api
end box
box "Router Group (Service)" #FFF3E0
  participant "RouterManager" as mgr
end box
box "Router Group (Repository)" #E8F5E9
  participant "RouterStore" as store
end box
database "RouterDirectory" as dir

== RTG-04 SWITCH Model ==

user -> router : PATCH /models/active
activate router
router -> api : rtg04 SWITCH Model(target_model)
activate api
api -> mgr : rtg04 SWITCH Model(target_model)
activate mgr

alt switch succeeds
  mgr -> store : rtg04 SWITCH Model(target_model)
  activate store
  store -> dir : rtg04 SWITCH Model(target_model)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : SWITCHING (#FF8F00)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else model not in catalog
  mgr --> api : 404 Not Found
  deactivate mgr
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end

@enduml
