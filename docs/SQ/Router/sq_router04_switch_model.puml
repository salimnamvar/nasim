@startuml sq_router04_switch_model
' ============================================================
' Title:     RTG-04 — SWITCH Model
' Boundary:  nasim code agent
' Purpose:   Change the active model at runtime
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ModelRouter
' SM States: SWITCHING (#FF8F00)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RTG-04 SWITCH Model

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Router Group (Service)" #FFF3E0
  participant "ModelRouter" as mgr
end box

== RTG-04 SWITCH Model ==

user -> iface : PATCH /models/active
activate iface
iface -> router : PATCH /models/active
activate router
router -> mgr : rtg04 SWITCH Model(target_model)
activate mgr

alt switch succeeds
  ref over mgr : RTG-04 SWITCH Model
    ' Router lifecycle: → SWITCHING (#FF8F00)
    ' Owned by: RTG-04 SWITCH Model (SM/README.md)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else model not in catalog
  mgr --> router : 404 Not Found
  deactivate mgr
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
