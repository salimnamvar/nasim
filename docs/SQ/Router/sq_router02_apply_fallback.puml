@startuml sq_router02_apply_fallback
' ============================================================
' Title:     RTG-02 — APPLY Fallback
' Boundary:  nasim code agent
' Purpose:   Apply fallback chain when primary model fails
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> RouterAPI -> RouterManager -> RouterStore -> RouterDirectory
' SM States: FALLBACK (#EF6C00)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RTG-02 APPLY Fallback

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "RouterAPI" as api
end box
box "Router Group (Service)" #FFF3E0
  participant "RouterManager" as mgr
end box
box "Router Group (Repository)" #E8F5E9
  participant "RouterStore" as store
end box
database "RouterDirectory" as dir

== RTG-02 APPLY Fallback ==

user -> router : POST /models/fallback
activate router
router -> api : rtg02 APPLY Fallback(primary_model, chain)
activate api
api -> mgr : rtg02 APPLY Fallback(primary_model, chain)
activate mgr

alt fallback succeeds
  mgr -> store : rtg02 APPLY Fallback(primary_model, chain)
  activate store
  store -> dir : rtg02 APPLY Fallback(primary_model, chain)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : FALLBACK (#EF6C00)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else all models unavailable
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
