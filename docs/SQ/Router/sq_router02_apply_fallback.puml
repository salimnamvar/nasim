@startuml sq_router02_apply_fallback
' ============================================================
' Title:     RTG-02 — APPLY Fallback
' Boundary:  nasim code agent
' Purpose:   Apply fallback chain when primary model fails
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> RouterManager -> RouterStore -> RouterDirectory -> ModelBackend
' SM States: FALLBACK (#EF6C00)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RTG-02 APPLY Fallback

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Router Group (Service)" #FFF3E0
  participant "RouterManager" as mgr
end box
box "Router Group (Repository)" #E8F5E9
  participant "RouterStore" as store
end box
database "RouterDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "ModelBackend" as ModelBackend
end box



== RTG-02 APPLY Fallback ==

user -> iface : POST /models/fallback
activate iface
iface -> router : POST /models/fallback
activate router
router -> mgr : rtg02 APPLY Fallback(primary_model, chain)
activate mgr

alt fallback succeeds
  mgr -> store : rtg02 APPLY Fallback(primary_model, chain)
  activate store
  store -> dir : rtg02 APPLY Fallback(primary_model, chain)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#EF6C00>FALLBACK</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else all models unavailable
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
