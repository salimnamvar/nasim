@startuml sq_router02_apply_fallback
' ============================================================
' Title:     RTG-02 — APPLY Fallback
' Boundary:  nasim code agent
' Purpose:   Apply fallback chain when primary model fails
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ModelRouter
' SM States: FALLBACK (#EF6C00)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RTG-02 APPLY Fallback

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "ModelRouter" as mgr
end box

== RTG-02 APPLY Fallback ==

user -> iface : RTG-02 APPLY Fallback({primary_model, chain})
activate iface
iface -> router : RTG-02 APPLY Fallback({primary_model, chain})
activate router
router -> mgr : RTG-02 APPLY Fallback(primary_model, chain)
activate mgr

alt fallback succeeds
  ref over mgr : RTG-02 APPLY Fallback <back:#EF6C00>FALLBACK</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else all models unavailable
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "RTG-02_ALL_MODELS_UNAVAILABLE", message: "All models in fallback chain unavailable", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
