@startuml sq_router03_classify_task
' ============================================================
' Title:     RTG-03 — CLASSIFY Task
' Boundary:  nasim code agent
' Purpose:   Classify task type and select optimal model
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> RouterAPI -> RouterManager -> RouterStore -> RouterDirectory
' SM States: CLASSIFYING (#5C6BC0)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RTG-03 CLASSIFY Task

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "RouterAPI" as api
end box
box "Router Group (Service)" #FFF3E0
  participant "RouterManager" as mgr
end box
box "Router Group (Repository)" #E8F5E9
  participant "RouterStore" as store
end box
database "RouterDirectory" as dir

== RTG-03 CLASSIFY Task ==

user -> router : POST /tasks/classify
activate router
router -> api : rtg03 CLASSIFY Task(task_description, context)
activate api
api -> mgr : rtg03 CLASSIFY Task(task_description, context)
activate mgr

alt classification succeeds
  mgr -> store : rtg03 CLASSIFY Task(task_description, context)
  activate store
  store -> dir : rtg03 CLASSIFY Task(task_description, context)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : CLASSIFYING (#5C6BC0)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else confidence too low
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
