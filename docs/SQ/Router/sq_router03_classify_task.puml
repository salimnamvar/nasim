@startuml sq_router03_classify_task
' ============================================================
' Title:     RTG-03 — CLASSIFY Task
' Boundary:  nasim code agent
' Purpose:   Classify task type and select optimal model
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> RouterManager -> RouterStore -> RouterDirectory -> ModelBackend
' SM States: CLASSIFYING (#5C6BC0)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RTG-03 CLASSIFY Task

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Router Group (Service)" #FFF3E0
  participant "RouterManager" as mgr
end box
box "Router Group (Repository)" #E8F5E9
  participant "RouterStore" as store
end box
database "RouterDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "ModelBackend" as ModelBackend
end box



== RTG-03 CLASSIFY Task ==

user -> iface : POST /tasks/classify
activate iface
iface -> router : POST /tasks/classify
activate router
router -> mgr : rtg03 CLASSIFY Task(task_description, context)
activate mgr

alt classification succeeds
  mgr -> store : rtg03 CLASSIFY Task(task_description, context)
  activate store
  store -> dir : rtg03 CLASSIFY Task(task_description, context)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#5C6BC0>CLASSIFYING</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else confidence too low
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
