@startuml sq_ctx04_inject_context
!include ../common/sq_styles.puml
' ============================================================
' Title:     CTX-04 — Inject Context
' Boundary:  nasim code agent CLI
' Purpose:   Retrieve and inject context into the reasoning graph
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — CTX-04 INJECT Context

box "Context Group" #FFF3E0
  participant "PipelineOrchestrator" as pipe
  participant "InjectionProcessor" as inj
end box
box "RIM Group" #E8F5E9
  participant "RepoIndex" as rim
end box
actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box

note over user
  Scope:          CTX-04 INJECT Context — retrieve and inject context into the reasoning graph
  Preconditions:  RepoIndex populated; task description available
  Contexts:       Called by CTX-01 via ref
  Excludes:       Context truncation, distillation, compaction
  Rollback:       RepoIndex unavailable → skip injection, return (0, 0)
  Design:         Context blocks injected as nodes into reasoning graph; filtered by relevance score
  Returns:
    - Success: 200 + InjectionResult(nodes_added, tokens_used)
    - Failure: 200 + InjectionResult(0, 0) on IndexError
end note

== CTX-04 Inject Context ==

user -> router : types input
router -> agent : PROCESS(user_input)
agent -> pipe : CTX-04 INJECT(task_description, graph)
activate inj

inj -> rim : query_relevant(task_description)
activate rim
rim --> inj : relevant_nodes [file_refs, snippets]
deactivate rim

inj -> inj : filter by relevance score
inj -> inj : format context blocks

inj -> inj : inject into reasoning graph
inj --> pipe : InjectionResult(nodes_added, tokens_used)
deactivate inj

agent --> router : AgentEvent(Done)

break RepoIndex unavailable
    rim --> inj : IndexError
    inj -> inj : skip injection
    inj --> pipe : InjectionResult(0, 0)
end

note over user
  Flow:    CTX-04 → query RepoIndex → filter by relevance → format context blocks → inject into graph
  State:   No state change (reasoning graph extended with new nodes)
  Success: 200 + InjectionResult(nodes_added, tokens_used)
  Failure: 200: IndexError — skip injection, return InjectionResult(0, 0)
end note

@enduml
