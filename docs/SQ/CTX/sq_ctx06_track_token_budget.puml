@startuml sq_ctx06_track_token_budget
!include ../common/sq_styles.puml
' ============================================================
' Title:     CTX-06 — Track Token Budget
' Boundary:  nasim code agent CLI
' Purpose:   Track token count as messages are added
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
  participant "ConversationHistory" as history
end box

note over user
  Scope:          CTX-06 TRACK Token Budget — track token count as messages are added
  Preconditions:  ConversationHistory initialized; context_budget configured
  Contexts:       Called by CTX-01 via ref
  Excludes:       Message truncation, distillation, context injection
  Rollback:       token_count > budget → triggers CTX-02 COMPACT; otherwise no failure path
  Design:         Token estimation is additive; budget check on every message add
  Returns:
    - Success: 200 + ok (within budget)
    - Failure: 200 + COMPACT_NEEDED (exceeds budget, triggers CTX-02)
end note

== CTX-01 Track Token Count ==

user -> router : types input
activate router
router -> agent : PROCESS(user_input)
activate agent
agent -> history : CTX-06 ADD_MESSAGE(msg)
activate history
history -> history : self.messages.append(msg)
history -> history : self.token_count += estimate_tokens(msg)

alt token_count > context_budget
    history --> agent : COMPACT_NEEDED
    deactivate history
    agent -> agent : trigger CTX-02 (COMPACT Context)
else within budget
    history --> agent : ok
    deactivate history
end

agent --> router : AgentEvent(Done)

deactivate agent
deactivate router

note over user
  Flow:    CTX-06 → append message → estimate tokens → check budget → ok or trigger CTX-02
  State:   No state change (token_count updated in ConversationHistory)
  Success: 200 + ok (within budget)
  Failure: 200: token_count > context_budget — trigger CTX-02 COMPACT
end note

@enduml
