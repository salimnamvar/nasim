@startuml sq_ctx02_truncate_nodes
!include ../common/sq_styles.puml
' ============================================================
' Title:     CTX-02 — TRUNCATE Nodes
' Boundary:  nasim code agent
' Purpose:   Truncate context when token budget exceeded
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
  participant "ConversationHistory" as history
  participant "ContextCompactor" as compactor
end box
box "Provider Group" #FFF3E0
  participant "Provider" as provider
end box

note over user
  Scope:          CTX-02 TRUNCATE Nodes — truncate context when token budget exceeded
  Preconditions:  ContextGraph populated; ContextPrioritizer scores available; token budget exceeded
  Contexts:       Called by CTX-01 via ref
  Excludes:       Node importance scoring, context injection
  Rollback:       LLM failure → fallback to truncate oldest messages
  Design:         Protects system prompt nodes from truncation; uses secondary LLM for summarization
  Returns:
    - Success: 200 + shortened messages (summarized)
    - Failure: 200 + shortened messages (truncated oldest fallback)
end note

== CTX-02 TRUNCATE Nodes ==

user -> router : types input
activate router
router -> agent : PROCESS(user_input)
activate agent
agent -> history : CTX-02 TRUNCATE(messages, budget)
activate history
compactor -> compactor : query ContextPrioritizer for node importance scores
compactor -> compactor : sort nodes by ascending importance (lowest first)
compactor -> compactor : protect system prompt nodes (never truncated)
compactor -> compactor : drop lowest-importance nodes until within budget
compactor -> compactor : build summarization prompt

compactor -> provider : chat([summary_prompt + selected_messages])
activate provider

break Secondary LLM call fails
    provider --> compactor : ProviderError
    deactivate provider
    compactor -> compactor : fallback: truncate oldest messages
    compactor --> history : shortened messages (truncated)
end

provider --> compactor : summary text
deactivate provider
compactor -> compactor : create summary message
compactor -> compactor : replace selected messages with summary
compactor --> history : shortened messages (summarized)

agent --> router : AgentEvent(Done)

deactivate agent
deactivate router

note over user
  Flow:    CTX-02 → query importance scores → sort ascending → protect system prompt → drop lowest → summarize via LLM
  State:   No state change (messages shortened in-place)
  Success: 200 + shortened messages (summarized)
  Failure: 200: LLM call fails — fallback to truncate oldest messages
end note

@enduml
