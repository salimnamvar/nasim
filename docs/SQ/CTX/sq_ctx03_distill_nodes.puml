@startuml sq_ctx03_distill_nodes
!include ../common/sq_styles.puml
' ============================================================
' Title:     CTX-03 — Distill Nodes
' Boundary:  nasim code agent CLI
' Purpose:   Summarize old message exchanges into compact form
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
  participant "ContextCompactor" as compactor
end box
box "Provider Group" #FFF3E0
  participant "Provider" as provider
end box
box "Repository Group" #E8F5E9
  participant "ContextStore" as ctx_store
end box

note over user
  Scope:          CTX-03 DISTILL Nodes — summarize old message exchanges into compact form
  Preconditions:  Old messages present in conversation history; Provider available
  Contexts:       Called by CTX-01 via ref
  Excludes:       Node truncation, context injection
  Rollback:       Summary empty or provider fails → use truncated raw content as summary
  Design:         Summary stored as system role message in ContextStore
  Returns:
    - Success: 200 + summary message stored
    - Failure: 200 + truncated raw content used as summary
end note

== CTX-03 Summarize Old Exchanges ==

user -> router : types input
activate router
router -> agent : PROCESS(user_input)
activate agent
agent -> compactor : CTX-03 DISTILL(messages)
activate compactor
compactor -> compactor : build prompt: "Summarize these exchanges concisely"
compactor -> provider : chat([summary_prompt + old_messages])
activate provider

break Summary is empty or provider fails
    provider --> compactor : empty/error
    deactivate provider
    compactor -> compactor : use truncated raw content as summary
end

provider --> compactor : summary text
deactivate provider
compactor -> compactor : create summary message {role: "system", content: summary}
compactor --> compactor : return summary message
compactor -> ctx_store : store summary
activate ctx_store
ctx_store --> compactor : stored
deactivate ctx_store

agent --> router : AgentEvent(Done)

deactivate compactor
deactivate agent
deactivate router

note over user
  Flow:    CTX-03 → build summary prompt → LLM summarize → create summary message → store
  State:   No state change (old messages replaced by summary in ContextStore)
  Success: 200 + summary message stored
  Failure: 200: LLM empty/fails — use truncated raw content as summary
end note

@enduml
