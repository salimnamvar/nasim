@startuml sq_cfg01_load_config
' ============================================================
' Title:     CFG-01 — LOAD Config
' Boundary:  nasim code agent
' Purpose:   Load configuration from layered sources
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ConfigAPI -> ConfigManager -> ConfigStore -> ConfigDirectory
' SM States: SERVING (#E0F7FA)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CFG-01 LOAD Config

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ConfigAPI" as api
end box
box "Config Group (Service)" #FFF3E0
  participant "ConfigManager" as mgr
end box
box "Config Group (Repository)" #E8F5E9
  participant "ConfigStore" as store
end box
database "ConfigDirectory" as dir

== CFG-01 LOAD Config ==

user -> router : GET /config
activate router
router -> api : CFG-01 LOAD Config({cli_args})
activate api
api -> mgr : CFG-01 LOAD Config({cli_args})
activate mgr

alt validation succeeds
  mgr -> store : CFG-01 LOAD Config({cli_args})
  activate store
  store -> dir : CFG-01 LOAD Config({cli_args})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : SERVING (#E0F7FA) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
