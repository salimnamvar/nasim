@startuml sq_cfg01_load_config
' ============================================================
' Title:     CFG-01 — LOAD Config
' Boundary:  nasim code agent
' Purpose:   Load configuration from layered sources
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ConfigManager -> ConfigStore -> ConfigDirectory -> FileSystem
' SM States: SERVING (#E0F7FA)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CFG-01 LOAD Config

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Config Group (Service)" #FFF3E0
  participant "ConfigManager" as mgr
end box
box "Config Group (Repository)" #E8F5E9
  participant "ConfigStore" as store
end box
database "ConfigDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== CFG-01 LOAD Config ==

user -> iface : GET /config
activate iface
iface -> router : GET /config
activate router
router -> mgr : CFG-01 LOAD Config({cli_args})
activate mgr

alt validation succeeds
  mgr -> store : CFG-01 LOAD Config({cli_args})
  activate store
  store -> dir : CFG-01 LOAD Config({cli_args})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : SERVING (#E0F7FA) ...
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
