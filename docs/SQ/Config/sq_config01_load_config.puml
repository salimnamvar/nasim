@startuml sq_cfg01_load_config
' ============================================================
' Title:     CFG-01 — LOAD Config
' Boundary:  nasim code agent
' Purpose:   Load configuration from layered sources
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ConfigLoader
' SM States: SERVING (#E0F7FA)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CFG-01 LOAD Config

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Config Group (Repository)" #E8F5E9
  participant "ConfigLoader" as mgr
end box

== CFG-01 LOAD Config ==

user -> iface : GET /config
activate iface
iface -> router : GET /config
activate router
router -> mgr : CFG-01 LOAD Config({cli_args})
activate mgr

alt validation succeeds
  ref over mgr : CFG-01 LOAD Config
    ' Config lifecycle: → SERVING (#E0F7FA)
    ' Owned by: CFG-01 LOAD Config (SM/README.md)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
