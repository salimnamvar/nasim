@startuml sq_config03_apply_layered_config
' ============================================================
' Title:     CFG-03 — APPLY Layered Config
' Boundary:  nasim code agent
' Purpose:   Apply layered configuration merging global, project, env, and CLI
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ConfigLoader
' SM States: SERVING (#E0F7FA)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CFG-03 APPLY Layered Config

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Config Group (Repository)" #E8F5E9
  participant "ConfigLoader" as mgr
end box

== CFG-03 APPLY Layered Config ==

user -> iface : POST /config/apply
activate iface
iface -> router : POST /config/apply
activate router
router -> mgr : CFG-03 APPLY Layered Config({global_defaults, project_overrides, env_overrides, cli_args})
activate mgr

alt merge succeeds
  ref over mgr : CFG-03 APPLY Layered Config
    ' Config lifecycle: → SERVING (#E0F7FA)
    ' Owned by: CFG-03 APPLY Layered Config (SM/README.md)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else merge fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
