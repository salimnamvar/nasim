@startuml sq_config03_apply_layered_config
' ============================================================
' Title:     CFG-03 — APPLY Layered Config
' Boundary:  nasim code agent
' Purpose:   Apply layered configuration merging global, project, env, and CLI
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ConfigLoader
' SM States: SERVING (#E0F7FA)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CFG-03 APPLY Layered Config

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "ConfigLoader" as mgr
end box

== CFG-03 APPLY Layered Config ==

user -> iface : CFG-03 APPLY Layered Config({global_defaults, project_overrides, env_overrides, cli_args})
activate iface
iface -> router : CFG-03 APPLY Layered Config({global_defaults, project_overrides, env_overrides, cli_args})
activate router
router -> mgr : CFG-03 APPLY Layered Config({global_defaults, project_overrides, env_overrides, cli_args})
activate mgr

alt merge succeeds
  ref over mgr : CFG-03 APPLY Layered Config <back:#E0F7FA>SERVING</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else merge fails
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "CFG-03_MERGE_ERROR", message: "Layered config merge failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
