@startuml sq_cfg03_apply_layered_config
' ============================================================
' Title:     CFG-03 — APPLY Layered Config
' Boundary:  nasim code agent
' Purpose:   Apply layered configuration merging global, project, env, and CLI
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ConfigAPI -> ConfigManager -> ConfigStore -> ConfigDirectory
' SM States: SERVING (#E0F7FA)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CFG-03 APPLY Layered Config

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ConfigAPI" as api
end box
box "Config Group (Service)" #FFF3E0
  participant "ConfigManager" as mgr
end box
box "Config Group (Repository)" #E8F5E9
  participant "ConfigStore" as store
end box
database "ConfigDirectory" as dir

== CFG-03 APPLY Layered Config ==

user -> router : POST /config/apply
activate router
router -> api : CFG-03 APPLY Layered Config({global_defaults, project_overrides, env_overrides, cli_args})
activate api
api -> mgr : CFG-03 APPLY Layered Config({global_defaults, project_overrides, env_overrides, cli_args})
activate mgr

alt merge succeeds
  mgr -> store : CFG-03 APPLY Layered Config({global_defaults, project_overrides, env_overrides, cli_args})
  activate store
  store -> dir : CFG-03 APPLY Layered Config({global_defaults, project_overrides, env_overrides, cli_args})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : SERVING (#E0F7FA) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else merge fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
