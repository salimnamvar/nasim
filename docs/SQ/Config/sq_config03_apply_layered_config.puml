@startuml sq_cfg03_apply_layered_config
' ============================================================
' Title:     CFG-03 — APPLY Layered Config
' Boundary:  nasim code agent
' Purpose:   Apply layered configuration merging global, project, env, and CLI
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ConfigManager -> ConfigStore -> ConfigDirectory -> FileSystem
' SM States: SERVING (#E0F7FA)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CFG-03 APPLY Layered Config

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Config Group (Service)" #FFF3E0
  participant "ConfigManager" as mgr
end box
box "Config Group (Repository)" #E8F5E9
  participant "ConfigStore" as store
end box
database "ConfigDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== CFG-03 APPLY Layered Config ==

user -> iface : POST /config/apply
activate iface
iface -> router : POST /config/apply
activate router
router -> mgr : CFG-03 APPLY Layered Config({global_defaults, project_overrides, env_overrides, cli_args})
activate mgr

alt merge succeeds
  mgr -> store : CFG-03 APPLY Layered Config({global_defaults, project_overrides, env_overrides, cli_args})
  activate store
  store -> dir : CFG-03 APPLY Layered Config({global_defaults, project_overrides, env_overrides, cli_args})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : SERVING (#E0F7FA) ...
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else merge fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
