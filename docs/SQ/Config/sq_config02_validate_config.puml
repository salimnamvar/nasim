@startuml sq_cfg02_validate_config
' ============================================================
' Title:     CFG-02 — VALIDATE Config
' Boundary:  nasim code agent
' Purpose:   Validate configuration field types and values
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ConfigManager -> ConfigStore -> ConfigDirectory -> FileSystem
' SM States: SERVING (#E0F7FA)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CFG-02 VALIDATE Config

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Config Group (Service)" #FFF3E0
  participant "ConfigManager" as mgr
end box
box "Config Group (Repository)" #E8F5E9
  participant "ConfigStore" as store
end box
database "ConfigDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== CFG-02 VALIDATE Config ==

user -> iface : POST /config/validate
activate iface
iface -> router : POST /config/validate
activate router
router -> mgr : CFG-02 VALIDATE Config({config_object})
activate mgr

alt validation passes
  mgr -> store : CFG-02 VALIDATE Config({config_object})
  activate store
  store -> dir : CFG-02 VALIDATE Config({config_object})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#E0F7FA>SERVING</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
