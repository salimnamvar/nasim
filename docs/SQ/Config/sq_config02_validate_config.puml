@startuml sq_config02_validate_config
' ============================================================
' Title:     CFG-02 — VALIDATE Config
' Boundary:  nasim code agent
' Purpose:   Validate configuration field types and values
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> ConfigLoader
' SM States: SERVING (#E0F7FA)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CFG-02 VALIDATE Config

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "ConfigRepository" as mgr
end box

== CFG-02 VALIDATE Config ==

user -> iface : CFG-02 VALIDATE Config({config_object})
activate iface
iface -> router : CFG-02 VALIDATE Config({config_object})
activate router
router -> mgr : CFG-02 VALIDATE Config({config_object})
activate mgr

alt validation passes
  ref over mgr : CFG-02 VALIDATE Config <back:#E0F7FA>SERVING</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "CFG-02_VALIDATION_ERROR", message: "Config validation failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
