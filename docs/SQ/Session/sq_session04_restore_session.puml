@startuml sq_session04_restore_session
' ============================================================
' Title:     SSN-04 — RESTORE Session
' Boundary:  nasim code agent
' Purpose:   Resume a previous session by loading its history
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionStore -> SessionStorage
' SM States: SAVED (#1565C0), RESTORED (#1E88E5), ACTIVE (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-04 RESTORE Session

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box

database "SessionStorage" as storage

== SSN-04 RESTORE Session ==

user -> iface : POST /sessions/{session_id}:restore
activate iface
iface -> router : POST /sessions/{session_id}:restore
activate router

router -> store : SSN-04 RESTORE Session({session_id})
activate store

alt session_id is empty
    router --> iface : 400 INVALID_ARGUMENT
    iface --> user : 400 Bad Request
    deactivate router
    deactivate iface
end

alt session not found
    store --> router : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate router
    deactivate iface
end

store -> storage : SSN-04 RESTORE Session({session_id})
activate storage

alt disk read error
    storage --> store : IOError
    deactivate storage
    store --> router : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate router
    deactivate iface
end

storage --> store : 200 OK
deactivate storage

ref over store : SSN-04 RESTORE Session
  ' Session lifecycle: SAVED → RESTORED (#1E88E5) → ACTIVE (#43A047)
  ' Owned by: API-03 GET Session (SM/README.md)

store --> router : 200 OK
deactivate store
router --> iface : 200 OK
iface --> user : 200 OK
deactivate router
deactivate iface

@enduml
