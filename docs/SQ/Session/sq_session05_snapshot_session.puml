@startuml sq_session05_snapshot_session
' ============================================================
' Title:     SSN-05 — SNAPSHOT Session
' Boundary:  nasim code agent
' Purpose:   Create a point-in-time snapshot of session state
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SessionAPI -> SessionManager -> SessionStore -> SessionDirectory
' SM States: ACTIVE (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-05 SNAPSHOT Session

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "SessionAPI" as api
end box
box "Session Group (Service)" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

== SSN-05 SNAPSHOT Session ==

user -> router : POST /sessions/{session_id}:snapshot
activate router

router -> api : ssn05 SNAPSHOT Session({session_id})
activate api

alt session_id is empty
    api --> router : 400 INVALID_ARGUMENT
    router --> user : 400 Bad Request
    deactivate api
    deactivate router
    end
end

api -> mgr : ssn05 SNAPSHOT Session({session_id})
activate mgr

mgr -> store : READ Session({session_id})
activate store

break Session not found
    store --> mgr : 404 NOT_FOUND
    mgr --> api : 404 NOT_FOUND
    api --> router : 404 NOT_FOUND
    router --> user : 404 Not Found
    deactivate store
    deactivate mgr
    deactivate api
    deactivate router
    end
end

store --> mgr : 200 OK
deactivate store

mgr -> store : INSERT Snapshot({session_id})
activate store

alt serialization error
    store --> mgr : 500 INTERNAL
    mgr --> api : 500 INTERNAL
    api --> router : 500 INTERNAL
    router --> user : 500 Internal Error
    deactivate store
    deactivate mgr
    deactivate api
    deactivate router
    end
end

store -> dir : INSERT SnapshotFile({session_id}/{snapshot_id}.json)
activate dir

alt disk write error
    dir --> store : IOError
    deactivate dir
    store --> store : rollback
    store --> mgr : 500 INTERNAL
    mgr --> api : 500 INTERNAL
    api --> router : 500 INTERNAL
    router --> user : 500 Internal Error
    deactivate store
    deactivate mgr
    deactivate api
    deactivate router
    end
end

dir --> store : 200 OK
deactivate dir

hnote over store : ACTIVE(#43A047) snapshot point created

store --> mgr : 200 OK — {snapshot_id}
deactivate store
mgr --> api : 200 OK — {snapshot_id}
deactivate mgr
api --> router : 200 OK — {snapshot_id}
deactivate api
router --> user : 200 OK — {snapshot_id}
deactivate router

@enduml
