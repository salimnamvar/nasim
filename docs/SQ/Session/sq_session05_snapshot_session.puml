@startuml sq_session05_snapshot_session
' ============================================================
' Title:     SSN-05 — SNAPSHOT Session
' Boundary:  nasim code agent
' Purpose:   Create a point-in-time snapshot of session state
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionVersioning -> SessionStore -> SessionStorage
' SM States: (no state change — snapshot is versioning operation)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-05 SNAPSHOT Session

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionVersioning" as versioning
  participant "SessionStore" as store
end box

database "SessionStorage" as storage

== SSN-05 SNAPSHOT Session ==

user -> iface : POST /sessions/{session_id}:snapshot
activate iface
iface -> router : POST /sessions/{session_id}:snapshot
activate router

router -> versioning : SSN-05 SNAPSHOT Session({session_id})
activate versioning

alt session_id is empty
    router --> iface : 400 INVALID_ARGUMENT
    iface --> user : 400 Bad Request
    deactivate router
    deactivate iface
end

versioning -> store : SSN-05 SNAPSHOT Session({session_id})
activate store

alt session not found
    store --> versioning : 404 NOT_FOUND
    versioning --> router : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate versioning
    deactivate router
    deactivate iface
end

store -> storage : SSN-05 SNAPSHOT Session({session_id})
activate storage

alt disk read error
    storage --> store : IOError
    deactivate storage
    store --> versioning : 500 INTERNAL
    versioning --> router : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate versioning
    deactivate router
    deactivate iface
end

storage --> store : 200 OK
deactivate storage

store --> versioning : 200 OK — {session_data}
deactivate store

versioning -> storage : SSN-05 SNAPSHOT Session({session_id}, {snapshot_id})
activate storage

alt disk write error
    storage --> versioning : IOError
    deactivate storage
    versioning --> router : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate versioning
    deactivate router
    deactivate iface
end

storage --> versioning : 200 OK
deactivate storage

versioning --> router : 200 OK — {snapshot_id}
deactivate versioning
router --> iface : 200 OK — {snapshot_id}
iface --> user : 200 OK — {snapshot_id}
deactivate router
deactivate iface

@enduml
