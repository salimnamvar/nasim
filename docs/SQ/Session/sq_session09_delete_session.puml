@startuml sq_session09_delete_session
' ============================================================
' Title:     SSN-09 — DELETE Session
' Boundary:  nasim code agent
' Purpose:   Permanently delete a session and its associated data
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionStore -> SessionStorage
' SM States: ACTIVE (#43A047), CLOSED (#757575)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-09 DELETE Session

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box

database "SessionStorage" as storage

== SSN-09 DELETE Session ==

user -> iface : DELETE /sessions/{session_id}
activate iface
iface -> router : DELETE /sessions/{session_id}
activate router

router -> store : SSN-09 DELETE Session({session_id})
activate store

alt session_id is empty
    router --> iface : 400 INVALID_ARGUMENT
    iface --> user : 400 Bad Request
    deactivate router
    deactivate iface
end

alt session not found
    store --> router : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate router
    deactivate iface
end

store -> storage : SSN-09 DELETE Session({session_id})
activate storage

alt permission denied
    storage --> store : PermissionError
    deactivate storage
    store --> router : 403 FORBIDDEN
    router --> iface : 403 Forbidden
    iface --> user : 403 Forbidden
    deactivate store
    deactivate router
    deactivate iface
end

storage --> store : 200 OK — removed
deactivate storage

ref over store : SSN-09 DELETE Session
  ' Session lifecycle: ACTIVE → CLOSED (#757575)
  ' Owned by: API-05 DELETE Session (SM/README.md)

store --> router : 200 OK — delete_confirmed({session_id})
deactivate store
router --> iface : 200 OK — delete_confirmed({session_id})
iface --> user : 200 OK — delete_confirmed({session_id})
deactivate router
deactivate iface

@enduml
