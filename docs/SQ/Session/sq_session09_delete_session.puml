@startuml sq_session09_delete_session
' ============================================================
' Title:     SSN-09 — DELETE Session
' Boundary:  nasim code agent
' Purpose:   Permanently delete a session and its associated data
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionManager -> SessionStore -> SessionDirectory -> FileSystem
' SM States: ACTIVE (#43A047), SAVED (#1565C0), CLOSED (#757575)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-09 DELETE Session

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Session Group (Service)" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== SSN-09 DELETE Session ==

user -> iface : DELETE /sessions/{session_id}
activate iface
iface -> router : DELETE /sessions/{session_id}
activate router

router -> mgr : ssn09 DELETE Session({session_id})

alt session_id is empty
    router --> iface : 400 INVALID_ARGUMENT
    router --> iface : 400 Bad Request
    iface --> user : 400 Bad Request
    deactivate router
    deactivate iface
    end
end

activate mgr

mgr -> store : DELETE Session({session_id})
activate store

break Session not found
    store --> mgr : 404 NOT_FOUND
    mgr --> router : 404 NOT_FOUND
    router --> iface : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate mgr
    deactivate router
    deactivate iface
    end
end

store -> dir : REMOVE SessionFile({session_id}.jsonl)
activate dir

break Permission denied
    dir --> store : PermissionError
    deactivate dir
    store --> mgr : 403 FORBIDDEN
    mgr --> router : 403 FORBIDDEN
    router --> iface : 403 FORBIDDEN
    router --> iface : 403 Forbidden
    iface --> user : 403 Forbidden
    deactivate store
    deactivate mgr
    deactivate router
    deactivate iface
    end
end

dir --> store : 200 OK — removed
deactivate dir

    store -> store : TRANSITION State(<back:#43A047>ACTIVE</back> → <back:#757575>CLOSED</back>)

store --> mgr : 200 OK — delete_confirmed({session_id})
deactivate store
mgr --> router : 200 OK — delete_confirmed({session_id})
deactivate mgr
router --> iface : 200 OK — delete_confirmed({session_id})
iface --> user : 200 OK — delete_confirmed({session_id})
deactivate router
deactivate iface

@enduml
