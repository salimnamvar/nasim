@startuml sq_session09_delete_session
' ============================================================
' Title:     SSN-09 — DELETE Session
' Boundary:  nasim code agent
' Purpose:   Permanently delete a session and its associated data
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SessionAPI -> SessionManager -> SessionStore -> SessionDirectory
' SM States: ACTIVE (#43A047), SAVED (#1565C0), CLOSED (#757575)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-09 DELETE Session

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "SessionAPI" as api
end box
box "Session Group (Service)" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

== SSN-09 DELETE Session ==

user -> router : DELETE /sessions/{session_id}
activate router

router -> api : ssn09 DELETE Session({session_id})
activate api

alt session_id is empty
    api --> router : 400 INVALID_ARGUMENT
    router --> user : 400 Bad Request
    deactivate api
    deactivate router
    end
end

api -> mgr : ssn09 DELETE Session({session_id})
activate mgr

mgr -> store : DELETE Session({session_id})
activate store

break Session not found
    store --> mgr : 404 NOT_FOUND
    mgr --> api : 404 NOT_FOUND
    api --> router : 404 NOT_FOUND
    router --> user : 404 Not Found
    deactivate store
    deactivate mgr
    deactivate api
    deactivate router
    end
end

store -> dir : REMOVE SessionFile({session_id}.jsonl)
activate dir

break Permission denied
    dir --> store : PermissionError
    deactivate dir
    store --> mgr : 403 FORBIDDEN
    mgr --> api : 403 FORBIDDEN
    api --> router : 403 FORBIDDEN
    router --> user : 403 Forbidden
    deactivate store
    deactivate mgr
    deactivate api
    deactivate router
    end
end

dir --> store : 200 OK — removed
deactivate dir

hnote over store : ACTIVE(#43A047) -> CLOSED(#757575)

store --> mgr : 200 OK — delete_confirmed({session_id})
deactivate store
mgr --> api : 200 OK — delete_confirmed({session_id})
deactivate mgr
api --> router : 200 OK — delete_confirmed({session_id})
deactivate api
router --> user : 200 OK — delete_confirmed({session_id})
deactivate router

@enduml
