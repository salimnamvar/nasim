@startuml sq_session06_revert_turn
' ============================================================
' Title:     SSN-06 — REVERT Turn
' Boundary:  nasim code agent
' Purpose:   Restore session to a previous snapshot or turn
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionVersioning -> SessionStore -> SessionStorage
' SM States: (no state change — revert is versioning operation)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-06 REVERT Turn

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionVersioning" as versioning
  participant "SessionStore" as store
end box

database "SessionStorage" as storage

== SSN-06 REVERT Turn ==

user -> iface : POST /sessions/{session_id}:revert
activate iface
iface -> router : POST /sessions/{session_id}:revert
activate router

router -> versioning : SSN-06 REVERT Session({session_id}, {target_turn})
activate versioning

alt session_id is empty
    router --> iface : 400 INVALID_ARGUMENT
    iface --> user : 400 Bad Request
    deactivate router
    deactivate iface
end

versioning -> store : SSN-06 READ Snapshot({session_id}, {target_turn})
activate store

alt session not found
    store --> versioning : 404 NOT_FOUND
    versioning --> router : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate versioning
    deactivate router
    deactivate iface
end

alt snapshot not found
    store --> versioning : 404 NOT_FOUND
    versioning --> router : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate versioning
    deactivate router
    deactivate iface
end

store -> storage : SSN-06 READ Snapshot({session_id}, {target_turn})
activate storage

alt disk read error
    storage --> store : IOError
    deactivate storage
    store --> versioning : 500 INTERNAL
    versioning --> router : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate versioning
    deactivate router
    deactivate iface
end

storage --> store : 200 OK
deactivate storage

store --> versioning : 200 OK — {snapshot_messages}
deactivate store

versioning -> store : SSN-06 UPDATE Session({session_id}, {messages})
activate store

alt update error
    store --> versioning : 500 INTERNAL
    versioning --> router : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate versioning
    deactivate router
    deactivate iface
end

store --> versioning : 200 OK
deactivate store

versioning --> router : 200 OK
deactivate versioning
router --> iface : 200 OK
iface --> user : 200 OK
deactivate router
deactivate iface

@enduml
