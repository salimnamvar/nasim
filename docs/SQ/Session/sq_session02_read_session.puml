@startuml sq_session02_read_session
' ============================================================
' Title:     SSN-02 — READ Session
' Boundary:  nasim code agent
' Purpose:   Load conversation history from disk
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SessionAPI -> SessionManager -> SessionStore -> SessionDirectory
' SM States: SAVED (#1565C0), RESTORED (#1E88E5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-02 READ Session

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "SessionAPI" as api
end box
box "Session Group (Service)" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

== SSN-02 READ Session ==

user -> router : GET /sessions/{session_id}
activate router

router -> api : ssn02 READ Session({session_id})
activate api

alt session_id is empty
    api --> router : 400 INVALID_ARGUMENT
    router --> user : 400 Bad Request
    deactivate api
    deactivate router
    end
end

api -> mgr : ssn02 READ Session({session_id})
activate mgr

mgr -> store : READ Session({session_id})
activate store

break Session not found
    store --> mgr : 404 NOT_FOUND
    mgr --> api : 404 NOT_FOUND
    api --> router : 404 NOT_FOUND
    router --> user : 404 Not Found
    deactivate store
    deactivate mgr
    deactivate api
    deactivate router
    end
end

store -> dir : READ SessionFile({session_id}.jsonl)
activate dir

break Disk read error
    dir --> store : IOError
    deactivate dir
    store --> mgr : 500 INTERNAL
    mgr --> api : 500 INTERNAL
    api --> router : 500 INTERNAL
    router --> user : 500 Internal Error
    deactivate store
    deactivate mgr
    deactivate api
    deactivate router
    end
end

dir --> store : 200 OK
deactivate dir

hnote over store : SAVED(#1565C0) -> RESTORED(#1E88E5)

store --> mgr : 200 OK
deactivate store
mgr --> api : 200 OK
deactivate mgr
api --> router : 200 OK
deactivate api
router --> user : 200 OK
deactivate router

@enduml
