@startuml sq_session02_read_session
' ============================================================
' Title:     SSN-02 — READ Session
' Boundary:  nasim code agent
' Purpose:   Load conversation history from disk
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionManager -> SessionStore -> SessionDirectory -> FileSystem
' SM States: SAVED (#1565C0), RESTORED (#1E88E5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-02 READ Session

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Session Group (Service)" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== SSN-02 READ Session ==

user -> iface : GET /sessions/{session_id}
activate iface
iface -> router : GET /sessions/{session_id}
activate router

router -> mgr : ssn02 READ Session({session_id})

alt session_id is empty
    router --> iface : 400 INVALID_ARGUMENT
    router --> iface : 400 Bad Request
    iface --> user : 400 Bad Request
    deactivate router
    deactivate iface
    end
end

activate mgr

mgr -> store : READ Session({session_id})
activate store

break Session not found
    store --> mgr : 404 NOT_FOUND
    mgr --> router : 404 NOT_FOUND
    router --> iface : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate mgr
    deactivate router
    deactivate iface
    end
end

store -> dir : READ SessionFile({session_id}.jsonl)
activate dir

break Disk read error
    dir --> store : IOError
    deactivate dir
    store --> mgr : 500 INTERNAL
    mgr --> router : 500 INTERNAL
    router --> iface : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate mgr
    deactivate router
    deactivate iface
    end
end

dir --> store : 200 OK
deactivate dir

hnote over store : SAVED(#1565C0) -> RESTORED(#1E88E5)

store --> mgr : 200 OK
deactivate store
mgr --> router : 200 OK
deactivate mgr
router --> iface : 200 OK
router --> iface : 200 OK
iface --> user : 200 OK
deactivate router
deactivate iface

@enduml
