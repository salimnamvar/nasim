@startuml sq_session02_read_session
' ============================================================
' Title:     SSN-02 — READ Session
' Boundary:  nasim code agent
' Purpose:   Load conversation history from disk
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionStore -> SessionStorage
' SM States: SAVED (#1565C0), RESTORED (#1E88E5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-02 READ Session

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionStore" as store
end box

database "SessionStorage" as storage

== SSN-02 READ Session ==

user -> iface : GET /sessions/{session_id}
activate iface
iface -> router : GET /sessions/{session_id}
activate router

router -> store : SSN-02 READ Session({session_id})
activate store

alt session_id is empty
    router --> iface : 400 INVALID_ARGUMENT
    iface --> user : 400 Bad Request
    deactivate router
    deactivate iface
end

alt session not found
    store --> router : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate router
    deactivate iface
end

store -> storage : SSN-02 READ Session({session_id})
activate storage

alt disk read error
    storage --> store : IOError
    deactivate storage
    store --> router : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate router
    deactivate iface
end

storage --> store : 200 OK
deactivate storage

ref over store : SSN-02 READ Session
  ' Session lifecycle: SAVED → RESTORED (#1E88E5)
  ' Owned by: API-03 GET Session (SM/README.md)

store --> router : 200 OK
deactivate store
router --> iface : 200 OK
iface --> user : 200 OK
deactivate router
deactivate iface

@enduml
