@startuml sq_session07_search_sessions
' ============================================================
' Title:     SSN-07 — SEARCH Sessions
' Boundary:  nasim code agent
' Purpose:   Full-text search across session history
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SessionAPI -> SessionManager -> SessionStore -> SessionDirectory
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-07 SEARCH Sessions

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "SessionAPI" as api
end box
box "Session Group (Service)" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

== SSN-07 SEARCH Sessions ==

user -> router : GET /sessions:search?q={query}
activate router

router -> api : ssn07 SEARCH Sessions({query}, {page_size}, {page_token})
activate api

api -> mgr : ssn07 SEARCH Sessions({query}, {page_size}, {page_token})
activate mgr

mgr -> store : SEARCH Sessions({query}, {page_size}, {page_token})
activate store

store -> dir : QUERY Index({query})
activate dir

alt Index not available
    dir --> store : IndexError
    deactivate dir
    store -> store : ssn07 SEARCH Sessions({query}, fallback)
    store --> mgr : 200 OK — [{session_id, snippet, score}]
    mgr --> api : 200 OK — [{session_id, snippet, score}]
    api --> router : 200 OK — [{session_id, snippet, score}]
    router --> user : 200 OK — [{session_id, snippet, score}]
    deactivate store
    deactivate mgr
    deactivate api
    deactivate router
    end
end

dir --> store : 200 OK — [{session_id, snippet, rank}]
deactivate dir

store --> mgr : 200 OK — [{session_id, snippet, score}]
deactivate store
mgr --> api : 200 OK — [{session_id, snippet, score}]
deactivate mgr
api --> router : 200 OK — [{session_id, snippet, score}]
deactivate api
router --> user : 200 OK — [{session_id, snippet, score}]
deactivate router

@enduml
