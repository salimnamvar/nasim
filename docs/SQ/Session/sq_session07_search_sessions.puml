@startuml sq_session07_search_sessions
' ============================================================
' Title:     SSN-07 — SEARCH Sessions
' Boundary:  nasim code agent
' Purpose:   Full-text search across session history
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionSearch -> SessionStorage
' SM States: (no state change — read-only search)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-07 SEARCH Sessions

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "SessionService" as svc
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionSearch" as search
end box

database "SessionStorage" as storage

== SSN-07 SEARCH Sessions ==

user -> iface : GET /sessions:search?q={query}
activate iface
iface -> router : GET /sessions:search?q={query}
activate router

router -> svc : SSN-07 SEARCH Sessions({query}, {page_size}, {page_token})
activate svc
svc -> search : SSN-07 SEARCH Sessions({query}, {page_size}, {page_token})
activate search

search -> storage : SSN-07 SEARCH Sessions({query}, {page_size}, {page_token})
activate storage

alt index not available
    storage --> search : IndexError
    deactivate storage
    search -> storage : SSN-07 SEARCH Sessions({query}, fallback)
    activate storage
    storage --> search : 200 OK — [{session_id, snippet, score}]
    deactivate storage
    search --> svc : 200 OK — [{session_id, snippet, score}]
    deactivate search
    svc --> router : 200 OK — [{session_id, snippet, score}]
    deactivate svc
    router --> iface : 200 OK — [{session_id, snippet, score}]
    iface --> user : 200 OK — [{session_id, snippet, score}]
    deactivate router
    deactivate iface
end

storage --> search : 200 OK — [{session_id, snippet, rank}]
deactivate storage

search --> svc : 200 OK — [{session_id, snippet, score}]
deactivate search
svc --> router : 200 OK — [{session_id, snippet, score}]
deactivate svc
router --> iface : 200 OK — [{session_id, snippet, score}]
iface --> user : 200 OK — [{session_id, snippet, score}]
deactivate router
deactivate iface

@enduml
