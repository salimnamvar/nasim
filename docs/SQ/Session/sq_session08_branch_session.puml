@startuml sq_session08_branch_session
' ============================================================
' Title:     SSN-08 — BRANCH Session
' Boundary:  nasim code agent
' Purpose:   Fork session into a new branch for parallel exploration
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SessionAPI -> SessionManager -> SessionStore -> SessionDirectory
' SM States: ACTIVE (#43A047), BRANCHED (#7B1FA2)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-08 BRANCH Session

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "SessionAPI" as api
end box
box "Session Group (Service)" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

== SSN-08 BRANCH Session ==

user -> router : POST /sessions/{session_id}:branch
activate router

router -> api : ssn08 BRANCH Session({session_id}, {from_turn})
activate api

alt session_id is empty
    api --> router : 400 INVALID_ARGUMENT
    router --> user : 400 Bad Request
    deactivate api
    deactivate router
    end
end

api -> mgr : ssn08 BRANCH Session({session_id}, {from_turn})
activate mgr

mgr -> store : READ Session({session_id})
activate store

break Session not found
    store --> mgr : 404 NOT_FOUND
    mgr --> api : 404 NOT_FOUND
    api --> router : 404 NOT_FOUND
    router --> user : 404 Not Found
    deactivate store
    deactivate mgr
    deactivate api
    deactivate router
    end
end

store --> mgr : 200 OK — {session_data}
deactivate store

hnote over mgr : ACTIVE(#43A047) -> BRANCHED(#7B1FA2)

mgr -> store : INSERT BranchSession({session_id}, {branch_id}, {from_turn})
activate store

alt Copy failure
    store --> mgr : 500 INTERNAL
    mgr --> api : 500 INTERNAL
    api --> router : 500 INTERNAL
    router --> user : 500 Internal Error
    deactivate store
    deactivate mgr
    deactivate api
    deactivate router
    end
end

store -> dir : INSERT SessionFile({branch_id}.jsonl)
activate dir

alt Disk write error
    dir --> store : IOError
    deactivate dir
    store --> store : rollback
    store --> mgr : 500 INTERNAL
    mgr --> api : 500 INTERNAL
    api --> router : 500 INTERNAL
    router --> user : 500 Internal Error
    deactivate store
    deactivate mgr
    deactivate api
    deactivate router
    end
end

dir --> store : 200 OK
deactivate dir

store --> mgr : 200 OK — {branch_id}
deactivate store
mgr --> api : 200 OK — {branch_id}
deactivate mgr
api --> router : 200 OK — {branch_id}
deactivate api
router --> user : 200 OK — {branch_id}
deactivate router

@enduml
