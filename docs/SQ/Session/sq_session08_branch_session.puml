@startuml sq_session08_branch_session
' ============================================================
' Title:     SSN-08 — BRANCH Session
' Boundary:  nasim code agent
' Purpose:   Fork session into a new branch for parallel exploration
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionManager -> SessionStore -> SessionDirectory -> FileSystem
' SM States: ACTIVE (#43A047), BRANCHED (#7B1FA2)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-08 BRANCH Session

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Session Group (Service)" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== SSN-08 BRANCH Session ==

user -> iface : POST /sessions/{session_id}:branch
activate iface
iface -> router : POST /sessions/{session_id}:branch
activate router

router -> mgr : ssn08 BRANCH Session({session_id}, {from_turn})

alt session_id is empty
    router --> iface : 400 INVALID_ARGUMENT
    router --> iface : 400 Bad Request
    iface --> user : 400 Bad Request
    deactivate router
    deactivate iface
    end
end

activate mgr

mgr -> store : READ Session({session_id})
activate store

break Session not found
    store --> mgr : 404 NOT_FOUND
    mgr --> router : 404 NOT_FOUND
    router --> iface : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate mgr
    deactivate router
    deactivate iface
    end
end

store --> mgr : 200 OK — {session_data}
deactivate store

hnote over mgr : ACTIVE(#43A047) -> BRANCHED(#7B1FA2)

mgr -> store : INSERT BranchSession({session_id}, {branch_id}, {from_turn})
activate store

alt Copy failure
    store --> mgr : 500 INTERNAL
    mgr --> router : 500 INTERNAL
    router --> iface : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate mgr
    deactivate router
    deactivate iface
    end
end

store -> dir : INSERT SessionFile({branch_id}.jsonl)
activate dir

alt Disk write error
    dir --> store : IOError
    deactivate dir
    store --> store : rollback
    store --> mgr : 500 INTERNAL
    mgr --> router : 500 INTERNAL
    router --> iface : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate mgr
    deactivate router
    deactivate iface
    end
end

dir --> store : 200 OK
deactivate dir

store --> mgr : 200 OK — {branch_id}
deactivate store
mgr --> router : 200 OK — {branch_id}
deactivate mgr
router --> iface : 200 OK — {branch_id}
router --> iface : 200 OK — {branch_id}
iface --> user : 200 OK — {branch_id}
deactivate router
deactivate iface

@enduml
