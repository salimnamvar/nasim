@startuml sq_session03_list_sessions
' ============================================================
' Title:     SSN-03 — LIST Sessions
' Boundary:  nasim code agent
' Purpose:   List available saved sessions
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SessionAPI -> SessionManager -> SessionStore -> SessionDirectory
' SM States: SAVED (#1565C0)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-03 LIST Sessions

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "SessionAPI" as api
end box
box "Session Group (Service)" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

== SSN-03 LIST Sessions ==

user -> router : GET /sessions
activate router

router -> api : ssn03 LIST Sessions({page_size}, {page_token})
activate api

api -> mgr : ssn03 LIST Sessions({page_size}, {page_token})
activate mgr

mgr -> store : LIST Sessions({page_size}, {page_token})
activate store

store -> dir : SCAN SessionDirectory({pattern})
activate dir

alt Directory not found
    dir --> store : FileNotFoundError
    deactivate dir
    store --> mgr : 200 OK — [] (empty list)
    mgr --> api : 200 OK — [] (empty list)
    api --> router : 200 OK — [] (empty list)
    router --> user : 200 OK — [] (empty list)
    deactivate store
    deactivate mgr
    deactivate api
    deactivate router
    end
end

dir --> store : 200 OK — [{session_id, created_at, message_count}]
deactivate dir

store --> mgr : 200 OK — [{session_id, created_at, message_count}]
deactivate store
mgr --> api : 200 OK — [{session_id, created_at, message_count}]
deactivate mgr
api --> router : 200 OK — [{session_id, created_at, message_count}]
deactivate api
router --> user : 200 OK — [{session_id, created_at, message_count}]
deactivate router

@enduml
