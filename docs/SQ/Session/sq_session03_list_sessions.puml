@startuml sq_session03_list_sessions
' ============================================================
' Title:     SSN-03 — LIST Sessions
' Boundary:  nasim code agent
' Purpose:   List available saved sessions
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> SessionService -> SessionStore
' SM States: (no state change — read-only)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-03 LIST Sessions

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "SessionService" as svc
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionService" as store
end box

database "SessionStore" as storage

== SSN-03 LIST Sessions ==

user -> iface : GET /sessions
activate iface
iface -> router : GET /sessions
activate router

router -> svc : SSN-03 LIST Sessions({page_size}, {page_token})
activate svc
svc -> store : SSN-03 LIST Sessions({page_size}, {page_token})
activate store

store -> storage : SSN-03 LIST Sessions({page_size}, {page_token})
activate storage

alt directory not found
    storage --> store : FileNotFoundError
    deactivate storage
    store --> svc : 200 OK — [] (empty list)
    svc --> router : 200 OK — [] (empty list)
    router --> iface : 200 OK — [] (empty list)
    iface --> user : 200 OK — [] (empty list)
    deactivate store
    deactivate svc
    deactivate router
    deactivate iface
end

storage --> store : 200 OK — [{session_id, created_at, message_count}]
deactivate storage

store --> svc : 200 OK — [{session_id, created_at, message_count}]
deactivate store
svc --> router : 200 OK — [{session_id, created_at, message_count}]
deactivate svc
router --> iface : 200 OK — [{session_id, created_at, message_count}]
iface --> user : 200 OK — [{session_id, created_at, message_count}]
deactivate router
deactivate iface

@enduml
