@startuml sq_session03_list_sessions
' ============================================================
' Title:     SSN-03 — LIST Sessions
' Boundary:  nasim code agent
' Purpose:   List available saved sessions
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionStore -> SessionStorage
' SM States: (no state change — read-only)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-03 LIST Sessions

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionStore" as store
end box

database "SessionStorage" as storage

== SSN-03 LIST Sessions ==

user -> iface : GET /sessions
activate iface
iface -> router : GET /sessions
activate router

router -> store : SSN-03 LIST Sessions({page_size}, {page_token})
activate store

store -> storage : SSN-03 LIST Sessions({page_size}, {page_token})
activate storage

alt directory not found
    storage --> store : FileNotFoundError
    deactivate storage
    store --> router : 200 OK — [] (empty list)
    router --> iface : 200 OK — [] (empty list)
    iface --> user : 200 OK — [] (empty list)
    deactivate store
    deactivate router
    deactivate iface
end

storage --> store : 200 OK — [{session_id, created_at, message_count}]
deactivate storage

store --> router : 200 OK — [{session_id, created_at, message_count}]
deactivate store
router --> iface : 200 OK — [{session_id, created_at, message_count}]
iface --> user : 200 OK — [{session_id, created_at, message_count}]
deactivate router
deactivate iface

@enduml
