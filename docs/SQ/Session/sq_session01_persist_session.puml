@startuml sq_session01_persist_session
' ============================================================
' Title:     SSN-01 — PERSIST Session
' Boundary:  nasim code agent
' Purpose:   Persist session messages to disk via SessionStore
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionManager -> SessionStore -> SessionDirectory -> FileSystem
' SM States: ACTIVE (#43A047), SAVED (#2E7D32)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SSN-01 PERSIST Session

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Session Group (Service)" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== SSN-01 PERSIST Session ==

user -> iface : POST /sessions/{session_id}:persist
activate iface
iface -> router : POST /sessions/{session_id}:persist
activate router

router -> mgr : ssn01 PERSIST Session({session_id})

alt session_id is empty
    router --> iface : 400 INVALID_ARGUMENT
    router --> iface : 400 Bad Request
    iface --> user : 400 Bad Request
    deactivate router
    deactivate iface
    end
end

activate mgr

mgr -> store : READ Session({session_id})
activate store

break Session not found
    store --> mgr : 404 NOT_FOUND
    mgr --> router : 404 NOT_FOUND
    router --> iface : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate mgr
    deactivate router
    deactivate iface
    end
end

store --> mgr : 200 OK
deactivate store

mgr -> store : INSERT SessionSnapshot({session_id}, {messages})
activate store

alt serialization error
    store --> mgr : 500 INTERNAL
    mgr --> router : 500 INTERNAL
    router --> iface : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate mgr
    deactivate router
    deactivate iface
    end
end

store -> dir : INSERT SessionFile({session_id}.jsonl)
activate dir

alt disk write error
    dir --> store : IOError
    deactivate dir
    store --> store : rollback
    store --> mgr : 500 INTERNAL
    mgr --> router : 500 INTERNAL
    router --> iface : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate mgr
    deactivate router
    deactivate iface
    end
end

dir --> store : 200 OK
deactivate dir

    store -> store : TRANSITION State(<back:#43A047>ACTIVE</back> → <back:#2E7D32>SAVED</back>)

store --> mgr : 200 OK
deactivate store
mgr --> router : 200 OK
deactivate mgr
router --> iface : 200 OK
iface --> user : 200 OK
deactivate router
deactivate iface

@enduml
