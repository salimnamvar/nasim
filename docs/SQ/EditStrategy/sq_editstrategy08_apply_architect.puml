@startuml sq_editstrategy08_apply_architect
' ============================================================
' Title:     EDT-08 — APPLY Architect
' Boundary:  nasim code agent
' Purpose:   Apply an architect-level structural edit
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ArchitectCoder
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-08 APPLY Architect

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "ArchitectCoder" as coder
end box

== EDT-08 APPLY Architect ==

user -> iface : EDT-08 APPLY Architect({file_path, structural_changes})
activate iface
iface -> router : EDT-08 APPLY Architect({file_path, structural_changes})
activate router
router -> coder : EDT-08 APPLY Architect({file_path, structural_changes})
activate coder

alt validation succeeds
  ref over coder : EDT-08 APPLY Architect <back:#B2DFDB>TOOL_EXEC</back>
  coder --> router : 200 OK
  deactivate coder
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  coder --> router : {error: {code: "EDT-08_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate coder
  router --> iface : {error: {code: "EDT-08_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  iface --> user : {error: {code: "EDT-08_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
