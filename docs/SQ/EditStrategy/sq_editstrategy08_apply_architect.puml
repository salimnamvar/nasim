@startuml sq_edt08_apply_architect
' ============================================================
' Title:     EDT-08 — APPLY Architect
' Boundary:  nasim code agent
' Purpose:   Apply an architect-level structural edit
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> EditAPI -> EditManager -> EditStore -> EditDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-08 APPLY Architect

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "EditAPI" as api
end box
box "Edit Strategy Group (Service)" #FFF3E0
  participant "EditManager" as mgr
end box
box "Edit Strategy Group (Repository)" #E8F5E9
  participant "EditStore" as store
end box
database "EditDirectory" as dir

== EDT-08 APPLY Architect ==

user -> router : POST /editstrategy/architect
activate router
router -> api : EDT-08 APPLY Architect({file_path, structural_changes})
activate api
api -> mgr : EDT-08 APPLY Architect({file_path, structural_changes})
activate mgr

alt validation succeedt
  mgr -> store : EDT-08 APPLY Architect({file_path, structural_changes})
  activate store
  store -> dir : EDT-08 APPLY Architect({file_path, structural_changes})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : TOOL_EXEC (#B2DFDB) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
