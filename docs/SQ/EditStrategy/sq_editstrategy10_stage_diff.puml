@startuml sq_editstrategy10_stage_diff
' ============================================================
' Title:     EDT-10 — STAGE Diff
' Boundary:  nasim code agent
' Purpose:   Stage a computed diff for user review and approval
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EditStrategyManager
' SM States: EMPTY (#9FA8DA), STAGING (#FFE082), STAGED (#C5E1A5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-10 STAGE Diff

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "EditStrategyManager" as mgr
end box

== EDT-10 STAGE Diff ==

user -> iface : EDT-10 STAGE Diff({file_path, diff_content})
activate iface
iface -> router : EDT-10 STAGE Diff({file_path, diff_content})
activate router
router -> mgr : EDT-10 STAGE Diff({file_path, diff_content})
activate mgr

alt validation succeeds
  ref over mgr : EDT-10 STAGE Diff <back:#FFE082>STAGING</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  ref over mgr : EDT-10 STAGE Diff <back:#9FA8DA>EMPTY</back>
  mgr --> router : {error: {code: "EDT-10_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate mgr
  router --> iface : {error: {code: "EDT-10_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  iface --> user : {error: {code: "EDT-10_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
