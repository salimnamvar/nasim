@startuml sq_edt10_stage_diff
' ============================================================
' Title:     EDT-10 — STAGE Diff
' Boundary:  nasim code agent
' Purpose:   Stage a computed diff for user review and approval
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> EditAPI -> EditManager -> EditStore -> EditDirectory
' SM States: EMPTY (#9FA8DA), STAGING (#FFE082), STAGED (#C5E1A5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-10 STAGE Diff

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "EditAPI" as api
end box
box "Edit Strategy Group (Service)" #FFF3E0
  participant "EditManager" as mgr
end box
box "Edit Strategy Group (Repository)" #E8F5E9
  participant "EditStore" as store
end box
database "EditDirectory" as dir

== EDT-10 STAGE Diff ==

user -> router : POST /editstrategy/stage-diff
activate router
router -> api : EDT-10 STAGE Diff({file_path, diff_content})
activate api
api -> mgr : EDT-10 STAGE Diff({file_path, diff_content})
activate mgr

alt validation succeedt
  mgr -> store : EDT-10 STAGE Diff({file_path, diff_content})
  activate store
  store -> dir : EDT-10 STAGE Diff({file_path, diff_content})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : STAGING (#FFE082) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  ... hnote over mgr : EMPTY (#9FA8DA) ...
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
