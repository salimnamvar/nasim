@startuml sq_editstrategy10_stage_diff
' ============================================================
' Title:     EDT-10 — STAGE Diff
' Boundary:  nasim code agent
' Purpose:   Stage a computed diff for user review and approval
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EditStrategyManager
' SM States: EMPTY (#9FA8DA), STAGING (#FFE082), STAGED (#C5E1A5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-10 STAGE Diff

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "EditStrategy Group" #FFF3E0
  participant "EditStrategyManager" as mgr
end box

== EDT-10 STAGE Diff ==

user -> iface : POST /editstrategy/stage-diff
activate iface
iface -> router : POST /editstrategy/stage-diff
activate router
router -> mgr : EDT-10 STAGE Diff({file_path, diff_content})
activate mgr

alt validation succeeds
  ref over mgr : TRANSITION State(<back:#FFE082>STAGING</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  ref over mgr : TRANSITION State(<back:#9FA8DA>EMPTY</back>)
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
