@startuml sq_edt02_apply_search_replace
' ============================================================
' Title:     EDT-02 — APPLY Search-Replace
' Boundary:  nasim code agent
' Purpose:   Apply a search-and-replace edit to a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SearchReplaceCoder
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-02 APPLY Search-Replace

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "EditStrategy Group" #FFF3E0
  participant "SearchReplaceCoder" as coder
end box

== EDT-02 APPLY Search-Replace ==

user -> iface : POST /editstrategy/search-replace
activate iface
iface -> router : POST /editstrategy/search-replace
activate router
router -> coder : EDT-02 APPLY Search-Replace({file_path, old_text, new_text})
activate coder

alt validation succeeds
  ref over coder : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  coder --> router : 200 OK
  deactivate coder
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  coder --> router : 422 Unprocessable
  deactivate coder
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
