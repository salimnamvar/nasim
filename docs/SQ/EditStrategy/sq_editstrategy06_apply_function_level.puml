@startuml sq_editstrategy06_apply_function_level
' ============================================================
' Title:     EDT-06 — APPLY Function-Level
' Boundary:  nasim code agent
' Purpose:   Apply a function-level edit to a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> FunctionLevelCoder
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-06 APPLY Function-Level

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "FunctionLevelCoder" as coder
end box

== EDT-06 APPLY Function-Level ==

user -> iface : POST /editstrategy/function-level
activate iface
iface -> router : POST /editstrategy/function-level
activate router
router -> coder : EDT-06 APPLY Function-Level({file_path, function_name, new_body})
activate coder

alt validation succeeds
  ref over coder : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  coder --> router : 200 OK
  deactivate coder
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  coder --> router : 422 Unprocessable
  deactivate coder
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
