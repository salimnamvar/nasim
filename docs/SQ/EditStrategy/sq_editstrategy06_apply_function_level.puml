@startuml sq_editstrategy06_apply_function_level
' ============================================================
' Title:     EDITSTRATEGY-06 — APPLY Function-Level
' Boundary:  nasim code agent
' Purpose:   Apply a function-level edit to a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> EditStrategyRepository
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDITSTRATEGY-06 APPLY Function-Level

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "EditStrategyRepository" as coder
end box

== EDITSTRATEGY-06 APPLY Function-Level ==

user -> iface : EDITSTRATEGY-06 APPLY Function-Level({file_path, function_name, new_body})
activate iface
iface -> router : EDITSTRATEGY-06 APPLY Function-Level({file_path, function_name, new_body})
activate router
router -> coder : EDITSTRATEGY-06 APPLY Function-Level({file_path, function_name, new_body})
activate coder

alt validation succeeds
  ref over coder : EDITSTRATEGY-06 APPLY Function-Level <back:#B2DFDB>TOOL_EXEC</back>
  coder --> router : 200 OK
  deactivate coder
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  coder --> router : {error: {code: "EDITSTRATEGY-06_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate coder
  router --> iface : {error: {code: "EDITSTRATEGY-06_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  iface --> user : {error: {code: "EDITSTRATEGY-06_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
