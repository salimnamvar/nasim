@startuml sq_editstrategy05_apply_fenced_block
' ============================================================
' Title:     EDT-05 — APPLY Fenced Block
' Boundary:  nasim code agent
' Purpose:   Apply a fenced code-block edit to a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> FencedBlockCoder
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-05 APPLY Fenced Block

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "EditStrategy Group" #FFF3E0
  participant "FencedBlockCoder" as coder
end box

== EDT-05 APPLY Fenced Block ==

user -> iface : POST /editstrategy/fenced-block
activate iface
iface -> router : POST /editstrategy/fenced-block
activate router
router -> coder : EDT-05 APPLY Fenced Block({file_path, block_language, block_content})
activate coder

alt validation succeeds
  ref over coder : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  coder --> router : 200 OK
  deactivate coder
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  coder --> router : 422 Unprocessable
  deactivate coder
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
