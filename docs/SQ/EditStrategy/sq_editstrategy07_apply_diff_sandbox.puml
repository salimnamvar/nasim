@startuml sq_edt07_apply_diff_sandbox
' ============================================================
' Title:     EDT-07 — APPLY Diff Sandbox
' Boundary:  nasim code agent
' Purpose:   Apply an edit inside a sandboxed diff workspace
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> EditAPI -> EditManager -> EditStore -> EditDirectory
' SM States: STAGING (#F1F8E9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-07 APPLY Diff Sandbox

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "EditAPI" as api
end box
box "Edit Strategy Group (Service)" #FFF3E0
  participant "EditManager" as mgr
end box
box "Edit Strategy Group (Repository)" #E8F5E9
  participant "EditStore" as store
end box
database "EditDirectory" as dir

== EDT-07 APPLY Diff Sandbox ==

user -> router : POST /editstrategy/diff-sandbox
activate router
router -> api : EDT-07 APPLY Diff Sandbox({file_path, edit_content})
activate api
api -> mgr : EDT-07 APPLY Diff Sandbox({file_path, edit_content})
activate mgr

alt validation succeedt
  mgr -> store : EDT-07 APPLY Diff Sandbox({file_path, edit_content})
  activate store
  store -> dir : EDT-07 APPLY Diff Sandbox({file_path, edit_content})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : STAGING (#F1F8E9) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
