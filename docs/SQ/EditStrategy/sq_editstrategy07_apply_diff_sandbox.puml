@startuml sq_edt07_apply_diff_sandbox
' ============================================================
' Title:     EDT-07 — APPLY Diff Sandbox
' Boundary:  nasim code agent
' Purpose:   Apply an edit inside a sandboxed diff workspace
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EditstrategyManager -> EditstrategyStore -> EditstrategyDirectory -> FileSystem
' SM States: STAGING (#F1F8E9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-07 APPLY Diff Sandbox

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Edit Strategy Group (Service)" #FFF3E0
  participant "EditManager" as mgr
end box
box "Edit Strategy Group (Repository)" #E8F5E9
  participant "EditStore" as store
end box
database "EditDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== EDT-07 APPLY Diff Sandbox ==

user -> iface : POST /editstrategy/diff-sandbox
activate iface
iface -> router : POST /editstrategy/diff-sandbox
activate router
router -> mgr : EDT-07 APPLY Diff Sandbox({file_path, edit_content})
activate mgr

alt validation succeedt
  mgr -> store : EDT-07 APPLY Diff Sandbox({file_path, edit_content})
  activate store
  store -> dir : EDT-07 APPLY Diff Sandbox({file_path, edit_content})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : STAGING (#F1F8E9) ...
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
