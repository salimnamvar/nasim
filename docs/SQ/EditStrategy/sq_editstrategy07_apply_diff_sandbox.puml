@startuml sq_editstrategy07_apply_diff_sandbox
' ============================================================
' Title:     EDT-07 — APPLY Diff Sandbox
' Boundary:  nasim code agent
' Purpose:   Apply an edit inside a sandboxed diff workspace
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> DiffSandboxCoder
' SM States: STAGING (#F1F8E9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-07 APPLY Diff Sandbox

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "DiffSandboxCoder" as coder
end box

== EDT-07 APPLY Diff Sandbox ==

user -> iface : POST /editstrategy/diff-sandbox
activate iface
iface -> router : POST /editstrategy/diff-sandbox
activate router
router -> coder : EDT-07 APPLY Diff Sandbox({file_path, edit_content})
activate coder

alt validation succeeds
  ref over coder : TRANSITION State(<back:#F1F8E9>STAGING</back>)
  coder --> router : 200 OK
  deactivate coder
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  coder --> router : 422 Unprocessable
  deactivate coder
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
