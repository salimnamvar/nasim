@startuml sq_editstrategy01_select_strategy
' ============================================================
' Title:     EDT-01 — SELECT Strategy
' Boundary:  nasim code agent
' Purpose:   Choose optimal edit format for the target model
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> StrategySelector
' SM States: THINKING (#D7CCC8)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-01 SELECT Strategy

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "EditStrategy Group" #FFF3E0
  participant "StrategySelector" as sel
end box

== EDT-01 SELECT Strategy ==

user -> iface : GET /editstrategy/strategy
activate iface
iface -> router : GET /editstrategy/strategy
activate router
router -> sel : EDT-01 SELECT Strategy({file_path, edit_description, model_id})
activate sel

alt strategy found
  ref over sel : TRANSITION State(<back:#D7CCC8>THINKING</back>)
  sel --> router : 200 OK
  deactivate sel
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else strategy not found
  sel --> router : 404 Not Found
  deactivate sel
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
