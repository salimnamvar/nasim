@startuml sq_edt01_select_strategy
' ============================================================
' Title:     EDT-01 — SELECT Strategy
' Boundary:  nasim code agent
' Purpose:   Choose optimal edit format for the target model
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EditstrategyManager -> EditstrategyStore -> EditstrategyDirectory -> FileSystem
' SM States: THINKING (#D7CCC8)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-01 SELECT Strategy

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Edit Strategy Group (Service)" #FFF3E0
  participant "EditManager" as mgr
end box
box "Edit Strategy Group (Repository)" #E8F5E9
  participant "EditStore" as store
end box
database "EditDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== EDT-01 SELECT Strategy ==

user -> iface : GET /editstrategy/strategy
activate iface
iface -> router : GET /editstrategy/strategy
activate router
router -> mgr : EDT-01 SELECT Strategy({file_path, edit_description, model_id})
activate mgr

alt strategy found
  mgr -> store : EDT-01 SELECT Strategy({file_path, edit_description, model_id})
  activate store
  store -> dir : EDT-01 SELECT Strategy({file_path, edit_description, model_id})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : THINKING (#D7CCC8) ...
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else strategy not found
  mgr --> router : 404 Not Found
  deactivate mgr
  router --> iface : 404 Not Found
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
