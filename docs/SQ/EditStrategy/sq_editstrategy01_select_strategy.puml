@startuml sq_edt01_select_strategy
' ============================================================
' Title:     EDT-01 — SELECT Strategy
' Boundary:  nasim code agent
' Purpose:   Choose optimal edit format for the target model
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> EditAPI -> EditManager -> EditStore -> EditDirectory
' SM States: THINKING (#D7CCC8)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-01 SELECT Strategy

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "EditAPI" as api
end box
box "Edit Strategy Group (Service)" #FFF3E0
  participant "EditManager" as mgr
end box
box "Edit Strategy Group (Repository)" #E8F5E9
  participant "EditStore" as store
end box
database "EditDirectory" as dir

== EDT-01 SELECT Strategy ==

user -> router : GET /editstrategy/strategy
activate router
router -> api : EDT-01 SELECT Strategy({file_path, edit_description, model_id})
activate api
api -> mgr : EDT-01 SELECT Strategy({file_path, edit_description, model_id})
activate mgr

alt strategy found
  mgr -> store : EDT-01 SELECT Strategy({file_path, edit_description, model_id})
  activate store
  store -> dir : EDT-01 SELECT Strategy({file_path, edit_description, model_id})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : THINKING (#D7CCC8) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else strategy not found
  mgr --> api : 404 Not Found
  deactivate mgr
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end

@enduml
