@startuml sq_edt04_apply_unified_diff
' ============================================================
' Title:     EDT-04 — APPLY Unified Diff
' Boundary:  nasim code agent
' Purpose:   Apply a unified-diff patch to a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> UnifiedDiffCoder
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-04 APPLY Unified Diff

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "EditStrategy Group" #FFF3E0
  participant "UnifiedDiffCoder" as coder
end box

== EDT-04 APPLY Unified Diff ==

user -> iface : POST /editstrategy/unified-diff
activate iface
iface -> router : POST /editstrategy/unified-diff
activate router
router -> coder : EDT-04 APPLY Unified Diff({file_path, diff_content})
activate coder

alt validation succeeds
  ref over coder : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  coder --> router : 200 OK
  deactivate coder
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  coder --> router : 422 Unprocessable
  deactivate coder
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
