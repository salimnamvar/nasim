@startuml sq_editstrategy04_apply_unified_diff
' ============================================================
' Title:     EDT-04 — APPLY Unified Diff
' Boundary:  nasim code agent
' Purpose:   Apply a unified-diff patch to a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> UnifiedDiffCoder
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-04 APPLY Unified Diff

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "UnifiedDiffCoder" as coder
end box

== EDT-04 APPLY Unified Diff ==

user -> iface : EDT-04 APPLY Unified Diff({file_path, diff_content})
activate iface
iface -> router : EDT-04 APPLY Unified Diff({file_path, diff_content})
activate router
router -> coder : EDT-04 APPLY Unified Diff({file_path, diff_content})
activate coder

alt validation succeeds
  ref over coder : EDT-04 APPLY Unified Diff <back:#B2DFDB>TOOL_EXEC</back>
  coder --> router : 200 OK
  deactivate coder
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  coder --> router : {error: {code: "EDT-04_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate coder
  router --> iface : {error: {code: "EDT-04_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  iface --> user : {error: {code: "EDT-04_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
