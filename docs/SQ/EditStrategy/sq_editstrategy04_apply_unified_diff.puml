@startuml sq_edt04_apply_unified_diff
' ============================================================
' Title:     EDT-04 — APPLY Unified Diff
' Boundary:  nasim code agent
' Purpose:   Apply a unified-diff patch to a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EditstrategyManager -> EditstrategyStore -> EditstrategyDirectory -> FileSystem
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-04 APPLY Unified Diff

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Edit Strategy Group (Service)" #FFF3E0
  participant "EditManager" as mgr
end box
box "Edit Strategy Group (Repository)" #E8F5E9
  participant "EditStore" as store
end box
database "EditDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== EDT-04 APPLY Unified Diff ==

user -> iface : POST /editstrategy/unified-diff
activate iface
iface -> router : POST /editstrategy/unified-diff
activate router
router -> mgr : EDT-04 APPLY Unified Diff({file_path, diff_content})
activate mgr

alt validation succeedt
  mgr -> store : EDT-04 APPLY Unified Diff({file_path, diff_content})
  activate store
  store -> dir : EDT-04 APPLY Unified Diff({file_path, diff_content})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
