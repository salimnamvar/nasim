@startuml sq_editstrategy09_apply_inline_patch
' ============================================================
' Title:     EDT-09 — APPLY Inline Patch
' Boundary:  nasim code agent
' Purpose:   Apply an inline patch edit to a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> InlinePatchCoder
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-09 APPLY Inline Patch

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "InlinePatchCoder" as coder
end box

== EDT-09 APPLY Inline Patch ==

user -> iface : EDT-09 APPLY Inline Patch({file_path, patch_content})
activate iface
iface -> router : EDT-09 APPLY Inline Patch({file_path, patch_content})
activate router
router -> coder : EDT-09 APPLY Inline Patch({file_path, patch_content})
activate coder

alt validation succeeds
  ref over coder : EDT-09 APPLY Inline Patch <back:#B2DFDB>TOOL_EXEC</back>
  coder --> router : 200 OK
  deactivate coder
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  coder --> router : {error: {code: "EDT-09_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate coder
  router --> iface : {error: {code: "EDT-09_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  iface --> user : {error: {code: "EDT-09_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
