@startuml sq_editstrategy03_apply_whole_file
' ============================================================
' Title:     EDT-03 — APPLY Whole-File
' Boundary:  nasim code agent
' Purpose:   Replace entire file content with new content
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> WholeFileCoder
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDT-03 APPLY Whole-File

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "WholeFileCoder" as coder
end box

== EDT-03 APPLY Whole-File ==

user -> iface : POST /editstrategy/whole-file
activate iface
iface -> router : POST /editstrategy/whole-file
activate router
router -> coder : EDT-03 APPLY Whole-File({file_path, content})
activate coder

alt validation succeeds
  ref over coder : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  coder --> router : 200 OK
  deactivate coder
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  coder --> router : 422 Unprocessable
  deactivate coder
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
