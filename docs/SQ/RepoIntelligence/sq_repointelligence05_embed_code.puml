@startuml sq_repointelligence05_embed_code
' ============================================================
' Title:     REPOINTELLIGENCE-05 — EMBED Code
' Boundary:  nasim code agent
' Purpose:   Generate vector embeddings for code fragments
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> EmbeddingService -> EmbeddingAdapter
' SM States: EMBEDDING (#E6EE9C)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- REPOINTELLIGENCE-05 EMBED Code

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "RepoIntelligenceRepository" as mgr
end box

box "Repository" REPOSITORY_COLOR
  participant "RepoIntelligenceRepository" as embeddingAdapter
end box

== REPOINTELLIGENCE-05 EMBED Code ==

user -> iface : REPOINTELLIGENCE-05 EMBED Code({code_fragments})
activate iface
iface -> router : REPOINTELLIGENCE-05 EMBED Code({code_fragments})
activate router
router -> mgr : REPOINTELLIGENCE-05 EMBED Code({code_fragments})
activate mgr

alt embedding_model available and embed completes
  ref over mgr : REPOINTELLIGENCE-05 EMBED Code({code_fragments}) <back:#E6EE9C>EMBEDDING</back>
  mgr -> embeddingAdapter : REPOINTELLIGENCE-05 PERSIST Embedding({code_fragments})
  activate embeddingAdapter
  embeddingAdapter --> mgr : 200 OK
  deactivate embeddingAdapter
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else provider error
  mgr --> router : 503 UNAVAILABLE\n{error: {code: "REPOINTELLIGENCE-05_PROVIDER_ERROR", message: "Embedding provider unavailable", status: 503}}
  deactivate mgr
  router --> iface : 503 UNAVAILABLE\n{error: {code: "REPOINTELLIGENCE-05_PROVIDER_ERROR", message: "Embedding provider unavailable", status: 503}}
  iface --> user : 503 UNAVAILABLE\n{error: {code: "REPOINTELLIGENCE-05_PROVIDER_ERROR", message: "Embedding provider unavailable", status: 503}}
  deactivate router
  deactivate iface
end

@enduml
