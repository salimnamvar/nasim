@startuml sq_repointelligence05_embed_code
' ============================================================
' Title:     RIM-05 — EMBED Code
' Boundary:  nasim code agent
' Purpose:   Generate vector embeddings for code fragments
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EmbeddingAdapter
' SM States: EMBEDDING (#E6EE9C)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-05 EMBED Code

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "EmbeddingAdapter" as mgr
end box

== RIM-05 EMBED Code ==

user -> iface : RIM-05 EMBED Code({code_fragments})
activate iface
iface -> router : RIM-05 EMBED Code({code_fragments})
activate router
router -> mgr : RIM-05 EMBED Code({code_fragments})
activate mgr

alt embedding_model available and embed completes
  ref over mgr : RIM-05 EMBED Code({code_fragments})
    <back:#E6EE9C>EMBEDDING</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else provider error
  mgr --> router : 503 UNAVAILABLE\n{error: {code: "RIM-05_PROVIDER_ERROR", message: "Embedding provider unavailable", status: 503}}
  deactivate mgr
  router --> iface : 503 UNAVAILABLE
  iface --> user : 503 UNAVAILABLE
  deactivate router
  deactivate iface
end

@enduml
