@startuml sq_repointelligence05_embed_code
' ============================================================
' Title:     RIM-05 — EMBED Code
' Boundary:  nasim code agent
' Purpose:   Generate vector embeddings for code fragments
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> EmbeddingAdapter
' SM States: EMBEDDING (#E6EE9C)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-05 EMBED Code

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "EmbeddingAdapter" as mgr
end box

== RIM-05 EMBED Code ==

user -> iface : POST /embeddings
activate iface
iface -> router : POST /embeddings
activate router
router -> mgr : rim05 EMBED Code(code_fragments)
activate mgr

alt embed succeeds
  ref over mgr : RIM-05 TRANSITION State
    ' SM States: EMBEDDING (#E6EE9C)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else provider error
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
