@startuml sq_repointelligence05_embed_code
' ============================================================
' Title:     RIM-05 — EMBED Code
' Boundary:  nasim code agent
' Purpose:   Generate vector embeddings for code fragments
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> RepoIntelligenceAPI -> RepoIntelligenceManager -> RepoIntelligenceStore -> RepoIntelligenceDirectory
' SM States: EMBEDDING (#E6EE9C)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-05 EMBED Code

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "RepoIntelligenceAPI" as api
end box
box "RepoIntelligence Group (Service)" #FFF3E0
  participant "RepoIntelligenceManager" as mgr
end box
box "RepoIntelligence Group (Repository)" #E8F5E9
  participant "RepoIntelligenceStore" as store
end box
database "RepoIntelligenceDirectory" as dir

== RIM-05 EMBED Code ==

user -> router : POST /embeddings
activate router
router -> api : rim05 EMBED Code(code_fragments)
activate api
api -> mgr : rim05 EMBED Code(code_fragments)
activate mgr

alt embed succeeds
  mgr -> store : rim05 EMBED Code(code_fragments)
  activate store
  store -> dir : rim05 EMBED Code(code_fragments)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : EMBEDDING (#E6EE9C)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else provider error
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
