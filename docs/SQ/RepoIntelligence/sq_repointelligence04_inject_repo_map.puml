@startuml sq_repointelligence04_inject_repo_map
' ============================================================
' Title:     RIM-04 — INJECT RepoMap
' Boundary:  nasim code agent
' Purpose:   Token-budgeted repo-map injection into LLM context
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> RepoIntelligenceManager -> RepoIntelligenceStore -> RepoIntelligenceDirectory -> FileSystem
' SM States: INDEXED (#7CB342)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-04 INJECT RepoMap

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "RepoIntelligence Group (Service)" #FFF3E0
  participant "RepoIntelligenceManager" as mgr
end box
box "RepoIntelligence Group (Repository)" #E8F5E9
  participant "RepoIntelligenceStore" as store
end box
database "RepoIntelligenceDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== RIM-04 INJECT RepoMap ==

user -> iface : POST /repomap/inject
activate iface
iface -> router : POST /repomap/inject
activate router
router -> mgr : rim04 INJECT RepoMap(budget_tokens, ranked_symbols)
activate mgr

alt inject succeeds
  mgr -> store : rim04 INJECT RepoMap(budget_tokens, ranked_symbols)
  activate store
  store -> dir : rim04 INJECT RepoMap(budget_tokens, ranked_symbols)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#7CB342>INDEXED</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else budget exhausted
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
