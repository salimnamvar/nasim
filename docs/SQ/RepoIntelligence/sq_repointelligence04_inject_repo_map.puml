@startuml sq_repointelligence04_inject_repo_map
' ============================================================
' Title:     RIM-04 — INJECT RepoMap
' Boundary:  nasim code agent
' Purpose:   Token-budgeted repo-map injection into LLM context
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> RepoIntelligenceAPI -> RepoIntelligenceManager -> RepoIntelligenceStore -> RepoIntelligenceDirectory
' SM States: INDEXED (#7CB342)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-04 INJECT RepoMap

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "RepoIntelligenceAPI" as api
end box
box "RepoIntelligence Group (Service)" #FFF3E0
  participant "RepoIntelligenceManager" as mgr
end box
box "RepoIntelligence Group (Repository)" #E8F5E9
  participant "RepoIntelligenceStore" as store
end box
database "RepoIntelligenceDirectory" as dir

== RIM-04 INJECT RepoMap ==

user -> router : POST /repomap/inject
activate router
router -> api : rim04 INJECT RepoMap(budget_tokens, ranked_symbols)
activate api
api -> mgr : rim04 INJECT RepoMap(budget_tokens, ranked_symbols)
activate mgr

alt inject succeeds
  mgr -> store : rim04 INJECT RepoMap(budget_tokens, ranked_symbols)
  activate store
  store -> dir : rim04 INJECT RepoMap(budget_tokens, ranked_symbols)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : INDEXED (#7CB342)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else budget exhausted
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
