@startuml sq_repointelligence04_inject_repo_map
' ============================================================
' Title:     RIM-04 — INJECT RepoMap
' Boundary:  nasim code agent
' Purpose:   Token-budgeted repo-map injection into LLM context
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> RepoMapBuilder
' SM States: INDEXED (#7CB342)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-04 INJECT RepoMap

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "RepoMapBuilder" as mgr
end box

== RIM-04 INJECT RepoMap ==

user -> iface : RIM-04 INJECT RepoMap({budget_tokens, ranked_symbols})
activate iface
iface -> router : RIM-04 INJECT RepoMap({budget_tokens, ranked_symbols})
activate router
router -> mgr : RIM-04 INJECT RepoMap({budget_tokens, ranked_symbols})
activate mgr

alt budget_sufficient and injection completes
  ref over mgr : RIM-04 INJECT RepoMap({budget_tokens, ranked_symbols})
    <back:#7CB342>INDEXED</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else budget exhausted
  mgr --> router : 409 FAILED_PRECONDITION\n{error: {code: "RIM-04_BUDGET_EXCEEDED", message: "Token budget exhausted", status: 409}}
  deactivate mgr
  router --> iface : 409 FAILED_PRECONDITION
  iface --> user : 409 FAILED_PRECONDITION
  deactivate router
  deactivate iface
end

@enduml
