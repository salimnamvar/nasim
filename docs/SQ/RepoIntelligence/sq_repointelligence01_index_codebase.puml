@startuml sq_repointelligence01_index_codebase
' ============================================================
' Title:     RIM-01 — INDEX Codebase
' Boundary:  nasim code agent
' Purpose:   Build AST index and symbol graph from project source
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> RepoIntelligenceAPI -> RepoIntelligenceManager -> RepoIntelligenceStore -> RepoIntelligenceDirectory
' SM States: INDEXING (#4FC3F7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-01 INDEX Codebase

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "RepoIntelligenceAPI" as api
end box
box "RepoIntelligence Group (Service)" #FFF3E0
  participant "RepoIntelligenceManager" as mgr
end box
box "RepoIntelligence Group (Repository)" #E8F5E9
  participant "RepoIntelligenceStore" as store
end box
database "RepoIntelligenceDirectory" as dir

== RIM-01 INDEX Codebase ==

user -> router : POST /project/{root}:index
activate router
router -> api : rim01 INDEX Codebase(project_root)
activate api
api -> mgr : rim01 INDEX Codebase(project_root)
activate mgr

alt indexing succeeds
  mgr -> store : rim01 INDEX Codebase(project_root)
  activate store
  store -> dir : rim01 INDEX Codebase(project_root)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : INDEXING (#4FC3F7)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else parse failure
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
