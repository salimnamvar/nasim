@startuml sq_repointelligence01_index_codebase
' ============================================================
' Title:     RIM-01 — INDEX Codebase
' Boundary:  nasim code agent
' Purpose:   Build AST index and symbol graph from project source
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> RepoIntelligenceManager
' SM States: INDEXING (#4FC3F7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-01 INDEX Codebase

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "RepoIntelligenceManager" as mgr
end box

== RIM-01 INDEX Codebase ==

user -> iface : POST /project/{root}:index
activate iface
iface -> router : POST /project/{root}:index
activate router
router -> mgr : rim01 INDEX Codebase(project_root)
activate mgr

alt indexing succeeds
  ref over mgr : RIM-01 TRANSITION State
    ' SM States: INDEXING (#4FC3F7)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else parse failure
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
