@startuml sq_repointelligence01_index_codebase
' ============================================================
' Title:     REPOINTELLIGENCE-01 — INDEX Codebase
' Boundary:  nasim code agent
' Purpose:   Build AST index and symbol graph from project source
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> RepoIntelligenceService -> ASTIndexAdapter
' SM States: INDEXING (#4FC3F7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- REPOINTELLIGENCE-01 INDEX Codebase

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "RepoIntelligenceRepository" as mgr
end box

box "Repository" REPOSITORY_COLOR
  participant "RepoIntelligenceRepository" as ast
end box

== REPOINTELLIGENCE-01 INDEX Codebase ==

user -> iface : REPOINTELLIGENCE-01 INDEX Codebase({project_root})
activate iface
iface -> router : REPOINTELLIGENCE-01 INDEX Codebase({project_root})
activate router
router -> mgr : REPOINTELLIGENCE-01 INDEX Codebase({project_root})
activate mgr

alt ast_extraction completes without error
  ref over mgr : REPOINTELLIGENCE-01 INDEX Codebase({project_root}) <back:#4FC3F7>INDEXING</back>
  mgr -> ast : REPOINTELLIGENCE-01 INDEX Codebase({project_root})
  activate ast
  ast --> mgr : 200 OK
  deactivate ast
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else parse validation fails
  mgr --> router : 400 BAD_REQUEST\n{error: {code: "REPOINTELLIGENCE-01_PARSE_ERROR", message: "AST extraction failed", status: 400}}
  deactivate mgr
  router --> iface : 400 BAD_REQUEST\n{error: {code: "REPOINTELLIGENCE-01_PARSE_ERROR", message: "AST extraction failed", status: 400}}
  iface --> user : 400 BAD_REQUEST\n{error: {code: "REPOINTELLIGENCE-01_PARSE_ERROR", message: "AST extraction failed", status: 400}}
  deactivate router
  deactivate iface
end

@enduml
