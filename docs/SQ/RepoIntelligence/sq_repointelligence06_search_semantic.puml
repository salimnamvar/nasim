@startuml sq_repointelligence06_search_semantic
' ============================================================
' Title:     RIM-06 — SEARCH Semantic
' Boundary:  nasim code agent
' Purpose:   Embedding-based code similarity search across repository
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SemanticSearchService
' SM States: INDEXED (#7CB342)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-06 SEARCH Semantic

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "RepoIntelligence Group (Repository)" #E8F5E9
  participant "SemanticSearchService" as mgr
end box


== RIM-06 SEARCH Semantic ==

user -> iface : GET /semantic/search?q={query}
activate iface
iface -> router : GET /semantic/search?q={query}
activate router
router -> mgr : rim06 SEARCH Semantic(query, top_k)
activate mgr

alt search succeeds
  ref over mgr : RIM-06 TRANSITION State
    ' SM States: INDEXED (#7CB342)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else no results
  mgr --> router : 404 Not Found
  deactivate mgr
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
