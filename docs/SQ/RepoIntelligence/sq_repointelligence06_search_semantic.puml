@startuml sq_repointelligence06_search_semantic
' ============================================================
' Title:     RIM-06 — SEARCH Semantic
' Boundary:  nasim code agent
' Purpose:   Embedding-based code similarity search across repository
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> RepoIntelligenceAPI -> RepoIntelligenceManager -> RepoIntelligenceStore -> RepoIntelligenceDirectory
' SM States: INDEXED (#7CB342)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-06 SEARCH Semantic

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "RepoIntelligenceAPI" as api
end box
box "RepoIntelligence Group (Service)" #FFF3E0
  participant "RepoIntelligenceManager" as mgr
end box
box "RepoIntelligence Group (Repository)" #E8F5E9
  participant "RepoIntelligenceStore" as store
end box
database "RepoIntelligenceDirectory" as dir

== RIM-06 SEARCH Semantic ==

user -> router : GET /semantic/search?q={query}
activate router
router -> api : rim06 SEARCH Semantic(query, top_k)
activate api
api -> mgr : rim06 SEARCH Semantic(query, top_k)
activate mgr

alt search succeeds
  mgr -> store : rim06 SEARCH Semantic(query, top_k)
  activate store
  store -> dir : rim06 SEARCH Semantic(query, top_k)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : INDEXED (#7CB342)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else no results
  mgr --> api : 404 Not Found
  deactivate mgr
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end

@enduml
