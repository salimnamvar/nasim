@startuml sq_repointelligence02_build_symbol_graph
' ============================================================
' Title:     RIM-02 — BUILD Symbol Graph
' Boundary:  nasim code agent
' Purpose:   Build cross-file symbol reference graph
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> RepoIntelligenceAPI -> RepoIntelligenceManager -> RepoIntelligenceStore -> RepoIntelligenceDirectory
' SM States: BUILDING_GRAPH (#9C27B0)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-02 BUILD Symbol Graph

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "RepoIntelligenceAPI" as api
end box
box "RepoIntelligence Group (Service)" #FFF3E0
  participant "RepoIntelligenceManager" as mgr
end box
box "RepoIntelligence Group (Repository)" #E8F5E9
  participant "RepoIntelligenceStore" as store
end box
database "RepoIntelligenceDirectory" as dir

== RIM-02 BUILD Symbol Graph ==

user -> router : POST /symbol/graph
activate router
router -> api : rim02 BUILD Symbol Graph(ast_index)
activate api
api -> mgr : rim02 BUILD Symbol Graph(ast_index)
activate mgr

alt build succeeds
  mgr -> store : rim02 BUILD Symbol Graph(ast_index)
  activate store
  store -> dir : rim02 BUILD Symbol Graph(ast_index)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : BUILDING_GRAPH (#9C27B0)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else reference resolution fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
