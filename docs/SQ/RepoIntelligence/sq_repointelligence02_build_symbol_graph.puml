@startuml sq_repointelligence02_build_symbol_graph
' ============================================================
' Title:     RIM-02 — BUILD Symbol Graph
' Boundary:  nasim code agent
' Purpose:   Build cross-file symbol reference graph
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> RepoIntelligenceManager -> RepoIntelligenceStore -> RepoIntelligenceDirectory -> FileSystem
' SM States: BUILDING_GRAPH (#9C27B0)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-02 BUILD Symbol Graph

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "RepoIntelligence Group (Service)" #FFF3E0
  participant "RepoIntelligenceManager" as mgr
end box
box "RepoIntelligence Group (Repository)" #E8F5E9
  participant "RepoIntelligenceStore" as store
end box
database "RepoIntelligenceDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== RIM-02 BUILD Symbol Graph ==

user -> iface : POST /symbol/graph
activate iface
iface -> router : POST /symbol/graph
activate router
router -> mgr : rim02 BUILD Symbol Graph(ast_index)
activate mgr

alt build succeeds
  mgr -> store : rim02 BUILD Symbol Graph(ast_index)
  activate store
  store -> dir : rim02 BUILD Symbol Graph(ast_index)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : BUILDING_GRAPH (#9C27B0)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else reference resolution fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
