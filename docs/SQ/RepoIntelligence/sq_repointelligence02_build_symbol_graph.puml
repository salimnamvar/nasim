@startuml sq_repointelligence02_build_symbol_graph
' ============================================================
' Title:     REPOINTELLIGENCE-02 — BUILD Symbol Graph
' Boundary:  nasim code agent
' Purpose:   Build cross-file symbol reference graph
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> SymbolGraphService -> SymbolGraphRepository
' SM States: BUILDING_GRAPH (#9C27B0)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- REPOINTELLIGENCE-02 BUILD Symbol Graph

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "RepoIntelligenceRepository" as mgr
end box

box "Repository" REPOSITORY_COLOR
  participant "RepoIntelligenceRepository" as symbolRepo
end box

== REPOINTELLIGENCE-02 BUILD Symbol Graph ==

user -> iface : REPOINTELLIGENCE-02 BUILD Symbol Graph({ast_index})
activate iface
iface -> router : REPOINTELLIGENCE-02 BUILD Symbol Graph({ast_index})
activate router
router -> mgr : REPOINTELLIGENCE-02 BUILD SymbolGraph({ast_index})
activate mgr

alt reference_resolution completes without error
  ref over mgr : REPOINTELLIGENCE-02 BUILD SymbolGraph({ast_index}) <back:#9C27B0>BUILDING_GRAPH</back>
  mgr -> symbolRepo : REPOINTELLIGENCE-02 PERSIST SymbolGraph({ast_index, references})
  activate symbolRepo
  symbolRepo --> mgr : 200 OK
  deactivate symbolRepo
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else reference resolution fails
  mgr --> router : 500 INTERNAL\n{error: {code: "REPOINTELLIGENCE-02_GRAPH_ERROR", message: "Symbol graph construction failed", status: 500}}
  deactivate mgr
  router --> iface : 500 INTERNAL\n{error: {code: "REPOINTELLIGENCE-02_GRAPH_ERROR", message: "Symbol graph construction failed", status: 500}}
  iface --> user : 500 INTERNAL\n{error: {code: "REPOINTELLIGENCE-02_GRAPH_ERROR", message: "Symbol graph construction failed", status: 500}}
  deactivate router
  deactivate iface
end

@enduml
