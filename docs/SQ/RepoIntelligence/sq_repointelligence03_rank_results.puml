@startuml sq_repointelligence03_rank_results
' ============================================================
' Title:     RIM-03 — RANK Results
' Boundary:  nasim code agent
' Purpose:   PageRank ranking with chat-personalization for symbol importance
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> RankingService
' SM States: INDEXED (#7CB342)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-03 RANK Results

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "RankingService" as mgr
end box

== RIM-03 RANK Results ==

user -> iface : GET /symbols/ranked?query={query}
activate iface
iface -> router : GET /symbols/ranked?query={query}
activate router
router -> mgr : RIM-03 RANK Results({graph, chat_context})
activate mgr

alt graph_not_empty and ranking completes
  ref over mgr : RIM-03 RANK Results({graph, chat_context})
    <back:#7CB342>INDEXED</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else empty graph
  mgr --> router : 409 FAILED_PRECONDITION\n{error: {code: "RIM-03_EMPTY_GRAPH", message: "Cannot rank empty graph", status: 409}}
  deactivate mgr
  router --> iface : 409 FAILED_PRECONDITION
  iface --> user : 409 FAILED_PRECONDITION
  deactivate router
  deactivate iface
end

@enduml
