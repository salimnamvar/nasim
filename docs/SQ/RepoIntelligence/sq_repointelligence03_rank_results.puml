@startuml sq_repointelligence03_rank_results
' ============================================================
' Title:     RIM-03 — RANK Results
' Boundary:  nasim code agent
' Purpose:   PageRank ranking with chat-personalization for symbol importance
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> RankingService
' SM States: INDEXED (#7CB342)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-03 RANK Results

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "RepoIntelligence Group (Repository)" #E8F5E9
  participant "RankingService" as mgr
end box


== RIM-03 RANK Results ==

user -> iface : GET /symbols/ranked?query={query}
activate iface
iface -> router : GET /symbols/ranked?query={query}
activate router
router -> mgr : rim03 RANK Results(graph, chat_context)
activate mgr

alt ranking succeeds
  ref over mgr : RIM-03 TRANSITION State
    ' SM States: INDEXED (#7CB342)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else empty graph
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
