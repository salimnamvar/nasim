@startuml sq_repointelligence03_rank_results
' ============================================================
' Title:     RIM-03 — RANK Results
' Boundary:  nasim code agent
' Purpose:   PageRank ranking with chat-personalization for symbol importance
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> RepoIntelligenceAPI -> RepoIntelligenceManager -> RepoIntelligenceStore -> RepoIntelligenceDirectory
' SM States: INDEXED (#7CB342)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- RIM-03 RANK Results

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "RepoIntelligenceAPI" as api
end box
box "RepoIntelligence Group (Service)" #FFF3E0
  participant "RepoIntelligenceManager" as mgr
end box
box "RepoIntelligence Group (Repository)" #E8F5E9
  participant "RepoIntelligenceStore" as store
end box
database "RepoIntelligenceDirectory" as dir

== RIM-03 RANK Results ==

user -> router : GET /symbols/ranked?query={query}
activate router
router -> api : rim03 RANK Results(graph, chat_context)
activate api
api -> mgr : rim03 RANK Results(graph, chat_context)
activate mgr

alt ranking succeeds
  mgr -> store : rim03 RANK Results(graph, chat_context)
  activate store
  store -> dir : rim03 RANK Results(graph, chat_context)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : INDEXED (#7CB342)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else empty graph
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
