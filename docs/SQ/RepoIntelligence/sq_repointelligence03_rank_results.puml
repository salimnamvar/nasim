@startuml sq_repointelligence03_rank_results
' ============================================================
' Title:     REPOINTELLIGENCE-03 — RANK Results
' Boundary:  nasim code agent
' Purpose:   PageRank ranking with chat-personalization for symbol importance
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> RankingService -> SymbolGraphRepository
' SM States: INDEXED (#7CB342)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- REPOINTELLIGENCE-03 RANK Results

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "RepoIntelligenceRepository" as mgr
end box

box "Repository" REPOSITORY_COLOR
  participant "RepoIntelligenceRepository" as symbolRepo
end box

== REPOINTELLIGENCE-03 RANK Results ==

user -> iface : REPOINTELLIGENCE-03 RANK Results({query, chat_context})
activate iface
iface -> router : REPOINTELLIGENCE-03 RANK Results({query, chat_context})
activate router
router -> mgr : REPOINTELLIGENCE-03 RANK Results({graph, chat_context})
activate mgr

alt graph_not_empty and ranking completes
  ref over mgr : REPOINTELLIGENCE-03 RANK Results({graph, chat_context}) <back:#7CB342>INDEXED</back>
  mgr -> symbolRepo : REPOINTELLIGENCE-03 READ SymbolGraph({project_root})
  activate symbolRepo
  symbolRepo --> mgr : 200 OK
  deactivate symbolRepo
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else empty graph
  mgr --> router : 409 FAILED_PRECONDITION\n{error: {code: "REPOINTELLIGENCE-03_EMPTY_GRAPH", message: "Cannot rank empty graph", status: 409}}
  deactivate mgr
  router --> iface : 409 FAILED_PRECONDITION\n{error: {code: "REPOINTELLIGENCE-03_EMPTY_GRAPH", message: "Cannot rank empty graph", status: 409}}
  iface --> user : 409 FAILED_PRECONDITION\n{error: {code: "REPOINTELLIGENCE-03_EMPTY_GRAPH", message: "Cannot rank empty graph", status: 409}}
  deactivate router
  deactivate iface
end

@enduml
