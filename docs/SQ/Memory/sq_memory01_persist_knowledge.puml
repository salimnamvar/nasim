@startuml sq_memory01_persist_knowledge
' ============================================================
' Title:     MEM-01 — PERSIST Knowledge
' Boundary:  nasim code agent
' Purpose:   Store cross-session knowledge entries
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> MemoryStore
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MEM-01 PERSIST Knowledge

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Memory Group (Repository)" #E8F5E9
  participant "MemoryStore" as store
end box

== MEM-01 PERSIST Knowledge ==

user -> iface : POST /knowledge
activate iface
iface -> router : POST /knowledge
activate router
router -> store : MEM-01 PERSIST Knowledge({key, value, scope})
activate store

store --> router : 200 OK
deactivate store
router --> iface : 200 OK
iface --> user : 200 OK
deactivate router
deactivate iface

@enduml
