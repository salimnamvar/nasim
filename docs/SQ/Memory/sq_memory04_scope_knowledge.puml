@startuml sq_memory04_scope_knowledge
' ============================================================
' Title:     MEM-04 — SCOPE Knowledge
' Boundary:  nasim code agent
' Purpose:   Filter knowledge by scope (global, project, session)
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> MemoryStore
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MEM-04 SCOPE Knowledge

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Memory Group (Repository)" #E8F5E9
  participant "MemoryStore" as store
end box

== MEM-04 SCOPE Knowledge ==

user -> iface : GET /knowledge:scope
activate iface
iface -> router : GET /knowledge:scope
activate router
router -> store : MEM-04 SCOPE Knowledge({query, scope})
activate store

alt no matching scope
  store --> router : 404 Not Found
  deactivate store
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
else scoped results
  store --> router : 200 OK
  deactivate store
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
end

@enduml
