@startuml sq_memory04_scope_knowledge
' ============================================================
' Title:     MEM-04 — SCOPE Knowledge
' Boundary:  nasim code agent
' Purpose:   Filter knowledge by scope (global, project, session)
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> MemoryManager -> MemoryStore -> MemoryDirectory -> FileSystem
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MEM-04 SCOPE Knowledge

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Memory Group (Service)" #FFF3E0
  participant "MemoryManager" as mgr
end box
box "Memory Group (Repository)" #E8F5E9
  participant "MemoryStore" as store
end box
database "MemoryDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== MEM-04 SCOPE Knowledge ==

user -> iface : GET /knowledge:scope
activate iface
iface -> router : GET /knowledge:scope
activate router
router -> mgr : MEM-04 SCOPE Knowledge({query, scope})
activate mgr

alt validation succeeds
  mgr -> store : MEM-04 SCOPE Knowledge({query, scope})
  activate store
  store -> dir : MEM-04 SCOPE Knowledge({query, scope})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
