@startuml sq_memory02_recall_knowledge
' ============================================================
' Title:     MEM-02 — RECALL Knowledge
' Boundary:  nasim code agent
' Purpose:   Retrieve previously stored knowledge
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> MemoryManager -> MemoryStore -> MemoryDirectory -> FileSystem
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MEM-02 RECALL Knowledge

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Memory Group (Service)" #FFF3E0
  participant "MemoryManager" as mgr
end box
box "Memory Group (Repository)" #E8F5E9
  participant "MemoryStore" as store
end box
database "MemoryDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== MEM-02 RECALL Knowledge ==

user -> iface : GET /knowledge/{key}
activate iface
iface -> router : GET /knowledge/{key}
activate router
router -> mgr : MEM-02 RECALL Knowledge({key, scope})
activate mgr

alt validation succeeds
  mgr -> store : MEM-02 RECALL Knowledge({key, scope})
  activate store
  store -> dir : MEM-02 RECALL Knowledge({key, scope})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else key not found
  mgr --> router : 404 Not Found
  deactivate mgr
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
