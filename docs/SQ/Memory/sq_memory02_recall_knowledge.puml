@startuml sq_memory02_recall_knowledge
' ============================================================
' Title:     MEM-02 — RECALL Knowledge
' Boundary:  nasim code agent
' Purpose:   Retrieve previously stored knowledge
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> MemoryAPI -> MemoryManager -> MemoryStore -> MemoryDirectory
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MEM-02 RECALL Knowledge

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "MemoryAPI" as api
end box
box "Memory Group (Service)" #FFF3E0
  participant "MemoryManager" as mgr
end box
box "Memory Group (Repository)" #E8F5E9
  participant "MemoryStore" as store
end box
database "MemoryDirectory" as dir

== MEM-02 RECALL Knowledge ==

user -> router : GET /knowledge/{key}
activate router
router -> api : MEM-02 RECALL Knowledge({key, scope})
activate api
api -> mgr : MEM-02 RECALL Knowledge({key, scope})
activate mgr

alt validation succeeds
  mgr -> store : MEM-02 RECALL Knowledge({key, scope})
  activate store
  store -> dir : MEM-02 RECALL Knowledge({key, scope})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else key not found
  mgr --> api : 404 Not Found
  deactivate mgr
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end

@enduml
