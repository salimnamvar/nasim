@startuml sq_memory01_persist_knowledge
' ============================================================
' Title:     MEMORYREPOSITORY-01 — PERSIST Knowledge
' Boundary:  nasim code agent
' Purpose:   Store cross-session knowledge entries
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> MemoryStore
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- MEMORYREPOSITORY-01 PERSIST Knowledge

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Task Service" as svc
end box

box "Repository" REPOSITORY_COLOR
  participant "Memory Repository" as store
end box

== MEMORYREPOSITORY-01 PERSIST Knowledge ==

user -> iface : POST /knowledge
activate iface
iface -> router : POST /knowledge
activate router
router -> svc : MEMORYREPOSITORY-01 PERSIST Knowledge({key, value, scope})
activate svc
svc -> store : MEMORYREPOSITORY-01 PERSIST Knowledge({key, value, scope})
activate store

alt store unavailable
  store --> svc : 503 Service Unavailable
  deactivate store
  svc --> router : 503 Service Unavailable
  deactivate svc
  router --> iface : 503 Service Unavailable
  iface --> user : 503 Service Unavailable
  deactivate router
  deactivate iface
else persisted
  store --> svc : 200 OK
  deactivate store
  svc --> router : 200 OK
  deactivate svc
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
end

@enduml
