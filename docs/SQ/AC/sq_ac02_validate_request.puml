@startuml sq_ac02_validate_request
' ============================================================
' Title:     AC-02 — VALIDATE Request
' Boundary:  nasim code agent
' Purpose:   Validate request format, permissions, and protocol
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> InterfaceAdapter -> AgentController -> SafetyService
' SM States: LISTENING (#E8EAF6), IDLE (#ECEFF1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- AC-02 VALIDATE Request

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "SafetyService" as safety
end box

== AC-02 VALIDATE Request ==

user -> iface : AC-02 VALIDATE Request({payload})
activate iface

iface -> router : AC-02 VALIDATE Request({payload})
activate router

router -> safety : AC-02 VALIDATE Request({payload})
activate safety

alt format valid AND permissions ok
  safety --> router : 200 OK — {validated}
  deactivate safety
  router --> iface : 200 OK — {validated}
  deactivate router
  iface --> user : 200 OK — {validated}
  deactivate iface

else invalid format
  safety --> router : 422 INVALID_ARGUMENT\n{error: {code: "AC-02_FORMAT_ERROR", message: "Request format not recognized", status: 422}}
  deactivate safety
  router --> iface : 422 INVALID_ARGUMENT
  deactivate router
  iface --> user : 422 INVALID_ARGUMENT
  deactivate iface

else permission denied
  safety --> router : 403 PERMISSION_DENIED\n{error: {code: "AC-02_PERMISSION_ERROR", message: "Operation not permitted from this interface", status: 403}}
  deactivate safety
  router --> iface : 403 PERMISSION_DENIED
  deactivate router
  iface --> user : 403 PERMISSION_DENIED
  deactivate iface
end

@enduml
