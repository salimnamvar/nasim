@startuml sq_editstrategy06_apply_function_level
' ============================================================
' Title:     EDITSTRATEGYREPOSITORY-06 — APPLY Function-Level
' Boundary:  nasim code agent
' Purpose:   Apply a function-level edit to a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> Edit Strategy Repository
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDITSTRATEGYREPOSITORY-06 APPLY Function-Level

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Edit Strategy Repository" as coder
end box

== EDITSTRATEGYREPOSITORY-06 APPLY Function-Level ==

user -> iface : EDITSTRATEGYREPOSITORY-06 APPLY Function-Level({file_path, function_name, new_body})
activate iface
iface -> router : EDITSTRATEGYREPOSITORY-06 APPLY Function-Level({file_path, function_name, new_body})
activate router
router -> coder : EDITSTRATEGYREPOSITORY-06 APPLY Function-Level({file_path, function_name, new_body})
activate coder

alt validation succeeds
  ref over coder : EDITSTRATEGYREPOSITORY-06 APPLY Function-Level <back:#B2DFDB>TOOL_EXEC</back>
  coder --> router : 200 OK
  deactivate coder
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  coder --> router : {error: {code: "EDITSTRATEGYREPOSITORY-06_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate coder
  router --> iface : {error: {code: "EDITSTRATEGYREPOSITORY-06_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  iface --> user : {error: {code: "EDITSTRATEGYREPOSITORY-06_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
