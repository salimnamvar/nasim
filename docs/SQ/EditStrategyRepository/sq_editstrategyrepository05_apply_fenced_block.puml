@startuml sq_editstrategy05_apply_fenced_block
' ============================================================
' Title:     EDITSTRATEGYREPOSITORY-05 — APPLY Fenced Block
' Boundary:  nasim code agent
' Purpose:   Apply a fenced code-block edit to a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> EditStrategyRepository
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EDITSTRATEGYREPOSITORY-05 APPLY Fenced Block

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "EditStrategyRepository" as coder
end box

== EDITSTRATEGYREPOSITORY-05 APPLY Fenced Block ==

user -> iface : EDITSTRATEGYREPOSITORY-05 APPLY Fenced Block({file_path, block_language, block_content})
activate iface
iface -> router : EDITSTRATEGYREPOSITORY-05 APPLY Fenced Block({file_path, block_language, block_content})
activate router
router -> coder : EDITSTRATEGYREPOSITORY-05 APPLY Fenced Block({file_path, block_language, block_content})
activate coder

alt validation succeeds
  ref over coder : EDITSTRATEGYREPOSITORY-05 APPLY Fenced Block <back:#B2DFDB>TOOL_EXEC</back>
  coder --> router : 200 OK
  deactivate coder
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  coder --> router : {error: {code: "EDITSTRATEGYREPOSITORY-05_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate coder
  router --> iface : {error: {code: "EDITSTRATEGYREPOSITORY-05_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  iface --> user : {error: {code: "EDITSTRATEGYREPOSITORY-05_VALIDATION_ERROR", message: "Validation failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
