@startuml sq_ssn04_restore_session
!include ../common/sq_styles.puml
' ============================================================
' Title:     SSN-04 — Restore Session
' Boundary:  nasim code agent CLI
' Purpose:   Resume a previous session by loading its history
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Session Group" #E8F5E9
  participant "SessionStore" as store
end box

note over user
  Scope:          SSN-04 Restore Session — Resume a previous session by loading its history
  Preconditions:  Session may or may not exist on disk
  Contexts:       Called by user-facing resume command
  Excludes:       Session creation, snapshotting, branching
  Rollback:       Session not found → 404 NOT_FOUND, start fresh; delegates to SSN-02 for read
  Design:         Composes SSN-02 (load) + SSN-01 (persist) for resume; starts fresh on 404
  Returns:
    - Success: 200 OK — Session(id, messages)
    - Failure: 404 NOT_FOUND — fallback to fresh session
end note

== SSN-04 Resume Session ==

user -> router : types input
activate router
router -> agent : PROCESS(user_input)
activate agent

agent -> store : ssn04 READ Session(session_id)
activate store
ref over store
  SSN-02: Load Session
end ref

alt Session found
    store --> agent : 200 OK — Session(id, messages)
    deactivate store
    agent -> agent : ssn01 PERSIST Session(session_id, messages)
    agent --> router : AgentEvent(Done)
else Session not found
    store --> agent : 404 NOT_FOUND
    deactivate store
    agent -> agent : start fresh
    agent --> router : AgentEvent(Done)
end

    deactivate agent
deactivate router

note over user
  Flow:    SSN-04 → SSN-02 (load) → SSN-01 (persist) → 200 OK, or 404 → start fresh
  State:   No state change
  Success: 200 OK — Session(id, messages)
  Failure: 404 NOT_FOUND: session missing — start fresh session
end note

@enduml
