@startuml sq_ssn03_list_sessions
!include ../common/sq_styles.puml
' ============================================================
' Title:     SSN-03 — List Sessions
' Boundary:  nasim code agent CLI
' Purpose:   List available saved sessions
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Session Group" #E8F5E9
  participant "SessionStore" as store
end box
database "Session Directory" as dir

note over user
  Scope:          SSN-03 List Sessions — List available saved sessions with pagination
  Preconditions:  None
  Contexts:       Called by user-facing list command
  Excludes:       Session content, search, deletion
  Rollback:       No sessions directory → 404 NOT_FOUND, return empty list
  Design:         Paginated results (default 20 per page); metadata-only (no message content)
  Returns:
    - Success: 200 OK — session list + nextPageToken
    - Failure: 404 NOT_FOUND — empty list
end note

== SSN-03 List Sessions ==

user -> router : types input
activate router
router -> agent : PROCESS(user_input)
activate agent

agent -> store : ssn03 LIST Sessions(pageSize=20, pageToken="abc")
activate store
store -> dir : scan ~/.nasim/sessions/
activate dir

break No sessions directory
    dir --> store : FileNotFoundError
    deactivate dir
    store --> agent : 404 NOT_FOUND — [] (empty list)
    agent --> router : AgentEvent(Done)
end

store -> store : read metadata from each session
store --> agent : 200 OK — [(id, created_at, message_count), ...], nextPageToken
agent --> router : AgentEvent(Done)

deactivate store
deactivate agent
deactivate router

note over user
  Flow:    SSN-03 → scan sessions dir → read metadata → 200 OK or 404
  State:   No state change
  Success: 200 OK — [(id, created_at, message_count), ...], nextPageToken
  Failure: 404 NOT_FOUND: no sessions directory — return empty list
end note

@enduml
