@startuml sq_ssn01_persist_session
!include ../common/sq_styles.puml
' ============================================================
' Title:     SSN-01 — Persist Session
' Boundary:  nasim code agent CLI
' Purpose:   Persist conversation history to disk
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Session Group" #E8F5E9
  participant "SessionStore" as store
end box
database "Session Directory" as dir

note over user
  Scope:          SSN-01 Persist Session — Save conversation messages to disk as JSONL
  Preconditions:  Session exists in memory with messages; disk writable
  Contexts:       Called by AGT-15 (agent process loop) after each turn; called internally by SSN-04
  Excludes:       Snapshot versioning, index updates, search indexing
  Rollback:       Disk write failure → 500 INTERNAL, log warning, session data preserved in memory
  Design:         JSONL format for append-friendly writes; single file per session; no partial writes
  Returns:
    - Success: 200 OK — save complete
    - Failure: 500 INTERNAL — disk write error
end note

== SSN-01 Save Session ==

user -> router : types input
activate router
router -> agent : PROCESS(user_input)
activate agent

agent -> store : ssn01 PERSIST Session(session_id, messages)
activate store
store -> store : serialize messages to JSON Lines
store -> dir : write session.jsonl
activate dir

break Disk write error
    dir --> store : IOError
    deactivate dir
    store --> agent : 500 INTERNAL — log warning("Session save failed")
    agent --> router : AgentEvent(Error)
end

store --> agent : 200 OK — save complete
agent --> router : AgentEvent(Done)

deactivate store
deactivate agent
deactivate router

note over user
  Flow:    SSN-01 → serialize messages → write session.jsonl → 200 OK
  State:   No state change
  Success: 200 OK — save complete
  Failure: 500 INTERNAL: disk write error — session data preserved in memory, warning logged
end note

@enduml
