@startuml sq_tool17_update_todo
' ============================================================
' Title:     TL-17 — UPDATE Todo
' Boundary:  nasim code agent
' Purpose:   Update status or content of an existing todo item
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolManager -> ToolStore -> ToolDirectory -> FileSystem
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-17 UPDATE Todo

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== TL-17 UPDATE Todo ==

user -> iface : POST /tools/update_todo:execute
activate iface
iface -> router : POST /tools/update_todo:execute
activate router
router -> mgr : TL-17 UPDATE Todo(todoId, status, description, updateMask)
router -> orch : TL-17 UPDATE Todo(todoId, status, description, updateMask)
activate orch

alt validation succeeds
  orch -> registry : TL-17 UPDATE Todo(todoId, status, description, updateMask)
  activate registry
  registry -> dir : TL-17 UPDATE Todo(todoId, status, description, updateMask)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else todo not found
  orch --> router : 404 Not Found
  deactivate orch
  router --> iface : 404 Not Found
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
else invalid transition
  orch --> router : 422 Unprocessable
  deactivate orch
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end
@enduml
