@startuml sq_tool17_update_todo
' ============================================================
' Title:     TL-17 — UPDATE Todo
' Boundary:  nasim code agent
' Purpose:   Update status or content of an existing todo item
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> TodoTool
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-17 UPDATE Todo

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "TodoTool" as tool
end box

== TL-17 UPDATE Todo ==

user -> iface : POST /tools/update_todo:execute
activate iface
iface -> router : POST /tools/update_todo:execute
activate router

router -> tool : TL-17 UPDATE Todo(todoId, status, description, updateMask)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TL-17 UPDATE Todo
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TL-17 UPDATE Todo (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else todo not found
  tool --> router : 404 Not Found
  deactivate tool
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
else invalid transition
  tool --> router : 422 Unprocessable
  deactivate tool
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end
@enduml
