@startuml sq_tool17_update_todo
' ============================================================
' Title:     TL-17 — UPDATE Todo
' Boundary:  nasim code agent
' Purpose:   Update status or content of an existing todo item
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolOrchestrator -> ToolRegistry -> ToolDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-17 UPDATE Todo

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ToolAPI" as api
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

== TL-17 UPDATE Todo ==

user -> router : POST /tools/update_todo:execute
activate router
router -> api : TL-17 UPDATE Todo(todoId, status, description, updateMask)
activate api
api -> orch : TL-17 UPDATE Todo(todoId, status, description, updateMask)
activate orch

alt validation succeeds
  orch -> registry : TL-17 UPDATE Todo(todoId, status, description, updateMask)
  activate registry
  registry -> dir : TL-17 UPDATE Todo(todoId, status, description, updateMask)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> api : 200 OK
  deactivate orch
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else todo not found
  orch --> api : 404 Not Found
  deactivate orch
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
else invalid transition
  orch --> api : 422 Unprocessable
  deactivate orch
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end
@enduml
