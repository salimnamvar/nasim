@startuml sq_tool14_list_registered_tools
' ============================================================
' Title:     TL-14 — LIST Registered Tools
' Boundary:  nasim code agent
' Purpose:   Return list of all tools registered in the ToolRegistry
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolRegistry
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-14 LIST Registered Tools

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as tool
end box

== TL-14 LIST Registered Tools ==

user -> iface : POST /tools/list_registered:execute
activate iface
iface -> router : POST /tools/list_registered:execute
activate router

router -> tool : TL-14 LIST Registered Tools(pageSize, pageToken)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TL-14 LIST Registered Tools
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TL-14 LIST Registered Tools (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else registry unavailable
  tool --> router : 503 Service Unavailable
  deactivate tool
  router --> iface : 503 Service Unavailable
  iface --> user : 503 Service Unavailable
  deactivate router
  deactivate iface
else invalid pagination
  tool --> router : 400 Bad Request
  deactivate tool
  router --> iface : 400 Bad Request
  iface --> user : 400 Bad Request
  deactivate router
  deactivate iface
end
@enduml
