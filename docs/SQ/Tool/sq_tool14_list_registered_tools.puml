@startuml sq_tool14_list_registered_tools
' ============================================================
' Title:     TL-14 — LIST Registered Tools
' Boundary:  nasim code agent
' Purpose:   Return list of all tools registered in the ToolRegistry
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolManager -> ToolStore -> ToolDirectory -> FileSystem
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-14 LIST Registered Tools

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== TL-14 LIST Registered Tools ==

user -> iface : POST /tools/list_registered:execute
activate iface
iface -> router : POST /tools/list_registered:execute
activate router
router -> mgr : TL-14 LIST Registered Tools(pageSize, pageToken)
router -> orch : TL-14 LIST Registered Tools(pageSize, pageToken)
activate orch

alt validation succeeds
  orch -> registry : TL-14 LIST Registered Tools(pageSize, pageToken)
  activate registry
  registry -> dir : TL-14 LIST Registered Tools(pageSize, pageToken)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else registry unavailable
  orch --> router : 503 Service Unavailable
  deactivate orch
  router --> iface : 503 Service Unavailable
  router --> iface : 503 Service Unavailable
  iface --> user : 503 Service Unavailable
  deactivate router
  deactivate iface
else invalid pagination
  orch --> router : 400 Bad Request
  deactivate orch
  router --> iface : 400 Bad Request
  router --> iface : 400 Bad Request
  iface --> user : 400 Bad Request
  deactivate router
  deactivate iface
end
@enduml
