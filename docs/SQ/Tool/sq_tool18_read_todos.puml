@startuml sq_tool18_read_todos
' ============================================================
' Title:     TL-18 — READ Todos
' Boundary:  nasim code agent
' Purpose:   List all todo items or filter by status
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolManager -> ToolStore -> ToolDirectory -> FileSystem
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-18 READ Todos

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== TL-18 READ Todos ==

user -> iface : POST /tools/read_todos:execute
activate iface
iface -> router : POST /tools/read_todos:execute
activate router
router -> mgr : TL-18 READ Todos(statusFilter)
router -> orch : TL-18 READ Todos(statusFilter)
activate orch

alt validation succeeds
  orch -> registry : TL-18 READ Todos(statusFilter)
  activate registry
  registry -> dir : TL-18 READ Todos(statusFilter)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
      orch -> orch : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else no todos found
  orch --> router : 404 Not Found
  deactivate orch
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
else invalid filter
  orch --> router : 400 Bad Request
  deactivate orch
  router --> iface : 400 Bad Request
  iface --> user : 400 Bad Request
  deactivate router
  deactivate iface
end
@enduml
