@startuml sq_tool18_read_todos
' ============================================================
' Title:     TL-18 — READ Todos
' Boundary:  nasim code agent
' Purpose:   List all todo items or filter by status
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolOrchestrator -> ToolRegistry -> ToolDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-18 READ Todos

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ToolAPI" as api
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

== TL-18 READ Todos ==

user -> router : POST /tools/read_todos:execute
activate router
router -> api : TL-18 READ Todos(statusFilter)
activate api
api -> orch : TL-18 READ Todos(statusFilter)
activate orch

alt validation succeeds
  orch -> registry : TL-18 READ Todos(statusFilter)
  activate registry
  registry -> dir : TL-18 READ Todos(statusFilter)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> api : 200 OK
  deactivate orch
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else no todos found
  orch --> api : 404 Not Found
  deactivate orch
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
else invalid filter
  orch --> api : 400 Bad Request
  deactivate orch
  api --> router : 400 Bad Request
  deactivate api
  router --> user : 400 Bad Request
  deactivate router
end
@enduml
