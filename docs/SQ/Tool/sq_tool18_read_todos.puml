@startuml sq_tool18_read_todos
' ============================================================
' Title:     TL-18 — READ Todos
' Boundary:  nasim code agent
' Purpose:   List all todo items or filter by status
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> TodoTool
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-18 READ Todos

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "ToolService" as tool
end box

== TL-18 READ Todos ==

user -> iface : POST /tools/read_todos:execute
activate iface
iface -> router : POST /tools/read_todos:execute
activate router

router -> tool : TL-18 READ Todos(statusFilter)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TL-18 READ Todos
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TL-18 READ Todos (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else no todos found
  tool --> router : 404 Not Found
  deactivate tool
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
else invalid filter
  tool --> router : 400 Bad Request
  deactivate tool
  router --> iface : 400 Bad Request
  iface --> user : 400 Bad Request
  deactivate router
  deactivate iface
end
@enduml
