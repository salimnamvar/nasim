@startuml sq_tool02_insert_file
' ============================================================
' Title:     TL-02 — INSERT File
' Boundary:  nasim code agent
' Purpose:   Create or overwrite a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolOrchestrator -> ToolRegistry -> ToolDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-02 INSERT File

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ToolAPI" as api
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

== TL-02 INSERT File ==

user -> router : POST /tools/insert_file:execute
activate router
router -> api : TL-02 INSERT File(path, content)
activate api
api -> orch : TL-02 INSERT File(path, content)
activate orch

alt validation succeeds
  orch -> registry : TL-02 INSERT File(path, content)
  activate registry
  registry -> dir : TL-02 INSERT File(path, content)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> api : 200 OK
  deactivate orch
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else write error
  orch --> api : 500 Internal Server Error
  deactivate orch
  api --> router : 500 Internal Server Error
  deactivate api
  router --> user : 500 Internal Server Error
  deactivate router
else permission denied
  orch --> api : 403 Forbidden
  deactivate orch
  api --> router : 403 Forbidden
  deactivate api
  router --> user : 403 Forbidden
  deactivate router
end
@enduml
