@startuml sq_tool02_insert_file
' ============================================================
' Title:     TOOL-02 — INSERT File
' Boundary:  nasim code agent
' Purpose:   Create or overwrite a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> WriteFileTool
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TOOL-02 INSERT File

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "ToolService" as tool
end box

== TOOL-02 INSERT File ==

user -> iface : POST /tools/insert_file:execute
activate iface
iface -> router : POST /tools/insert_file:execute
activate router

router -> tool : TOOL-02 INSERT File(path, content)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TOOL-02 INSERT File
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TOOL-02 INSERT File (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else write error
  tool --> router : 500 Internal Server Error
  deactivate tool
  router --> iface : 500 Internal Server Error
  iface --> user : 500 Internal Server Error
  deactivate router
  deactivate iface
else permission denied
  tool --> router : 403 Forbidden
  deactivate tool
  router --> iface : 403 Forbidden
  iface --> user : 403 Forbidden
  deactivate router
  deactivate iface
end
@enduml
