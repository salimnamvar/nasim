@startuml sq_tool08_search_find
' ============================================================
' Title:     TL-08 — SEARCH Find
' Boundary:  nasim code agent
' Purpose:   Find files by name pattern with depth limit
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> FindFileTool
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-08 SEARCH Find

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Tool Group (Repository)" #E8F5E9
  participant "FindFileTool" as tool
end box

== TL-08 SEARCH Find ==

user -> iface : POST /tools/search_find:execute
activate iface
iface -> router : POST /tools/search_find:execute
activate router

router -> tool : TL-08 SEARCH Find(namePattern, path, maxDepth)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TL-08 SEARCH Find
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TL-08 SEARCH Find (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else path not found
  tool --> router : 404 Not Found
  deactivate tool
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
else permission denied
  tool --> router : 403 Forbidden
  deactivate tool
  router --> iface : 403 Forbidden
  iface --> user : 403 Forbidden
  deactivate router
  deactivate iface
end
@enduml
