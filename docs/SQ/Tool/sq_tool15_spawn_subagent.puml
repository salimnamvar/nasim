@startuml sq_tool15_spawn_subagent
' ============================================================
' Title:     TL-15 — SPAWN Subagent
' Boundary:  nasim code agent
' Purpose:   Create a child subagent via SubagentTool
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolOrchestrator -> ToolRegistry -> ToolDirectory
' SM States: SPAWNING (#FFAB91), RUNNING (#BCAAA4)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-15 SPAWN Subagent

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ToolAPI" as api
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

== TL-15 SPAWN Subagent ==

user -> router : POST /tools/spawn_subagent:execute
activate router
router -> api : TL-15 SPAWN Subagent(prompt, subagentType)
activate api
api -> orch : TL-15 SPAWN Subagent(prompt, subagentType)
activate orch

alt validation succeeds
  orch -> registry : TL-15 SPAWN Subagent(prompt, subagentType)
  activate registry
  registry -> dir : TL-15 SPAWN Subagent(prompt, subagentType)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : SPAWNING (#FFAB91)
  hnote over orch : RUNNING (#BCAAA4)
  orch --> api : 200 OK
  deactivate orch
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else spawn limit reached
  orch --> api : 429 Too Many Requests
  deactivate orch
  api --> router : 429 Too Many Requests
  deactivate api
  router --> user : 429 Too Many Requests
  deactivate router
else spawn failed
  orch --> api : 500 Internal Server Error
  deactivate orch
  api --> router : 500 Internal Server Error
  deactivate api
  router --> user : 500 Internal Server Error
  deactivate router
end
@enduml
