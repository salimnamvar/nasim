@startuml sq_tool15_spawn_subagent
' ============================================================
' Title:     TL-15 — SPAWN Subagent
' Boundary:  nasim code agent
' Purpose:   Create a child subagent via SubagentTool
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolManager -> ToolStore -> ToolDirectory -> FileSystem
' SM States: SPAWNING (#FFAB91), RUNNING (#BCAAA4)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-15 SPAWN Subagent

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== TL-15 SPAWN Subagent ==

user -> iface : POST /tools/spawn_subagent:execute
activate iface
iface -> router : POST /tools/spawn_subagent:execute
activate router
router -> mgr : TL-15 SPAWN Subagent(prompt, subagentType)
router -> orch : TL-15 SPAWN Subagent(prompt, subagentType)
activate orch

alt validation succeeds
  orch -> registry : TL-15 SPAWN Subagent(prompt, subagentType)
  activate registry
  registry -> dir : TL-15 SPAWN Subagent(prompt, subagentType)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : SPAWNING (#FFAB91)
  hnote over orch : RUNNING (#BCAAA4)
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else spawn limit reached
  orch --> router : 429 Too Many Requests
  deactivate orch
  router --> iface : 429 Too Many Requests
  router --> iface : 429 Too Many Requests
  iface --> user : 429 Too Many Requests
  deactivate router
  deactivate iface
else spawn failed
  orch --> router : 500 Internal Server Error
  deactivate orch
  router --> iface : 500 Internal Server Error
  router --> iface : 500 Internal Server Error
  iface --> user : 500 Internal Server Error
  deactivate router
  deactivate iface
end
@enduml
