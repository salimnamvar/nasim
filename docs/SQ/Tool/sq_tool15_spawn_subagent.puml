@startuml sq_tool15_spawn_subagent
' ============================================================
' Title:     TL-15 — SPAWN Subagent
' Boundary:  nasim code agent
' Purpose:   Create a child subagent via SubagentTool
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SubagentTool
' SM States: SPAWNING (#FFAB91), RUNNING (#BCAAA4)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-15 SPAWN Subagent

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Tool Group (Repository)" #E8F5E9
  participant "SubagentTool" as tool
end box

== TL-15 SPAWN Subagent ==

user -> iface : POST /tools/spawn_subagent:execute
activate iface
iface -> router : POST /tools/spawn_subagent:execute
activate router

router -> tool : TL-15 SPAWN Subagent(prompt, subagentType)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TL-15 SPAWN Subagent
    ' State: <back:#FFAB91>SPAWNING</back> → <back:#BCAAA4>RUNNING</back>
    ' Owned by: TL-15 SPAWN Subagent (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else spawn limit reached
  tool --> router : 429 Too Many Requests
  deactivate tool
  router --> iface : 429 Too Many Requests
  iface --> user : 429 Too Many Requests
  deactivate router
  deactivate iface
else spawn failed
  tool --> router : 500 Internal Server Error
  deactivate tool
  router --> iface : 500 Internal Server Error
  iface --> user : 500 Internal Server Error
  deactivate router
  deactivate iface
end
@enduml
