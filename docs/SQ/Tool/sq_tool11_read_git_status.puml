@startuml sq_tool11_read_git_status
' ============================================================
' Title:     TL-11 — READ Git Status
' Boundary:  nasim code agent
' Purpose:   Git operations: status, diff, commit
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> GitTool
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-11 READ Git Status

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "GitTool" as tool
end box

== TL-11 READ Git Status ==

user -> iface : POST /tools/read_git_status:execute
activate iface
iface -> router : POST /tools/read_git_status:execute
activate router

router -> tool : TL-11 READ Git Status(action, args)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TL-11 READ Git Status
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TL-11 READ Git Status (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else not a git repo
  tool --> router : 422 Unprocessable
  deactivate tool
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
else git error
  tool --> router : 500 Internal Server Error
  deactivate tool
  router --> iface : 500 Internal Server Error
  iface --> user : 500 Internal Server Error
  deactivate router
  deactivate iface
end
@enduml
