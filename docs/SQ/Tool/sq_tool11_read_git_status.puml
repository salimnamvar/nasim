@startuml sq_tool11_read_git_status
' ============================================================
' Title:     TL-11 — READ Git Status
' Boundary:  nasim code agent
' Purpose:   Git operations: status, diff, commit
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolManager -> ToolStore -> ToolDirectory -> FileSystem
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-11 READ Git Status

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== TL-11 READ Git Status ==

user -> iface : POST /tools/read_git_status:execute
activate iface
iface -> router : POST /tools/read_git_status:execute
activate router
router -> mgr : TL-11 READ Git Status(action, args)
router -> orch : TL-11 READ Git Status(action, args)
activate orch

alt validation succeeds
  orch -> registry : TL-11 READ Git Status(action, args)
  activate registry
  registry -> dir : TL-11 READ Git Status(action, args)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else not a git repo
  orch --> router : 422 Unprocessable
  deactivate orch
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
else git error
  orch --> router : 500 Internal Server Error
  deactivate orch
  router --> iface : 500 Internal Server Error
  router --> iface : 500 Internal Server Error
  iface --> user : 500 Internal Server Error
  deactivate router
  deactivate iface
end
@enduml
