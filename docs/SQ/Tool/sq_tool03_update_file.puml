@startuml sq_tool03_update_file
' ============================================================
' Title:     TL-03 — UPDATE File
' Boundary:  nasim code agent
' Purpose:   Replace an exact string in a file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolOrchestrator -> ToolRegistry -> ToolDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-03 UPDATE File

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ToolAPI" as api
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

== TL-03 UPDATE File ==

user -> router : POST /tools/update_file:execute
activate router
router -> api : TL-03 UPDATE File(path, oldString, newString)
activate api
api -> orch : TL-03 UPDATE File(path, oldString, newString)
activate orch

alt validation succeeds
  orch -> registry : TL-03 UPDATE File(path, oldString, newString)
  activate registry
  registry -> dir : TL-03 UPDATE File(path, oldString, newString)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> api : 200 OK
  deactivate orch
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else string not found
  orch --> api : 404 Not Found
  deactivate orch
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
else ambiguous match
  orch --> api : 422 Unprocessable
  deactivate orch
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end
@enduml
