@startuml sq_tool22_update_plan
' ============================================================
' Title:     TOOL-22 — UPDATE Plan
' Boundary:  nasim code agent
' Purpose:   Update status or content of an existing plan step
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> PlanTool
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TOOL-22 UPDATE Plan

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "ToolService" as tool
end box

== TOOL-22 UPDATE Plan ==

user -> iface : POST /tools/update_plan:execute
activate iface
iface -> router : POST /tools/update_plan:execute
activate router

router -> tool : TOOL-22 UPDATE Plan(stepId, status, description, updateMask)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TOOL-22 UPDATE Plan
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TOOL-22 UPDATE Plan (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else step not found
  tool --> router : 404 Not Found
  deactivate tool
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
else invalid transition
  tool --> router : 422 Unprocessable
  deactivate tool
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end
@enduml
