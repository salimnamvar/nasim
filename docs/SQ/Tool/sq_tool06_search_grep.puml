@startuml sq_tool06_search_grep
' ============================================================
' Title:     TL-06 — SEARCH Grep
' Boundary:  nasim code agent
' Purpose:   Search file contents by regex pattern
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> GrepTool
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-06 SEARCH Grep

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Tool Group (Repository)" #E8F5E9
  participant "GrepTool" as tool
end box

== TL-06 SEARCH Grep ==

user -> iface : POST /tools/search_grep:execute
activate iface
iface -> router : POST /tools/search_grep:execute
activate router

router -> tool : TL-06 SEARCH Grep(pattern, path, caseSensitive, includeGlob)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TL-06 SEARCH Grep
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TL-06 SEARCH Grep (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else no matches
  tool --> router : 404 Not Found
  deactivate tool
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
else path error
  tool --> router : 400 Bad Request
  deactivate tool
  router --> iface : 400 Bad Request
  iface --> user : 400 Bad Request
  deactivate router
  deactivate iface
end
@enduml
