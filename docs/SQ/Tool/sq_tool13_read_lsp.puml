@startuml sq_tool13_read_lsp
' ============================================================
' Title:     TL-13 — READ LSP
' Boundary:  nasim code agent
' Purpose:   Query LSP server for hover, definition, or references
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolManager -> ToolStore -> ToolDirectory -> FileSystem
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-13 READ LSP

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== TL-13 READ LSP ==

user -> iface : POST /tools/read_lsp:execute
activate iface
iface -> router : POST /tools/read_lsp:execute
activate router
router -> mgr : TL-13 READ LSP(query, params)
router -> orch : TL-13 READ LSP(query, params)
activate orch

alt validation succeeds
  orch -> registry : TL-13 READ LSP(query, params)
  activate registry
  registry -> dir : TL-13 READ LSP(query, params)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
      orch -> orch : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else server unreachable
  orch --> router : 502 Bad Gateway
  deactivate orch
  router --> iface : 502 Bad Gateway
  iface --> user : 502 Bad Gateway
  deactivate router
  deactivate iface
else no results
  orch --> router : 404 Not Found
  deactivate orch
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end
@enduml
