@startuml sq_tool13_read_lsp
' ============================================================
' Title:     TL-13 — READ LSP
' Boundary:  nasim code agent
' Purpose:   Query LSP server for hover, definition, or references
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolOrchestrator -> ToolRegistry -> ToolDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-13 READ LSP

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ToolAPI" as api
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

== TL-13 READ LSP ==

user -> router : POST /tools/read_lsp:execute
activate router
router -> api : TL-13 READ LSP(query, params)
activate api
api -> orch : TL-13 READ LSP(query, params)
activate orch

alt validation succeeds
  orch -> registry : TL-13 READ LSP(query, params)
  activate registry
  registry -> dir : TL-13 READ LSP(query, params)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> api : 200 OK
  deactivate orch
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else server unreachable
  orch --> api : 502 Bad Gateway
  deactivate orch
  api --> router : 502 Bad Gateway
  deactivate api
  router --> user : 502 Bad Gateway
  deactivate router
else no results
  orch --> api : 404 Not Found
  deactivate orch
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end
@enduml
