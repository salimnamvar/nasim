@startuml sq_tool04_list_directory
' ============================================================
' Title:     TL-04 — LIST Directory
' Boundary:  nasim code agent
' Purpose:   List files and directories at a path with pagination
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolOrchestrator -> ToolRegistry -> ToolDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-04 LIST Directory

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ToolAPI" as api
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

== TL-04 LIST Directory ==

user -> router : POST /tools/list_directory:execute
activate router
router -> api : TL-04 LIST Directory(path, pageSize, pageToken)
activate api
api -> orch : TL-04 LIST Directory(path, pageSize, pageToken)
activate orch

alt validation succeeds
  orch -> registry : TL-04 LIST Directory(path, pageSize, pageToken)
  activate registry
  registry -> dir : TL-04 LIST Directory(path, pageSize, pageToken)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> api : 200 OK
  deactivate orch
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else path not found
  orch --> api : 404 Not Found
  deactivate orch
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
else not a directory
  orch --> api : 422 Unprocessable
  deactivate orch
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end
@enduml
