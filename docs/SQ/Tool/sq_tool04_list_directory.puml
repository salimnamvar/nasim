@startuml sq_tool04_list_directory
' ============================================================
' Title:     TL-04 — LIST Directory
' Boundary:  nasim code agent
' Purpose:   List files and directories at a path with pagination
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> DirTool
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-04 LIST Directory

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "DirTool" as tool
end box

== TL-04 LIST Directory ==

user -> iface : POST /tools/list_directory:execute
activate iface
iface -> router : POST /tools/list_directory:execute
activate router

router -> tool : TL-04 LIST Directory(path, pageSize, pageToken)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TL-04 LIST Directory
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TL-04 LIST Directory (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else path not found
  tool --> router : 404 Not Found
  deactivate tool
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
else not a directory
  tool --> router : 422 Unprocessable
  deactivate tool
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end
@enduml
