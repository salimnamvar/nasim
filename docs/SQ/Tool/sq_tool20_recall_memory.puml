@startuml sq_tool20_recall_memory
' ============================================================
' Title:     TOOL-20 — RECALL Memory
' Boundary:  nasim code agent
' Purpose:   Recall knowledge from memory via MemoryTool
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> MemoryTool
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TOOL-20 RECALL Memory

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "ToolService" as tool
end box

== TOOL-20 RECALL Memory ==

user -> iface : POST /tools/recall_memory:execute
activate iface
iface -> router : POST /tools/recall_memory:execute
activate router

router -> tool : TOOL-20 RECALL Memory(query, scope)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TOOL-20 RECALL Memory
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TOOL-20 RECALL Memory (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else no matching knowledge
  tool --> router : 404 Not Found
  deactivate tool
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
else invalid query
  tool --> router : 400 Bad Request
  deactivate tool
  router --> iface : 400 Bad Request
  iface --> user : 400 Bad Request
  deactivate router
  deactivate iface
end
@enduml
