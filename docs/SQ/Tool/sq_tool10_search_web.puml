@startuml sq_tool10_search_web
' ============================================================
' Title:     TL-10 — SEARCH Web
' Boundary:  nasim code agent
' Purpose:   Search the web for information
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolOrchestrator -> ToolRegistry -> ToolDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-10 SEARCH Web

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ToolAPI" as api
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

== TL-10 SEARCH Web ==

user -> router : POST /tools/search_web:execute
activate router
router -> api : TL-10 SEARCH Web(query, numResults)
activate api
api -> orch : TL-10 SEARCH Web(query, numResults)
activate orch

alt validation succeeds
  orch -> registry : TL-10 SEARCH Web(query, numResults)
  activate registry
  registry -> dir : TL-10 SEARCH Web(query, numResults)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> api : 200 OK
  deactivate orch
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else backend unavailable
  orch --> api : 503 Service Unavailable
  deactivate orch
  api --> router : 503 Service Unavailable
  deactivate api
  router --> user : 503 Service Unavailable
  deactivate router
else invalid query
  orch --> api : 400 Bad Request
  deactivate orch
  api --> router : 400 Bad Request
  deactivate api
  router --> user : 400 Bad Request
  deactivate router
end
@enduml
