@startuml sq_tool10_search_web
' ============================================================
' Title:     TL-10 — SEARCH Web
' Boundary:  nasim code agent
' Purpose:   Search the web for information
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolManager -> ToolStore -> ToolDirectory -> FileSystem
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-10 SEARCH Web

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== TL-10 SEARCH Web ==

user -> iface : POST /tools/search_web:execute
activate iface
iface -> router : POST /tools/search_web:execute
activate router
router -> mgr : TL-10 SEARCH Web(query, numResults)
router -> orch : TL-10 SEARCH Web(query, numResults)
activate orch

alt validation succeeds
  orch -> registry : TL-10 SEARCH Web(query, numResults)
  activate registry
  registry -> dir : TL-10 SEARCH Web(query, numResults)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
      orch -> orch : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else backend unavailable
  orch --> router : 503 Service Unavailable
  deactivate orch
  router --> iface : 503 Service Unavailable
  iface --> user : 503 Service Unavailable
  deactivate router
  deactivate iface
else invalid query
  orch --> router : 400 Bad Request
  deactivate orch
  router --> iface : 400 Bad Request
  iface --> user : 400 Bad Request
  deactivate router
  deactivate iface
end
@enduml
