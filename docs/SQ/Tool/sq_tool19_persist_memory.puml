@startuml sq_tool19_persist_memory
' ============================================================
' Title:     TL-19 — PERSIST Memory
' Boundary:  nasim code agent
' Purpose:   Persist knowledge to memory via MemoryTool
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolManager -> ToolStore -> ToolDirectory -> FileSystem
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-19 PERSIST Memory

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== TL-19 PERSIST Memory ==

user -> iface : POST /tools/persist_memory:execute
activate iface
iface -> router : POST /tools/persist_memory:execute
activate router
router -> mgr : TL-19 PERSIST Memory(key, value, scope)
router -> orch : TL-19 PERSIST Memory(key, value, scope)
activate orch

alt validation succeeds
  orch -> registry : TL-19 PERSIST Memory(key, value, scope)
  activate registry
  registry -> dir : TL-19 PERSIST Memory(key, value, scope)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
      orch -> orch : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else storage failure
  orch --> router : 500 Internal Server Error
  deactivate orch
  router --> iface : 500 Internal Server Error
  iface --> user : 500 Internal Server Error
  deactivate router
  deactivate iface
else invalid scope
  orch --> router : 422 Unprocessable
  deactivate orch
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end
@enduml
