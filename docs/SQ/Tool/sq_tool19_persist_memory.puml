@startuml sq_tool19_persist_memory
' ============================================================
' Title:     TL-19 — PERSIST Memory
' Boundary:  nasim code agent
' Purpose:   Persist knowledge to memory via MemoryTool
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolOrchestrator -> ToolRegistry -> ToolDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-19 PERSIST Memory

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ToolAPI" as api
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

== TL-19 PERSIST Memory ==

user -> router : POST /tools/persist_memory:execute
activate router
router -> api : TL-19 PERSIST Memory(key, value, scope)
activate api
api -> orch : TL-19 PERSIST Memory(key, value, scope)
activate orch

alt validation succeeds
  orch -> registry : TL-19 PERSIST Memory(key, value, scope)
  activate registry
  registry -> dir : TL-19 PERSIST Memory(key, value, scope)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> api : 200 OK
  deactivate orch
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else storage failure
  orch --> api : 500 Internal Server Error
  deactivate orch
  api --> router : 500 Internal Server Error
  deactivate api
  router --> user : 500 Internal Server Error
  deactivate router
else invalid scope
  orch --> api : 422 Unprocessable
  deactivate orch
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end
@enduml
