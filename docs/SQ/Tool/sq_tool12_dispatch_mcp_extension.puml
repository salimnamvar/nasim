@startuml sq_tool12_dispatch_mcp_extension
' ============================================================
' Title:     TL-12 — DISPATCH MCP Extension
' Boundary:  nasim code agent
' Purpose:   Invoke tools from MCP server extensions
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolManager -> ToolStore -> ToolDirectory -> FileSystem
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-12 DISPATCH MCP Extension

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== TL-12 DISPATCH MCP Extension ==

user -> iface : POST /tools/dispatch_mcp:execute
activate iface
iface -> router : POST /tools/dispatch_mcp:execute
activate router
router -> mgr : TL-12 DISPATCH MCP Extension(toolName, args)
router -> orch : TL-12 DISPATCH MCP Extension(toolName, args)
activate orch

alt validation succeeds
  orch -> registry : TL-12 DISPATCH MCP Extension(toolName, args)
  activate registry
  registry -> dir : TL-12 DISPATCH MCP Extension(toolName, args)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
      orch -> orch : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else server unreachable
  orch --> router : 502 Bad Gateway
  deactivate orch
  router --> iface : 502 Bad Gateway
  iface --> user : 502 Bad Gateway
  deactivate router
  deactivate iface
else tool not found
  orch --> router : 404 Not Found
  deactivate orch
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end
@enduml
