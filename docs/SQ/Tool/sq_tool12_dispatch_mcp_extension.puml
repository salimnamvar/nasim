@startuml sq_tool12_dispatch_mcp_extension
' ============================================================
' Title:     TL-12 — DISPATCH MCP Extension
' Boundary:  nasim code agent
' Purpose:   Invoke tools from MCP server extensions
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolOrchestrator -> ToolRegistry -> ToolDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-12 DISPATCH MCP Extension

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ToolAPI" as api
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

== TL-12 DISPATCH MCP Extension ==

user -> router : POST /tools/dispatch_mcp:execute
activate router
router -> api : TL-12 DISPATCH MCP Extension(toolName, args)
activate api
api -> orch : TL-12 DISPATCH MCP Extension(toolName, args)
activate orch

alt validation succeeds
  orch -> registry : TL-12 DISPATCH MCP Extension(toolName, args)
  activate registry
  registry -> dir : TL-12 DISPATCH MCP Extension(toolName, args)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> api : 200 OK
  deactivate orch
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else server unreachable
  orch --> api : 502 Bad Gateway
  deactivate orch
  api --> router : 502 Bad Gateway
  deactivate api
  router --> user : 502 Bad Gateway
  deactivate router
else tool not found
  orch --> api : 404 Not Found
  deactivate orch
  api --> router : 404 Not Found
  deactivate api
  router --> user : 404 Not Found
  deactivate router
end
@enduml
