@startuml sq_tool12_dispatch_mcp_extension
' ============================================================
' Title:     TL-12 — DISPATCH MCP Extension
' Boundary:  nasim code agent
' Purpose:   Invoke tools from MCP server extensions
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> MCPRepository
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-12 DISPATCH MCP Extension

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "MCPRepository" as tool
end box

== TL-12 DISPATCH MCP Extension ==

user -> iface : POST /tools/dispatch_mcp:execute
activate iface
iface -> router : POST /tools/dispatch_mcp:execute
activate router

router -> tool : TL-12 DISPATCH MCP Extension(toolName, args)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TL-12 DISPATCH MCP Extension
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TL-12 DISPATCH MCP Extension (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else server unreachable
  tool --> router : 502 Bad Gateway
  deactivate tool
  router --> iface : 502 Bad Gateway
  iface --> user : 502 Bad Gateway
  deactivate router
  deactivate iface
else tool not found
  tool --> router : 404 Not Found
  deactivate tool
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end
@enduml
