@startuml sq_tool09_fetch_web_content
' ============================================================
' Title:     TL-09 — FETCH Web Content
' Boundary:  nasim code agent
' Purpose:   Fetch URL content and convert to markdown
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolOrchestrator -> ToolRegistry -> ToolDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-09 FETCH Web Content

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ToolAPI" as api
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

== TL-09 FETCH Web Content ==

user -> router : POST /tools/fetch_web:execute
activate router
router -> api : TL-09 FETCH Web Content(url, timeout)
activate api
api -> orch : TL-09 FETCH Web Content(url, timeout)
activate orch

alt validation succeeds
  orch -> registry : TL-09 FETCH Web Content(url, timeout)
  activate registry
  registry -> dir : TL-09 FETCH Web Content(url, timeout)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> api : 200 OK
  deactivate orch
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else http error
  orch --> api : 502 Bad Gateway
  deactivate orch
  api --> router : 502 Bad Gateway
  deactivate api
  router --> user : 502 Bad Gateway
  deactivate router
else timeout
  orch --> api : 504 Gateway Timeout
  deactivate orch
  api --> router : 504 Gateway Timeout
  deactivate api
  router --> user : 504 Gateway Timeout
  deactivate router
end
@enduml
