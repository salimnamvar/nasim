@startuml sq_tool09_fetch_web_content
' ============================================================
' Title:     TL-09 — FETCH Web Content
' Boundary:  nasim code agent
' Purpose:   Fetch URL content and convert to markdown
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolManager -> ToolStore -> ToolDirectory -> FileSystem
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-09 FETCH Web Content

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== TL-09 FETCH Web Content ==

user -> iface : POST /tools/fetch_web:execute
activate iface
iface -> router : POST /tools/fetch_web:execute
activate router
router -> mgr : TL-09 FETCH Web Content(url, timeout)
router -> orch : TL-09 FETCH Web Content(url, timeout)
activate orch

alt validation succeeds
  orch -> registry : TL-09 FETCH Web Content(url, timeout)
  activate registry
  registry -> dir : TL-09 FETCH Web Content(url, timeout)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
      orch -> orch : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else http error
  orch --> router : 502 Bad Gateway
  deactivate orch
  router --> iface : 502 Bad Gateway
  iface --> user : 502 Bad Gateway
  deactivate router
  deactivate iface
else timeout
  orch --> router : 504 Gateway Timeout
  deactivate orch
  router --> iface : 504 Gateway Timeout
  iface --> user : 504 Gateway Timeout
  deactivate router
  deactivate iface
end
@enduml
