@startuml sq_tool05_dispatch_shell_command
' ============================================================
' Title:     TL-05 — DISPATCH Shell Command
' Boundary:  nasim code agent
' Purpose:   Shell command execution with timeout
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolOrchestrator -> ToolRegistry -> ToolDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-05 DISPATCH Shell Command

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ToolAPI" as api
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

== TL-05 DISPATCH Shell Command ==

user -> router : POST /tools/dispatch_shell:execute
activate router
router -> api : TL-05 DISPATCH Shell Command(command, timeout)
activate api
api -> orch : TL-05 DISPATCH Shell Command(command, timeout)
activate orch

alt validation succeeds
  orch -> registry : TL-05 DISPATCH Shell Command(command, timeout)
  activate registry
  registry -> dir : TL-05 DISPATCH Shell Command(command, timeout)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
  hnote over orch : TOOL_EXEC (#B2DFDB)
  orch --> api : 200 OK
  deactivate orch
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else timeout
  orch --> api : 408 Request Timeout
  deactivate orch
  api --> router : 408 Request Timeout
  deactivate api
  router --> user : 408 Request Timeout
  deactivate router
else execution error
  orch --> api : 500 Internal Server Error
  deactivate orch
  api --> router : 500 Internal Server Error
  deactivate api
  router --> user : 500 Internal Server Error
  deactivate router
end
@enduml
