@startuml sq_tool05_dispatch_shell_command
' ============================================================
' Title:     TL-05 — DISPATCH Shell Command
' Boundary:  nasim code agent
' Purpose:   Shell command execution with timeout
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolManager -> ToolStore -> ToolDirectory -> FileSystem
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-05 DISPATCH Shell Command

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Tool Group (Service)" #FFF3E0
  participant "ToolOrchestrator" as orch
end box
box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box
database "ToolDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== TL-05 DISPATCH Shell Command ==

user -> iface : POST /tools/dispatch_shell:execute
activate iface
iface -> router : POST /tools/dispatch_shell:execute
activate router
router -> mgr : TL-05 DISPATCH Shell Command(command, timeout)
router -> orch : TL-05 DISPATCH Shell Command(command, timeout)
activate orch

alt validation succeeds
  orch -> registry : TL-05 DISPATCH Shell Command(command, timeout)
  activate registry
  registry -> dir : TL-05 DISPATCH Shell Command(command, timeout)
  activate dir
  dir --> registry : 200 OK
  deactivate dir
  registry --> orch : 200 OK
  deactivate registry
      orch -> orch : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else timeout
  orch --> router : 408 Request Timeout
  deactivate orch
  router --> iface : 408 Request Timeout
  iface --> user : 408 Request Timeout
  deactivate router
  deactivate iface
else execution error
  orch --> router : 500 Internal Server Error
  deactivate orch
  router --> iface : 500 Internal Server Error
  iface --> user : 500 Internal Server Error
  deactivate router
  deactivate iface
end
@enduml
