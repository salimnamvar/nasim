@startuml sq_tool05_dispatch_shell_command
' ============================================================
' Title:     TL-05 — DISPATCH Shell Command
' Boundary:  nasim code agent
' Purpose:   Shell command execution with timeout
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ShellTool
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- TL-05 DISPATCH Shell Command

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Tool Group (Repository)" #E8F5E9
  participant "ShellTool" as tool
end box

== TL-05 DISPATCH Shell Command ==

user -> iface : POST /tools/dispatch_shell:execute
activate iface
iface -> router : POST /tools/dispatch_shell:execute
activate router

router -> tool : TL-05 DISPATCH Shell Command(command, timeout)
activate tool

alt validation succeeds
  tool --> router : 200 OK
  deactivate tool
  ref over tool : TL-05 DISPATCH Shell Command
    ' State: <back:#B2DFDB>TOOL_EXEC</back>
    ' Owned by: TL-05 DISPATCH Shell Command (SM/README.md)
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else timeout
  tool --> router : 408 Request Timeout
  deactivate tool
  router --> iface : 408 Request Timeout
  iface --> user : 408 Request Timeout
  deactivate router
  deactivate iface
else execution error
  tool --> router : 500 Internal Server Error
  deactivate tool
  router --> iface : 500 Internal Server Error
  iface --> user : 500 Internal Server Error
  deactivate router
  deactivate iface
end
@enduml
