@startuml sq_vcs04_auto_commit
' ============================================================
' Title:     VCS-04 — AUTO-COMMIT
' Boundary:  nasim code agent
' Purpose:   Automatically commit changes with generated message
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> GitManager -> GitStore -> GitDirectory -> GitRepository
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- VCS-04 AUTO-COMMIT

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Git Group (Service)" #FFF3E0
  participant "GitManager" as mgr
end box
box "Git Group (Repository)" #E8F5E9
  participant "GitStore" as store
end box
database "GitDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "GitRepository" as GitRepository
end box



== VCS-04 AUTO-COMMIT ==

user -> iface : POST /git/auto-commit
activate iface
iface -> router : POST /git/auto-commit
activate router
router -> mgr : VCS-04 AUTO-COMMIT({repo_path, stage_all})
activate mgr

alt validation succeeds
  mgr -> store : VCS-04 AUTO-COMMIT({repo_path, stage_all})
  activate store
  store -> dir : VCS-04 AUTO-COMMIT({repo_path, stage_all})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#B2DFDB>TOOL_EXEC</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
