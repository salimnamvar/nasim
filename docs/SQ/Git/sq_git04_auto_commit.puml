@startuml sq_git04_auto_commit
' ============================================================
' Title:     VCS-04 — AUTO-COMMIT
' Boundary:  nasim code agent
' Purpose:   Automatically commit changes with generated message
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> GitIntegration
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- VCS-04 AUTO-COMMIT

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Git Group (Repository)" #E8F5E9
  participant "GitIntegration" as mgr
end box

== VCS-04 AUTO-COMMIT ==

user -> iface : POST /git/auto-commit
activate iface
iface -> router : POST /git/auto-commit
activate router
router -> mgr : VCS-04 AUTOCOMMIT Repo({repo_path, stage_all})
activate mgr

alt validation succeeds
  ref over mgr : VCS-04 AUTO-COMMIT
    ' Git lifecycle: → TOOL_EXEC (#B2DFDB)
    ' Owned by: VCS-04 AUTO-COMMIT (SM/README.md)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
