@startuml sq_vcs01_read_git_status
' ============================================================
' Title:     VCS-01 — READ Git Status
' Boundary:  nasim code agent
' Purpose:   Read working tree status and staged changes
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> GitAPI -> GitManager -> GitStore -> GitDirectory
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- VCS-01 READ Git Status

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "GitAPI" as api
end box
box "Git Group (Service)" #FFF3E0
  participant "GitManager" as mgr
end box
box "Git Group (Repository)" #E8F5E9
  participant "GitStore" as store
end box
database "GitDirectory" as dir

== VCS-01 READ Git Status ==

user -> router : GET /git/status
activate router
router -> api : VCS-01 READ Git Status({repo_path})
activate api
api -> mgr : VCS-01 READ Git Status({repo_path})
activate mgr

alt validation succeeds
  mgr -> store : VCS-01 READ Git Status({repo_path})
  activate store
  store -> dir : VCS-01 READ Git Status({repo_path})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : TOOL_EXEC (#B2DFDB) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
