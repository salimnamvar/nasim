@startuml sq_git02_insert_commit
' ============================================================
' Title:     GIT-02 — INSERT Commit
' Boundary:  nasim code agent
' Purpose:   Create a new commit from staged changes
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> GitIntegration
' SM States: TOOL_EXEC (#B2DFDB)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- GIT-02 INSERT Commit

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "GitRepository" as mgr
end box

== GIT-02 INSERT Commit ==

user -> iface : POST /git/commit
activate iface
iface -> router : POST /git/commit
activate router
router -> mgr : GIT-02 INSERT Commit({repo_path, message, files})
activate mgr

alt validation succeeds
  ref over mgr : GIT-02 INSERT Commit({repo_path, message, files}) <back:#B2DFDB>TOOL_EXEC</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "GIT-02_COMMIT_FAILED", message: "Git commit failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "GIT-02_COMMIT_FAILED", message: "Git commit failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "GIT-02_COMMIT_FAILED", message: "Git commit failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
