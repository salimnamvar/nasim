@startuml sq_plugins04_register_plugin_hooks
' ============================================================
' Title:     PLUGINS-04 — REGISTER Plugin Hooks
' Boundary:  nasim code agent
' Purpose:   Register all hooks declared in a plugin manifest
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> PluginLoader
' SM States: LOADED (#90CAF9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLUGINS-04 REGISTER Plugin Hooks

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "ToolService" as svc
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "ToolService" as mgr
end box

== PLUGINS-04 REGISTER Plugin Hooks ==

user -> iface : PLUGINS-04 REGISTER Plugin Hooks({manifest})
activate iface
iface -> router : PLUGINS-04 REGISTER Plugin Hooks({manifest})
activate router
router -> svc : PLUGINS-04 REGISTER Plugin Hooks({manifest})
activate svc
svc -> mgr : PLUGINS-04 REGISTER Plugin Hooks({manifest})
activate mgr

alt validation succeeds
  ref over mgr : PLUGINS-04 REGISTER Plugin Hooks <back:#90CAF9>LOADED</back> <back:#90CAF9>LOADED</back>
  mgr --> svc : 200 OK
  deactivate mgr
  svc --> router : 200 OK
  deactivate svc
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else registration fails
  mgr --> svc : 422 UNPROCESSABLE\n{error: {code: "PLUGINS-04_HOOK_REGISTRATION_FAILED", message: "Hook registration failed", status: 422}}
  deactivate mgr
  svc --> router : 422 UNPROCESSABLE\n{error: {code: "PLUGINS-04_HOOK_REGISTRATION_FAILED", message: "Hook registration failed", status: 422}}
  deactivate svc
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "PLUGINS-04_HOOK_REGISTRATION_FAILED", message: "Hook registration failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "PLUGINS-04_HOOK_REGISTRATION_FAILED", message: "Hook registration failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
