@startuml sq_plugins04_register_plugin_hooks
' ============================================================
' Title:     PLG-04 — REGISTER Plugin Hooks
' Boundary:  nasim code agent
' Purpose:   Register all hooks declared in a plugin manifest
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> PluginAPI -> PluginManager -> PluginStore -> PluginDirectory
' SM States: LOADED (#90CAF9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-04 REGISTER Plugin Hooks

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "PluginAPI" as api
end box
box "Plugins Group (Service)" #FFF3E0
  participant "PluginManager" as mgr
end box
box "Plugins Group (Repository)" #E8F5E9
  participant "PluginStore" as store
end box
database "PluginDirectory" as dir

== PLG-04 REGISTER Plugin Hooks ==

user -> router : POST /plugins/{id}/hooks:register
activate router
router -> api : PLG-04 REGISTER Plugin Hooks({manifest})
activate api
api -> mgr : PLG-04 REGISTER Plugin Hooks({manifest})
activate mgr

alt validation succeeds
  mgr -> store : PLG-04 REGISTER Plugin Hooks({manifest})
  activate store
  store -> dir : PLG-04 REGISTER Plugin Hooks({manifest})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : LOADED (#90CAF9)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else registration fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
