@startuml sq_plugins04_register_plugin_hooks
' ============================================================
' Title:     PLG-04 — REGISTER Plugin Hooks
' Boundary:  nasim code agent
' Purpose:   Register all hooks declared in a plugin manifest
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginLoader
' SM States: LOADED (#90CAF9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-04 REGISTER Plugin Hooks

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "PluginLoader" as mgr
end box

== PLG-04 REGISTER Plugin Hooks ==

user -> iface : POST /plugins/{id}/hooks:register
activate iface
iface -> router : POST /plugins/{id}/hooks:register
activate router
router -> mgr : PLG-04 REGISTER Plugin Hooks({manifest})
activate mgr

alt validation succeeds
  ref over mgr : PLG-04 TRANSITION State
    ' SM States: LOADED (#90CAF9)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else registration fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
