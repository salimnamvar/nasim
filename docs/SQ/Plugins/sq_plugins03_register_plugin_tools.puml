@startuml sq_plugins03_register_plugin_tools
' ============================================================
' Title:     PLG-03 — REGISTER Plugin Tools
' Boundary:  nasim code agent
' Purpose:   Register all tools declared in a plugin manifest
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> PluginAPI -> PluginManager -> PluginStore -> PluginDirectory
' SM States: LOADED (#90CAF9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-03 REGISTER Plugin Tools

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "PluginAPI" as api
end box
box "Plugins Group (Service)" #FFF3E0
  participant "PluginManager" as mgr
end box
box "Plugins Group (Repository)" #E8F5E9
  participant "PluginStore" as store
end box
database "PluginDirectory" as dir

== PLG-03 REGISTER Plugin Tools ==

user -> router : POST /plugins/{id}/tools:register
activate router
router -> api : PLG-03 REGISTER Plugin Tools({manifest})
activate api
api -> mgr : PLG-03 REGISTER Plugin Tools({manifest})
activate mgr

alt validation succeeds
  mgr -> store : PLG-03 REGISTER Plugin Tools({manifest})
  activate store
  store -> dir : PLG-03 REGISTER Plugin Tools({manifest})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : LOADED (#90CAF9)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else collision detected
  mgr --> api : 409 Conflict
  deactivate mgr
  api --> router : 409 Conflict
  deactivate api
  router --> user : 409 Conflict
  deactivate router
end

@enduml
