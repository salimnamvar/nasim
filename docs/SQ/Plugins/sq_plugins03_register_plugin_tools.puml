@startuml sq_plugins03_register_plugin_tools
' ============================================================
' Title:     PLG-03 — REGISTER Plugin Tools
' Boundary:  nasim code agent
' Purpose:   Register all tools declared in a plugin manifest
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginsManager -> PluginsStore -> PluginsDirectory -> PluginRuntime
' SM States: LOADED (#90CAF9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-03 REGISTER Plugin Tools

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Plugins Group (Service)" #FFF3E0
  participant "PluginManager" as mgr
end box
box "Plugins Group (Repository)" #E8F5E9
  participant "PluginStore" as store
end box
database "PluginDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "PluginRuntime" as PluginRuntime
end box



== PLG-03 REGISTER Plugin Tools ==

user -> iface : POST /plugins/{id}/tools:register
activate iface
iface -> router : POST /plugins/{id}/tools:register
activate router
router -> mgr : PLG-03 REGISTER Plugin Tools({manifest})
activate mgr

alt validation succeeds
  mgr -> store : PLG-03 REGISTER Plugin Tools({manifest})
  activate store
  store -> dir : PLG-03 REGISTER Plugin Tools({manifest})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#90CAF9>LOADED</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else collision detected
  mgr --> router : 409 Conflict
  deactivate mgr
  router --> iface : 409 Conflict
  iface --> user : 409 Conflict
  deactivate router
  deactivate iface
end

@enduml
