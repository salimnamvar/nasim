@startuml sq_plugins03_register_plugin_tools
' ============================================================
' Title:     PLG-03 — REGISTER Plugin Tools
' Boundary:  nasim code agent
' Purpose:   Register all tools declared in a plugin manifest
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> PluginLoader
' SM States: LOADED (#90CAF9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-03 REGISTER Plugin Tools

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "ToolService" as svc
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "ToolService" as mgr
end box

== PLG-03 REGISTER Plugin Tools ==

user -> iface : PLG-03 REGISTER Plugin Tools({manifest})
activate iface
iface -> router : PLG-03 REGISTER Plugin Tools({manifest})
activate router
router -> svc : PLG-03 REGISTER Plugin Tools({manifest})
activate svc
svc -> mgr : PLG-03 REGISTER Plugin Tools({manifest})
activate mgr

alt validation succeeds
  ref over mgr : PLG-03 REGISTER Plugin Tools <back:#90CAF9>LOADED</back> <back:#90CAF9>LOADED</back>
  mgr --> svc : 200 OK
  deactivate mgr
  svc --> router : 200 OK
  deactivate svc
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else collision detected
  mgr --> svc : 409 CONFLICT\n{error: {code: "PLG-03_TOOL_COLLISION", message: "Tool collision detected", status: 409}}
  deactivate mgr
  svc --> router : 409 CONFLICT\n{error: {code: "PLG-03_TOOL_COLLISION", message: "Tool collision detected", status: 409}}
  deactivate svc
  router --> iface : 409 CONFLICT\n{error: {code: "PLG-03_TOOL_COLLISION", message: "Tool collision detected", status: 409}}
  iface --> user : 409 CONFLICT\n{error: {code: "PLG-03_TOOL_COLLISION", message: "Tool collision detected", status: 409}}
  deactivate router
  deactivate iface
end

@enduml
