@startuml sq_plugins03_register_plugin_tools
' ============================================================
' Title:     PLG-03 — REGISTER Plugin Tools
' Boundary:  nasim code agent
' Purpose:   Register all tools declared in a plugin manifest
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginLoader
' SM States: LOADED (#90CAF9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-03 REGISTER Plugin Tools

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "PluginLoader" as mgr
end box

== PLG-03 REGISTER Plugin Tools ==

user -> iface : POST /plugins/{id}/tools:register
activate iface
iface -> router : POST /plugins/{id}/tools:register
activate router
router -> mgr : PLG-03 REGISTER Plugin Tools({manifest})
activate mgr

alt validation succeeds
  ref over mgr : PLG-03 TRANSITION State
    ' SM States: LOADED (#90CAF9)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else collision detected
  mgr --> router : 409 Conflict
  deactivate mgr
  router --> iface : 409 Conflict
  iface --> user : 409 Conflict
  deactivate router
  deactivate iface
end

@enduml
