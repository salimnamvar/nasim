@startuml sq_plugins05_enable_plugin
' ============================================================
' Title:     PLG-05 — ENABLE Plugin
' Boundary:  nasim code agent
' Purpose:   Load plugin and activate its tools and hooks
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginsManager -> PluginsStore -> PluginsDirectory -> PluginRuntime
' SM States: ENABLED (#4CAF50), ERROR (#EF5350)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-05 ENABLE Plugin

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Plugins Group (Service)" #FFF3E0
  participant "PluginManager" as mgr
end box
box "Plugins Group (Repository)" #E8F5E9
  participant "PluginStore" as store
end box
database "PluginDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "PluginRuntime" as PluginRuntime
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "PluginRuntime" as PluginRuntime
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "PluginRuntime" as PluginRuntime
end box

== PLG-05 ENABLE Plugin ==

user -> iface : POST /plugins/{id}:enable
activate iface
iface -> router : POST /plugins/{id}:enable
activate router
router -> mgr : PLG-05 ENABLE Plugin({plugin_id})
activate mgr

alt validation succeeds
  mgr -> store : PLG-05 ENABLE Plugin({plugin_id})
  activate store
  store -> dir : PLG-05 ENABLE Plugin({plugin_id})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : ENABLED (#4CAF50)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else activation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
