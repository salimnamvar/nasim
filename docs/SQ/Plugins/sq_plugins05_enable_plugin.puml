@startuml sq_plugins05_enable_plugin
' ============================================================
' Title:     PLG-05 — ENABLE Plugin
' Boundary:  nasim code agent
' Purpose:   Load plugin and activate its tools and hooks
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> PluginAPI -> PluginManager -> PluginStore -> PluginDirectory
' SM States: ENABLED (#4CAF50), ERROR (#EF5350)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-05 ENABLE Plugin

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "PluginAPI" as api
end box
box "Plugins Group (Service)" #FFF3E0
  participant "PluginManager" as mgr
end box
box "Plugins Group (Repository)" #E8F5E9
  participant "PluginStore" as store
end box
database "PluginDirectory" as dir

== PLG-05 ENABLE Plugin ==

user -> router : POST /plugins/{id}:enable
activate router
router -> api : PLG-05 ENABLE Plugin({plugin_id})
activate api
api -> mgr : PLG-05 ENABLE Plugin({plugin_id})
activate mgr

alt validation succeeds
  mgr -> store : PLG-05 ENABLE Plugin({plugin_id})
  activate store
  store -> dir : PLG-05 ENABLE Plugin({plugin_id})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : ENABLED (#4CAF50)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else activation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
