@startuml sq_plugins05_enable_plugin
' ============================================================
' Title:     PLG-05 — ENABLE Plugin
' Boundary:  nasim code agent
' Purpose:   Load plugin and activate its tools and hooks
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginLoader
' SM States: ENABLED (#4CAF50), ERROR (#EF5350)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-05 ENABLE Plugin

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Plugins Group (Infrastructure)" #F3E5F5
  participant "PluginLoader" as mgr
end box


== PLG-05 ENABLE Plugin ==

user -> iface : POST /plugins/{id}:enable
activate iface
iface -> router : POST /plugins/{id}:enable
activate router
router -> mgr : PLG-05 ENABLE Plugin({plugin_id})
activate mgr

alt validation succeeds
  ref over mgr : PLG-05 TRANSITION State
    ' SM States: ENABLED (#4CAF50), ERROR (#EF5350)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else activation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
