@startuml sq_plugins05_enable_plugin
' ============================================================
' Title:     PLG-05 — ENABLE Plugin
' Boundary:  nasim code agent
' Purpose:   Load plugin and activate its tools and hooks
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> PluginLoader
' SM States: ENABLED (#4CAF50), ERROR (#EF5350)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-05 ENABLE Plugin

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "ToolService" as svc
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "ToolService" as mgr
end box

== PLG-05 ENABLE Plugin ==

user -> iface : PLG-05 ENABLE Plugin({plugin_id})
activate iface
iface -> router : PLG-05 ENABLE Plugin({plugin_id})
activate router
router -> svc : PLG-05 ENABLE Plugin({plugin_id})
activate svc
svc -> mgr : PLG-05 ENABLE Plugin({plugin_id})
activate mgr

alt validation succeeds
  ref over mgr : PLG-05 ENABLE Plugin <back:#4CAF50>ENABLED</back>
  mgr --> svc : 200 OK
  deactivate mgr
  svc --> router : 200 OK
  deactivate svc
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else activation fails
  mgr --> svc : 422 UNPROCESSABLE\n{error: {code: "PLG-05_ACTIVATION_FAILED", message: "Plugin activation failed", status: 422}}
  deactivate mgr
  svc --> router : 422 UNPROCESSABLE\n{error: {code: "PLG-05_ACTIVATION_FAILED", message: "Plugin activation failed", status: 422}}
  deactivate svc
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "PLG-05_ACTIVATION_FAILED", message: "Plugin activation failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "PLG-05_ACTIVATION_FAILED", message: "Plugin activation failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
