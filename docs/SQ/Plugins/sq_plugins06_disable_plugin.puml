@startuml sq_plugins06_disable_plugin
' ============================================================
' Title:     PLG-06 — DISABLE Plugin
' Boundary:  nasim code agent
' Purpose:   Deactivate plugin tools and hooks, set state DISABLED
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginLoader
' SM States: DISABLED (#CE93D8), ERROR (#EF5350)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-06 DISABLE Plugin

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "PluginManager" as svc
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "PluginLoader" as mgr
end box

== PLG-06 DISABLE Plugin ==

user -> iface : PLG-06 DISABLE Plugin({plugin_id})
activate iface
iface -> router : PLG-06 DISABLE Plugin({plugin_id})
activate router
router -> svc : PLG-06 DISABLE Plugin({plugin_id})
activate svc
svc -> mgr : PLG-06 DISABLE Plugin({plugin_id})
activate mgr

alt validation succeeds
  ref over mgr : PLG-06 DISABLE Plugin <back:#CE93D8>DISABLED</back>
  mgr --> svc : 200 OK
  deactivate mgr
  svc --> router : 200 OK
  deactivate svc
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else deactivation fails
  mgr --> svc : 422 UNPROCESSABLE\n{error: {code: "PLG-06_DEACTIVATION_FAILED", message: "Plugin deactivation failed", status: 422}}
  deactivate mgr
  svc --> router : 422 UNPROCESSABLE\n{error: {code: "PLG-06_DEACTIVATION_FAILED", message: "Plugin deactivation failed", status: 422}}
  deactivate svc
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "PLG-06_DEACTIVATION_FAILED", message: "Plugin deactivation failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "PLG-06_DEACTIVATION_FAILED", message: "Plugin deactivation failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
