@startuml sq_plugins06_disable_plugin
' ============================================================
' Title:     PLG-06 — DISABLE Plugin
' Boundary:  nasim code agent
' Purpose:   Deactivate plugin tools and hooks, set state DISABLED
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginsManager -> PluginsStore -> PluginsDirectory -> PluginRuntime
' SM States: DISABLED (#CE93D8), ERROR (#EF5350)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-06 DISABLE Plugin

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Plugins Group (Service)" #FFF3E0
  participant "PluginManager" as mgr
end box
box "Plugins Group (Repository)" #E8F5E9
  participant "PluginStore" as store
end box
database "PluginDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "PluginRuntime" as PluginRuntime
end box



== PLG-06 DISABLE Plugin ==

user -> iface : POST /plugins/{id}:disable
activate iface
iface -> router : POST /plugins/{id}:disable
activate router
router -> mgr : PLG-06 DISABLE Plugin({plugin_id})
activate mgr

alt validation succeeds
  mgr -> store : PLG-06 DISABLE Plugin({plugin_id})
  activate store
  store -> dir : PLG-06 DISABLE Plugin({plugin_id})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#CE93D8>DISABLED</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else deactivation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
