@startuml sq_plugins06_disable_plugin
' ============================================================
' Title:     PLG-06 — DISABLE Plugin
' Boundary:  nasim code agent
' Purpose:   Deactivate plugin tools and hooks, set state DISABLED
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginLoader
' SM States: DISABLED (#CE93D8), ERROR (#EF5350)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-06 DISABLE Plugin

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "PluginLoader" as mgr
end box

== PLG-06 DISABLE Plugin ==

user -> iface : POST /plugins/{id}:disable
activate iface
iface -> router : POST /plugins/{id}:disable
activate router
router -> mgr : PLG-06 DISABLE Plugin({plugin_id})
activate mgr

alt validation succeeds
  ref over mgr : PLG-06 TRANSITION State
    ' SM States: DISABLED (#CE93D8), ERROR (#EF5350)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else deactivation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
