@startuml sq_plugins01_discover_plugins
' ============================================================
' Title:     PLG-01 — DISCOVER Plugins
' Boundary:  nasim code agent
' Purpose:   Discover plugins from plugin directory
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> PluginAPI -> PluginManager -> PluginStore -> PluginDirectory
' SM States: DISCOVERED (#E0E0E0)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-01 DISCOVER Plugins

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "PluginAPI" as api
end box
box "Plugins Group (Service)" #FFF3E0
  participant "PluginManager" as mgr
end box
box "Plugins Group (Repository)" #E8F5E9
  participant "PluginStore" as store
end box
database "PluginDirectory" as dir

== PLG-01 DISCOVER Plugins ==

user -> router : GET /plugins:discover
activate router
router -> api : PLG-01 DISCOVER Plugins({plugin_dir})
activate api
api -> mgr : PLG-01 DISCOVER Plugins({plugin_dir})
activate mgr

alt validation succeeds
  mgr -> store : PLG-01 DISCOVER Plugins({plugin_dir})
  activate store
  store -> dir : PLG-01 DISCOVER Plugins({plugin_dir})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : DISCOVERED (#E0E0E0)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
