@startuml sq_plugins01_discover_plugins
' ============================================================
' Title:     PLG-01 — DISCOVER Plugins
' Boundary:  nasim code agent
' Purpose:   Discover plugins from plugin directory
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginLoader
' SM States: DISCOVERED (#E0E0E0)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-01 DISCOVER Plugins

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "PluginLoader" as mgr
end box

== PLG-01 DISCOVER Plugins ==

user -> iface : GET /plugins:discover
activate iface
iface -> router : GET /plugins:discover
activate router
router -> mgr : PLG-01 DISCOVER Plugins({plugin_dir})
activate mgr

alt validation succeeds
  ref over mgr : PLG-01 DISCOVER Plugins({plugin_dir})
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "PLG-01_DISCOVERY_FAILED", message: "Plugin discovery failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "PLG-01_DISCOVERY_FAILED", message: "Plugin discovery failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "PLG-01_DISCOVERY_FAILED", message: "Plugin discovery failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
