@startuml sq_plugins01_discover_plugins
' ============================================================
' Title:     PLG-01 — DISCOVER Plugins
' Boundary:  nasim code agent
' Purpose:   Discover plugins from plugin directory
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginsManager -> PluginsStore -> PluginsDirectory -> PluginRuntime
' SM States: DISCOVERED (#E0E0E0)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-01 DISCOVER Plugins

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Plugins Group (Service)" #FFF3E0
  participant "PluginManager" as mgr
end box
box "Plugins Group (Repository)" #E8F5E9
  participant "PluginStore" as store
end box
database "PluginDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "PluginRuntime" as PluginRuntime
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "PluginRuntime" as PluginRuntime
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "PluginRuntime" as PluginRuntime
end box

== PLG-01 DISCOVER Plugins ==

user -> iface : GET /plugins:discover
activate iface
iface -> router : GET /plugins:discover
activate router
router -> mgr : PLG-01 DISCOVER Plugins({plugin_dir})
activate mgr

alt validation succeeds
  mgr -> store : PLG-01 DISCOVER Plugins({plugin_dir})
  activate store
  store -> dir : PLG-01 DISCOVER Plugins({plugin_dir})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : DISCOVERED (#E0E0E0)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
