@startuml sq_plugins02_load_manifest
' ============================================================
' Title:     PLG-02 — LOAD Manifest
' Boundary:  nasim code agent
' Purpose:   Read and parse a plugin's manifest.yaml file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginLoader
' SM States: LOADING (#FFCC80), LOADED (#90CAF9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-02 LOAD Manifest

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Plugins Group (Infrastructure)" #F3E5F5
  participant "PluginLoader" as mgr
end box


== PLG-02 LOAD Manifest ==

user -> iface : GET /plugins/{id}:load
activate iface
iface -> router : GET /plugins/{id}:load
activate router
router -> mgr : PLG-02 LOAD Manifest({manifest_path})
activate mgr

alt validation succeeds
  ref over mgr : PLG-02 TRANSITION State
    ' SM States: LOADING (#FFCC80), LOADED (#90CAF9)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else manifest invalid
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
