@startuml sq_plugins02_load_manifest
' ============================================================
' Title:     PLG-02 — LOAD Manifest
' Boundary:  nasim code agent
' Purpose:   Read and parse a plugin's manifest.yaml file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginsManager -> PluginsStore -> PluginsDirectory -> PluginRuntime
' SM States: LOADING (#FFCC80), LOADED (#90CAF9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-02 LOAD Manifest

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Plugins Group (Service)" #FFF3E0
  participant "PluginManager" as mgr
end box
box "Plugins Group (Repository)" #E8F5E9
  participant "PluginStore" as store
end box
database "PluginDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "PluginRuntime" as PluginRuntime
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "PluginRuntime" as PluginRuntime
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "PluginRuntime" as PluginRuntime
end box

== PLG-02 LOAD Manifest ==

user -> iface : GET /plugins/{id}:load
activate iface
iface -> router : GET /plugins/{id}:load
activate router
router -> mgr : PLG-02 LOAD Manifest({manifest_path})
activate mgr

alt validation succeeds
  mgr -> store : PLG-02 LOAD Manifest({manifest_path})
  activate store
  store -> dir : PLG-02 LOAD Manifest({manifest_path})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : LOADING (#FFCC80) -> LOADED (#90CAF9)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else manifest invalid
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
