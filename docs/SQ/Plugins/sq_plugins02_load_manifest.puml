@startuml sq_plugins02_load_manifest
' ============================================================
' Title:     PLG-02 — LOAD Manifest
' Boundary:  nasim code agent
' Purpose:   Read and parse a plugin's manifest.yaml file
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PluginLoader
' SM States: LOADING (#FFCC80), LOADED (#90CAF9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- PLG-02 LOAD Manifest

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "PluginManager" as svc
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "PluginLoader" as mgr
end box

== PLG-02 LOAD Manifest ==

user -> iface : PLG-02 LOAD Manifest({manifest_path})
activate iface
iface -> router : PLG-02 LOAD Manifest({manifest_path})
activate router
router -> svc : PLG-02 LOAD Manifest({manifest_path})
activate svc
svc -> mgr : PLG-02 LOAD Manifest({manifest_path})
activate mgr

alt validation succeeds
  ref over mgr : PLG-02 LOAD Manifest <back:#FFCC80>LOADING</back>
  mgr --> svc : 200 OK
  deactivate mgr
  svc --> router : 200 OK
  deactivate svc
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else manifest invalid
  mgr --> svc : 422 UNPROCESSABLE\n{error: {code: "PLG-02_MANIFEST_INVALID", message: "Plugin manifest is invalid", status: 422}}
  deactivate mgr
  svc --> router : 422 UNPROCESSABLE\n{error: {code: "PLG-02_MANIFEST_INVALID", message: "Plugin manifest is invalid", status: 422}}
  deactivate svc
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "PLG-02_MANIFEST_INVALID", message: "Plugin manifest is invalid", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "PLG-02_MANIFEST_INVALID", message: "Plugin manifest is invalid", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
