@startuml sq_hooks02_dispatch_pre_tool_hook
' ============================================================
' Title:     HK-02 — DISPATCH Pre-Tool Hook
' Boundary:  nasim code agent
' Purpose:   Execute hooks before tool execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> HookManager
' SM States: HOOK_RUNNING (#FFFDE7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- HK-02 DISPATCH Pre-Tool Hook

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "HookManager" as mgr
end box

== HK-02 DISPATCH Pre-Tool Hook ==

user -> iface : POST /hooks/{id}:dispatch
activate iface
iface -> router : POST /hooks/{id}:dispatch
activate router
router -> mgr : HK-02 DISPATCH Pre-Tool Hook({tool_name, args})
activate mgr

alt validation succeeds
  ref over mgr : HK-02 DISPATCH Pre-Tool Hook({tool_name, args})
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "HK-02_PRE_TOOL_FAILED", message: "Pre-tool hook dispatch failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "HK-02_PRE_TOOL_FAILED", message: "Pre-tool hook dispatch failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "HK-02_PRE_TOOL_FAILED", message: "Pre-tool hook dispatch failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
