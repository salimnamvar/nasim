@startuml sq_hooks01_register_hook
' ============================================================
' Title:     HK-01 — REGISTER Hook
' Boundary:  nasim code agent
' Purpose:   Register a hook in the HookManager
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> HookManager
' SM States: HOOK_RUNNING (#FFFDE7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- HK-01 REGISTER Hook

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Hooks Group (Infrastructure)" #F3E5F5
  participant "HookManager" as mgr
end box


== HK-01 REGISTER Hook ==

user -> iface : POST /hooks
activate iface
iface -> router : POST /hooks
activate router
router -> mgr : HK-01 REGISTER Hook({hook_spec})
activate mgr

alt validation succeeds
  ref over mgr : HK-01 TRANSITION State
    ' SM States: HOOK_RUNNING (#FFFDE7)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
