@startuml sq_hooks06_validate_hook_result
' ============================================================
' Title:     HK-06 — VALIDATE Hook Result
' Boundary:  nasim code agent
' Purpose:   Validate a HookResult for correctness and safety
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> HooksManager -> HooksStore -> HooksDirectory -> HookRuntime
' SM States: HOOK_RUNNING (#FFFDE7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- HK-06 VALIDATE Hook Result

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Hooks Group (Service)" #FFF3E0
  participant "HooksManager" as mgr
end box
box "Hooks Group (Repository)" #E8F5E9
  participant "HooksStore" as store
end box
database "HooksDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "HookRuntime" as HookRuntime
end box



== HK-06 VALIDATE Hook Result ==

user -> iface : POST /hooks/{id}:validate
activate iface
iface -> router : POST /hooks/{id}:validate
activate router
router -> mgr : HK-06 VALIDATE Hook Result({hook_result})
activate mgr

alt validation succeeds
  mgr -> store : HK-06 VALIDATE Hook Result({hook_result})
  activate store
  store -> dir : HK-06 VALIDATE Hook Result({hook_result})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#FFFDE7>HOOK_RUNNING</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
