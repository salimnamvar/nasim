@startuml sq_hooks06_validate_hook_result
' ============================================================
' Title:     HK-06 — VALIDATE Hook Result
' Boundary:  nasim code agent
' Purpose:   Validate a HookResult for correctness and safety
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> HookManager
' SM States: HOOK_RUNNING (#FFFDE7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- HK-06 VALIDATE Hook Result

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "HookManager" as mgr
end box

== HK-06 VALIDATE Hook Result ==

user -> iface : POST /hooks/{id}:validate
activate iface
iface -> router : POST /hooks/{id}:validate
activate router
router -> mgr : HK-06 VALIDATE Hook Result({hook_result})
activate mgr

alt validation succeeds
  ref over mgr : HK-06 VALIDATE Hook Result({hook_result})
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "HK-06_VALIDATION_FAILED", message: "Hook validation failed", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "HK-06_VALIDATION_FAILED", message: "Hook validation failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "HK-06_VALIDATION_FAILED", message: "Hook validation failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
