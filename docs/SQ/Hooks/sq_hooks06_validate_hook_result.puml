@startuml sq_hooks06_validate_hook_result
' ============================================================
' Title:     HK-06 — VALIDATE Hook Result
' Boundary:  nasim code agent
' Purpose:   Validate a HookResult for correctness and safety
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> HookManager
' SM States: HOOK_RUNNING (#FFFDE7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- HK-06 VALIDATE Hook Result

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Hooks Group (Infrastructure)" #F3E5F5
  participant "HookManager" as mgr
end box


== HK-06 VALIDATE Hook Result ==

user -> iface : POST /hooks/{id}:validate
activate iface
iface -> router : POST /hooks/{id}:validate
activate router
router -> mgr : HK-06 VALIDATE Hook Result({hook_result})
activate mgr

alt validation succeeds
  ref over mgr : HK-06 TRANSITION State
    ' SM States: HOOK_RUNNING (#FFFDE7)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
