@startuml sq_hooks05_dispatch_post_llm_hook
' ============================================================
' Title:     HK-05 — DISPATCH Post-LLM Hook
' Boundary:  nasim code agent
' Purpose:   Execute hooks after LLM call completes
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> HooksAPI -> HooksManager -> HooksStore -> HooksDirectory
' SM States: HOOK_RUNNING (#FFFDE7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- HK-05 DISPATCH Post-LLM Hook

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "HooksAPI" as api
end box
box "Hooks Group (Service)" #FFF3E0
  participant "HooksManager" as mgr
end box
box "Hooks Group (Repository)" #E8F5E9
  participant "HooksStore" as store
end box
database "HooksDirectory" as dir

== HK-05 DISPATCH Post-LLM Hook ==

user -> router : POST /hooks/{id}:dispatch
activate router
router -> api : HK-05 DISPATCH Post-LLM Hook({llm_result})
activate api
api -> mgr : HK-05 DISPATCH Post-LLM Hook({llm_result})
activate mgr

alt validation succeeds
  mgr -> store : HK-05 DISPATCH Post-LLM Hook({llm_result})
  activate store
  store -> dir : HK-05 DISPATCH Post-LLM Hook({llm_result})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : HOOK_RUNNING (#FFFDE7)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
