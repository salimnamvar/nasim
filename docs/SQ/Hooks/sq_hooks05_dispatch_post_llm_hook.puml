@startuml sq_hooks05_dispatch_post_llm_hook
' ============================================================
' Title:     HK-05 — DISPATCH Post-LLM Hook
' Boundary:  nasim code agent
' Purpose:   Execute hooks after LLM call completes
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> HooksManager -> HooksStore -> HooksDirectory -> HookRuntime
' SM States: HOOK_RUNNING (#FFFDE7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- HK-05 DISPATCH Post-LLM Hook

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Hooks Group (Service)" #FFF3E0
  participant "HooksManager" as mgr
end box
box "Hooks Group (Repository)" #E8F5E9
  participant "HooksStore" as store
end box
database "HooksDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "HookRuntime" as HookRuntime
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "HookRuntime" as HookRuntime
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "HookRuntime" as HookRuntime
end box

== HK-05 DISPATCH Post-LLM Hook ==

user -> iface : POST /hooks/{id}:dispatch
activate iface
iface -> router : POST /hooks/{id}:dispatch
activate router
router -> mgr : HK-05 DISPATCH Post-LLM Hook({llm_result})
activate mgr

alt validation succeeds
  mgr -> store : HK-05 DISPATCH Post-LLM Hook({llm_result})
  activate store
  store -> dir : HK-05 DISPATCH Post-LLM Hook({llm_result})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : HOOK_RUNNING (#FFFDE7)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
