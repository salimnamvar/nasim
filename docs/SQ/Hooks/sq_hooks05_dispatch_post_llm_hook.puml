@startuml sq_hooks05_dispatch_post_llm_hook
' ============================================================
' Title:     HK-05 — DISPATCH Post-LLM Hook
' Boundary:  nasim code agent
' Purpose:   Execute hooks after LLM call completes
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> HookManager
' SM States: HOOK_RUNNING (#FFFDE7)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- HK-05 DISPATCH Post-LLM Hook

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "HookManager" as mgr
end box

== HK-05 DISPATCH Post-LLM Hook ==

user -> iface : POST /hooks/{id}:dispatch
activate iface
iface -> router : POST /hooks/{id}:dispatch
activate router
router -> mgr : HK-05 DISPATCH Post-LLM Hook({llm_result})
activate mgr

alt validation succeeds
  ref over mgr : HK-05 TRANSITION State
    ' SM States: HOOK_RUNNING (#FFFDE7)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
