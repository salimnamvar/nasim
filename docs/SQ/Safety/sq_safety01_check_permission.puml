@startuml sq_safety01_check_permission
' ============================================================
' Title:     SAF-01 — CHECK Permission
' Boundary:  nasim code agent
' Purpose:   Per-tool safety check before execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SafetyManager -> SafetyStore -> SafetyDirectory -> PolicyEngine
' SM States: PERMISSIVE (#9CCC65), ERROR (#F4511E)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SAF-01 CHECK Permission

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Safety Group (Service)" #FFF3E0
  participant "SafetyManager" as mgr
end box
box "Safety Group (Repository)" #E8F5E9
  participant "SafetyStore" as store
end box
database "SafetyDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "PolicyEngine" as PolicyEngine
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "PolicyEngine" as PolicyEngine
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "PolicyEngine" as PolicyEngine
end box

== SAF-01 CHECK Permission ==

user -> iface : GET /permissions/check/{tool}
activate iface
iface -> router : GET /permissions/check/{tool}
activate router
router -> mgr : saf01 CHECK Permission(tool_name, safety_mode)
activate mgr

alt permission allowed
  mgr -> store : saf01 CHECK Permission(tool_name, safety_mode)
  activate store
  store -> dir : saf01 CHECK Permission(tool_name, safety_mode)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : PERMISSIVE (#9CCC65)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else permission denied
  mgr --> router : 403 Forbidden
  deactivate mgr
  router --> iface : 403 Forbidden
  router --> iface : 403 Forbidden
  iface --> user : 403 Forbidden
  deactivate router
  deactivate iface
end

@enduml
