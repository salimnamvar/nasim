@startuml sq_safety01_check_permission
' ============================================================
' Title:     SAF-01 — CHECK Permission
' Boundary:  nasim code agent
' Purpose:   Per-tool safety check before execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SafetyAPI -> SafetyManager -> SafetyStore -> SafetyDirectory
' SM States: PERMISSIVE (#9CCC65), ERROR (#F4511E)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SAF-01 CHECK Permission

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "SafetyAPI" as api
end box
box "Safety Group (Service)" #FFF3E0
  participant "SafetyManager" as mgr
end box
box "Safety Group (Repository)" #E8F5E9
  participant "SafetyStore" as store
end box
database "SafetyDirectory" as dir

== SAF-01 CHECK Permission ==

user -> router : GET /permissions/check/{tool}
activate router
router -> api : saf01 CHECK Permission(tool_name, safety_mode)
activate api
api -> mgr : saf01 CHECK Permission(tool_name, safety_mode)
activate mgr

alt permission allowed
  mgr -> store : saf01 CHECK Permission(tool_name, safety_mode)
  activate store
  store -> dir : saf01 CHECK Permission(tool_name, safety_mode)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : PERMISSIVE (#9CCC65)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else permission denied
  mgr --> api : 403 Forbidden
  deactivate mgr
  api --> router : 403 Forbidden
  deactivate api
  router --> user : 403 Forbidden
  deactivate router
end

@enduml
