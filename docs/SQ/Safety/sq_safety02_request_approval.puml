@startuml sq_safety02_request_approval
' ============================================================
' Title:     SAF-02 — REQUEST Approval
' Boundary:  nasim code agent
' Purpose:   Display approval prompt for unsafe tool execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SafetyManager -> SafetyStore -> SafetyDirectory -> PolicyEngine
' SM States: AWAITING_APPROVAL (#FFF9C4)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SAF-02 REQUEST Approval

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Safety Group (Service)" #FFF3E0
  participant "SafetyManager" as mgr
end box
box "Safety Group (Repository)" #E8F5E9
  participant "SafetyStore" as store
end box
database "SafetyDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "PolicyEngine" as PolicyEngine
end box



== SAF-02 REQUEST Approval ==

user -> iface : POST /permissions/approval
activate iface
iface -> router : POST /permissions/approval
activate router
router -> mgr : saf02 REQUEST Approval(tool_name, args)
activate mgr

alt user approves
  mgr -> store : saf02 REQUEST Approval(tool_name, args)
  activate store
  store -> dir : saf02 REQUEST Approval(tool_name, args)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#FFF9C4>AWAITING_APPROVAL</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else user rejects
  mgr --> router : 403 Forbidden
  deactivate mgr
  router --> iface : 403 Forbidden
  iface --> user : 403 Forbidden
  deactivate router
  deactivate iface
end

@enduml
