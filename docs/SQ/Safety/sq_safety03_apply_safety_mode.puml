@startuml sq_safety03_apply_safety_mode
' ============================================================
' Title:     SAF-03 — APPLY Safety Mode
' Boundary:  nasim code agent
' Purpose:   Configure safety mode from config
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SafetyCoordinator
' SM States: ASK (#FDD835), PERMISSIVE (#9CCC65), BLOCK (#E91E63)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SAF-03 APPLY Safety Mode

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "SafetyCoordinator" as mgr
end box

== SAF-03 APPLY Safety Mode ==

user -> iface : SAF-03 APPLY Safety Mode({safety_mode})
activate iface
iface -> router : SAF-03 APPLY Safety Mode({safety_mode})
activate router
router -> mgr : SAF-03 APPLY Safety Mode(safety_mode)
activate mgr

alt mode applied
  ref over mgr : SAF-03 APPLY Safety Mode(safety_mode) <back:#FDD835>ASK</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else invalid mode
  mgr --> router : 422 UNPROCESSABLE\n{error: {code: "SAF-03_INVALID_MODE", message: "Invalid safety mode", status: 422}}
  deactivate mgr
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
