@startuml sq_safety03_apply_safety_mode
' ============================================================
' Title:     SAF-03 — APPLY Safety Mode
' Boundary:  nasim code agent
' Purpose:   Configure safety mode from config
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SafetyAPI -> SafetyManager -> SafetyStore -> SafetyDirectory
' SM States: ASK (#FDD835), PERMISSIVE (#9CCC65), BLOCK (#E91E63)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SAF-03 APPLY Safety Mode

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "SafetyAPI" as api
end box
box "Safety Group (Service)" #FFF3E0
  participant "SafetyManager" as mgr
end box
box "Safety Group (Repository)" #E8F5E9
  participant "SafetyStore" as store
end box
database "SafetyDirectory" as dir

== SAF-03 APPLY Safety Mode ==

user -> router : PATCH /safety/mode
activate router
router -> api : saf03 APPLY Safety Mode(safety_mode)
activate api
api -> mgr : saf03 APPLY Safety Mode(safety_mode)
activate mgr

alt mode applied
  mgr -> store : saf03 APPLY Safety Mode(safety_mode)
  activate store
  store -> dir : saf03 APPLY Safety Mode(safety_mode)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : ASK (#FDD835)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else invalid mode
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
