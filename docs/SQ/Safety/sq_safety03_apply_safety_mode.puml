@startuml sq_safety03_apply_safety_mode
' ============================================================
' Title:     SAF-03 — APPLY Safety Mode
' Boundary:  nasim code agent
' Purpose:   Configure safety mode from config
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SafetyManager -> SafetyStore -> SafetyDirectory -> PolicyEngine
' SM States: ASK (#FDD835), PERMISSIVE (#9CCC65), BLOCK (#E91E63)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SAF-03 APPLY Safety Mode

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Safety Group (Service)" #FFF3E0
  participant "SafetyManager" as mgr
end box
box "Safety Group (Repository)" #E8F5E9
  participant "SafetyStore" as store
end box
database "SafetyDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "PolicyEngine" as PolicyEngine
end box



== SAF-03 APPLY Safety Mode ==

user -> iface : PATCH /safety/mode
activate iface
iface -> router : PATCH /safety/mode
activate router
router -> mgr : saf03 APPLY Safety Mode(safety_mode)
activate mgr

alt mode applied
  mgr -> store : saf03 APPLY Safety Mode(safety_mode)
  activate store
  store -> dir : saf03 APPLY Safety Mode(safety_mode)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#FDD835>ASK</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else invalid mode
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
