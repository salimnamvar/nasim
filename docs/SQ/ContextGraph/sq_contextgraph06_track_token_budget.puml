@startuml sq_ctx06_track_token_budget
' ============================================================
' Title:     CTX-06 — TRACK Token Budget
' Boundary:  nasim code agent
' Purpose:   Track token consumption against allocated budget
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> TokenBudgetTracker
' SM States: COMPACTING (#E0F2F1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CTX-06 TRACK Token Budget

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "ContextGraph Group" #FFF3E0
  participant "TokenBudgetTracker" as tracker
end box

== CTX-06 TRACK Token Budget ==

user -> iface : GET /contextgraph/budget
activate iface
iface -> router : GET /contextgraph/budget
activate router
router -> tracker : CTX-06 TRACK Token Budget({used_tokens, total_budget})
activate tracker

alt budget sufficient
  ref over tracker : TRANSITION State(<back:#E0F2F1>COMPACTING</back>)
  tracker --> router : 200 OK
  deactivate tracker
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else budget exceeded
  tracker --> router : 429 Too Many Requests
  deactivate tracker
  router --> iface : 429 Too Many Requests
  iface --> user : 429 Too Many Requests
  deactivate router
  deactivate iface
end

@enduml
