@startuml sq_ctx06_track_token_budget
' ============================================================
' Title:     CTX-06 — TRACK Token Budget
' Boundary:  nasim code agent
' Purpose:   Track token consumption against allocated budget
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ContextgraphManager -> ContextgraphStore -> ContextgraphDirectory -> TokenBudget
' SM States: COMPACTING (#E0F2F1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CTX-06 TRACK Token Budget

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Context Graph Group (Service)" #FFF3E0
  participant "ContextGraphManager" as mgr
end box
box "Context Graph Group (Repository)" #E8F5E9
  participant "ContextGraphStore" as store
end box
database "ContextGraphDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "TokenBudget" as TokenBudget
end box



== CTX-06 TRACK Token Budget ==

user -> iface : GET /contextgraph/budget
activate iface
iface -> router : GET /contextgraph/budget
activate router
router -> mgr : CTX-06 TRACK Token Budget({used_tokens, total_budget})
activate mgr

alt budget sufficient
  mgr -> store : CTX-06 TRACK Token Budget({used_tokens, total_budget})
  activate store
  store -> dir : CTX-06 TRACK Token Budget({used_tokens, total_budget})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#E0F2F1>COMPACTING</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else budget exceeded
  mgr --> router : 429 Too Many Requests
  deactivate mgr
  router --> iface : 429 Too Many Requests
  iface --> user : 429 Too Many Requests
  deactivate router
  deactivate iface
end

@enduml
