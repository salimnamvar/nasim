@startuml sq_ctx04_inject_context
' ============================================================
' Title:     CTX-04 — INJECT Context
' Boundary:  nasim code agent
' Purpose:   Inject relevant context into the conversation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ContextGraphAPI -> ContextGraphManager -> ContextGraphStore -> ContextGraphDirectory
' SM States: COMPACTING (#E0F2F1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CTX-04 INJECT Context

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ContextGraphAPI" as api
end box
box "Context Graph Group (Service)" #FFF3E0
  participant "ContextGraphManager" as mgr
end box
box "Context Graph Group (Repository)" #E8F5E9
  participant "ContextGraphStore" as store
end box
database "ContextGraphDirectory" as dir

== CTX-04 INJECT Context ==

user -> router : POST /contextgraph/inject
activate router
router -> api : CTX-04 INJECT Context({query, max_results})
activate api
api -> mgr : CTX-04 INJECT Context({query, max_results})
activate mgr

alt injection succeeds
  mgr -> store : CTX-04 INJECT Context({query, max_results})
  activate store
  store -> dir : CTX-04 INJECT Context({query, max_results})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : COMPACTING (#E0F2F1) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else injection fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
