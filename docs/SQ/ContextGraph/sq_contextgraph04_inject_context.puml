@startuml sq_contextgraph04_inject_context
' ============================================================
' Title:     CTX-04 — INJECT Context
' Boundary:  nasim code agent
' Purpose:   Inject relevant context into the conversation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> InjectionProcessor
' SM States: COMPACTING (#E0F2F1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CTX-04 INJECT Context

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "InjectionProcessor" as inject
end box

== CTX-04 INJECT Context ==

user -> iface : POST /contextgraph/inject
activate iface
iface -> router : POST /contextgraph/inject
activate router
router -> inject : CTX-04 INJECT Context({query, max_results})
activate inject

alt injection succeeds
  ref over inject : TRANSITION State(<back:#E0F2F1>COMPACTING</back>)
  inject --> router : 200 OK
  deactivate inject
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else injection fails
  inject --> router : 422 Unprocessable
  deactivate inject
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
