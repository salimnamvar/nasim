@startuml sq_ctx05_compact_nodes
' ============================================================
' Title:     CTX-05 — COMPACT Nodes
' Boundary:  nasim code agent
' Purpose:   Compact low-importance nodes by merging or summarizing
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ContextgraphManager -> ContextgraphStore -> ContextgraphDirectory -> TokenBudget
' SM States: COMPACTING (#E0F2F1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CTX-05 COMPACT Nodes

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Context Graph Group (Service)" #FFF3E0
  participant "ContextGraphManager" as mgr
end box
box "Context Graph Group (Repository)" #E8F5E9
  participant "ContextGraphStore" as store
end box
database "ContextGraphDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TokenBudget" as TokenBudget
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TokenBudget" as TokenBudget
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "TokenBudget" as TokenBudget
end box

== CTX-05 COMPACT Nodes ==

user -> iface : POST /contextgraph/compact
activate iface
iface -> router : POST /contextgraph/compact
activate router
router -> mgr : CTX-05 COMPACT Nodes({nodes, strategy})
activate mgr

alt compaction succeeds
  mgr -> store : CTX-05 COMPACT Nodes({nodes, strategy})
  activate store
  store -> dir : CTX-05 COMPACT Nodes({nodes, strategy})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : COMPACTING (#E0F2F1) ...
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else compaction fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
