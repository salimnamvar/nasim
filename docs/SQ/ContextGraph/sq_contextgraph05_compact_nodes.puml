@startuml sq_contextgraph05_compact_nodes
' ============================================================
' Title:     CTX-05 — COMPACT Nodes
' Boundary:  nasim code agent
' Purpose:   Compact low-importance nodes by merging or summarizing
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> CompactionProcessor
' SM States: COMPACTING (#E0F2F1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CTX-05 COMPACT Nodes

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "CompactionProcessor" as compact
end box

== CTX-05 COMPACT Nodes ==

user -> iface : POST /contextgraph/compact
activate iface
iface -> router : POST /contextgraph/compact
activate router
router -> compact : CTX-05 COMPACT Nodes({nodes, strategy})
activate compact

alt compaction succeeds
  ref over compact : TRANSITION State(<back:#E0F2F1>COMPACTING</back>)
  compact --> router : 200 OK
  deactivate compact
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else compaction fails
  compact --> router : 422 Unprocessable
  deactivate compact
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
