@startuml sq_ctx02_truncate_nodes
' ============================================================
' Title:     CTX-02 — TRUNCATE Nodes
' Boundary:  nasim code agent
' Purpose:   Truncate low-priority context nodes to fit budget
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ContextGraphAPI -> ContextGraphManager -> ContextGraphStore -> ContextGraphDirectory
' SM States: COMPACTING (#E0F2F1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CTX-02 TRUNCATE Nodes

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "ContextGraphAPI" as api
end box
box "Context Graph Group (Service)" #FFF3E0
  participant "ContextGraphManager" as mgr
end box
box "Context Graph Group (Repository)" #E8F5E9
  participant "ContextGraphStore" as store
end box
database "ContextGraphDirectory" as dir

== CTX-02 TRUNCATE Nodes ==

user -> router : POST /contextgraph/truncate
activate router
router -> api : CTX-02 TRUNCATE Nodes({nodes, target_tokens})
activate api
api -> mgr : CTX-02 TRUNCATE Nodes({nodes, target_tokens})
activate mgr

alt truncation succeeds
  mgr -> store : CTX-02 TRUNCATE Nodes({nodes, target_tokens})
  activate store
  store -> dir : CTX-02 TRUNCATE Nodes({nodes, target_tokens})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : COMPACTING (#E0F2F1) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else truncation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
