@startuml sq_contextgraph02_truncate_nodes
' ============================================================
' Title:     CTX-02 — TRUNCATE Nodes
' Boundary:  nasim code agent
' Purpose:   Truncate low-priority context nodes to fit budget
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> TruncationProcessor
' SM States: COMPACTING (#E0F2F1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CTX-02 TRUNCATE Nodes

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "TruncationProcessor" as trunc
end box

== CTX-02 TRUNCATE Nodes ==

user -> iface : POST /contextgraph/truncate
activate iface
iface -> router : POST /contextgraph/truncate
activate router
router -> trunc : CTX-02 TRUNCATE Nodes({nodes, target_tokens})
activate trunc

alt truncation succeeds
  ref over trunc : TRANSITION State(<back:#E0F2F1>COMPACTING</back>)
  trunc --> router : 200 OK
  deactivate trunc
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else truncation fails
  trunc --> router : 422 Unprocessable
  deactivate trunc
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
