@startuml sq_contextgraph01_process_context
' ============================================================
' Title:     CTX-01 — PROCESS Context
' Boundary:  nasim code agent
' Purpose:   Orchestrate context processing pipeline stages
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PipelineOrchestrator
' SM States: (stateless — COMPACTING owned by AGT-06)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CTX-01 PROCESS Context

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "PipelineOrchestrator" as orch
end box

== CTX-01 PROCESS Context ==

user -> iface : CTX-01 PROCESS Context({graph, token_budget})
activate iface
iface -> router : CTX-01 PROCESS Context({graph, token_budget})
activate router
router -> orch : CTX-01 PROCESS Context({graph, token_budget})
activate orch

alt pipeline_stages complete
  ref over orch : CTX-01 PROCESS Context({graph, token_budget})
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else pipeline_error
  orch --> router : 422 UNPROCESSABLE\n{error: {code: "CTX-01_PIPELINE_ERROR", message: "Context processing pipeline failed", status: 422}}
  deactivate orch
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
