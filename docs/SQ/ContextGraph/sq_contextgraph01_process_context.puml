@startuml sq_ctx01_process_context
' ============================================================
' Title:     CTX-01 — PROCESS Context
' Boundary:  nasim code agent
' Purpose:   Orchestrate context processing pipeline stages
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> PipelineOrchestrator
' SM States: COMPACTING (#E0F2F1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CTX-01 PROCESS Context

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "ContextGraph Group" #FFF3E0
  participant "PipelineOrchestrator" as orch
end box

== CTX-01 PROCESS Context ==

user -> iface : POST /contextgraph/process
activate iface
iface -> router : POST /contextgraph/process
activate router
router -> orch : CTX-01 PROCESS Context({graph, token_budget})
activate orch

alt processing succeeds
  ref over orch : TRANSITION State(<back:#E0F2F1>COMPACTING</back>)
  orch --> router : 200 OK
  deactivate orch
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else processing fails
  orch --> router : 422 Unprocessable
  deactivate orch
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
