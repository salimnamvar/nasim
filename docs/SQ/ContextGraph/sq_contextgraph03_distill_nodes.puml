@startuml sq_ctx03_distill_nodes
' ============================================================
' Title:     CTX-03 — DISTILL Nodes
' Boundary:  nasim code agent
' Purpose:   Distill chat history nodes into concise summaries
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ContextgraphManager -> ContextgraphStore -> ContextgraphDirectory -> TokenBudget
' SM States: COMPACTING (#E0F2F1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CTX-03 DISTILL Nodes

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Context Graph Group (Service)" #FFF3E0
  participant "ContextGraphManager" as mgr
end box
box "Context Graph Group (Repository)" #E8F5E9
  participant "ContextGraphStore" as store
end box
database "ContextGraphDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "TokenBudget" as TokenBudget
end box



== CTX-03 DISTILL Nodes ==

user -> iface : POST /contextgraph/distill
activate iface
iface -> router : POST /contextgraph/distill
activate router
router -> mgr : CTX-03 DISTILL Nodes({nodes, max_tokens})
activate mgr

alt distillation succeeds
  mgr -> store : CTX-03 DISTILL Nodes({nodes, max_tokens})
  activate store
  store -> dir : CTX-03 DISTILL Nodes({nodes, max_tokens})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#E0F2F1>COMPACTING</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else distillation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
