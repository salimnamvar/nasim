@startuml sq_contextgraph03_distill_nodes
' ============================================================
' Title:     CTX-03 — DISTILL Nodes
' Boundary:  nasim code agent
' Purpose:   Distill chat history nodes into concise summaries
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> DistillationProcessor
' SM States: COMPACTING (#E0F2F1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CTX-03 DISTILL Nodes

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "ContextGraph Group" #FFF3E0
  participant "DistillationProcessor" as distill
end box

== CTX-03 DISTILL Nodes ==

user -> iface : POST /contextgraph/distill
activate iface
iface -> router : POST /contextgraph/distill
activate router
router -> distill : CTX-03 DISTILL Nodes({nodes, max_tokens})
activate distill

alt distillation succeeds
  ref over distill : TRANSITION State(<back:#E0F2F1>COMPACTING</back>)
  distill --> router : 200 OK
  deactivate distill
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else distillation fails
  distill --> router : 422 Unprocessable
  deactivate distill
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
