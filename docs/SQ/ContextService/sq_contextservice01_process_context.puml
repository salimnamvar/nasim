@startuml sq_contextservice01_process_context
' ============================================================
' Title:     CONTEXTSVC-01 — processContext
' Boundary:  NASIM Application — Service Layer
' Purpose:   Orchestrate context pipeline: truncate, distill, inject, compact.
' Intro:     Orchestrated sub-flow — invoked by TASKSVC-01, not agent_ctrl.
'             Full entry chain for master UC: see sq_taskservice01_process_user_task.
' Summary:   Token budget tracking (CONTEXTSVC-06) may trigger compaction
'             (CONTEXTSVC-05) transitioning agent SM to COMPACTING state.
' Milestone: v1.0
' Version:   10.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0), docs/UC/uc_context_svc.puml
' Review:    SQ Architect extraction 2026-07-01
' CSR Chain: Task Service → Context Service → {Memory, Repo Intelligence} Repository
' SM States: COMPACTING (sm_task_svc_agent.puml, owned by CONTEXTSVC-05)
' ============================================================

!include ../common/sq_styles.puml

title nasim — CONTEXTSVC-01 processContext

box "Service" SERVICE_COLOR
  participant "Task Service" as taskSvc
  participant "Context Service" as ctxSvc
end box

box "Repository" REPOSITORY_COLOR
  participant "Memory Repository" as memRepo
  participant "Repo Intelligence Repository" as rimRepo
end box

== CONTEXTSVC-01 processContext ==

taskSvc -> ctxSvc : CONTEXTSVC-01 processContext({graph, tokenBudget})
activate ctxSvc

ctxSvc -> ctxSvc : CONTEXTSVC-02 truncateNodes({graph})
ctxSvc -> ctxSvc : CONTEXTSVC-03 distillNodes({graph})

ctxSvc -> memRepo : MEMORYREPO-02 recallKnowledge({scope})
activate memRepo
memRepo --> ctxSvc : 200 OK — {knowledge}
deactivate memRepo

ctxSvc -> rimRepo : REPOINTELREPO-04 injectRepoMap({budget})
activate rimRepo
rimRepo --> ctxSvc : 200 OK — {repoMap}
deactivate rimRepo

ctxSvc -> ctxSvc : CONTEXTSVC-04 injectContext({graph, injections})
ctxSvc -> ctxSvc : CONTEXTSVC-06 trackTokenBudget({graph})

alt token_count > budget
  ctxSvc -> ctxSvc : CONTEXTSVC-05 compactNodes({graph})
  ref over taskSvc, ctxSvc : CONTEXTSVC-05 compactNodes\nState: <back:#D7CCC8>THINKING</back> → <back:#E0F2F1>COMPACTING</back> → <back:#D7CCC8>THINKING</back>
else within_budget
  ref over ctxSvc : CONTEXTSVC-01 processContext\nPipeline complete
end

break pipeline_error
  ctxSvc --> taskSvc : 422 UNPROCESSABLE\n{error: {code: "CONTEXTSVC-01_PIPELINE_ERROR"}}
  deactivate ctxSvc
end

ctxSvc --> taskSvc : 200 OK — {assembledContext}
deactivate ctxSvc

== Summary ==
' CONTEXTSVC-02..06 are sub-UCs included by CONTEXTSVC-01. DRY: identical flow
' extracted to sq_ref_assemble_context for reuse in TASKSVC-01.

@enduml