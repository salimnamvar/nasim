@startuml sq_contextgraph02_truncate_nodes
' ============================================================
' Title:     CONTEXTSERVICE-02 — TRUNCATE Nodes
' Boundary:  nasim code agent
' Purpose:   Truncate low-priority context nodes to fit budget
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> TruncationProcessor
' SM States: (stateless — COMPACTING owned by TASKSERVICE-06)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CONTEXTSERVICE-02 TRUNCATE Nodes

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "ContextService" as trunc
end box

== CONTEXTSERVICE-02 TRUNCATE Nodes ==

user -> iface : CONTEXTSERVICE-02 TRUNCATE Nodes({nodes, target_tokens})
activate iface
iface -> router : CONTEXTSERVICE-02 TRUNCATE Nodes({nodes, target_tokens})
activate router
router -> trunc : CONTEXTSERVICE-02 TRUNCATE Nodes({nodes, target_tokens})
activate trunc

alt priority_score threshold met
  ref over trunc : CONTEXTSERVICE-02 TRUNCATE Nodes({nodes, target_tokens})
  trunc --> router : 200 OK
  deactivate trunc
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else all_nodes_essential
  trunc --> router : 422 UNPROCESSABLE\n{error: {code: "CONTEXTSERVICE-02_TRUNCATION_FAILED", message: "Cannot truncate — all nodes essential", status: 422}}
  deactivate trunc
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
