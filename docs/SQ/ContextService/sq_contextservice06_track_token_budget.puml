@startuml sq_contextgraph06_track_token_budget
' ============================================================
' Title:     CONTEXTSERVICE-06 — TRACK Token Budget
' Boundary:  nasim code agent
' Purpose:   Track token consumption against allocated budget
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> TokenBudgetTracker
' SM States: (stateless — COMPACTING owned by TASKSERVICE-06)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CONTEXTSERVICE-06 TRACK Token Budget

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Context Service" as tracker
end box

== CONTEXTSERVICE-06 TRACK Token Budget ==

user -> iface : CONTEXTSERVICE-06 TRACK Token Budget({used_tokens, total_budget})
activate iface
iface -> router : CONTEXTSERVICE-06 TRACK Token Budget({used_tokens, total_budget})
activate router
router -> tracker : CONTEXTSERVICE-06 TRACK Token Budget({used_tokens, total_budget})
activate tracker

alt budget_within_limits
  ref over tracker : CONTEXTSERVICE-06 TRACK Token Budget({used_tokens, total_budget})
  tracker --> router : 200 OK
  deactivate tracker
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else budget_exceeded
  tracker --> router : 429 TOO_MANY_REQUESTS\n{error: {code: "CONTEXTSERVICE-06_BUDGET_EXCEEDED", message: "Token budget exceeded", status: 429}}
  deactivate tracker
  router --> iface : 429 TOO_MANY_REQUESTS
  iface --> user : 429 TOO_MANY_REQUESTS
  deactivate router
  deactivate iface
end

@enduml
