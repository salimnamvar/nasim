@startuml sq_contextgraph05_compact_nodes
' ============================================================
' Title:     CONTEXTSERVICE-05 — COMPACT Nodes
' Boundary:  nasim code agent
' Purpose:   Compact low-importance nodes by merging or summarizing
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> CompactionProcessor
' SM States: (stateless — COMPACTING owned by TASKSERVICE-06)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CONTEXTSERVICE-05 COMPACT Nodes

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "ContextService" as compact
end box

== CONTEXTSERVICE-05 COMPACT Nodes ==

user -> iface : CONTEXTSERVICE-05 COMPACT Nodes({nodes, strategy})
activate iface
iface -> router : CONTEXTSERVICE-05 COMPACT Nodes({nodes, strategy})
activate router
router -> compact : CONTEXTSERVICE-05 COMPACT Nodes({nodes, strategy})
activate compact

alt merge_threshold met
  ref over compact : CONTEXTSERVICE-05 COMPACT Nodes({nodes, strategy})
  compact --> router : 200 OK
  deactivate compact
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else compaction_fails
  compact --> router : 422 UNPROCESSABLE\n{error: {code: "CONTEXTSERVICE-05_COMPACTION_FAILED", message: "Node compaction failed", status: 422}}
  deactivate compact
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
