@startuml sq_contextgraph04_inject_context
' ============================================================
' Title:     CONTEXTSERVICE-04 — INJECT Context
' Boundary:  nasim code agent
' Purpose:   Inject relevant context into the conversation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> InjectionProcessor
' SM States: (stateless — COMPACTING owned by TASKSERVICE-06)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CONTEXTSERVICE-04 INJECT Context

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Context Service" as inject
end box

== CONTEXTSERVICE-04 INJECT Context ==

user -> iface : CONTEXTSERVICE-04 INJECT Context({query, max_results})
activate iface
iface -> router : CONTEXTSERVICE-04 INJECT Context({query, max_results})
activate router
router -> inject : CONTEXTSERVICE-04 INJECT Context({query, max_results})
activate inject

alt relevant_context found
  ref over inject : CONTEXTSERVICE-04 INJECT Context({query, max_results})
  inject --> router : 200 OK
  deactivate inject
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else no_relevant_context
  inject --> router : 404 NOT_FOUND\n{error: {code: "CONTEXTSERVICE-04_NO_RELEVANT_CONTEXT", message: "No relevant context found", status: 404}}
  deactivate inject
  router --> iface : 404 NOT_FOUND
  iface --> user : 404 NOT_FOUND
  deactivate router
  deactivate iface
end

@enduml
