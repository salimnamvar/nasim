@startuml sq_provider01_register_provider
' ============================================================
' Title:     LLMREPOSITORY-01 — REGISTER Provider
' Boundary:  nasim code agent
' Purpose:   Provider instantiation from config
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> Provider
' SM States: REGISTERING (#29B6F6), ACTIVE (#03A9F4), ERROR (#E64A19)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- LLMREPOSITORY-01 REGISTER Provider

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "LLMRepository" as mgr
end box

== LLMREPOSITORY-01 REGISTER Provider ==

user -> iface : POST /providers:register
activate iface
iface -> router : POST /providers:register
activate router
router -> mgr : LLMREPOSITORY-01 REGISTER Provider({config})
activate mgr

alt validation succeeds
  ref over mgr : LLMREPOSITORY-01 REGISTER Provider({config}) <back:#03A9F4>ACTIVE</back>
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
