@startuml sq_rtg04_switch_model
!include ../common/sq_styles.puml
' ============================================================
' Title:     RTG-04 — Switch Model
' Boundary:  nasim code agent
' Purpose:   Change the active model at runtime
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — RTG-04 UPDATE Model

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Router Group" #FFF3E0
  participant "ModelRouter" as router
end box


note over user
  Scope:          RTG-04 Switch Model — change the active model at runtime
  Preconditions:  Target model specified; model catalog available
  Contexts:       Called by AgentOrchestrator when user or system requests runtime model change
  Excludes:       Initial model selection, fallback chain application, task classification
  Rollback:       Model not in catalog → Error("model not available")
  Design:         Validates model availability, updates active model config atomically
  Returns:
    - Success: 200 OK — {previous_model, new_model}
    - Failure: 400 Bad Request — model not available
end note

== RTG-04 Switch Model ==

user -> router : types input
activate router
router -> agent : RTG-04 PROCESS(user_input)
activate agent

agent -> router : RTG-04 SWITCH Model(target_model, updateMask)
activate router

break Model not in catalog
    router --> agent : Error("model not available")
    agent --> router : AgentEvent(Error)
end

router -> router : RTG-04 VALIDATE ModelAvailability(target_model)
router -> router : RTG-04 UPDATE ActiveModelConfig(target_model)

router --> agent : Result(success=true, data={previous_model, new_model})

agent --> router : AgentEvent(Done)

deactivate agent
deactivate router

note over user
  Flow:    User → ServerRouter → AgentOrchestrator → ModelRouter → validate availability → update config → Result
  State:   No state change (updates runtime config; previous model tracked for rollback)
  Success: 200 OK — AgentEvent(Done) with {previous_model, new_model}
  Failure: 400 Bad Request: model not in catalog — propagate error to user
end note

@enduml
