@startuml sq_plg05_enable_plugin
!include ../common/sq_styles.puml
' ============================================================
' Title:     PLG-05 — Enable Plugin
' Boundary:  nasim code agent
' Purpose:   Load plugin and activate its tools and hooks
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Tool Group" #E8F5E9
  participant "PluginLoader" as loader
  participant "ToolRegistry" as registry
end box
box "Hooks Group" #F3E5F5
  participant "HookManager" as hm
end box

note over user
  Scope:          PLG-05 Enable Plugin — Loads plugin and activates its tools and hooks
  Preconditions:  Plugin manifest loaded, plugin in DISABLED or idle state
  Contexts:       Root entry point for enabling a plugin
  Excludes:       Plugin discovery, manifest loading
  Rollback:       Tool or hook registration failure → set state ERROR, log failure
  Design:         Delegates to PLG-03 and PLG-04, sets ENABLED on success, ERROR on failure
  Returns:
    - Success: 200 + plugin enabled
    - Failure: 200 + state set to ERROR
end note

user -> router : types input
router -> agent : PROCESS(user_input)

== PLG-05 Enable Plugin ==

agent -> loader : PLG-05 ENABLE_PLUGIN(plugin_id)
activate loader

loader -> loader : PLG-03 register_plugin_tools()
loader -> loader : PLG-04 register_plugin_hooks()
loader -> loader : set state ENABLED

break Tool or hook registration fails
    loader -> loader : set state ERROR, log failure
end

loader --> agent : plugin enabled
deactivate loader

agent --> router : AgentEvent(Done)

note over user
  Flow:    PLG-05 → PLG-03 register_tools → PLG-04 register_hooks → set ENABLED
  State:   DISABLED → ENABLED (or → ERROR on failure)
  Success: 200 + plugin enabled
  Failure: 200 + state ERROR — tool/hook registration failed, logged
end note

@enduml
