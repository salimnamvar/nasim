@startuml sq_sandbox02_apply_sandbox_policy
' ============================================================
' Title:     SBX-02 — APPLY Sandbox Policy
' Boundary:  nasim code agent
' Purpose:   Load and apply sandbox security policy
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SandboxManager -> SandboxStore -> SandboxDirectory -> HostShell
' SM States: IDLE (#78909C)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SBX-02 APPLY Sandbox Policy

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Sandbox Group (Service)" #FFF3E0
  participant "SandboxManager" as mgr
end box
box "Sandbox Group (Repository)" #E8F5E9
  participant "SandboxStore" as store
end box
database "SandboxDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "HostShell" as HostShell
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "HostShell" as HostShell
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "HostShell" as HostShell
end box

== SBX-02 APPLY Sandbox Policy ==

user -> iface : PATCH /sandbox/policy
activate iface
iface -> router : PATCH /sandbox/policy
activate router
router -> mgr : sbx02 APPLY Sandbox Policy(policy_path)
activate mgr

alt policy applied
  mgr -> store : sbx02 APPLY Sandbox Policy(policy_path)
  activate store
  store -> dir : sbx02 APPLY Sandbox Policy(policy_path)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : IDLE (#78909C)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else invalid policy
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
