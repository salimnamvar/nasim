@startuml sq_sandbox02_apply_sandbox_policy
' ============================================================
' Title:     SBX-02 — APPLY Sandbox Policy
' Boundary:  nasim code agent
' Purpose:   Load and apply sandbox security policy
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SandboxAPI -> SandboxManager -> SandboxStore -> SandboxDirectory
' SM States: IDLE (#78909C)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SBX-02 APPLY Sandbox Policy

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "SandboxAPI" as api
end box
box "Sandbox Group (Service)" #FFF3E0
  participant "SandboxManager" as mgr
end box
box "Sandbox Group (Repository)" #E8F5E9
  participant "SandboxStore" as store
end box
database "SandboxDirectory" as dir

== SBX-02 APPLY Sandbox Policy ==

user -> router : PATCH /sandbox/policy
activate router
router -> api : sbx02 APPLY Sandbox Policy(policy_path)
activate api
api -> mgr : sbx02 APPLY Sandbox Policy(policy_path)
activate mgr

alt policy applied
  mgr -> store : sbx02 APPLY Sandbox Policy(policy_path)
  activate store
  store -> dir : sbx02 APPLY Sandbox Policy(policy_path)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : IDLE (#78909C)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else invalid policy
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
