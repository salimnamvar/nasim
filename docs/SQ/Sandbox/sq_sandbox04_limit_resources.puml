@startuml sq_sandbox04_limit_resources
' ============================================================
' Title:     SBX-04 — LIMIT Resources
' Boundary:  nasim code agent
' Purpose:   Enforce CPU, memory, and disk quotas per sandbox instance
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SandboxAPI -> SandboxManager -> SandboxStore -> SandboxDirectory
' SM States: RESOURCE_EXCEEDED (#FF5722)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SBX-04 LIMIT Resources

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "SandboxAPI" as api
end box
box "Sandbox Group (Service)" #FFF3E0
  participant "SandboxManager" as mgr
end box
box "Sandbox Group (Repository)" #E8F5E9
  participant "SandboxStore" as store
end box
database "SandboxDirectory" as dir

== SBX-04 LIMIT Resources ==

user -> router : PATCH /sandbox/limits
activate router
router -> api : sbx04 LIMIT Resources(cgroup_id, quotas)
activate api
api -> mgr : sbx04 LIMIT Resources(cgroup_id, quotas)
activate mgr

alt limits set
  mgr -> store : sbx04 LIMIT Resources(cgroup_id, quotas)
  activate store
  store -> dir : sbx04 LIMIT Resources(cgroup_id, quotas)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : RESOURCE_EXCEEDED (#FF5722)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else cgroup setup fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
