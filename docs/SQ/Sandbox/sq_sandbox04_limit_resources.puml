@startuml sq_sandbox04_limit_resources
' ============================================================
' Title:     SBX-04 — LIMIT Resources
' Boundary:  nasim code agent
' Purpose:   Enforce CPU, memory, and disk quotas per sandbox instance
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SandboxManager -> SandboxStore -> SandboxDirectory -> HostShell
' SM States: RESOURCE_EXCEEDED (#FF5722)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SBX-04 LIMIT Resources

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Sandbox Group (Service)" #FFF3E0
  participant "SandboxManager" as mgr
end box
box "Sandbox Group (Repository)" #E8F5E9
  participant "SandboxStore" as store
end box
database "SandboxDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "HostShell" as HostShell
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "HostShell" as HostShell
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "HostShell" as HostShell
end box

== SBX-04 LIMIT Resources ==

user -> iface : PATCH /sandbox/limits
activate iface
iface -> router : PATCH /sandbox/limits
activate router
router -> mgr : sbx04 LIMIT Resources(cgroup_id, quotas)
activate mgr

alt limits set
  mgr -> store : sbx04 LIMIT Resources(cgroup_id, quotas)
  activate store
  store -> dir : sbx04 LIMIT Resources(cgroup_id, quotas)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : RESOURCE_EXCEEDED (#FF5722)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else cgroup setup fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
