@startuml sq_sandbox03_monitor_process
' ============================================================
' Title:     SBX-03 — MONITOR Process
' Boundary:  nasim code agent
' Purpose:   Monitor sandboxed process for timeout and resource usage
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SandboxMonitor
' SM States: MONITORING (#64B5F6)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SBX-03 MONITOR Process

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Infrastructure" INFRASTRUCTURE_COLOR
  participant "SandboxMonitor" as mgr
end box

== SBX-03 MONITOR Process ==

user -> iface : GET /sandbox/monitor/{process}
activate iface
iface -> router : GET /sandbox/monitor/{process}
activate router
router -> mgr : sbx03 MONITOR Process(process_id, limits)
activate mgr

alt normal completion
  ref over mgr : SBX-03 TRANSITION State
    ' SM States: MONITORING (#64B5F6)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else timeout or resource exceeded
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
