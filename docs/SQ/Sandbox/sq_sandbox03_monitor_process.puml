@startuml sq_sandbox03_monitor_process
' ============================================================
' Title:     SBX-03 — MONITOR Process
' Boundary:  nasim code agent
' Purpose:   Monitor sandboxed process for timeout and resource usage
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SandboxManager -> SandboxStore -> SandboxDirectory -> HostShell
' SM States: MONITORING (#64B5F6)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SBX-03 MONITOR Process

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Sandbox Group (Service)" #FFF3E0
  participant "SandboxManager" as mgr
end box
box "Sandbox Group (Repository)" #E8F5E9
  participant "SandboxStore" as store
end box
database "SandboxDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "HostShell" as HostShell
end box



== SBX-03 MONITOR Process ==

user -> iface : GET /sandbox/monitor/{process}
activate iface
iface -> router : GET /sandbox/monitor/{process}
activate router
router -> mgr : sbx03 MONITOR Process(process_id, limits)
activate mgr

alt normal completion
  mgr -> store : sbx03 MONITOR Process(process_id, limits)
  activate store
  store -> dir : sbx03 MONITOR Process(process_id, limits)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#64B5F6>MONITORING</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else timeout or resource exceeded
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
