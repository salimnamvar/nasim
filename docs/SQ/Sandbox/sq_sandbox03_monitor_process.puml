@startuml sq_sandbox03_monitor_process
' ============================================================
' Title:     SBX-03 — MONITOR Process
' Boundary:  nasim code agent
' Purpose:   Monitor sandboxed process for timeout and resource usage
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SandboxAPI -> SandboxManager -> SandboxStore -> SandboxDirectory
' SM States: MONITORING (#64B5F6)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SBX-03 MONITOR Process

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "SandboxAPI" as api
end box
box "Sandbox Group (Service)" #FFF3E0
  participant "SandboxManager" as mgr
end box
box "Sandbox Group (Repository)" #E8F5E9
  participant "SandboxStore" as store
end box
database "SandboxDirectory" as dir

== SBX-03 MONITOR Process ==

user -> router : GET /sandbox/monitor/{process}
activate router
router -> api : sbx03 MONITOR Process(process_id, limits)
activate api
api -> mgr : sbx03 MONITOR Process(process_id, limits)
activate mgr

alt normal completion
  mgr -> store : sbx03 MONITOR Process(process_id, limits)
  activate store
  store -> dir : sbx03 MONITOR Process(process_id, limits)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : MONITORING (#64B5F6)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else timeout or resource exceeded
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
