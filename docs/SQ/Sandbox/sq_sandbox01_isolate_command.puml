@startuml sq_sandbox01_isolate_command
' ============================================================
' Title:     SBX-01 — ISOLATE Command
' Boundary:  nasim code agent
' Purpose:   Execute command in OS-level sandbox
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SandboxAPI -> SandboxManager -> SandboxStore -> SandboxDirectory
' SM States: EXECUTING (#2196F3)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SBX-01 ISOLATE Command

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "API Group (Controller)" #FFF3E0
  participant "SandboxAPI" as api
end box
box "Sandbox Group (Service)" #FFF3E0
  participant "SandboxManager" as mgr
end box
box "Sandbox Group (Repository)" #E8F5E9
  participant "SandboxStore" as store
end box
database "SandboxDirectory" as dir

== SBX-01 ISOLATE Command ==

user -> router : POST /sandbox/isolate
activate router
router -> api : sbx01 ISOLATE Command(command, policy)
activate api
api -> mgr : sbx01 ISOLATE Command(command, policy)
activate mgr

alt execution succeeds
  mgr -> store : sbx01 ISOLATE Command(command, policy)
  activate store
  store -> dir : sbx01 ISOLATE Command(command, policy)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : EXECUTING (#2196F3)
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else timeout or violation
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
