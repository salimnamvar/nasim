@startuml sq_sandbox01_isolate_command
' ============================================================
' Title:     SBX-01 — ISOLATE Command
' Boundary:  nasim code agent
' Purpose:   Execute command in OS-level sandbox
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SandboxManager -> SandboxStore -> SandboxDirectory -> HostShell
' SM States: EXECUTING (#2196F3)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- SBX-01 ISOLATE Command

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Sandbox Group (Service)" #FFF3E0
  participant "SandboxManager" as mgr
end box
box "Sandbox Group (Repository)" #E8F5E9
  participant "SandboxStore" as store
end box
database "SandboxDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "HostShell" as HostShell
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "HostShell" as HostShell
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "HostShell" as HostShell
end box

== SBX-01 ISOLATE Command ==

user -> iface : POST /sandbox/isolate
activate iface
iface -> router : POST /sandbox/isolate
activate router
router -> mgr : sbx01 ISOLATE Command(command, policy)
activate mgr

alt execution succeeds
  mgr -> store : sbx01 ISOLATE Command(command, policy)
  activate store
  store -> dir : sbx01 ISOLATE Command(command, policy)
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  hnote over mgr : EXECUTING (#2196F3)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else timeout or violation
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
