@startuml sq_ref_truncate_nodes
' ============================================================
' Title:     REF — Truncate Nodes (CONTEXTSVC-02)
' Purpose:   Reusable sub-flow: truncate context graph nodes.
' Source:    docs/UC/uc_context_svc.puml
' SM:        THINKING (context pipeline stage)
' ============================================================

!include sq_styles.puml

participant "Context Service" as ctxSvc

ctxSvc -> ctxSvc : CONTEXTSVC-02 truncateNodes({graph})

ref over ctxSvc : CONTEXTSVC-02 truncateNodes\nState: <back:#D7CCC8>THINKING</back> (truncation)

ctxSvc --> ctxSvc : 200 OK — {truncatedGraph}

@enduml
