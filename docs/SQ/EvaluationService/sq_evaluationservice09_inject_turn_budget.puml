@startuml sq_evaluation09_inject_turn_budget
' ============================================================
' Title:     EVALUATIONSERVICE-09 — INJECT Turn Budget
' Boundary:  nasim code agent
' Purpose:   Inject remaining turn budget into the conversation
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> TurnBudgetInjector
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVALUATIONSERVICE-09 INJECT Turn Budget

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Evaluation Service" as injector
end box

== EVALUATIONSERVICE-09 INJECT Turn Budget ==

user -> iface : EVALUATIONSERVICE-09 INJECT Turn Budget({task_id, remaining_turns, max_turns})
activate iface
iface -> router : EVALUATIONSERVICE-09 INJECT Turn Budget({task_id, remaining_turns, max_turns})
activate router
router -> injector : EVALUATIONSERVICE-09 INJECT Turn Budget({task_id, remaining_turns, max_turns})
activate injector

alt injection succeeds
  ref over injector : EVALUATIONSERVICE-09 INJECT Turn Budget({task_id, remaining_turns, max_turns}) <back:#C5CAE9>CHECKING</back>({task_id, remaining_turns, max_turns})
  injector --> router : 200 OK
  deactivate injector
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else budget exceeded
  injector --> router : 422 UNPROCESSABLE\n{error: {code: "EVALUATIONSERVICE-09_BUDGET_EXCEEDED", message: "Turn budget exceeded", status: 422}}
  deactivate injector
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "EVALUATIONSERVICE-09_BUDGET_EXCEEDED", message: "Turn budget exceeded", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "EVALUATIONSERVICE-09_BUDGET_EXCEEDED", message: "Turn budget exceeded", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
