@startuml sq_evaluation08_detect_repetition
' ============================================================
' Title:     EVALUATIONSERVICE-08 — DETECT Repetition
' Boundary:  nasim code agent
' Purpose:   Detect repetitive tool call or response patterns
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> RepetitionDetector
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVALUATIONSERVICE-08 DETECT Repetition

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Evaluation Service" as detector
end box

== EVALUATIONSERVICE-08 DETECT Repetition ==

user -> iface : GET /evaluation/repetition
activate iface
iface -> router : GET /evaluation/repetition
activate router
router -> detector : EVALUATIONSERVICE-08 DETECT Repetition({task_id, recent_calls})
activate detector

alt no repetition
  ref over detector : EVALUATIONSERVICE-08 DETECT Repetition({task_id, recent_calls}) <back:#C5CAE9>CHECKING</back>({task_id, recent_calls})
  detector --> router : 200 OK
  deactivate detector
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else repetition detected
  detector --> router : 409 CONFLICT\n{error: {code: "EVALUATIONSERVICE-08_REPETITION_DETECTED", message: "Repetitive pattern detected", status: 409}}
  deactivate detector
  router --> iface : 409 CONFLICT\n{error: {code: "EVALUATIONSERVICE-08_REPETITION_DETECTED", message: "Repetitive pattern detected", status: 409}}
  iface --> user : 409 CONFLICT\n{error: {code: "EVALUATIONSERVICE-08_REPETITION_DETECTED", message: "Repetitive pattern detected", status: 409}}
  deactivate router
  deactivate iface
end

@enduml
