@startuml sq_evaluation02_check_task_completion
' ============================================================
' Title:     EVALUATIONSERVICE-02 — CHECK Task Completion
' Boundary:  nasim code agent
' Purpose:   Check whether the task's criteria are met
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> Agent Controller -> TaskEvaluator
' SM States: CHECKING (#C5CAE9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVALUATIONSERVICE-02 CHECK Task Completion

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

box "Service" SERVICE_COLOR
  participant "Evaluation Service" as eval
end box

== EVALUATIONSERVICE-02 CHECK Task Completion ==

user -> iface : EVALUATIONSERVICE-02 CHECK Task Completion({task_id})
activate iface
iface -> router : EVALUATIONSERVICE-02 CHECK Task Completion({task_id})
activate router
router -> eval : EVALUATIONSERVICE-02 CHECK Task Completion({task_id})
activate eval

alt criteria_met
  ref over eval : EVALUATIONSERVICE-02 CHECK Task Completion({task_id}) <back:#C5CAE9>CHECKING</back>
  eval --> router : 200 OK
  deactivate eval
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else criteria_unmet
  eval --> router : 422 UNPROCESSABLE\n{error: {code: "EVALUATIONSERVICE-02_CRITERIA_UNMET", message: "Task completion criteria not met", status: 422}}
  deactivate eval
  router --> iface : 422 UNPROCESSABLE
  iface --> user : 422 UNPROCESSABLE
  deactivate router
  deactivate iface
end

@enduml
