@startuml sq_evaluation07_record_quality_signal
' ============================================================
' Title:     EVALUATIONSERVICE-07 — RECORD Quality Signal
' Boundary:  nasim code agent
' Purpose:   Record and persist quality signals for scoring
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> QualitySignal
' SM States: SCORING (#FF8A65)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- EVALUATIONSERVICE-07 RECORD Quality Signal

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "EvaluationService" as signal
end box

== EVALUATIONSERVICE-07 RECORD Quality Signal ==

user -> iface : POST /evaluation/quality-signal
activate iface
iface -> router : POST /evaluation/quality-signal
activate router
router -> signal : EVALUATIONSERVICE-07 RECORD Quality Signal({task_id, score, signals})
activate signal

alt recording succeeds
  ref over signal : EVALUATIONSERVICE-07 RECORD Quality Signal({task_id, score, signals}) <back:#FF8A65>SCORING</back>({task_id, score, signals})
  signal --> router : 200 OK
  deactivate signal
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else recording fails
  signal --> router : 422 UNPROCESSABLE\n{error: {code: "EVALUATIONSERVICE-07_RECORD_FAILED", message: "Quality signal recording failed", status: 422}}
  deactivate signal
  router --> iface : 422 UNPROCESSABLE\n{error: {code: "EVALUATIONSERVICE-07_RECORD_FAILED", message: "Quality signal recording failed", status: 422}}
  iface --> user : 422 UNPROCESSABLE\n{error: {code: "EVALUATIONSERVICE-07_RECORD_FAILED", message: "Quality signal recording failed", status: 422}}
  deactivate router
  deactivate iface
end

@enduml
