@startuml sq_vcs04_auto_commit
!include ../common/sq_styles.puml
' ============================================================
' Title:     VCS-04 — AUTO-COMMIT
' Boundary:  nasim code agent
' Purpose:   Automatically commit changes after edit operations
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — VCS-04 AUTO-COMMIT

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Git Group" #E8F5E9
  participant "GitIntegration" as integration
  participant "GitStatus" as status
  participant "GitCommit" as commit
end box
box "Repository Group" #E8F5E9
  participant "GitRepository" as git_repo
end box


note over user
  Scope:          VCS-04 AUTO-COMMIT — automatically commit changes after edit operations
  Preconditions:  Git repository initialized; edit operation completed successfully
  Contexts:       Called by AgentOrchestrator after file edit/write operations
  Excludes:       Manual commit flow, staging, push, conflict resolution
  Rollback:       No changes detected → return error "no_changes"; commit fails → propagate git error
  Design:         Generates conventional commit message from edit context; atomic commit per edit
  Returns:
    - Success: 200 OK — {hash}
    - Failure: 400 Bad Request — no_changes
end note

== VCS-04 AUTO-COMMIT ==

user -> router : types input
router -> agent : VCS-04 PROCESS(user_input)

agent -> integration : VCS-04 AUTO-COMMIT(edit_context)
activate integration

integration -> status : VCS-04 READ DirtyStatus()
activate status
status --> integration : is_dirty
deactivate status

break No changes detected
    integration --> agent : Result(success=false, error="no_changes")
    agent --> router : AgentEvent(Done)
end

integration -> commit : VCS-04 INSERT Commit(generated_message, files)
activate commit
commit --> integration : Result(success=true, data={hash})
deactivate commit

integration --> agent : Result(success=true, data={hash})
deactivate integration

agent --> router : AgentEvent(Done)

note over user
  Flow:    User → ServerRouter → AgentOrchestrator → GitIntegration → check dirty → GitCommit → Result
  State:   No state change (creates commit in git history)
  Success: 200 OK — AgentEvent(Done) with {hash}
  Failure: 400 Bad Request: no_changes — skip commit, return to caller
end note

@enduml
