@startuml sq_vcs02_insert_commit
!include ../common/sq_styles.puml
' ============================================================
' Title:     VCS-02 — INSERT Commit
' Boundary:  nasim code agent
' Purpose:   Create a commit with conventional message
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — VCS-02 INSERT Commit

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Git Group" #E8F5E9
  participant "GitCommit" as commit
  participant "GitStatus" as status
end box
box "External" #F5F5F5
  participant "Git Repository" as git
end box


note over user
  Scope:          VCS-02 INSERT Commit — create commit with conventional message
  Preconditions:  Git repository initialized; files staged via git add
  Contexts:       Called by AgentOrchestrator after user confirms commit or auto-commit triggers
  Excludes:       Staging files, diff computation, push operations
  Rollback:       No staged files → error "no_staged_files"; invalid message → error "invalid_commit_message"
  Design:         Validates conventional commit format before executing git commit
  Returns:
    - Success: 200 OK — {hash, files}
    - Failure: 400 Bad Request — no_staged_files | invalid_commit_message
end note

== VCS-02 INSERT Commit ==

user -> router : types input
router -> agent : VCS-02 PROCESS(user_input)

agent -> commit : VCS-02 INSERT Commit(message, files)
activate commit

commit -> status : VCS-02 READ StagedFiles()
activate status
status --> commit : staged_files
deactivate status

break No staged files
    commit --> agent : Result(success=false, error="no_staged_files")
    agent --> router : AgentEvent(Error)
end

commit -> commit : VCS-02 VALIDATE Message(message)

break Invalid message format
    commit --> agent : Result(success=false, error="invalid_commit_message")
    agent --> router : AgentEvent(Error)
end

commit -> git : VCS-02 EXECUTE git_commit(message)
activate git
git --> commit : commit_output
deactivate git

commit --> agent : Result(success=true, data={hash, files})
deactivate commit

agent --> router : AgentEvent(Done)

note over user
  Flow:    User → ServerRouter → AgentOrchestrator → GitCommit → read staged → validate message → git commit → Result
  State:   No state change (creates commit in git history)
  Success: 200 OK — AgentEvent(Done) with {hash, files}
  Failure: 400 Bad Request: no_staged_files — prompt user to stage files; 400 Bad Request: invalid_commit_message — prompt for valid format
end note

@enduml
