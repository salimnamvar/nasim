@startuml sq_vcs01_read_git_status
!include ../common/sq_styles.puml
' ============================================================
' Title:     VCS-01 — READ Git Status
' Boundary:  nasim code agent
' Purpose:   Read working tree status and staged changes
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — VCS-01 READ Git Status

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Git Group" #E8F5E9
  participant "GitStatus" as status
end box
box "External" #F5F5F5
  participant "Git Repository" as git
end box


note over user
  Scope:          VCS-01 READ Git Status — read working tree and staged changes
  Preconditions:  Git repository exists in project root; git CLI available
  Contexts:       Called by AgentOrchestrator before commit/diff operations
  Excludes:       Diff computation, commit creation, branch switching
  Rollback:       Not a git repo → return error "not_a_git_repository"
  Design:         Uses porcelain output for stable parsing; no side effects
  Returns:
    - Success: 200 OK — {staged, modified, untracked}
    - Failure: 400 Bad Request — not_a_git_repository
end note

== VCS-01 READ Git Status ==

user -> router : types input
router -> agent : VCS-01 PROCESS(user_input)

agent -> status : VCS-01 READ GitStatus()
activate status

status -> git : VCS-01 EXECUTE git_status_porouslain()
activate git
git --> status : raw_output
deactivate git

status -> status : VCS-01 PARSE StatusOutput(raw_output)

break Not a git repo
    status --> agent : Result(success=false, error="not_a_git_repository")
    agent --> router : AgentEvent(Error)
end

status --> agent : Result(success=true, data={staged, modified, untracked})
deactivate status

agent --> router : AgentEvent(Done)

note over user
  Flow:    User → ServerRouter → AgentOrchestrator → GitStatus → git status → parse → Result
  State:   No state change (read-only)
  Success: 200 OK — AgentEvent(Done) with {staged, modified, untracked}
  Failure: 400 Bad Request: not_a_git_repository — propagate error to user
end note

@enduml
