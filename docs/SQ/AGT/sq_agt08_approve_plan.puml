@startuml sq_agt08_approve_plan
!include ../common/sq_styles.puml
' ============================================================
' Title:     AGT-08 — APPROVE Plan
' Boundary:  nasim code agent
' Purpose:   Execute queued tool calls from plan mode
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — AGT-08 APPROVE Plan

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
  participant "PlanSession" as plan
end box
box "Tool Group" #E8F5E9
  participant "ToolRegistry" as registry
end box
box "Repository Group" #E8F5E9
  participant "MemoryRepository" as memory
end box


note over user
  Scope:          AGT-08 APPROVE Plan — Execute queued tool calls
  Preconditions:  Plan queued via AGT-07, user approval received (/approve)
  Contexts:       /approve API endpoint
  Excludes:       Safety pipeline (AGT-15), Individual tool error handling
  Rollback:       Sequential execution, partial results on failure
  Design:         Sequential execution of queued calls, result aggregation
  Returns:
    - Success: 200 AgentEvent(Done) with all tool results
    - Failure: 400 partial results if any tool execution fails
end note

== AGT-08 APPROVE Plan ==

user -> router : /approve
router -> agent : APPROVE_Plan()
activate agent

agent -> plan : agt08 APPROVE Plan()
activate plan
plan -> plan : get pending_calls
plan -> plan : clear pending_calls

loop for each queued call
    plan -> registry : agt02 DISPATCH Tool Call({tool_name}, {args})
    activate registry
    registry --> plan : ToolResult
    deactivate registry
    plan -> plan : collect results
end

plan --> agent : all results
deactivate plan

agent --> router : AgentEvent(Done)
deactivate agent


note over user
  Flow:    AGT-08 → APPROVE Plan → loop AGT-02 → collect results
  State:   PLAN_QUEUED → TOOL_EXEC (per tool) → THINKING
  Success: 200 AgentEvent(Done) with aggregated tool results
  Failure: 400 partial results if any queued tool execution fails
end note

@enduml
