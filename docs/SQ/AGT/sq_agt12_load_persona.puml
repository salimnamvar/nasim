@startuml sq_agt12_load_persona
!include ../common/sq_styles.puml
' ============================================================
' Title:     AGT-12 — LOAD Persona
' Boundary:  nasim code agent
' Purpose:   Load persona configuration and apply system prompt
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — AGT-12 READ Persona

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
  participant "PersonaManager" as pm
end box
box "Config Group" #E8F5E9
  participant "PersonaRegistry" as reg
end box
box "Repository Group" #E8F5E9
  participant "MemoryRepository" as memory
end box


note over user
  Scope:          AGT-12 LOAD Persona — Load persona configuration
  Preconditions:  PersonaRegistry populated, persona_name provided
  Contexts:       AGT-11 DELEGATE to Persona, Direct persona load
  Excludes:       Persona switching (AGT-13), Tool execution with persona
  Rollback:       Invalid config → PersonaLoadError
  Design:         Config validation with system prompt and tool allowlist extraction
  Returns:
    - Success: 200 PersonaLoaded with parsed config
    - Failure: 400 PersonaLoadError on invalid config
end note

== AGT-12 LOAD Persona ==

user -> router : types input
router -> agent : PROCESS(user_input)
activate agent

agent -> pm : agt12 LOAD Persona({persona_name})
activate pm

pm -> reg : get_persona_config(persona_name)
activate reg
reg --> pm : config
deactivate reg

alt config valid
    pm -> pm : parse system prompt
    pm -> pm : extract tool allowlist
    pm -> pm : extract model override (if set)
    pm --> agent : PersonaLoaded(config)
else config invalid
    pm -> agent : PersonaLoadError
end

deactivate pm

agent --> router : AgentEvent(Done)
deactivate agent


note over user
  Flow:    AGT-12 → get_persona_config → parse prompt → extract allowlist
  State:   THINKING → PERSONA_ACTIVE → THINKING
  Success: 200 PersonaLoaded with system prompt and tool allowlist
  Failure: 400 PersonaLoadError on invalid or missing config
end note

@enduml
