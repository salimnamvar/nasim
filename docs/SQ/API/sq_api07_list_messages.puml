@startuml sq_api07_list_messages
' ============================================================
' Title:     API-07 — LIST Messages
' Boundary:  nasim code agent
' Purpose:   Retrieve message history for a session
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> MessageAPI -> SessionManager -> SessionStore
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-07 LIST Messages

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "ServerRouter" as router
end box
box "Controller" #FFF3E0
  participant "MessageAPI" as api
end box
box "Service" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Repository" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

== API-07 LIST Messages ==

user -> router : GET /v1/sessions/{id}/messages
activate router
router -> api : api07 LIST Messages({sessionId, pageSize, pageToken})
activate api
api -> mgr : api07 LIST Messages({sessionId, pageSize, pageToken})
activate mgr

alt validation succeeds
  mgr -> store : api07 LIST Messages({sessionId, pageSize, pageToken})
  activate store
  store -> dir : api07 LIST Messages({sessionId, pageSize, pageToken})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
