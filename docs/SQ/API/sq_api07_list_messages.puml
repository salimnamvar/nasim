@startuml sq_api07_list_messages
' ============================================================
' Title:     API-07 — LIST Messages
' Boundary:  nasim code agent
' Purpose:   Retrieve message history for a session
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionStore -> SessionStorage
' SM States: (no state change — read-only)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-07 LIST Messages

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box

database "SessionStorage" as storage

== API-07 LIST Messages ==

user -> iface : GET /v1/sessions/{id}/messages
activate iface
iface -> router : GET /v1/sessions/{id}/messages
activate router

router -> store : API-07 LIST Messages({sessionId, pageSize, pageToken})
activate store

alt validation fails
    store --> router : 422 Unprocessable
    router --> iface : 422 Unprocessable
    iface --> user : 422 Unprocessable
    deactivate store
    deactivate router
    deactivate iface
end

alt session not found
    store --> router : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate router
    deactivate iface
end

store -> storage : API-07 LIST Messages({sessionId, pageSize, pageToken})
activate storage

alt disk read error
    storage --> store : IOError
    deactivate storage
    store --> router : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate router
    deactivate iface
end

storage --> store : 200 OK — [{message_id, role, content}]
deactivate storage

store --> router : 200 OK — [{message_id, role, content}]
deactivate store
router --> iface : 200 OK — [{message_id, role, content}]
iface --> user : 200 OK — [{message_id, role, content}]
deactivate router
deactivate iface

@enduml
