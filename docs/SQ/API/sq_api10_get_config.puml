@startuml sq_api10_get_config
' ============================================================
' Title:     API-10 — GET Config
' Boundary:  nasim code agent
' Purpose:   Read current agent configuration
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ConfigLoader -> ConfigStorage
' SM States: (no state change — read-only)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-10 GET Config

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Config Group (Repository)" #E8F5E9
  participant "ConfigLoader" as loader
end box

database "ConfigStorage" as storage

== API-10 GET Config ==

user -> iface : GET /v1/config
activate iface
iface -> router : GET /v1/config
activate router

router -> loader : API-10 GET Config()
activate loader

loader -> storage : API-10 GET Config()
activate storage

alt config not found
    storage --> loader : FileNotFoundError
    deactivate storage
    loader --> router : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate loader
    deactivate router
    deactivate iface
end

storage --> loader : 200 OK — {config}
deactivate storage

loader --> router : 200 OK — {config}
deactivate loader
router --> iface : 200 OK — {config}
iface --> user : 200 OK — {config}
deactivate router
deactivate iface

@enduml
