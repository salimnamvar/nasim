@startuml sq_api10_get_config
' ============================================================
' Title:     API-10 — GET Config
' Boundary:  nasim code agent
' Purpose:   Read current agent configuration
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ConfigAPI -> ConfigManager -> ConfigLoader
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-10 GET Config

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "ServerRouter" as router
end box
box "Controller" #FFF3E0
  participant "ConfigAPI" as api
end box
box "Service" #FFF3E0
  participant "ConfigManager" as mgr
end box
box "Repository" #E8F5E9
  participant "ConfigLoader" as store
end box
database "ConfigDirectory" as dir

== API-10 GET Config ==

user -> router : GET /v1/config
activate router
router -> api : API-10 GET Config()
activate api
api -> mgr : API-10 GET Config()
activate mgr

alt validation succeeds
  mgr -> store : API-10 GET Config()
  activate store
  store -> dir : API-10 GET Config()
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
