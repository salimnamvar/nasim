@startuml sq_api04_update_session
' ============================================================
' Title:     API-04 — UPDATE Session
' Boundary:  nasim code agent
' Purpose:   Update session metadata or settings
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ApiManager -> ApiStore -> ApiDirectory -> FileSystem
' SM States: SAVED (#1565C0)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-04 UPDATE Session

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Entry Gate" #E3F2FD
  participant "ServerRouter" as router
end box
box "Service" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Repository" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== API-04 UPDATE Session ==

user -> iface : PATCH /v1/sessions/{id}
activate iface
iface -> router : PATCH /v1/sessions/{id}
activate router
router -> mgr : api04 UPDATE Session({sessionId, patchData})
activate mgr

alt validation succeeds
  mgr -> store : api04 UPDATE Session({sessionId, patchData})
  activate store
  store -> dir : api04 UPDATE Session({sessionId, patchData})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : SAVED (#1565C0) ...
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
