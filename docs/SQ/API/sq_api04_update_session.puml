@startuml sq_api04_update_session
' ============================================================
' Title:     API-04 — UPDATE Session
' Boundary:  nasim code agent
' Purpose:   Update session metadata or settings
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionStore -> SessionStorage
' SM States: ACTIVE (#43A047), SAVED (#1565C0)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-04 UPDATE Session

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box

database "SessionStorage" as storage

== API-04 UPDATE Session ==

user -> iface : PATCH /v1/sessions/{id}
activate iface
iface -> router : PATCH /v1/sessions/{id}
activate router

router -> store : API-04 UPDATE Session({sessionId, patchData})
activate store

alt validation fails
    store --> router : 422 Unprocessable
    router --> iface : 422 Unprocessable
    iface --> user : 422 Unprocessable
    deactivate store
    deactivate router
    deactivate iface
end

alt session not found
    store --> router : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate router
    deactivate iface
end

store -> storage : API-04 UPDATE Session({sessionId, patchData})
activate storage

alt disk write error
    storage --> store : IOError
    deactivate storage
    store --> router : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate router
    deactivate iface
end

storage --> store : 200 OK
deactivate storage

ref over store : API-04 UPDATE Session
  ' Session lifecycle: ACTIVE → SAVED (#1565C0)
  ' Owned by: API-04 UPDATE Session (SM/README.md)

store --> router : 200 OK
deactivate store
router --> iface : 200 OK
iface --> user : 200 OK
deactivate router
deactivate iface

@enduml
