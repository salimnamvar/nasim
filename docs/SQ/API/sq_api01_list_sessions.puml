@startuml sq_api01_list_sessions
' ============================================================
' Title:     API-01 — LIST Sessions
' Boundary:  nasim code agent
' Purpose:   List all sessions with pagination
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ApiManager -> ApiStore -> ApiDirectory -> FileSystem
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-01 LIST Sessions

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Entry Gate" #E3F2FD
  participant "ServerRouter" as router
end box
box "Service" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Repository" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== API-01 LIST Sessions ==

user -> iface : GET /v1/sessions
activate iface
iface -> router : GET /v1/sessions
activate router
router -> mgr : api01 LIST Sessions({pageSize, pageToken})
activate mgr

alt validation succeeds
  mgr -> store : api01 LIST Sessions({pageSize, pageToken})
  activate store
  store -> dir : api01 LIST Sessions({pageSize, pageToken})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
