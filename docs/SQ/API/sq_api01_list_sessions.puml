@startuml sq_api01_list_sessions
' ============================================================
' Title:     API-01 — LIST Sessions
' Boundary:  nasim code agent
' Purpose:   List all sessions with pagination
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionStore -> SessionStorage
' SM States: (no state change — read-only)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-01 LIST Sessions

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionStore" as store
end box

database "SessionStorage" as storage

== API-01 LIST Sessions ==

user -> iface : GET /v1/sessions
activate iface
iface -> router : GET /v1/sessions
activate router

router -> store : API-01 LIST Sessions({pageSize, pageToken})
activate store

alt validation fails
    store --> router : 422 Unprocessable
    router --> iface : 422 Unprocessable
    iface --> user : 422 Unprocessable
    deactivate store
    deactivate router
    deactivate iface
end

store -> storage : API-01 LIST Sessions({pageSize, pageToken})
activate storage

alt directory not found
    storage --> store : FileNotFoundError
    deactivate storage
    store --> router : 200 OK — [] (empty list)
    router --> iface : 200 OK — [] (empty list)
    iface --> user : 200 OK — [] (empty list)
    deactivate store
    deactivate router
    deactivate iface
end

storage --> store : 200 OK — [{session_id, created_at, message_count}]
deactivate storage

store --> router : 200 OK — [{session_id, created_at, message_count}]
deactivate store
router --> iface : 200 OK — [{session_id, created_at, message_count}]
iface --> user : 200 OK — [{session_id, created_at, message_count}]
deactivate router
deactivate iface

@enduml
