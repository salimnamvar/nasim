@startuml sq_api05_delete_session
' ============================================================
' Title:     API-05 — DELETE Session
' Boundary:  nasim code agent
' Purpose:   Delete a session (hard delete)
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SessionAPI -> SessionManager -> SessionStore
' SM States: CLOSED (#757575)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-05 DELETE Session

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "ServerRouter" as router
end box
box "Controller" #FFF3E0
  participant "SessionAPI" as api
end box
box "Service" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Repository" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

== API-05 DELETE Session ==

user -> router : DELETE /v1/sessions/{id}
activate router
router -> api : api05 DELETE Session({sessionId})
activate api
api -> mgr : api05 DELETE Session({sessionId})
activate mgr

alt validation succeeds
  mgr -> store : api05 DELETE Session({sessionId})
  activate store
  store -> dir : api05 DELETE Session({sessionId})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : CLOSED (#757575) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
