@startuml sq_api02_create_session
' ============================================================
' Title:     API-02 — CREATE Session
' Boundary:  nasim code agent
' Purpose:   Create and persist a new agent session
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionStore -> SessionStorage
' SM States: CREATED (#BBDEFB), ACTIVE (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-02 CREATE Session

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionStore" as store
end box

database "SessionStorage" as storage

== API-02 CREATE Session ==

user -> iface : POST /v1/sessions
activate iface
iface -> router : POST /v1/sessions
activate router

router -> store : API-02 CREATE Session({sessionData})
activate store

alt validation fails
    store --> router : 422 Unprocessable
    router --> iface : 422 Unprocessable
    iface --> user : 422 Unprocessable
    deactivate store
    deactivate router
    deactivate iface
end

store -> storage : API-02 CREATE Session({sessionData})
activate storage

alt disk write error
    storage --> store : IOError
    deactivate storage
    store --> router : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate store
    deactivate router
    deactivate iface
end

storage --> store : 200 OK
deactivate storage

ref over store : API-02 CREATE Session
  ' Session lifecycle: CREATED (#BBDEFB) → ACTIVE (#43A047)
  ' Owned by: API-02 CREATE Session (SM/README.md)

store --> router : 200 OK
deactivate store
router --> iface : 200 OK
iface --> user : 200 OK
deactivate router
deactivate iface

@enduml
