@startuml sq_api02_create_session
' ============================================================
' Title:     API-02 — CREATE Session
' Boundary:  nasim code agent
' Purpose:   Create and persist a new agent session
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> SessionAPI -> SessionManager -> SessionStore
' SM States: ACTIVE (#43A047)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-02 CREATE Session

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "ServerRouter" as router
end box
box "Controller" #FFF3E0
  participant "SessionAPI" as api
end box
box "Service" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Repository" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

== API-02 CREATE Session ==

user -> router : POST /v1/sessions
activate router
router -> api : api02 CREATE Session({sessionData})
activate api
api -> mgr : api02 CREATE Session({sessionData})
activate mgr

alt validation succeeds
  mgr -> store : api02 CREATE Session({sessionData})
  activate store
  store -> dir : api02 CREATE Session({sessionData})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : ACTIVE (#43A047) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
