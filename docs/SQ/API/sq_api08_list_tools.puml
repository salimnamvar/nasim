@startuml sq_api08_list_tools
' ============================================================
' Title:     API-08 — LIST Tools
' Boundary:  nasim code agent
' Purpose:   List all registered tools available to the agent
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolRegistry
' SM States: (no state change — read-only)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-08 LIST Tools

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Tool Group (Repository)" #E8F5E9
  participant "ToolRegistry" as registry
end box

== API-08 LIST Tools ==

user -> iface : GET /v1/tools
activate iface
iface -> router : GET /v1/tools
activate router

router -> registry : API-08 LIST Tools({pageSize, pageToken})
activate registry

alt validation fails
    registry --> router : 422 Unprocessable
    router --> iface : 422 Unprocessable
    iface --> user : 422 Unprocessable
    deactivate registry
    deactivate router
    deactivate iface
end

registry --> router : 200 OK — [{name, description, parameters}]
deactivate registry
router --> iface : 200 OK — [{name, description, parameters}]
iface --> user : 200 OK — [{name, description, parameters}]
deactivate router
deactivate iface

@enduml
