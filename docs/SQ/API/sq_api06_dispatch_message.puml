@startuml sq_api06_dispatch_message
' ============================================================
' Title:     API-06 — DISPATCH Message
' Boundary:  nasim code agent
' Purpose:   Dispatch a user message through the agent and stream SSE response
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ApiManager -> ApiStore -> ApiDirectory -> FileSystem
' SM States: SERVING (#E0F7FA), THINKING (#D7CCC8), RESPONDING (#D1C4E9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-06 DISPATCH Message

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Entry Gate" #E3F2FD
  participant "ServerRouter" as router
end box
box "Service" #FFF3E0
  participant "AgentOrchestrator" as mgr
end box
box "Repository" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== API-06 DISPATCH Message ==

user -> iface : POST /v1/sessions/{id}:dispatch
activate iface
iface -> router : POST /v1/sessions/{id}:dispatch
activate router
router -> mgr : api06 DISPATCH Message({sessionId, message})
activate mgr

alt validation succeeds
  mgr -> store : api06 DISPATCH Message({sessionId, message})
  activate store
  store -> dir : api06 DISPATCH Message({sessionId, message})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : THINKING (#D7CCC8) ...
  ref over mgr
    AGT-01: PROCESS User Task
  end ref
  ... hnote over mgr : RESPONDING (#D1C4E9) ...
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
