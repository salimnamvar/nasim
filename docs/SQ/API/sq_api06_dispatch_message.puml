@startuml sq_api06_dispatch_message
' ============================================================
' Title:     API-06 — DISPATCH Message
' Boundary:  nasim code agent
' Purpose:   Dispatch a user message through the agent and stream SSE response
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> AgentOrchestrator -> SessionStore -> SessionStorage
' SM States: SERVING (#E0F7FA), THINKING (#D7CCC8), RESPONDING (#D1C4E9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-06 DISPATCH Message

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Service" SERVICE_COLOR
  participant "AgentOrchestrator" as orchestrator
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionStore" as store
end box

== API-06 DISPATCH Message ==

user -> iface : POST /v1/sessions/{id}:dispatch
activate iface
iface -> router : POST /v1/sessions/{id}:dispatch
activate router

router -> orchestrator : API-06 DISPATCH Message({sessionId, message})
activate orchestrator

alt validation fails
    orchestrator --> router : 422 Unprocessable
    router --> iface : 422 Unprocessable
    iface --> user : 422 Unprocessable
    deactivate orchestrator
    deactivate router
    deactivate iface
end

orchestrator -> store : API-06 READ Session({sessionId})
activate store

alt session not found
    store --> orchestrator : 404 NOT_FOUND
    orchestrator --> router : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate orchestrator
    deactivate router
    deactivate iface
end

store --> orchestrator : 200 OK — {session_data}
deactivate store

ref over orchestrator : API-06 DISPATCH Message
  ' Agent lifecycle: SERVING → THINKING (#D7CCC8) → RESPONDING (#D1C4E9)
  ' Owned by: API-06 DISPATCH Message (SM/README.md)

ref over orchestrator
  AGT-01: PROCESS User Task
end ref

orchestrator --> router : 200 OK — {events}
deactivate orchestrator
router --> iface : 200 OK — {events}
iface --> user : 200 OK — {events}
deactivate router
deactivate iface

@enduml
