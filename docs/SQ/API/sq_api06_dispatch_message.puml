@startuml sq_api06_dispatch_message
' ============================================================
' Title:     API-06 — DISPATCH Message
' Boundary:  nasim code agent
' Purpose:   Dispatch a user message through the agent and stream SSE response
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> AgentOrchestrator -> SessionService -> SessionStore
' SM States: SERVING (#E0F7FA), THINKING (#D7CCC8), RESPONDING (#D1C4E9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-06 DISPATCH Message

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Service" SERVICE_COLOR
  participant "TaskService" as orchestrator
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionService" as store
end box

== API-06 DISPATCH Message ==

user -> iface : API-06 DISPATCH Message({sessionId, message})
activate iface
iface -> router : API-06 DISPATCH Message({sessionId, message})
activate router

router -> orchestrator : API-06 DISPATCH Message({sessionId, message})
activate orchestrator

alt validation fails
    orchestrator --> router : 422 UNPROCESSABLE\n{error: {code: "API-06_VALIDATION_ERROR", message: "Invalid message data", status: 422}}
    router --> iface : 422 UNPROCESSABLE
    iface --> user : 422 UNPROCESSABLE
    deactivate orchestrator
    deactivate router
    deactivate iface
end

orchestrator -> store : API-03 GET Session({sessionId})
activate store

alt session not found
    store --> orchestrator : 404 NOT_FOUND\n{error: {code: "API-06_SESSION_NOT_FOUND", message: "Session not found", status: 404}}
    orchestrator --> router : 404 NOT_FOUND
    router --> iface : 404 NOT_FOUND
    iface --> user : 404 NOT_FOUND
    deactivate store
    deactivate orchestrator
    deactivate router
    deactivate iface
end

store --> orchestrator : 200 OK — {session_data}
deactivate store

ref over orchestrator : API-06 DISPATCH Message <back:#E0F7FA>SERVING</back> → <back:#D7CCC8>THINKING</back> → <back:#D1C4E9>RESPONDING</back>

ref over orchestrator
  AGENT-01: PROCESS User Task
end ref

orchestrator --> router : 200 OK — {events}
deactivate orchestrator
router --> iface : 200 OK — {events}
iface --> user : 200 OK — {events}
deactivate router
deactivate iface

@enduml
