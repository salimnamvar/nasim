@startuml sq_api06_dispatch_message
' ============================================================
' Title:     API-06 — DISPATCH Message
' Boundary:  nasim code agent
' Purpose:   Dispatch a user message through the agent and stream SSE response
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> DispatchAPI -> AgentOrchestrator -> SessionStore
' SM States: SERVING (#E0F7FA), THINKING (#D7CCC8), RESPONDING (#D1C4E9)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-06 DISPATCH Message

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "ServerRouter" as router
end box
box "Controller" #FFF3E0
  participant "DispatchAPI" as api
end box
box "Service" #FFF3E0
  participant "AgentOrchestrator" as mgr
end box
box "Repository" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

== API-06 DISPATCH Message ==

user -> router : POST /v1/sessions/{id}:dispatch
activate router
router -> api : api06 DISPATCH Message({sessionId, message})
activate api
api -> mgr : api06 DISPATCH Message({sessionId, message})
activate mgr

alt validation succeeds
  mgr -> store : api06 DISPATCH Message({sessionId, message})
  activate store
  store -> dir : api06 DISPATCH Message({sessionId, message})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  ... hnote over mgr : THINKING (#D7CCC8) ...
  ref over mgr
    AGT-01: PROCESS User Task
  end ref
  ... hnote over mgr : RESPONDING (#D1C4E9) ...
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
