@startuml sq_api09_get_tool
' ============================================================
' Title:     API-09 — GET Tool
' Boundary:  nasim code agent
' Purpose:   Read details of a specific registered tool
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ApiManager -> ApiStore -> ApiDirectory -> FileSystem
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-09 GET Tool

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "Entry Gate" #E3F2FD
  participant "ServerRouter" as router
end box
box "Service" #FFF3E0
  participant "ToolManager" as mgr
end box
box "Repository" #E8F5E9
  participant "ToolRegistry" as store
end box
database "ToolDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== API-09 GET Tool ==

user -> iface : GET /v1/tools/{name}
activate iface
iface -> router : GET /v1/tools/{name}
activate router
router -> mgr : API-09 GET Tool({name})
activate mgr

alt validation succeeds
  mgr -> store : API-09 GET Tool({name})
  activate store
  store -> dir : API-09 GET Tool({name})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
