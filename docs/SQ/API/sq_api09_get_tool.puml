@startuml sq_api09_get_tool
' ============================================================
' Title:     API-09 — GET Tool
' Boundary:  nasim code agent
' Purpose:   Read details of a specific registered tool
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ToolRegistry
' SM States: (no state change — read-only)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-09 GET Tool

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "ToolRegistry" as registry
end box

== API-09 GET Tool ==

user -> iface : GET /v1/tools/{name}
activate iface
iface -> router : GET /v1/tools/{name}
activate router

router -> registry : API-09 GET Tool({name})
activate registry

alt tool not found
    registry --> router : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate registry
    deactivate router
    deactivate iface
end

registry --> router : 200 OK — {name, description, parameters, safe}
deactivate registry
router --> iface : 200 OK — {name, description, parameters, safe}
iface --> user : 200 OK — {name, description, parameters, safe}
deactivate router
deactivate iface

@enduml
