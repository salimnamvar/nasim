@startuml sq_api09_get_tool
' ============================================================
' Title:     API-09 — GET Tool
' Boundary:  nasim code agent
' Purpose:   Read details of a specific registered tool
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> ServerRouter -> ToolAPI -> ToolManager -> ToolRegistry
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-09 GET Tool

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "ServerRouter" as router
end box
box "Controller" #FFF3E0
  participant "ToolAPI" as api
end box
box "Service" #FFF3E0
  participant "ToolManager" as mgr
end box
box "Repository" #E8F5E9
  participant "ToolRegistry" as store
end box
database "ToolDirectory" as dir

== API-09 GET Tool ==

user -> router : GET /v1/tools/{name}
activate router
router -> api : API-09 GET Tool({name})
activate api
api -> mgr : API-09 GET Tool({name})
activate mgr

alt validation succeeds
  mgr -> store : API-09 GET Tool({name})
  activate store
  store -> dir : API-09 GET Tool({name})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> api : 200 OK
  deactivate mgr
  api --> router : 200 OK
  deactivate api
  router --> user : 200 OK
  deactivate router
else validation fails
  mgr --> api : 422 Unprocessable
  deactivate mgr
  api --> router : 422 Unprocessable
  deactivate api
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
