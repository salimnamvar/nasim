@startuml sq_api11_update_config
' ============================================================
' Title:     API-11 — UPDATE Config
' Boundary:  nasim code agent
' Purpose:   Update agent configuration at runtime
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ConfigLoader -> ConfigStorage
' SM States: (no state change — config is not an entity lifecycle)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-11 UPDATE Config

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Config Group (Repository)" #E8F5E9
  participant "ConfigLoader" as loader
end box

database "ConfigStorage" as storage

== API-11 UPDATE Config ==

user -> iface : PATCH /v1/config
activate iface
iface -> router : PATCH /v1/config
activate router

router -> loader : API-11 UPDATE Config({patchData})
activate loader

alt validation fails
    loader --> router : 422 Unprocessable
    router --> iface : 422 Unprocessable
    iface --> user : 422 Unprocessable
    deactivate loader
    deactivate router
    deactivate iface
end

loader -> storage : API-11 UPDATE Config({patchData})
activate storage

alt disk write error
    storage --> loader : IOError
    deactivate storage
    loader --> router : 500 INTERNAL
    router --> iface : 500 Internal Error
    iface --> user : 500 Internal Error
    deactivate loader
    deactivate router
    deactivate iface
end

storage --> loader : 200 OK
deactivate storage

loader --> router : 200 OK
deactivate loader
router --> iface : 200 OK
iface --> user : 200 OK
deactivate router
deactivate iface

@enduml
