@startuml sq_api11_update_config
' ============================================================
' Title:     API-11 — UPDATE Config
' Boundary:  nasim code agent
' Purpose:   Update agent configuration at runtime
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ApiManager -> ApiStore -> ApiDirectory -> FileSystem
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-11 UPDATE Config

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "Entry Gate" #E3F2FD
  participant "ServerRouter" as router
end box
box "Service" #FFF3E0
  participant "ConfigManager" as mgr
end box
box "Repository" #E8F5E9
  participant "ConfigLoader" as store
end box
database "ConfigDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== API-11 UPDATE Config ==

user -> iface : PATCH /v1/config
activate iface
iface -> router : PATCH /v1/config
activate router
router -> mgr : api11 UPDATE Config({patchData})
activate mgr

alt validation succeeds
  mgr -> store : api11 UPDATE Config({patchData})
  activate store
  store -> dir : api11 UPDATE Config({patchData})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
