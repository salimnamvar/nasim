@startuml sq_api03_get_session
' ============================================================
' Title:     API-03 — GET Session
' Boundary:  nasim code agent
' Purpose:   Read a session's current state and messages
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> ApiManager -> ApiStore -> ApiDirectory -> FileSystem
' SM States: RESTORED (#1E88E5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-03 GET Session

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "Entry Gate" #E3F2FD
  participant "ServerRouter" as router
end box
box "Service" #FFF3E0
  participant "SessionManager" as mgr
end box
box "Repository" #E8F5E9
  participant "SessionStore" as store
end box
database "SessionDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== API-03 GET Session ==

user -> iface : GET /v1/sessions/{id}
activate iface
iface -> router : GET /v1/sessions/{id}
activate router
router -> mgr : api03 GET Session({sessionId})
activate mgr

alt validation succeeds
  mgr -> store : api03 GET Session({sessionId})
  activate store
  store -> dir : api03 GET Session({sessionId})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> mgr : 200 OK
  deactivate store
      mgr -> mgr : TRANSITION State(<back:#1E88E5>RESTORED</back>)
  mgr --> router : 200 OK
  deactivate mgr
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else validation fails
  mgr --> router : 422 Unprocessable
  deactivate mgr
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
