@startuml sq_api03_get_session
' ============================================================
' Title:     API-03 — GET Session
' Boundary:  nasim code agent
' Purpose:   Read a session's current state and messages
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> SessionStore -> SessionStorage
' SM States: SAVED (#1565C0), RESTORED (#1E88E5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-03 GET Session

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

box "Session Group (Repository)" #E8F5E9
  participant "SessionStore" as store
end box

database "SessionStorage" as storage

== API-03 GET Session ==

user -> iface : GET /v1/sessions/{id}
activate iface
iface -> router : GET /v1/sessions/{id}
activate router

router -> store : API-03 GET Session({sessionId})
activate store

alt validation fails
    store --> router : 422 Unprocessable
    router --> iface : 422 Unprocessable
    iface --> user : 422 Unprocessable
    deactivate store
    deactivate router
    deactivate iface
end

store -> storage : API-03 GET Session({sessionId})
activate storage

alt session not found
    storage --> store : 404 NOT_FOUND
    deactivate storage
    store --> router : 404 NOT_FOUND
    router --> iface : 404 Not Found
    iface --> user : 404 Not Found
    deactivate store
    deactivate router
    deactivate iface
end

storage --> store : 200 OK
deactivate storage

ref over store : API-03 GET Session
  ' Session lifecycle: SAVED → RESTORED (#1E88E5)
  ' Owned by: API-03 GET Session (SM/README.md)

store --> router : 200 OK
deactivate store
router --> iface : 200 OK
iface --> user : 200 OK
deactivate router
deactivate iface

@enduml
