@startuml sq_api03_get_session
' ============================================================
' Title:     API-03 — GET Session
' Boundary:  nasim code agent
' Purpose:   Read a session's current state and messages
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> AgentController -> SessionService -> Session Store
' SM States: SAVED (#1565C0), RESTORED (#1E88E5)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- API-03 GET Session

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

box "Repository" REPOSITORY_COLOR
  participant "SessionService" as store
end box

database "Session Store" as storage

== API-03 GET Session ==

user -> iface : API-03 GET Session({sessionId})
activate iface
iface -> router : API-03 GET Session({sessionId})
activate router

router -> store : API-03 GET Session({sessionId})
activate store

alt validation fails
    store --> router : 422 UNPROCESSABLE\n{error: {code: "API-03_VALIDATION_ERROR", message: "Invalid session ID", status: 422}}
    router --> iface : 422 UNPROCESSABLE
    iface --> user : 422 UNPROCESSABLE
    deactivate store
    deactivate router
    deactivate iface
end

store -> storage : API-03 GET Session({sessionId})
activate storage

alt session not found
    storage --> store : 404 NOT_FOUND\n{error: {code: "API-03_SESSION_NOT_FOUND", message: "Session not found", status: 404}}
    deactivate storage
    store --> router : 404 NOT_FOUND
    router --> iface : 404 NOT_FOUND
    iface --> user : 404 NOT_FOUND
    deactivate store
    deactivate router
    deactivate iface
end

storage --> store : 200 OK
deactivate storage

ref over store : API-03 GET Session <back:#1565C0>SAVED</back> → <back:#1E88E5>RESTORED</back>

store --> router : 200 OK
deactivate store
router --> iface : 200 OK
iface --> user : 200 OK
deactivate router
deactivate iface

@enduml
