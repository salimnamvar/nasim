@startuml sq_evl03_check_success
!include ../common/sq_styles.puml
' ============================================================
' Title:     EVL-03 — CHECK Success
' Boundary:  nasim code agent
' Purpose:   Run user-defined success checks and return pass/fail
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

actor "User" as user

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Evaluation Group" #FFF3E0
  participant "EvaluationEngine" as engine
  participant "SuccessCheckRunner" as runner
end box
box "Tool Group" #E8F5E9
  participant "ShellRunner" as shell
end box
box "Repository Group" #E8F5E9
  participant "EvaluationRepository" as eval_repo
end box


note over user
  Scope:          EVL-03 CHECK Success — Run user-defined success checks and return pass/fail
  Preconditions:  Edit has been applied; check_commands are defined in config
  Contexts:       Called by EvaluationEngine after edit application
  Excludes:       LLM-based validation (EVL-04); test suite execution (EVL-05)
  Rollback:       Checks are read-only; no state change
  Design:         Runs shell commands with 30s timeout; aggregates exit codes
  Returns:
    - Success: 200 OK — SuccessCheckResult(passed, results[])
    - Failure: 400 BAD_REQUEST: check command failed
end note


== EVL-03 CHECK Success ==

agent -> engine : EVL-03 CHECK_SUCCESS(check_commands[])
activate engine

engine -> runner : run_checks(check_commands)
activate runner

loop for each check_command
    runner -> shell : execute(check_command, timeout=30s)
    activate shell
    alt exit_code == 0
        shell --> runner : CheckOutput(exit_code=0, stdout)
    else exit_code != 0
        shell --> runner : CheckOutput(exit_code, stderr)
    end
    deactivate shell

    runner -> runner : record_result(check_command, output)
end

runner -> runner : aggregate_results()

runner --> engine : SuccessCheckResult(passed, results[])
deactivate runner

engine --> agent : SuccessCheckResult
deactivate engine

agent --> router : AgentEvent(Done)


note over user
  Flow:    EVL-03 → agent → engine → runner → shell(execute, loop) → aggregate_results → Done
  State:   No state change
  Success: 200 OK — SuccessCheckResult(passed, results[])
  Failure: 400 BAD_REQUEST: check failed — trigger retry (EVL-06)
end note

@enduml
