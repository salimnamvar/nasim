@startuml sq_cli01_process_user_input
' ============================================================
' Title:     CLI-01 — PROCESS User Input
' Boundary:  nasim code agent
' Purpose:   REPL input loop routes through API, renders SSE output
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> REPLSession -> ServerRouter
' SM States: LISTENING (#E8EAF6), THINKING (#D7CCC8), RESPONDING (#D1C4E9), IDLE (#ECEFF1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-01 PROCESS User Input

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "CLI Group" #E3F2FD
  participant "REPLSession" as repl
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

== CLI-01 PROCESS User Input ==

user -> iface : CLI-01 PROCESS Input({input})
activate iface
iface -> repl : CLI-01 PROCESS Input({input})
activate repl
repl -> router : CLI-01 PARSE Input({input})
activate router

alt is slash command
  ref over repl
    CLI-02: DISPATCH Slash Command
  end ref
  router --> repl : 200 OK
  deactivate router
  repl --> iface : 200 OK
  deactivate repl
  iface --> user : 200 OK
  deactivate iface
  ref over repl : TRANSITION State(<back:#ECEFF1>IDLE</back>)
else normal input
  repl -> router : CLI-01 EXECUTE Input({input})
  ref over repl : TRANSITION State(<back:#E8EAF6>LISTENING</back>)
  ref over repl : TRANSITION State(<back:#D7CCC8>THINKING</back>)
  ref over router
    API-06: DISPATCH Message
  end ref
  ref over repl : TRANSITION State(<back:#D1C4E9>RESPONDING</back>)
  router --> repl : 200 OK
  deactivate router
  repl --> iface : 200 OK
  deactivate repl
  iface --> user : 200 OK
  deactivate iface
end

@enduml
