@startuml sq_cli01_process_user_input
' ============================================================
' Title:     CLI-01 — PROCESS User Input
' Boundary:  nasim code agent
' Purpose:   REPL input loop routes through API, renders SSE output
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIRouter -> CLIController -> CLIExecutor -> CLIStore
' SM States: LISTENING (#E8EAF6), THINKING (#D7CCC8), RESPONDING (#D1C4E9), IDLE (#ECEFF1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-01 PROCESS User Input

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Controller" #FFF3E0
  participant "CLIController" as ctrl
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

== CLI-01 PROCESS User Input ==

user -> router : CLI-01 PROCESS Input({input})
activate router
router -> ctrl : CLI-01 PROCESS Input({input})
activate ctrl

ctrl -> ctrl : CLI-01 PARSE Input({input})
alt is slash command
  ref over ctrl
    CLI-02: DISPATCH Slash Command
  end ref
  ctrl --> router : 200 OK
  deactivate ctrl
  router --> user : 200 OK
  deactivate router
  ... hnote over user : IDLE (#ECEFF1) ...
else normal input
  ctrl -> exec : CLI-01 EXECUTE Input({input})
  activate exec
  ... hnote over exec : LISTENING (#E8EAF6) ...
  exec -> store : CLI-01 PROCESS Input({input})
  activate store
  store -> dir : CLI-01 PROCESS Input({input})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  ... hnote over exec : THINKING (#D7CCC8) ...
  ref over exec
    API-06: DISPATCH Message
  end ref
  ... hnote over exec : RESPONDING (#D1C4E9) ...
  exec --> ctrl : 200 OK
  deactivate exec
  ctrl --> router : 200 OK
  deactivate ctrl
  router --> user : 200 OK
  deactivate router
end

@enduml
