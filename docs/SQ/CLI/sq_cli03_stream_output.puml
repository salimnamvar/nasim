@startuml sq_cli03_stream_output
' ============================================================
' Title:     CLI-03 — STREAM Output
' Boundary:  nasim code agent
' Purpose:   Streaming token-by-token output with rich formatting
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> CliManager -> CliStore -> CliDirectory -> FileSystem
' SM States: RESPONDING (#D1C4E9), IDLE (#ECEFF1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-03 STREAM Output

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== CLI-03 STREAM Output ==

user -> iface : CLI-03 STREAM Output({sessionId})
activate iface
iface -> router : CLI-03 STREAM Output({sessionId})
activate router
router -> router : CLI-03 STREAM Output({sessionId})
router -> exec : CLI-03 STREAM Output({sessionId})
activate exec
... hnote over exec : RESPONDING (#D1C4E9) ...

alt stream available
  exec -> store : CLI-03 STREAM Output({sessionId})
  activate store
  store -> dir : CLI-03 STREAM Output({sessionId})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> router : 200 OK
  deactivate exec
  router --> router : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
  ... hnote over user : IDLE (#ECEFF1) ...
else stream unavailable
  exec --> router : 503 Unavailable
  deactivate exec
  router --> router : 503 Unavailable
  router --> iface : 503 Unavailable
  iface --> user : 503 Unavailable
  deactivate router
  deactivate iface
end

@enduml
