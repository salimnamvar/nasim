@startuml sq_cli03_stream_output
' ============================================================
' Title:     CLI-03 — STREAM Output
' Boundary:  nasim code agent
' Purpose:   Streaming token-by-token output with rich formatting
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> REPLSession -> Renderer -> ServerRouter
' SM States: RESPONDING (#D1C4E9), IDLE (#ECEFF1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-03 STREAM Output

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
  participant "REPLSession" as repl
  participant "Renderer" as renderer
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

== CLI-03 STREAM Output ==

user -> iface : CLI-03 STREAM Output({sessionId})
activate iface
iface -> repl : CLI-03 STREAM Output({sessionId})
activate repl
repl -> renderer : CLI-03 STREAM Output({sessionId})
activate renderer
renderer -> router : CLI-03 SUBSCRIBE Stream({sessionId})
activate router
ref over repl : TRANSITION State(<back:#D1C4E9>RESPONDING</back>)

alt stream available
  router --> renderer : 200 OK
  deactivate router
  renderer --> repl : 200 OK
  deactivate renderer
  repl --> iface : 200 OK
  deactivate repl
  iface --> user : 200 OK
  deactivate iface
  ref over repl : TRANSITION State(<back:#ECEFF1>IDLE</back>)
else stream unavailable
  router --> renderer : 503 Unavailable
  deactivate router
  renderer --> repl : 503 Unavailable
  deactivate renderer
  repl --> iface : 503 Unavailable
  deactivate repl
  iface --> user : 503 Unavailable
  deactivate iface
end

@enduml
