@startuml sq_cli03_stream_output
!include ../common/sq_styles.puml
' ============================================================
' Title:     CLI-03 — STREAM Output
' Boundary:  nasim code agent CLI
' Purpose:   Streaming token-by-token output with rich formatting
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — CLI-03 STREAM Output

actor "User" as user

box "CLI Interface Container" #E3F2FD
  participant "REPLSession" as repl
  participant "Renderer" as renderer
end box
box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box


== CLI-03 STREAM Output ==

user -> repl : await response
activate repl

repl -> router : api06 DISPATCH Message({session_id}, {message})
activate router

router --> repl : SSE stream (AgentEvents)
deactivate router

hnote over repl #E0F7FA : **State: STREAMING**

loop for each AgentEvent in stream
    alt TextChunk event
        repl -> renderer : cli03 RENDER TextChunk({token})
        activate renderer
        renderer --> user : streamed token
        deactivate renderer
    else ToolStart event
        repl -> renderer : cli03 RENDER ToolStart({tool_name})
        activate renderer
        renderer --> user : tool call display
        deactivate renderer
    else ToolResult event
        repl -> renderer : cli03 RENDER ToolResult({result})
        activate renderer
        renderer --> user : tool result preview
        deactivate renderer
    else Error event
        repl -> renderer : cli03 RENDER Error({error})
        activate renderer
        renderer --> user : red error display
        deactivate renderer
    else Done event
        repl -> renderer : cli03 RENDER Done()
        activate renderer
        renderer --> user : formatted completion
        deactivate renderer
    end
end

hnote over repl #ECEFF1 : **State: IDLE**

deactivate repl


@enduml
