@startuml sq_cli03_stream_output
' ============================================================
' Title:     CLI-03 — STREAM Output
' Boundary:  nasim code agent
' Purpose:   Streaming token-by-token output with rich formatting
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIAdapter -> REPLSession -> Renderer -> AgentController
' SM States: RESPONDING (#D1C4E9), IDLE (#ECEFF1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-03 STREAM Output

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLIAdapter" as iface
  participant "CLIAdapter" as repl
  participant "CLIAdapter" as renderer
end box

box "API" API_COLOR
  participant "AgentController" as router
end box

== CLI-03 STREAM Output ==

user -> iface : CLI-03 STREAM Output({sessionId})
activate iface
iface -> repl : CLI-03 STREAM Output({sessionId})
activate repl
repl -> renderer : CLI-03 STREAM Output({sessionId})
activate renderer
renderer -> router : CLI-03 SUBSCRIBE Stream({sessionId})
activate router

alt stream available
  ref over repl : CLI-03 STREAM Output({sessionId})
  router --> renderer : 200 OK
  deactivate router
  renderer --> repl : 200 OK
  deactivate renderer
  repl --> iface : 200 OK
  deactivate repl
  iface --> user : 200 OK
  deactivate iface
  ref over repl : CLI-03 STREAM Output({sessionId})     <back:#ECEFF1>IDLE</back>
else stream unavailable
  ref over repl : CLI-03 STREAM Output({sessionId})     <back:#ECEFF1>IDLE</back>
  router --> renderer : 503 SERVICE_UNAVAILABLE\n{error: {code: "CLI-03_STREAM_UNAVAILABLE", message: "Stream unavailable", status: 503}}
  deactivate router
  renderer --> repl : 503 SERVICE_UNAVAILABLE\n{error: {code: "CLI-03_STREAM_UNAVAILABLE", message: "Stream unavailable", status: 503}}
  deactivate renderer
  repl --> iface : 503 SERVICE_UNAVAILABLE\n{error: {code: "CLI-03_STREAM_UNAVAILABLE", message: "Stream unavailable", status: 503}}
  deactivate repl
  iface --> user : 503 SERVICE_UNAVAILABLE\n{error: {code: "CLI-03_STREAM_UNAVAILABLE", message: "Stream unavailable", status: 503}}
  deactivate iface
end

@enduml
