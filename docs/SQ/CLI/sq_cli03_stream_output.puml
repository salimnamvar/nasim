@startuml sq_cli03_stream_output
' ============================================================
' Title:     CLI-03 — STREAM Output
' Boundary:  nasim code agent
' Purpose:   Streaming token-by-token output with rich formatting
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIRouter -> CLIController -> CLIExecutor -> CLIStore
' SM States: RESPONDING (#D1C4E9), IDLE (#ECEFF1)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-03 STREAM Output

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Controller" #FFF3E0
  participant "CLIController" as ctrl
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

== CLI-03 STREAM Output ==

user -> router : CLI-03 STREAM Output({sessionId})
activate router
router -> ctrl : CLI-03 STREAM Output({sessionId})
activate ctrl
ctrl -> exec : CLI-03 STREAM Output({sessionId})
activate exec
... hnote over exec : RESPONDING (#D1C4E9) ...

alt stream available
  exec -> store : CLI-03 STREAM Output({sessionId})
  activate store
  store -> dir : CLI-03 STREAM Output({sessionId})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> ctrl : 200 OK
  deactivate exec
  ctrl --> router : 200 OK
  deactivate ctrl
  router --> user : 200 OK
  deactivate router
  ... hnote over user : IDLE (#ECEFF1) ...
else stream unavailable
  exec --> ctrl : 503 Unavailable
  deactivate exec
  ctrl --> router : 503 Unavailable
  deactivate ctrl
  router --> user : 503 Unavailable
  deactivate router
end

@enduml
