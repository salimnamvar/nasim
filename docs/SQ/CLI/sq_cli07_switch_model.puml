@startuml sq_cli07_switch_model
' ============================================================
' Title:     CLI-07 — SWITCH Model
' Boundary:  nasim code agent
' Purpose:   Switch active model via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIRouter -> CLIController -> CLIExecutor -> CLIStore
' SM States: ROUTING (#EDE7F6)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-07 SWITCH Model

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Controller" #FFF3E0
  participant "CLIController" as ctrl
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

== CLI-07 SWITCH Model ==

user -> router : CLI-07 SWITCH Model({modelName})
activate router
router -> ctrl : CLI-07 SWITCH Model({modelName})
activate ctrl
ctrl -> exec : CLI-07 SWITCH Model({modelName})
activate exec
... hnote over exec : ROUTING (#EDE7F6) ...

alt model available
  exec -> store : CLI-07 SWITCH Model({modelName})
  activate store
  store -> dir : CLI-07 SWITCH Model({modelName})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> ctrl : 200 OK
  deactivate exec
  ctrl --> router : 200 OK
  deactivate ctrl
  router --> user : 200 OK
  deactivate router
else model not available
  exec --> ctrl : 404 Not Found
  deactivate exec
  ctrl --> router : 404 Not Found
  deactivate ctrl
  router --> user : 404 Not Found
  deactivate router
end

@enduml
