@startuml sq_cli07_switch_model
!include ../common/sq_styles.puml
' ============================================================
' Title:     CLI-07 — Switch Model
' Boundary:  nasim code agent CLI
' Purpose:   Switch active model via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — CLI-07 UPDATE Model

actor "User" as user

note over user
  Scope:          CLI-07 — Switch Model
  Preconditions:  REPLSession active, model available in routing table
  Contexts:       Called via /model slash command from CLI-01
  Excludes:       Plan mode (CLI-05), session management, output streaming
  Rollback:       Model not found → CommandError returned
  Design:         Model validation via RTGModelRouter, update active model pointer
  Returns:
    - Success: CommandResult with confirmation ("Switched to {model_name}")
    - Failure: CommandError on model not found
end note #E3F2FD
  participant "REPLSession" as repl
end box
box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
  participant "SlashCommandHandler" as cmd
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Routing Group" #FFF3E0
  participant "RTGModelRouter" as rtg
end box
box "Repository Group" #E8F5E9
  participant "SessionRepository" as session_repo
end box


== CLI-07 Switch Model ==

user -> repl : "/model {model_name}"
repl -> cmd : dispatch("/model {model_name}")
activate cmd

cmd -> cmd : parse model name
cmd -> rtg : switchModel(model_name, updateMask)
activate rtg

rtg -> rtg : validate model availability
rtg -> rtg : update active model pointer

rtg --> cmd : ModelSwitched(new_model)
deactivate rtg

cmd --> repl : CommandResult("Switched to {model_name}")
deactivate cmd


break Model not found
    rtg --> cmd : ModelNotFoundError
    cmd --> repl : CommandError
end

note over user
  Flow:    user → REPLSession → SlashCommandHandler → RTGModelRouter → SlashCommandHandler → REPLSession
  State:   No state change (model pointer updated)
  Success: CommandResult with "Switched to {model_name}"
  Failure: Model not found: CommandError
end note

@enduml
