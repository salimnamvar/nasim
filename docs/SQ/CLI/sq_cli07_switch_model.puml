!include ../common/sq_styles.puml
' ============================================================
' Title:     CLI-07 — SWITCH Model
' Boundary:  nasim code agent CLI
' Purpose:   Switch active model via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — CLI-07 SWITCH Model

actor "User" as user

box "CLI Interface Container" #E3F2FD
  participant "REPLSession" as repl
  participant "SlashCommandHandler" as cmdhandler
end box
box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Router Group" #FFF3E0
  participant "ModelRouter" as mrouter
end box


== CLI-07 SWITCH Model ==

user -> repl : /model {model_name}
activate repl

repl -> cmdhandler : cli02 PARSE SlashCommand({input})
activate cmdhandler

cmdhandler -> router : cli07 SWITCH Model({model_name})
activate router

router -> mrouter : rtg04 SWITCH Model({model_name})
activate mrouter

mrouter -> mrouter : rtg04 VALIDATE ModelAvailability({model_name})

break model not in catalog
    mrouter --> router : Error("model not available")
    router --> cmdhandler : 404 NOT_FOUND — Model not in catalog
    cmdhandler --> repl : CommandResult(Error)
    repl --> user : "Error: model {model_name} not available"
end

mrouter -> mrouter : rtg04 UPDATE ActiveModelConfig({model_name})

mrouter --> router : 200 OK — {previous_model, new_model}
deactivate mrouter

router --> cmdhandler : 200 OK — ModelSwitched
deactivate router

cmdhandler --> repl : CommandResult(ModelSwitched)
deactivate cmdhandler

repl --> user : "Model switched: {previous_model} → {new_model}"
deactivate repl


@enduml
