@startuml sq_cli07_switch_model
' ============================================================
' Title:     CLI-07 — SWITCH Model
' Boundary:  nasim code agent
' Purpose:   Switch active model via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> SlashCommandHandler -> ServerRouter
' SM States: ROUTING (#EDE7F6)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-07 SWITCH Model

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "CLI Group" #E3F2FD
  participant "SlashCommandHandler" as sch
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

== CLI-07 SWITCH Model ==

user -> iface : CLI-07 SWITCH Model({modelName})
activate iface
iface -> sch : CLI-07 SWITCH Model({modelName})
activate sch
sch -> router : CLI-07 SWITCH Model({modelName})
activate router
ref over sch : TRANSITION State(<back:#EDE7F6>ROUTING</back>)

alt model available
  router --> sch : 200 OK
  deactivate router
  sch --> iface : 200 OK
  deactivate sch
  iface --> user : 200 OK
  deactivate iface
else model not available
  router --> sch : 404 Not Found
  deactivate router
  sch --> iface : 404 Not Found
  deactivate sch
  iface --> user : 404 Not Found
  deactivate iface
end

@enduml
