@startuml sq_cli07_switch_model
' ============================================================
' Title:     CLI-07 — SWITCH Model
' Boundary:  nasim code agent
' Purpose:   Switch active model via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> CliManager -> CliStore -> CliDirectory -> FileSystem
' SM States: ROUTING (#EDE7F6)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-07 SWITCH Model

actor "User" as user

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Interface Layer" #INTERFACE_COLOR
  participant "CLI Process" as iface
end box

box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

box "Infrastructure Layer" #INFRASTRUCTURE_COLOR
  participant "FileSystem" as FileSystem
end box

== CLI-07 SWITCH Model ==

user -> iface : CLI-07 SWITCH Model({modelName})
activate iface
iface -> router : CLI-07 SWITCH Model({modelName})
activate router
router -> router : CLI-07 SWITCH Model({modelName})
router -> exec : CLI-07 SWITCH Model({modelName})
activate exec
... hnote over exec : ROUTING (#EDE7F6) ...

alt model available
  exec -> store : CLI-07 SWITCH Model({modelName})
  activate store
  store -> dir : CLI-07 SWITCH Model({modelName})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> router : 200 OK
  deactivate exec
  router --> router : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else model not available
  exec --> router : 404 Not Found
  deactivate exec
  router --> router : 404 Not Found
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
