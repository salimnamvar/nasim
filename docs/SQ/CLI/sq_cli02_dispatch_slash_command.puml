@startuml sq_cli02_dispatch_slash_command
' ============================================================
' Title:     CLI-02 — DISPATCH Slash Command
' Boundary:  nasim code agent
' Purpose:   Slash command routing and execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> SlashCommandHandler -> ServerRouter
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-02 DISPATCH Slash Command

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "CLI Group" #E3F2FD
  participant "SlashCommandHandler" as sch
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

== CLI-02 DISPATCH Slash Command ==

user -> iface : CLI-02 DISPATCH SlashCommand({input})
activate iface
iface -> sch : CLI-02 DISPATCH SlashCommand({input})
activate sch
sch -> router : CLI-02 PARSE CommandName({input})
activate router

alt command recognised
  router --> sch : 200 OK
  deactivate router
  sch --> iface : 200 OK
  deactivate sch
  iface --> user : 200 OK
  deactivate iface
else unknown command
  router --> sch : 404 Not Found
  deactivate router
  sch --> iface : 404 Not Found
  deactivate sch
  iface --> user : 404 Not Found
  deactivate iface
end

@enduml
