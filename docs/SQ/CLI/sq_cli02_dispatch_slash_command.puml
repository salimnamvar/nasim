!include ../common/sq_styles.puml
' ============================================================
' Title:     CLI-02 — DISPATCH Slash Command
' Boundary:  nasim code agent CLI
' Purpose:   Slash command routing and execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — CLI-02 DISPATCH Slash Command

actor "User" as user

box "CLI Interface Container" #E3F2FD
  participant "REPLSession" as repl
  participant "SlashCommandHandler" as cmdhandler
end box
box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Config Group" #E8F5E9
  participant "ConfigLoader" as config
end box


== CLI-02 DISPATCH Slash Command ==

user -> repl : enter slash command
activate repl
repl -> repl : check for slash command prefix

repl -> cmdhandler : cli02 PARSE SlashCommand({input})
activate cmdhandler
cmdhandler -> cmdhandler : extract command name and args

alt /sessions command
    cmdhandler -> router : api01 LIST Sessions({filters})
    activate router
    router --> cmdhandler : 200 OK — SessionList
    deactivate router
    cmdhandler --> repl : CommandResult(SessionsList)
else /config command
    cmdhandler -> config : cfg01 READ Config()
    activate config
    config --> cmdhandler : 200 OK — Config
    deactivate config
    cmdhandler --> repl : CommandResult(ConfigDisplay)
else /plan command
    cmdhandler -> router : cli05 ENABLE Plan Mode()
    activate router
    router -> agent : agt07 QUEUE Plan()
    activate agent
    agent --> router : PlanSession(queued)
    deactivate agent
    router --> cmdhandler : 200 OK — PlanEnabled
    deactivate router
    cmdhandler --> repl : CommandResult(PlanMode)
else /model command
    cmdhandler -> router : cli07 SWITCH Model({model_name})
    activate router
    router --> cmdhandler : 200 OK — ModelSwitched
    deactivate router
    cmdhandler --> repl : CommandResult(ModelSwitched)
else unknown command
    cmdhandler --> repl : CommandResult(UnknownCommand)
end

repl --> user : display command result
deactivate cmdhandler
deactivate repl


@enduml
