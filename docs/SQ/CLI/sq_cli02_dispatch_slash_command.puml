@startuml sq_cli02_dispatch_slash_command
' ============================================================
' Title:     CLI-02 — DISPATCH Slash Command
' Boundary:  nasim code agent
' Purpose:   Slash command routing and execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIRouter -> CLIController -> CLIExecutor -> CLIStore
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-02 DISPATCH Slash Command

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Controller" #FFF3E0
  participant "CLIController" as ctrl
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

== CLI-02 DISPATCH Slash Command ==

user -> router : CLI-02 DISPATCH SlashCommand({input})
activate router
router -> ctrl : CLI-02 PARSE SlashCommand({input})
activate ctrl

ctrl -> ctrl : CLI-02 PARSE CommandName({input})
ctrl -> exec : CLI-02 DISPATCH Command({command, args})
activate exec

alt command recognised
  exec -> store : CLI-02 ROUTE Command({command, args})
  activate store
  store -> dir : CLI-02 ROUTE Command({command, args})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> ctrl : 200 OK
  deactivate exec
  ctrl --> router : 200 OK
  deactivate ctrl
  router --> user : 200 OK
  deactivate router
else unknown command
  exec --> ctrl : 404 Not Found
  deactivate exec
  ctrl --> router : 404 Not Found
  deactivate ctrl
  router --> user : 404 Not Found
  deactivate router
end

@enduml
