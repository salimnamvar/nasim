@startuml sq_cli02_dispatch_slash_command
' ============================================================
' Title:     CLI-02 — DISPATCH Slash Command
' Boundary:  nasim code agent
' Purpose:   Slash command routing and execution
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> CliManager -> CliStore -> CliDirectory -> FileSystem
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-02 DISPATCH Slash Command

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== CLI-02 DISPATCH Slash Command ==

user -> iface : CLI-02 DISPATCH SlashCommand({input})
activate iface
iface -> router : CLI-02 DISPATCH SlashCommand({input})
activate router
router -> router : CLI-02 PARSE SlashCommand({input})

router -> router : CLI-02 PARSE CommandName({input})
router -> exec : CLI-02 DISPATCH Command({command, args})
activate exec

alt command recognised
  exec -> store : CLI-02 ROUTE Command({command, args})
  activate store
  store -> dir : CLI-02 ROUTE Command({command, args})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> router : 200 OK
  deactivate exec
  router --> router : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else unknown command
  exec --> router : 404 Not Found
  deactivate exec
  router --> router : 404 Not Found
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
