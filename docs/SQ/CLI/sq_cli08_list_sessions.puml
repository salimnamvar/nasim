@startuml sq_cli08_list_sessions
' ============================================================
' Title:     CLI-08 — LIST Sessions
' Boundary:  nasim code agent
' Purpose:   List sessions via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIRouter -> CLIController -> CLIExecutor -> CLIStore
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-08 LIST Sessions

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Controller" #FFF3E0
  participant "CLIController" as ctrl
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

== CLI-08 LIST Sessions ==

user -> router : CLI-08 LIST Sessions()
activate router
router -> ctrl : CLI-08 LIST Sessions({pageSize, pageToken})
activate ctrl
ctrl -> exec : CLI-08 LIST Sessions({pageSize, pageToken})
activate exec

alt sessions found
  exec -> store : CLI-08 LIST Sessions({pageSize, pageToken})
  activate store
  store -> dir : CLI-08 LIST Sessions({pageSize, pageToken})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> ctrl : 200 OK
  deactivate exec
  ctrl --> router : 200 OK
  deactivate ctrl
  router --> user : 200 OK
  deactivate router
else no sessions
  exec --> ctrl : 404 Not Found
  deactivate exec
  ctrl --> router : 404 Not Found
  deactivate ctrl
  router --> user : 404 Not Found
  deactivate router
end

@enduml
