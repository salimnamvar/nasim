@startuml sq_cli08_list_sessions
' ============================================================
' Title:     CLI-08 — LIST Sessions
' Boundary:  nasim code agent
' Purpose:   List sessions via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> CliManager -> CliStore -> CliDirectory -> FileSystem
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-08 LIST Sessions

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== CLI-08 LIST Sessions ==

user -> iface : CLI-08 LIST Sessions()
activate iface
iface -> router : CLI-08 LIST Sessions()
activate router
router -> router : CLI-08 LIST Sessions({pageSize, pageToken})
router -> exec : CLI-08 LIST Sessions({pageSize, pageToken})
activate exec

alt sessions found
  exec -> store : CLI-08 LIST Sessions({pageSize, pageToken})
  activate store
  store -> dir : CLI-08 LIST Sessions({pageSize, pageToken})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> router : 200 OK
  deactivate exec
  router --> router : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else no sessions
  exec --> router : 404 Not Found
  deactivate exec
  router --> router : 404 Not Found
  router --> iface : 404 Not Found
  iface --> user : 404 Not Found
  deactivate router
  deactivate iface
end

@enduml
