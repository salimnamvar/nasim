@startuml sq_cli08_list_sessions
!include ../common/sq_styles.puml
' ============================================================
' Title:     CLI-08 — List Sessions
' Boundary:  nasim code agent CLI
' Purpose:   List sessions via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — CLI-08 LIST Sessions

actor "User" as user

box "Controller Group" #E3F2FD
  participant "ServerRouter" as router
  participant "SlashCommandHandler" as cmd
end box
box "Service Group" #FFF3E0
  participant "SessionService" as svc
end box
box "Repository Group" #E8F5E9
  participant "SessionStore" as ssn
end box

note over user
  Scope:          CLI-08 LIST Sessions
  Preconditions:  REPLSession active, SessionStore accessible
  Contexts:       Called via /sessions slash command from CLI-01
  Excludes:       Normal message flow, model switching, output streaming
  Rollback:       SessionStore unavailable → error
  Design:         Table formatting for session display; delegates to SSN-03 via Service
  Returns:
    - Success: CommandResult with formatted session table
    - Failure: Error if SessionStore unavailable
end note


== CLI-08 LIST Sessions ==

user -> router : "/sessions"
activate router
router -> cmd : dispatch("/sessions")
activate cmd

cmd -> svc : CLI-08 LIST Sessions(pageSize=100, pageToken="")
activate svc

ref over svc, ssn
  SSN-03: LIST Sessions
end ref

svc --> cmd : SessionList{sessions, nextPageToken}
deactivate svc

cmd -> cmd : format session table

cmd --> router : CommandResult(formatted_table)
deactivate cmd

router --> user : displayed session list
deactivate router

note over user
  Flow:    CLI-08 → router → cmd → svc → SSN-03 → svc → cmd → router → user
  State:   No state change
  Success: CommandResult with formatted session table
  Failure: SessionStore unavailable — error displayed
end note


@enduml
