@startuml sq_cli08_list_sessions
' ============================================================
' Title:     CLI-08 — LIST Sessions
' Boundary:  nasim code agent
' Purpose:   List sessions via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> SlashCommandHandler -> ServerRouter
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-08 LIST Sessions

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "CLI Group" #E3F2FD
  participant "SlashCommandHandler" as sch
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

== CLI-08 LIST Sessions ==

user -> iface : CLI-08 LIST Sessions({pageSize, pageToken})
activate iface
iface -> sch : CLI-08 LIST Sessions({pageSize, pageToken})
activate sch
sch -> router : CLI-08 LIST Sessions({pageSize, pageToken})
activate router

alt sessions found
  router --> sch : 200 OK
  deactivate router
  sch --> iface : 200 OK
  deactivate sch
  iface --> user : 200 OK
  deactivate iface
else no sessions
  router --> sch : 404 Not Found
  deactivate router
  sch --> iface : 404 Not Found
  deactivate sch
  iface --> user : 404 Not Found
  deactivate iface
end

@enduml
