@startuml sq_cli05_enable_plan_mode
!include ../common/sq_styles.puml
' ============================================================
' Title:     CLI-05 — Enable Plan Mode
' Boundary:  nasim code agent CLI
' Purpose:   Toggle plan mode via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — CLI-05 ENABLE Plan Mode

actor "User" as user

note over user
  Scope:          CLI-05 — Enable Plan Mode
  Preconditions:  REPLSession active, AgentOrchestrator available
  Contexts:       Called via /plan slash command from CLI-01
  Excludes:       Model switching (CLI-07), session management, output streaming
  Rollback:       Toggle error → CommandError returned
  Design:         Toggle via SlashCommandHandler, state managed by AgentOrchestrator
  Returns:
    - Success: CommandResult with confirmation message
    - Failure: CommandError on toggle failure
end note #E3F2FD
  participant "REPLSession" as repl
end box
box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
  participant "SlashCommandHandler" as cmd
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box


== CLI-05 Enable Plan Mode ==

user -> repl : "/plan-mode"
repl -> cmd : dispatch("/plan-mode")
activate cmd

cmd -> cmd : parse command arguments
cmd -> cmd : toggle plan_mode flag

cmd -> agent : setPlanMode(enabled/disabled)
activate agent
agent --> cmd : planModeUpdated
deactivate agent

cmd --> repl : CommandResult(confirmation)
deactivate cmd


break Toggle error
    cmd --> repl : CommandError
end

note over user
  Flow:    user → REPLSession → SlashCommandHandler → AgentOrchestrator → REPLSession
  State:   IDLE → PLANNING or PLANNING → IDLE
  Success: CommandResult with confirmation ("Plan mode: ON/OFF")
  Failure: Toggle error: CommandError
end note

@enduml
