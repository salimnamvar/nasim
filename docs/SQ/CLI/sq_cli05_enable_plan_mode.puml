@startuml sq_cli05_enable_plan_mode
!include ../common/sq_styles.puml
' ============================================================
' Title:     CLI-05 — ENABLE Plan Mode
' Boundary:  nasim code agent CLI
' Purpose:   Toggle plan mode via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — CLI-05 ENABLE Plan Mode

actor "User" as user

box "CLI Interface Container" #E3F2FD
  participant "REPLSession" as repl
  participant "SlashCommandHandler" as cmdhandler
end box
box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "AgentOrchestrator" as agent
  participant "PlanSession" as plan
end box


== CLI-05 ENABLE Plan Mode ==

user -> repl : /plan
activate repl

repl -> cmdhandler : cli02 PARSE SlashCommand({input})
activate cmdhandler

cmdhandler -> router : cli05 ENABLE Plan Mode()
activate router

router -> agent : agt07 QUEUE Plan()
activate agent

agent -> plan : agt07 INSERT Plan({pending_calls})
activate plan
plan --> agent : PlanSession(queued)
deactivate plan

hnote over plan #FFF9C4 : **State: PLAN_ACTIVE**

agent --> router : 200 OK — PlanEnabled
deactivate agent

router --> cmdhandler : 200 OK — PlanEnabled
deactivate router

cmdhandler --> repl : CommandResult(PlanModeEnabled)
deactivate cmdhandler

repl --> user : "Plan mode enabled — tool calls will be queued"
deactivate repl


@enduml
