@startuml sq_cli05_enable_plan_mode
' ============================================================
' Title:     CLI-05 — ENABLE Plan Mode
' Boundary:  nasim code agent
' Purpose:   Toggle plan mode via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIRouter -> CLIController -> CLIExecutor -> CLIStore
' SM States: PLANNING (#FFCCBC)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-05 ENABLE Plan Mode

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Controller" #FFF3E0
  participant "CLIController" as ctrl
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

== CLI-05 ENABLE Plan Mode ==

user -> router : CLI-05 ENABLE Plan Mode()
activate router
router -> ctrl : CLI-05 ENABLE Plan Mode()
activate ctrl
ctrl -> exec : CLI-05 ENABLE Plan Mode()
activate exec
... hnote over exec : PLANNING (#FFCCBC) ...

alt plan mode enabled
  exec -> store : CLI-05 ENABLE Plan Mode()
  activate store
  store -> dir : CLI-05 ENABLE Plan Mode()
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> ctrl : 200 OK
  deactivate exec
  ctrl --> router : 200 OK
  deactivate ctrl
  router --> user : 200 OK
  deactivate router
else plan mode failed
  exec --> ctrl : 503 Unavailable
  deactivate exec
  ctrl --> router : 503 Unavailable
  deactivate ctrl
  router --> user : 503 Unavailable
  deactivate router
end

@enduml
