@startuml sq_cli05_enable_plan_mode
' ============================================================
' Title:     CLI-05 — ENABLE Plan Mode
' Boundary:  nasim code agent
' Purpose:   Toggle plan mode via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> CliManager -> CliStore -> CliDirectory -> FileSystem
' SM States: PLANNING (#FFCCBC)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-05 ENABLE Plan Mode

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== CLI-05 ENABLE Plan Mode ==

user -> iface : CLI-05 ENABLE Plan Mode()
activate iface
iface -> router : CLI-05 ENABLE Plan Mode()
activate router
router -> router : CLI-05 ENABLE Plan Mode()
router -> exec : CLI-05 ENABLE Plan Mode()
activate exec
    exec -> exec : TRANSITION State(<back:#FFCCBC>PLANNING</back>)

alt plan mode enabled
  exec -> store : CLI-05 ENABLE Plan Mode()
  activate store
  store -> dir : CLI-05 ENABLE Plan Mode()
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> router : 200 OK
  deactivate exec
  router --> router : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else plan mode failed
  exec --> router : 503 Unavailable
  deactivate exec
  router --> router : 503 Unavailable
  router --> iface : 503 Unavailable
  iface --> user : 503 Unavailable
  deactivate router
  deactivate iface
end

@enduml
