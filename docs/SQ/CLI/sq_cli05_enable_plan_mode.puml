@startuml sq_cli05_enable_plan_mode
' ============================================================
' Title:     CLI-05 — ENABLE Plan Mode
' Boundary:  nasim code agent
' Purpose:   Toggle plan mode via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> SlashCommandHandler -> ServerRouter
' SM States: PLANNING (#FFCCBC)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-05 ENABLE Plan Mode

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box

box "CLI Group" #E3F2FD
  participant "SlashCommandHandler" as sch
end box

box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box

== CLI-05 ENABLE Plan Mode ==

user -> iface : CLI-05 ENABLE Plan Mode()
activate iface
iface -> sch : CLI-05 ENABLE Plan Mode()
activate sch
sch -> router : CLI-05 TOGGLE Plan Mode()
activate router
ref over sch : TRANSITION State(<back:#FFCCBC>PLANNING</back>)

alt plan mode enabled
  router --> sch : 200 OK
  deactivate router
  sch --> iface : 200 OK
  deactivate sch
  iface --> user : 200 OK
  deactivate iface
else plan mode failed
  router --> sch : 503 Unavailable
  deactivate router
  sch --> iface : 503 Unavailable
  deactivate sch
  iface --> user : 503 Unavailable
  deactivate iface
end

@enduml
