@startuml sq_cli05_enable_plan_mode
' ============================================================
' Title:     CLI-05 — ENABLE Plan Mode
' Boundary:  nasim code agent
' Purpose:   Toggle plan mode via slash command
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> SlashCommandHandler -> ServerRouter
' SM States: PLANNING (#FFCCBC)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-05 ENABLE Plan Mode

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
  participant "SlashCommandHandler" as sch
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

== CLI-05 ENABLE Plan Mode ==

user -> iface : CLI-05 ENABLE Plan Mode()
activate iface
iface -> sch : CLI-05 ENABLE Plan Mode()
activate sch
sch -> router : CLI-05 TOGGLE Plan Mode()
activate router

alt plan mode enabled
  ref over sch : CLI-05 ENABLE Plan Mode()
  router --> sch : 200 OK
  deactivate router
  sch --> iface : 200 OK
  deactivate sch
  iface --> user : 200 OK
  deactivate iface
else plan mode failed
  ref over sch : CLI-05 ENABLE Plan Mode()     <back:#ECEFF1>IDLE</back>
  router --> sch : 503 SERVICE_UNAVAILABLE\n{error: {code: "CLI-05_PLAN_MODE_FAILED", message: "Plan mode toggle failed", status: 503}}
  deactivate router
  sch --> iface : 503 SERVICE_UNAVAILABLE\n{error: {code: "CLI-05_PLAN_MODE_FAILED", message: "Plan mode toggle failed", status: 503}}
  deactivate sch
  iface --> user : 503 SERVICE_UNAVAILABLE\n{error: {code: "CLI-05_PLAN_MODE_FAILED", message: "Plan mode toggle failed", status: 503}}
  deactivate iface
end

@enduml
