@startuml sq_cli04_read_cli_arguments
' ============================================================
' Title:     CLI-04 — READ CLI Arguments
' Boundary:  nasim code agent
' Purpose:   Startup argument parsing and config initialization
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIRouter -> CLIController -> CLIExecutor -> CLIStore
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-04 READ CLI Arguments

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Controller" #FFF3E0
  participant "CLIController" as ctrl
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

== CLI-04 READ CLI Arguments ==

user -> router : CLI-04 PARSE Argv({argv})
activate router
router -> ctrl : CLI-04 PARSE Argv({argv})
activate ctrl
ctrl -> exec : CLI-04 PARSE Argv({argv})
activate exec

alt valid arguments
  exec -> store : CLI-04 LOAD Config({parsedArgs})
  activate store
  store -> dir : CLI-04 LOAD Config({parsedArgs})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> ctrl : 200 OK
  deactivate exec
  ctrl --> router : 200 OK
  deactivate ctrl
  router --> user : 200 OK
  deactivate router
else invalid arguments
  exec --> ctrl : 422 Unprocessable
  deactivate exec
  ctrl --> router : 422 Unprocessable
  deactivate ctrl
  router --> user : 422 Unprocessable
  deactivate router
end

@enduml
