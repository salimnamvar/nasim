@startuml sq_cli04_read_cli_arguments
!include ../common/sq_styles.puml
' ============================================================
' Title:     CLI-04 — READ CLI Arguments
' Boundary:  nasim code agent CLI
' Purpose:   Startup argument parsing and config initialization
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — CLI-04 READ CLI Arguments

actor "User" as user

box "CLI Interface Container" #E3F2FD
  participant "ArgParser" as argparser
end box
box "Config Group" #E8F5E9
  participant "ConfigLoader" as config
end box


== CLI-04 READ CLI Arguments ==

user -> argparser : pass CLI arguments (argv)
activate argparser

argparser -> argparser : cli04 PARSE Argv({argv})
argparser -> argparser : validate required flags

alt invalid arguments
    argparser --> user : error: invalid argument — {detail}
else valid arguments
    argparser -> config : cfg01 LOAD Config({cli_args})
    activate config

    config -> config : cfg01 READ Global Defaults(~/.nasim/config.yaml)
    config -> config : cfg01 READ Project Overrides(.nasim/config.yaml)
    config -> config : cfg01 READ Env Overrides(NASIM_*)
    config -> config : cfg03 APPLY Layered Config(global, project, env, cli)

    break invalid YAML or missing required fields
        config --> argparser : ConfigError({detail})
        argparser --> user : error: config load failed — {detail}
    end

    config --> argparser : Config object
    deactivate config

    argparser --> user : Config loaded — nasim ready
end

deactivate argparser


@enduml
