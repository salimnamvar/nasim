@startuml sq_cli04_read_cli_arguments
' ============================================================
' Title:     CLI-04 — READ CLI Arguments
' Boundary:  nasim code agent
' Purpose:   Startup argument parsing and config initialization
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Adapter -> REPLSession -> ArgParser -> Agent Controller
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-04 READ CLI Arguments

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Adapter" as iface
  participant "CLI Adapter" as repl
  participant "CLI Adapter" as argparser
end box

box "API" API_COLOR
  participant "Agent Controller" as router
end box

== CLI-04 READ CLI Arguments ==

user -> iface : CLI-04 PARSE Argv({argv})
activate iface
iface -> repl : CLI-04 PARSE Argv({argv})
activate repl
repl -> argparser : CLI-04 PARSE Argv({argv})
activate argparser
argparser -> router : CLI-04 LOAD Config({parsedArgs})
activate router

alt valid arguments
  router --> argparser : 200 OK
  deactivate router
  argparser --> repl : 200 OK
  deactivate argparser
  repl --> iface : 200 OK
  deactivate repl
  iface --> user : 200 OK
  deactivate iface
else invalid arguments
  router --> argparser : 422 Unprocessable
  deactivate router
  argparser --> repl : 422 Unprocessable
  deactivate argparser
  repl --> iface : 422 Unprocessable
  deactivate repl
  iface --> user : 422 Unprocessable
  deactivate iface
end

@enduml
