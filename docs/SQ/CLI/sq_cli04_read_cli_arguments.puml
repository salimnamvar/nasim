@startuml sq_cli04_read_cli_arguments
' ============================================================
' Title:     CLI-04 — READ CLI Arguments
' Boundary:  nasim code agent
' Purpose:   Startup argument parsing and config initialization
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> CliManager -> CliStore -> CliDirectory -> FileSystem
' SM States: —
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-04 READ CLI Arguments

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== CLI-04 READ CLI Arguments ==

user -> iface : CLI-04 PARSE Argv({argv})
activate iface
iface -> router : CLI-04 PARSE Argv({argv})
activate router
router -> router : CLI-04 PARSE Argv({argv})
router -> exec : CLI-04 PARSE Argv({argv})
activate exec

alt valid arguments
  exec -> store : CLI-04 LOAD Config({parsedArgs})
  activate store
  store -> dir : CLI-04 LOAD Config({parsedArgs})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> router : 200 OK
  deactivate exec
  router --> router : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else invalid arguments
  exec --> router : 422 Unprocessable
  deactivate exec
  router --> router : 422 Unprocessable
  router --> iface : 422 Unprocessable
  iface --> user : 422 Unprocessable
  deactivate router
  deactivate iface
end

@enduml
