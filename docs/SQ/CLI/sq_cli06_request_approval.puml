@startuml sq_cli06_request_approval
' ============================================================
' Title:     CLI-06 — REQUEST Approval
' Boundary:  nasim code agent
' Purpose:   Display approval prompt and collect developer decision
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> REPLSession -> ServerRouter
' SM States: AWAITING_APPROVAL (#FFF9C4)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-06 REQUEST Approval

actor "User" as user

box "Interface" INTERFACE_COLOR
  participant "CLI Process" as iface
  participant "REPLSession" as repl
end box

box "API" API_COLOR
  participant "ServerRouter" as router
end box

== CLI-06 REQUEST Approval ==

user -> iface : CLI-06 REQUEST Approval({toolName, args})
activate iface
iface -> repl : CLI-06 REQUEST Approval({toolName, args})
activate repl
repl -> router : CLI-06 REGISTER Approval({toolName})
activate router

alt user approves
  ref over repl : CLI-06 REQUEST Approval({toolName, args})
  router --> repl : 200 OK
  deactivate router
  repl --> iface : 200 OK
  deactivate repl
  iface --> user : 200 OK
  deactivate iface
else user rejects
  ref over repl : CLI-06 REQUEST Approval({toolName, args})     <back:#ECEFF1>IDLE</back>
  router --> repl : 403 FORBIDDEN\n{error: {code: "CLI-06_USER_REJECTED", message: "User rejected approval", status: 403}}
  deactivate router
  repl --> iface : 403 FORBIDDEN\n{error: {code: "CLI-06_USER_REJECTED", message: "User rejected approval", status: 403}}
  deactivate repl
  iface --> user : 403 FORBIDDEN\n{error: {code: "CLI-06_USER_REJECTED", message: "User rejected approval", status: 403}}
  deactivate iface
end

@enduml
