@startuml sq_cli06_request_approval
!include ../common/sq_styles.puml
' ============================================================
' Title:     CLI-06 — REQUEST Approval
' Boundary:  nasim code agent CLI
' Purpose:   Display approval prompt and collect developer decision
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — CLI-06 REQUEST Approval

actor "User" as user

box "CLI Interface Container" #E3F2FD
  participant "REPLSession" as repl
end box
box "API Group (Entry Gate)" #E3F2FD
  participant "ServerRouter" as router
end box
box "Agent Group" #FFF3E0
  participant "SafetyCoordinator" as safety
end box


== CLI-06 REQUEST Approval ==

user -> repl : await approval prompt
activate repl

repl -> router : cli06 REQUEST Approval({tool_name}, {args})
activate router

router -> safety : saf02 REQUEST Approval({tool_name}, {args})
activate safety

safety -> repl : saf02 DISPLAY Approval({tool_name}, {args})

hnote over safety #FFF9C4 : **State: AWAITING_APPROVAL**

repl --> user : "Allow {tool_name}({args})? [y/N]"

user -> repl : y or N

alt user = y
    repl -> safety : saf02 APPROVE Action({tool_name})
    safety --> router : approved
    router --> repl : 200 OK — Approved
    repl --> user : "Approved — executing {tool_name}"
else user = N
    repl -> safety : saf02 REJECT Action({tool_name})
    safety --> router : rejected
    router --> repl : 403 PERMISSION_DENIED — Rejected by user
    repl --> user : "Rejected — {tool_name} will not execute"
end

deactivate safety
deactivate router
deactivate repl


@enduml
