@startuml sq_cli06_request_approval
' ============================================================
' Title:     CLI-06 — REQUEST Approval
' Boundary:  nasim code agent
' Purpose:   Display approval prompt and collect developer decision
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLIRouter -> CLIController -> CLIExecutor -> CLIStore
' SM States: AWAITING_APPROVAL (#FFF9C4)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-06 REQUEST Approval

actor "User" as user

box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Controller" #FFF3E0
  participant "CLIController" as ctrl
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

== CLI-06 REQUEST Approval ==

user -> router : CLI-06 REQUEST Approval({toolName, args})
activate router
router -> ctrl : CLI-06 REQUEST Approval({toolName, args})
activate ctrl
ctrl -> exec : CLI-06 REQUEST Approval({toolName, args})
activate exec
... hnote over exec : AWAITING_APPROVAL (#FFF9C4) ...

alt user approves
  exec -> store : CLI-06 APPROVE Action({toolName})
  activate store
  store -> dir : CLI-06 APPROVE Action({toolName})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> ctrl : 200 OK
  deactivate exec
  ctrl --> router : 200 OK
  deactivate ctrl
  router --> user : 200 OK
  deactivate router
else user rejects
  exec -> store : CLI-06 REJECT Action({toolName})
  activate store
  store --> exec : 200 OK
  deactivate store
  exec --> ctrl : 403 Forbidden
  deactivate exec
  ctrl --> router : 403 Forbidden
  deactivate ctrl
  router --> user : 403 Forbidden
  deactivate router
end

@enduml
