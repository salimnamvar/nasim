@startuml sq_cli06_request_approval
!include ../common/sq_styles.puml
' ============================================================
' Title:     CLI-06 — Request Approval
' Boundary:  nasim code agent CLI
' Purpose:   Display approval prompt and collect developer decision
' Milestone: v1.0
' Version:   9.1.0
' Source:    CAR refinement loop — API-First transformation
' Review:    docs/SQ/README.md
' ============================================================

title nasim — CLI-06 REQUEST Approval

actor "User" as user

note over user
  Scope:          CLI-06 — Request Approval
  Preconditions:  AgentOrchestrator active, tool call pending approval
  Contexts:       Called by agent during tool execution when safety requires approval
  Excludes:       Normal message flow, slash commands, output streaming
  Rollback:       Timeout or denial → tool call denied
  Design:         Interactive approval with timeout, SafetyCoordinator determines approval requirement
  Returns:
    - Success: Approved, tool call proceeds
    - Failure: Denied (user rejection or timeout)
end note #E3F2FD
  participant "Renderer" as renderer
end box
box "Service Group" #FFF3E0
  participant "AgentOrchestrator" as agent
end box
box "Safety Group" #FFF3E0
  participant "SafetyCoordinator" as safety
end box
box "Repository Group" #E8F5E9
  participant "SessionRepository" as session_repo
end box


== CLI-06 Request Approval ==

agent -> safety : requires_approval(tool_call)
activate safety
safety --> agent : true
deactivate safety

agent -> renderer : request_approval(tool_description, args)
activate renderer

renderer --> user : "Allow {tool}({args})? [y/N]"
user --> renderer : decision (y/n/timeout)

alt approved
    renderer --> agent : Approved
else denied
    renderer --> agent : Denied
else timeout
    renderer --> agent : Denied(timeout)
end

deactivate renderer

note over user
  Flow:    AgentOrchestrator → SafetyCoordinator → Renderer → user → Renderer → AgentOrchestrator
  State:   No state change
  Success: Approved, tool call proceeds
  Failure: Denied: user rejection or timeout — tool call blocked
end note

@enduml
