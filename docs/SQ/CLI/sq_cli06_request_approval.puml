@startuml sq_cli06_request_approval
' ============================================================
' Title:     CLI-06 — REQUEST Approval
' Boundary:  nasim code agent
' Purpose:   Display approval prompt and collect developer decision
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/UC/README.md, docs/SM/README.md
' Review:    —
' CSR Chain: User -> CLI Process -> ServerRouter -> CliManager -> CliStore -> CliDirectory -> FileSystem
' SM States: AWAITING_APPROVAL (#FFF9C4)
' ============================================================

!include ../common/sq_styles.puml

title nasim -- CLI-06 REQUEST Approval

actor "User" as user

box "Interface Layer" #E3F2FD
  participant "CLI Process" as iface
end box



box "Entry Gate" #E3F2FD
  participant "CLIRouter" as router
end box
box "Service" #FFF3E0
  participant "CLIExecutor" as exec
end box
box "Repository" #E8F5E9
  participant "CLIStore" as store
end box
database "CLIDirectory" as dir

box "Infrastructure Layer" #ECEFF1
  participant "FileSystem" as FileSystem
end box



== CLI-06 REQUEST Approval ==

user -> iface : CLI-06 REQUEST Approval({toolName, args})
activate iface
iface -> router : CLI-06 REQUEST Approval({toolName, args})
activate router
router -> router : CLI-06 REQUEST Approval({toolName, args})
router -> exec : CLI-06 REQUEST Approval({toolName, args})
activate exec
    exec -> exec : TRANSITION State(<back:#FFF9C4>AWAITING_APPROVAL</back>)

alt user approves
  exec -> store : CLI-06 APPROVE Action({toolName})
  activate store
  store -> dir : CLI-06 APPROVE Action({toolName})
  activate dir
  dir --> store : 200 OK
  deactivate dir
  store --> exec : 200 OK
  deactivate store
  exec --> router : 200 OK
  deactivate exec
  router --> router : 200 OK
  router --> iface : 200 OK
  iface --> user : 200 OK
  deactivate router
  deactivate iface
else user rejects
  exec -> store : CLI-06 REJECT Action({toolName})
  activate store
  store --> exec : 200 OK
  deactivate store
  exec --> router : 403 Forbidden
  deactivate exec
  router --> router : 403 Forbidden
  router --> iface : 403 Forbidden
  iface --> user : 403 Forbidden
  deactivate router
  deactivate iface
end

@enduml
