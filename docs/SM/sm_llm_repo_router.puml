@startuml sm_llm_repo_router
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — LLM Repository: Router Lifecycle State Machine
' Boundary:  NASIM Application — Repository Layer
' Purpose:   Model routing lifecycle (classify, select, fallback, switch).
' Milestone: v1.0
' Version:   2.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0), docs/UC/uc_llm_repo.puml
' Review:    SM Architect extraction 2026-07-01 (C4+UC source of truth)
' Note:      Router UCs are LLMREPOSITORY-05..08 per uc_llm_repo.puml.
' ============================================================

title nasim — LLM Repository: Router Lifecycle

[*] --> IDLE : LLMREPOSITORY-05

state "IDLE" as IDLE #EEEEEE
IDLE : No routing in progress.
IDLE : Default state.

state "CLASSIFYING" as CLASSIFYING #5C6BC0
CLASSIFYING : Task classification for model routing.
CLASSIFYING : LLMREPOSITORY-07 CLASSIFY Task.

state "SELECTING" as SELECTING #3F51B5
SELECTING : Model selection in progress.
SELECTING : LLMREPOSITORY-05 SELECT Model.

state "SWITCHING" as SWITCHING #FF8F00
SWITCHING : Runtime model switch in progress.
SWITCHING : LLMREPOSITORY-08 SWITCH Model.

state "FALLBACK" as FALLBACK #EF6C00
FALLBACK : Falling back to next available model.
FALLBACK : LLMREPOSITORY-06 APPLY Fallback.

state "ERROR" as ERROR #BF360C
ERROR : Routing or fallback failed.
ERROR : All models exhausted or classification failed.

IDLE --> CLASSIFYING : LLMREPOSITORY-07
CLASSIFYING --> SELECTING : LLMREPOSITORY-05
CLASSIFYING --> ERROR : LLMREPOSITORY-07
SELECTING --> IDLE : LLMREPOSITORY-05
SELECTING --> FALLBACK : LLMREPOSITORY-06 / [primary_unavailable]
FALLBACK --> SELECTING : LLMREPOSITORY-06
FALLBACK --> ERROR : LLMREPOSITORY-06 / [exhausted]
IDLE --> SWITCHING : LLMREPOSITORY-08
SWITCHING --> IDLE : LLMREPOSITORY-08
SWITCHING --> ERROR : LLMREPOSITORY-08
ERROR --> IDLE : LLMREPOSITORY-05

IDLE --> [*] : LLMREPOSITORY-05

@enduml