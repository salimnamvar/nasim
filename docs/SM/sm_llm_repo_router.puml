@startuml sm_llm_repo_router
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — LLM Repository: Router Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Selection lifecycle for LLM Repository (Router).
'            States: IDLE → CLASSIFYING → SELECTING → IDLE | FALLBACK
' Milestone: v1.0
' Version:   1.0.0
' Source:    C4 component diagram (LLM Repository), docs/UC/README.md (LLMREPO-01, LLMREPO-02, LLMREPO-03, LLMREPO-04)
' Review:    CAR audit 2026-06-27
' Convention: All transitions are triggered by the corresponding UC ID
'             as listed in docs/UC/README.md.
' ============================================================

title nasim — LLM Repository: Router Lifecycle

[*] --> IDLE : LLMREPO-01

state "IDLE" as IDLE #EEEEEE
IDLE : No routing in progress.
IDLE : Default state.

state "CLASSIFYING" as CLASSIFYING #5C6BC0
CLASSIFYING : Task classification for model routing.
CLASSIFYING : LLMREPO-03 CLASSIFY Task.

state "SELECTING" as SELECTING #3F51B5
SELECTING : Model selection in progress.
SELECTING : LLMREPO-01 SELECT Model.

state "SWITCHING" as SWITCHING #FF8F00
SWITCHING : Runtime model switch in progress.
SWITCHING : LLMREPO-04 SWITCH Model.

state "FALLBACK" as FALLBACK #EF6C00
FALLBACK : Falling back to next available model.
FALLBACK : LLMREPO-02 APPLY Fallback.

state "ERROR" as ERROR #BF360C
ERROR : Routing or fallback failed.
ERROR : All models exhausted or classification failed.

IDLE --> CLASSIFYING : LLMREPO-03
CLASSIFYING --> SELECTING : LLMREPO-01
CLASSIFYING --> ERROR : LLMREPO-03
SELECTING --> IDLE : LLMREPO-01
SELECTING --> FALLBACK : LLMREPO-02
FALLBACK --> SELECTING : LLMREPO-02
FALLBACK --> ERROR : LLMREPO-02
IDLE --> SWITCHING : LLMREPO-04
SWITCHING --> IDLE : LLMREPO-04
SWITCHING --> ERROR : LLMREPO-04
ERROR --> IDLE : LLMREPO-01

IDLE --> [*] : LLMREPO-01

@enduml
