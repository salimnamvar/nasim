@startuml sm_diff_staging_lifecycle
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Diff Staging Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Staging lifecycle for Edit Strategy Repository (Diff).
'            States: EMPTY → STAGING → STAGED → AWAITING_APPROVAL → APPROVED → APPLYING → APPLIED
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/UC/README.md (EDITSTRATEGYREPOSITORY-10, SAFETYSERVICE-02)
' Review:    CAR audit 2026-06-27
' Convention: All transitions are triggered by the corresponding UC ID
'             as listed in docs/UC/README.md.
' ============================================================

title nasim — Diff Staging Lifecycle

[*] --> EMPTY : EDITSTRATEGYREPOSITORY-10

state "EMPTY" as EMPTY #9FA8DA
EMPTY : No diff staged.
EMPTY : Default state.

state "STAGING" as STAGING #FFE082
STAGING : Diff being computed.
STAGING : EDITSTRATEGYREPOSITORY-10 STAGE Diff.

state "STAGED" as STAGED #C5E1A5
STAGED : Diff ready for review.
STAGED : EDITSTRATEGYREPOSITORY-10 STAGE Diff.

state "AWAITING_APPROVAL" as AWAITING_APPROVAL #FFD54F
AWAITING_APPROVAL : Diff presented to user for approval.
AWAITING_APPROVAL : SAFETYSERVICE-02 REQUEST Approval.

state "APPROVED" as APPROVED #AED581
APPROVED : User approved diff.
APPROVED : SAFETYSERVICE-02 REQUEST Approval.

state "APPLYING" as APPLYING #81C784
APPLYING : Approved diff being applied.
APPLYING : EDITSTRATEGYREPOSITORY-10 STAGE Diff.

state "APPLIED" as APPLIED #009688
APPLIED : Diff successfully applied.
APPLIED : EDITSTRATEGYREPOSITORY-10 STAGE Diff.

state "ERROR" as ERROR #E53935
ERROR : Diff computation or application failed.
ERROR : EDITSTRATEGYREPOSITORY-10 STAGE Diff.

EMPTY --> STAGING : EDITSTRATEGYREPOSITORY-10
STAGING --> STAGED : EDITSTRATEGYREPOSITORY-10
STAGING --> ERROR : EDITSTRATEGYREPOSITORY-10
STAGED --> AWAITING_APPROVAL : EDITSTRATEGYREPOSITORY-10
AWAITING_APPROVAL --> APPROVED : SAFETYSERVICE-02
AWAITING_APPROVAL --> EMPTY : SAFETYSERVICE-02
APPROVED --> APPLYING : EDITSTRATEGYREPOSITORY-10
APPLYING --> APPLIED : EDITSTRATEGYREPOSITORY-10
APPLYING --> ERROR : EDITSTRATEGYREPOSITORY-10
APPLIED --> EMPTY : EDITSTRATEGYREPOSITORY-10
ERROR --> EMPTY : EDITSTRATEGYREPOSITORY-10

APPLIED --> [*] : EDITSTRATEGYREPOSITORY-10

@enduml
