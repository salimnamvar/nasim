@startuml sm_session_lifecycle
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Session Lifecycle State Machine (API-First)
' Boundary:  nasim code agent
' Purpose:   Entity lifecycle for Session (persisted to disk).
'            All mutations routed through API Group (Entry Gate).
' Milestone: v1.0
' Version:   8.0.0
' Source:    CAR refinement loop — API-First transformation
' Review:    —
' ============================================================

title nasim — Session Lifecycle (API-First)

[*] --> CREATED : HTTPADAPTER-02

state "CREATED" as CREATED #BBDEFB
CREATED : Session record initialized.
CREATED : HTTPADAPTER-02 CREATE Session.

state "ACTIVE" as ACTIVE #43A047
ACTIVE : Session accepting messages.
ACTIVE : HTTPADAPTER-03 GET Session, HTTPADAPTER-06 DISPATCH Message.

state "SAVED" as SAVED #1565C0
SAVED : Session persisted to disk.
SAVED : HTTPADAPTER-01 LIST Sessions, HTTPADAPTER-04 UPDATE Session.

state "RESTORED" as RESTORED #1E88E5
RESTORED : Session loaded from disk.
RESTORED : HTTPADAPTER-03 GET Session.

state "BRANCHED" as BRANCHED #7B1FA2
BRANCHED : Session forked from parent.
BRANCHED : WIRELOGREPOSITORY-04 FORK Session.

state "CLOSED" as CLOSED #757575
CLOSED : Session terminated.
CLOSED : Terminal state.

CREATED --> ACTIVE : HTTPADAPTER-02
ACTIVE --> SAVED : HTTPADAPTER-04
ACTIVE --> BRANCHED : WIRELOGREPOSITORY-04
ACTIVE --> CLOSED : HTTPADAPTER-05
SAVED --> RESTORED : HTTPADAPTER-03
RESTORED --> ACTIVE : HTTPADAPTER-02
RESTORED --> SAVED : HTTPADAPTER-04
RESTORED --> CLOSED : HTTPADAPTER-05
BRANCHED --> ACTIVE : HTTPADAPTER-02
BRANCHED --> CLOSED : HTTPADAPTER-05
SAVED --> CLOSED : HTTPADAPTER-05

CLOSED --> [*] : HTTPADAPTER-05

@enduml
