@startuml sm_agent_lifecycle
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Agent Lifecycle State Machine (API-First)
' Boundary:  nasim code agent
' Purpose:   Process FSM showing all agent states and transitions.
'            All entry points route through the API (HTTPADP-06).
' Milestone: v1.0
' Version:   8.0.0
' Source:    C4 component diagram (Task Service), docs/UC/README.md
' Review:    —
' Note:      Process FSM, not entity lifecycle. SMT rules from sm.md
'            do not apply (documented deviation).
' Convention: All transitions are triggered by the corresponding UC ID
'            (e.g., EVALUATIONSERVICE-01, EDITSTRATEGYREPOSITORY-10, TASKSERVICE-07) as listed in docs/UC/README.md.
'            Entry/exit transitions use HTTPADP-06 (DISPATCH Message) as the
'            sole entry gate for all interface containers.
' ============================================================

title nasim — Agent Lifecycle (API-First)

[*] --> IDLE : TASKSERVICE-01

state "IDLE" as IDLE #ECEFF1
IDLE : Agent waiting for user input.
IDLE : No active provider call.

state "LISTENING" as LISTENING #E8EAF6
LISTENING : Receiving and parsing user input.
LISTENING : HTTPADP-06 DISPATCH Message (via any interface).

state "THINKING" as THINKING #D7CCC8
THINKING : LLM processing messages.
THINKING : LLMREPOSITORY-02 REQUEST Chat or LLMREPOSITORY-03 STREAM Chat.

state "TOOL_EXEC" as TOOL_EXEC #B2DFDB
TOOL_EXEC : Executing a tool call.
TOOL_EXEC : TASKSERVICE-02 DISPATCH Tool Call.

state "RESPONDING" as RESPONDING #D1C4E9
RESPONDING : Streaming final text to user via API SSE.
RESPONDING : HTTPADP-06 DISPATCH Message (SSE response).

state "ERROR" as ERROR #FFEBEE
ERROR : Error occurred.
ERROR : TASKSERVICE-14 HANDLE Error.

state "COMPACTING" as COMPACTING #E0F2F1
COMPACTING : Summarizing old exchanges.
COMPACTING : TASKSERVICE-06 COMPACT Context.

state "AWAITING_APPROVAL" as AWAITING_APPROVAL #FFF9C4
AWAITING_APPROVAL : Waiting for user permission.
AWAITING_APPROVAL : SAFETYSERVICE-02 REQUEST Approval.

state "PLANNING" as PLANNING #FFCCBC
PLANNING : Plan mode, tool calls queued.
PLANNING : TASKSERVICE-07 QUEUE Plan.

state "HOOK_RUNNING" as HOOK_RUNNING #FFFDE7
HOOK_RUNNING : Pre/post hook executing.
HOOK_RUNNING : TOOLSERVICE-02..05 DISPATCH Hook.

state "ROUTING" as ROUTING #EDE7F6
ROUTING : Model selection in progress.
ROUTING : LLMREPOSITORY-01 SELECT Model.

state "SERVING" as SERVING #E0F7FA
SERVING : API processing request from any interface.
SERVING : HTTPADP-06 DISPATCH Message.

state "EVALUATING" as EVALUATING #F9FBE7
EVALUATING : Evaluating task completion.
EVALUATING : EVALUATIONSERVICE-01 EVALUATE Task.

state "REVIEWING" as REVIEWING #FFF8E1
REVIEWING : LLM review of results.
REVIEWING : EVALUATIONSERVICE-04 VALIDATE With LLM.

state "RETRYING" as RETRYING #FBE9E7
RETRYING : Retrying with feedback.
RETRYING : EVALUATIONSERVICE-06 COORDINATE Retry.

state "STAGING" as STAGING #F1F8E9
STAGING : Diff sandbox staging.
STAGING : EDITSTRATEGYREPOSITORY-10 STAGE Diff.

state "AWAITING_DIFF_APPROVAL" as AWAITING_DIFF_APPROVAL #FCE4EC
AWAITING_DIFF_APPROVAL : Presenting diff to user.
AWAITING_DIFF_APPROVAL : SAFETYSERVICE-02 REQUEST Approval.

' ============================================================
' Entry transitions: ALL go through HTTPADP-06 (sole entry gate)
' ============================================================

IDLE --> LISTENING : HTTPADP-06
IDLE --> SERVING : HTTPADP-06

LISTENING --> THINKING : HTTPADP-06

THINKING --> RESPONDING : LLMREPOSITORY-02
THINKING --> TOOL_EXEC : LLMREPOSITORY-02
THINKING --> COMPACTING : TASKSERVICE-06
THINKING --> ROUTING : LLMREPOSITORY-01
THINKING --> ERROR : LLMREPOSITORY-02
THINKING --> RESPONDING : HTTPADP-06
THINKING --> EVALUATING : EVALUATIONSERVICE-01

ROUTING --> THINKING : LLMREPOSITORY-01

TOOL_EXEC --> THINKING : TASKSERVICE-02
TOOL_EXEC --> AWAITING_APPROVAL : SAFETYSERVICE-02
TOOL_EXEC --> HOOK_RUNNING : TOOLSERVICE-02
TOOL_EXEC --> ERROR : TASKSERVICE-02
TOOL_EXEC --> STAGING : EDITSTRATEGYREPOSITORY-10

HOOK_RUNNING --> TOOL_EXEC : TOOLSERVICE-02
HOOK_RUNNING --> IDLE : TOOLSERVICE-02

AWAITING_APPROVAL --> TOOL_EXEC : SAFETYSERVICE-02
AWAITING_APPROVAL --> IDLE : SAFETYSERVICE-02

COMPACTING --> THINKING : TASKSERVICE-06

' ============================================================
' Exit transitions: response flows back through HTTPADP-06
' ============================================================

RESPONDING --> IDLE : HTTPADP-06

ERROR --> IDLE : TASKSERVICE-14

SERVING --> THINKING : HTTPADP-06
SERVING --> IDLE : HTTPADP-06

IDLE --> PLANNING : TASKSERVICE-07
PLANNING --> IDLE : TASKSERVICE-07

EVALUATING --> REVIEWING : EVALUATIONSERVICE-01
EVALUATING --> RETRYING : EVALUATIONSERVICE-01
EVALUATING --> THINKING : EVALUATIONSERVICE-01

REVIEWING --> THINKING : EVALUATIONSERVICE-04
REVIEWING --> RETRYING : EVALUATIONSERVICE-04

RETRYING --> THINKING : EVALUATIONSERVICE-06
RETRYING --> ERROR : EVALUATIONSERVICE-06

STAGING --> AWAITING_DIFF_APPROVAL : EDITSTRATEGYREPOSITORY-10
STAGING --> ERROR : EDITSTRATEGYREPOSITORY-10

AWAITING_DIFF_APPROVAL --> TOOL_EXEC : SAFETYSERVICE-02
AWAITING_DIFF_APPROVAL --> IDLE : SAFETYSERVICE-02

IDLE --> [*] : TASKSERVICE-01

@enduml
