@startuml sm_safety_mode_lifecycle
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Safety Mode Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Mode lifecycle for SafetyCoordinator.
'            Modes: PERMISSIVE, ASK, BLOCK.
'            All mode transitions via SAF-03 APPLY Safety Mode.
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/UC/README.md (SAF-01, SAF-03)
' Review:    CAR audit 2026-06-27
' Convention: All transitions are triggered by the corresponding UC ID
'             as listed in docs/UC/README.md.
' ============================================================

title nasim — Safety Mode Lifecycle

[*] --> UNINITIALIZED : SAF-03

state "UNINITIALIZED" as UNINITIALIZED #BDBDBD
UNINITIALIZED : Safety system not initialized.
UNINITIALIZED : Default state before first mode apply.

state "PERMISSIVE" as PERMISSIVE #9CCC65
PERMISSIVE : All operations allowed, no approval prompts.
PERMISSIVE : SAF-03 APPLY Safety Mode.

state "ASK" as ASK #FDD835
ASK : User approval required for sensitive operations.
ASK : SAF-03 APPLY Safety Mode.

state "BLOCK" as BLOCK #E91E63
BLOCK : Dangerous operations blocked entirely.
BLOCK : SAF-03 APPLY Safety Mode.

state "ERROR" as ERROR #F4511E
ERROR : Safety system encountered an error.
ERROR : SAF-01 CHECK Permission failure.

UNINITIALIZED --> PERMISSIVE : SAF-03
UNINITIALIZED --> ASK : SAF-03
UNINITIALIZED --> BLOCK : SAF-03
PERMISSIVE --> ASK : SAF-03
PERMISSIVE --> BLOCK : SAF-03
ASK --> PERMISSIVE : SAF-03
ASK --> BLOCK : SAF-03
BLOCK --> PERMISSIVE : SAF-03
BLOCK --> ASK : SAF-03
PERMISSIVE --> ERROR : SAF-01
ASK --> ERROR : SAF-01
BLOCK --> ERROR : SAF-01
ERROR --> UNINITIALIZED : SAF-03

UNINITIALIZED --> [*] : SAF-03

@enduml
