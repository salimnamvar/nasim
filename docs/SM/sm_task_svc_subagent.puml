@startuml sm_task_svc_subagent
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Task Service: Subagent Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Entity lifecycle for Task Service (Subagent child processes).
'            States: IDLE → SPAWNING → RUNNING → COMPLETED | FAILED
' Milestone: v1.0
' Version:   10.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0), docs/UC/uc_task_svc.puml
' Review:    SM Architect extraction 2026-07-01 (C4+UC source of truth)
' Convention: All transitions are triggered by the corresponding UC ID
'             as listed in docs/UC/README.md.
' ============================================================

title nasim — Task Service: Subagent Lifecycle

[*] --> IDLE : TASKSVC-09

state "IDLE" as IDLE #CFD8DC
IDLE : No child agent active.
IDLE : Default state.

state "SPAWNING" as SPAWNING #FFAB91
SPAWNING : Child agent process initializing.
SPAWNING : Session created, orchestrator assigned.

state "RUNNING" as RUNNING #BCAAA4
RUNNING : Child agent executing task.
RUNNING : Provider calls, tool dispatches in progress.

state "COMPLETED" as COMPLETED #80CBC4
COMPLETED : Child agent finished successfully.
COMPLETED : Results aggregated to parent.

state "FAILED" as FAILED #EF9A9A
FAILED : Child agent encountered unrecoverable error.
FAILED : Error reported to parent, child cleaned up.

IDLE --> SPAWNING : TASKSVC-09
SPAWNING --> RUNNING : TASKSVC-09
SPAWNING --> FAILED : TASKSVC-09
RUNNING --> COMPLETED : TASKSVC-10
RUNNING --> FAILED : TASKSVC-14
COMPLETED --> IDLE : TASKSVC-10
FAILED --> IDLE : TASKSVC-14

COMPLETED --> [*] : TASKSVC-10
FAILED --> [*] : TASKSVC-14

@enduml
