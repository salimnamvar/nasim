@startuml sm_sandbox_repo_sandbox
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Sandbox Repository: Execution Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Process lifecycle for Sandbox Repository (sandboxed commands).
'            States: IDLE → EXECUTING → COMPLETED | TIMEOUT | FAILED
' Milestone: v1.0
' Version:   1.0.0
' Source:    C4 component diagram (Sandbox Repository), docs/UC/README.md (SANDBOXREPO-01, SANDBOXREPO-03, SANDBOXREPO-04)
' Review:    CAR audit 2026-06-27
' Convention: All transitions are triggered by the corresponding UC ID
'             as listed in docs/UC/README.md.
' ============================================================

title nasim — Sandbox Repository: Execution Lifecycle

[*] --> IDLE : SANDBOXREPO-01

state "IDLE" as IDLE #78909C
IDLE : No process running in sandbox.
IDLE : Default state.

state "EXECUTING" as EXECUTING #2196F3
EXECUTING : Process running in sandbox.
EXECUTING : SANDBOXREPO-01 ISOLATE Command.

state "MONITORING" as MONITORING #64B5F6
MONITORING : Process being monitored for resource usage.
MONITORING : SANDBOXREPO-03 MONITOR Process.

state "COMPLETED" as COMPLETED #8BC34A
COMPLETED : Process finished successfully.
COMPLETED : SANDBOXREPO-01 ISOLATE Command.

state "TIMEOUT" as TIMEOUT #FFB74D
TIMEOUT : Process exceeded time limit.
TIMEOUT : SANDBOXREPO-03 MONITOR Process.

state "FAILED" as FAILED #D32F2F
FAILED : Process crashed or was killed.
FAILED : SANDBOXREPO-01 ISOLATE Command.

state "RESOURCE_EXCEEDED" as RESOURCE_EXCEEDED #FF5722
RESOURCE_EXCEEDED : Process exceeded CPU, memory, or disk quota.
RESOURCE_EXCEEDED : SANDBOXREPO-04 LIMIT Resources.

IDLE --> EXECUTING : SANDBOXREPO-01
EXECUTING --> MONITORING : SANDBOXREPO-03
MONITORING --> EXECUTING : SANDBOXREPO-03
EXECUTING --> COMPLETED : SANDBOXREPO-01
EXECUTING --> FAILED : SANDBOXREPO-01
EXECUTING --> TIMEOUT : SANDBOXREPO-03
EXECUTING --> RESOURCE_EXCEEDED : SANDBOXREPO-04
MONITORING --> TIMEOUT : SANDBOXREPO-03
MONITORING --> RESOURCE_EXCEEDED : SANDBOXREPO-04
TIMEOUT --> IDLE : SANDBOXREPO-01
FAILED --> IDLE : SANDBOXREPO-01
RESOURCE_EXCEEDED --> IDLE : SANDBOXREPO-04

COMPLETED --> [*] : SANDBOXREPO-01

@enduml
