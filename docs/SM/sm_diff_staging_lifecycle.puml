@startuml sm_diff_staging_lifecycle
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Diff Staging Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Staging lifecycle for EditStrategyRepository (Diff).
'            States: EMPTY → STAGING → STAGED → AWAITING_APPROVAL → APPROVED → APPLYING → APPLIED
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/UC/README.md (EDITSTRATEGY-10, SAFETY-02)
' Review:    CAR audit 2026-06-27
' Convention: All transitions are triggered by the corresponding UC ID
'             as listed in docs/UC/README.md.
' ============================================================

title nasim — Diff Staging Lifecycle

[*] --> EMPTY : EDITSTRATEGY-10

state "EMPTY" as EMPTY #9FA8DA
EMPTY : No diff staged.
EMPTY : Default state.

state "STAGING" as STAGING #FFE082
STAGING : Diff being computed.
STAGING : EDITSTRATEGY-10 STAGE Diff.

state "STAGED" as STAGED #C5E1A5
STAGED : Diff ready for review.
STAGED : EDITSTRATEGY-10 STAGE Diff.

state "AWAITING_APPROVAL" as AWAITING_APPROVAL #FFD54F
AWAITING_APPROVAL : Diff presented to user for approval.
AWAITING_APPROVAL : SAFETY-02 REQUEST Approval.

state "APPROVED" as APPROVED #AED581
APPROVED : User approved diff.
APPROVED : SAFETY-02 REQUEST Approval.

state "APPLYING" as APPLYING #81C784
APPLYING : Approved diff being applied.
APPLYING : EDITSTRATEGY-10 STAGE Diff.

state "APPLIED" as APPLIED #009688
APPLIED : Diff successfully applied.
APPLIED : EDITSTRATEGY-10 STAGE Diff.

state "ERROR" as ERROR #E53935
ERROR : Diff computation or application failed.
ERROR : EDITSTRATEGY-10 STAGE Diff.

EMPTY --> STAGING : EDITSTRATEGY-10
STAGING --> STAGED : EDITSTRATEGY-10
STAGING --> ERROR : EDITSTRATEGY-10
STAGED --> AWAITING_APPROVAL : EDITSTRATEGY-10
AWAITING_APPROVAL --> APPROVED : SAFETY-02
AWAITING_APPROVAL --> EMPTY : SAFETY-02
APPROVED --> APPLYING : EDITSTRATEGY-10
APPLYING --> APPLIED : EDITSTRATEGY-10
APPLYING --> ERROR : EDITSTRATEGY-10
APPLIED --> EMPTY : EDITSTRATEGY-10
ERROR --> EMPTY : EDITSTRATEGY-10

APPLIED --> [*] : EDITSTRATEGY-10

@enduml
