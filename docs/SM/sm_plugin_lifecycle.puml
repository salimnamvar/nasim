@startuml sm_plugin_lifecycle
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Plugin Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Entity lifecycle for Plugin (persisted in config)
' Milestone: v1.0
' Version:   6.0.0
' Source:    docs/UC/README.md
' Review:    docs/audit/audit.2026.06.20.sq-sm-chain.car.md
' ============================================================

title nasim — Plugin Lifecycle

[*] --> DISCOVERED : PLUGINS-01

state "DISCOVERED" as DISCOVERED #E0E0E0
DISCOVERED : Plugin found on filesystem.
DISCOVERED : PLUGINS-01 DISCOVER Plugins.

state "LOADING" as LOADING #FFCC80
LOADING : Plugin manifest being parsed.
LOADING : PLUGINS-02 LOAD Manifest.

state "LOADED" as LOADED #90CAF9
LOADED : Plugin manifest parsed, tools registered.
LOADED : PLUGINS-03 REGISTER Plugin Tools.

state "ENABLED" as ENABLED #4CAF50
ENABLED : Plugin active and available.
ENABLED : PLUGINS-05 ENABLE Plugin.

state "DISABLED" as DISABLED #CE93D8
DISABLED : Plugin deactivated.
DISABLED : PLUGINS-06 DISABLE Plugin.

state "ERROR" as ERROR #EF5350
ERROR : Plugin failed to load or crashed.
ERROR : Load error or runtime exception.

DISCOVERED --> LOADING : PLUGINS-02
DISCOVERED --> ERROR : PLUGINS-01
LOADING --> LOADED : PLUGINS-03
LOADING --> ERROR : PLUGINS-02
LOADED --> ENABLED : PLUGINS-05
LOADED --> DISABLED : PLUGINS-06
ENABLED --> DISABLED : PLUGINS-06
DISABLED --> ENABLED : PLUGINS-05
ENABLED --> ERROR : PLUGINS-01
LOADED --> ERROR : PLUGINS-03

ERROR --> DISCOVERED : PLUGINS-01

ENABLED --> [*] : PLUGINS-06
DISABLED --> [*] : PLUGINS-06

@enduml
