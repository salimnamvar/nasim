@startuml sm_sandbox_execution_lifecycle
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Sandbox Execution Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Process lifecycle for SandboxRepository (sandboxed commands).
'            States: IDLE → EXECUTING → COMPLETED | TIMEOUT | FAILED
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/UC/README.md (SANDBOX-01, SANDBOX-03, SANDBOX-04)
' Review:    CAR audit 2026-06-27
' Convention: All transitions are triggered by the corresponding UC ID
'             as listed in docs/UC/README.md.
' ============================================================

title nasim — Sandbox Execution Lifecycle

[*] --> IDLE : SANDBOX-01

state "IDLE" as IDLE #78909C
IDLE : No process running in sandbox.
IDLE : Default state.

state "EXECUTING" as EXECUTING #2196F3
EXECUTING : Process running in sandbox.
EXECUTING : SANDBOX-01 ISOLATE Command.

state "MONITORING" as MONITORING #64B5F6
MONITORING : Process being monitored for resource usage.
MONITORING : SANDBOX-03 MONITOR Process.

state "COMPLETED" as COMPLETED #8BC34A
COMPLETED : Process finished successfully.
COMPLETED : SANDBOX-01 ISOLATE Command.

state "TIMEOUT" as TIMEOUT #FFB74D
TIMEOUT : Process exceeded time limit.
TIMEOUT : SANDBOX-03 MONITOR Process.

state "FAILED" as FAILED #D32F2F
FAILED : Process crashed or was killed.
FAILED : SANDBOX-01 ISOLATE Command.

state "RESOURCE_EXCEEDED" as RESOURCE_EXCEEDED #FF5722
RESOURCE_EXCEEDED : Process exceeded CPU, memory, or disk quota.
RESOURCE_EXCEEDED : SANDBOX-04 LIMIT Resources.

IDLE --> EXECUTING : SANDBOX-01
EXECUTING --> MONITORING : SANDBOX-03
MONITORING --> EXECUTING : SANDBOX-03
EXECUTING --> COMPLETED : SANDBOX-01
EXECUTING --> FAILED : SANDBOX-01
EXECUTING --> TIMEOUT : SANDBOX-03
EXECUTING --> RESOURCE_EXCEEDED : SANDBOX-04
MONITORING --> TIMEOUT : SANDBOX-03
MONITORING --> RESOURCE_EXCEEDED : SANDBOX-04
TIMEOUT --> IDLE : SANDBOX-01
FAILED --> IDLE : SANDBOX-01
RESOURCE_EXCEEDED --> IDLE : SANDBOX-04

COMPLETED --> [*] : SANDBOX-01

@enduml
