@startuml sm_task_svc_plan
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Task Service: Plan Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Entity lifecycle for Plan (owned by Task Service)
' Milestone: v1.0
' Version:   6.0.0
' Source:    C4 component diagram (Task Service), docs/UC/README.md
' Review:    docs/audit/audit.2026.06.20.sq-sm-chain.car.md
' ============================================================

title nasim — Task Service: Plan Lifecycle

[*] --> EMPTY : TASKSVC-07

state "EMPTY" as EMPTY #F5F5F5
EMPTY : No plan active.
EMPTY : Default state.

state "BUILDING" as BUILDING #FFE0B2
BUILDING : Plan being constructed.
BUILDING : TASKSVC-07 QUEUE Plan.

state "QUEUED" as QUEUED #E3F2FD
QUEUED : Plan queued for approval.
QUEUED : Plan construction complete.

state "APPROVED" as APPROVED #388E3C
APPROVED : Plan approved by user.
APPROVED : TASKSVC-08 APPROVE Plan.

state "EXECUTING" as EXECUTING #A5D6A7
EXECUTING : Plan steps being executed.
EXECUTING : Approved plan, tool calls dispatched.

state "COMPLETED" as COMPLETED #1B5E20
COMPLETED : All plan steps finished.
COMPLETED : Terminal state.

state "REJECTED" as REJECTED #B71C1C
REJECTED : Plan rejected by user.
REJECTED : Terminal state.

EMPTY --> BUILDING : TASKSVC-07
BUILDING --> QUEUED : TASKSVC-07
BUILDING --> EMPTY : TASKSVC-07
QUEUED --> APPROVED : TASKSVC-08
QUEUED --> REJECTED : TASKSVC-08
APPROVED --> EXECUTING : TASKSVC-08
EXECUTING --> COMPLETED : TASKSVC-01
EXECUTING --> EMPTY : TASKSVC-14
COMPLETED --> [*] : TASKSVC-01
REJECTED --> [*] : TASKSVC-08

@enduml
