@startuml sm_router_lifecycle
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Router Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Selection lifecycle for LLM Repository (Router).
'            States: IDLE → CLASSIFYING → SELECTING → IDLE | FALLBACK
' Milestone: v1.0
' Version:   1.0.0
' Source:    C4 component diagram (LLM Repository), docs/UC/README.md (LLMREPOSITORY-01, LLMREPOSITORY-02, LLMREPOSITORY-03, LLMREPOSITORY-04)
' Review:    CAR audit 2026-06-27
' Convention: All transitions are triggered by the corresponding UC ID
'             as listed in docs/UC/README.md.
' ============================================================

title nasim — Router Lifecycle

[*] --> IDLE : LLMREPOSITORY-01

state "IDLE" as IDLE #EEEEEE
IDLE : No routing in progress.
IDLE : Default state.

state "CLASSIFYING" as CLASSIFYING #5C6BC0
CLASSIFYING : Task classification for model routing.
CLASSIFYING : LLMREPOSITORY-03 CLASSIFY Task.

state "SELECTING" as SELECTING #3F51B5
SELECTING : Model selection in progress.
SELECTING : LLMREPOSITORY-01 SELECT Model.

state "SWITCHING" as SWITCHING #FF8F00
SWITCHING : Runtime model switch in progress.
SWITCHING : LLMREPOSITORY-04 SWITCH Model.

state "FALLBACK" as FALLBACK #EF6C00
FALLBACK : Falling back to next available model.
FALLBACK : LLMREPOSITORY-02 APPLY Fallback.

state "ERROR" as ERROR #BF360C
ERROR : Routing or fallback failed.
ERROR : All models exhausted or classification failed.

IDLE --> CLASSIFYING : LLMREPOSITORY-03
CLASSIFYING --> SELECTING : LLMREPOSITORY-01
CLASSIFYING --> ERROR : LLMREPOSITORY-03
SELECTING --> IDLE : LLMREPOSITORY-01
SELECTING --> FALLBACK : LLMREPOSITORY-02
FALLBACK --> SELECTING : LLMREPOSITORY-02
FALLBACK --> ERROR : LLMREPOSITORY-02
IDLE --> SWITCHING : LLMREPOSITORY-04
SWITCHING --> IDLE : LLMREPOSITORY-04
SWITCHING --> ERROR : LLMREPOSITORY-04
ERROR --> IDLE : LLMREPOSITORY-01

IDLE --> [*] : LLMREPOSITORY-01

@enduml
