@startuml sm_task_svc_persona
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Task Service: Persona Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Entity lifecycle for Task Service (Persona roles).
'            States: UNLOADED → LOADING → ACTIVE ↔ SWITCHING
' Milestone: v1.0
' Version:   2.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0), docs/UC/uc_task_svc.puml
' Review:    SM Architect extraction 2026-07-01 (C4+UC source of truth)
' Convention: All transitions are triggered by the corresponding UC ID
'             as listed in docs/UC/README.md.
' ============================================================

title nasim — Task Service: Persona Lifecycle

[*] --> UNLOADED : TASKSVC-12

state "UNLOADED" as UNLOADED #9E9E9E
UNLOADED : No persona loaded.
UNLOADED : Default state.

state "LOADING" as LOADING #FFC107
LOADING : Persona configuration being loaded.
LOADING : TASKSVC-12 LOAD Persona.

state "ACTIVE" as ACTIVE #4DB6AC
ACTIVE : Persona active and available for delegation.
ACTIVE : TASKSVC-11 DELEGATE to Persona.

state "SWITCHING" as SWITCHING #FF9800
SWITCHING : Switching to different persona at runtime.
SWITCHING : TASKSVC-13 SWITCH Persona.

state "ERROR" as ERROR #F44336
ERROR : Persona load or switch failed.
ERROR : Load error or switch failure.

UNLOADED --> LOADING : TASKSVC-12
LOADING --> ACTIVE : TASKSVC-12
LOADING --> ERROR : TASKSVC-12
ACTIVE --> SWITCHING : TASKSVC-13
SWITCHING --> ACTIVE : TASKSVC-13
SWITCHING --> ERROR : TASKSVC-13
ACTIVE --> UNLOADED : TASKSVC-11
ERROR --> UNLOADED : TASKSVC-12

UNLOADED --> [*] : TASKSVC-12

@enduml
