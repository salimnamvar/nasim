@startuml sm_evaluation_lifecycle
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Evaluation Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Process lifecycle for EvaluationService.
'            Orchestrates: checks, LLM review, test suites, scoring, retry.
' Milestone: v1.0
' Version:   1.0.0
' Source:    C4 component diagram (EvaluationService), docs/UC/README.md (EVALUATIONSERVICE-01..EVALUATIONSERVICE-09)
' Review:    CAR audit 2026-06-27
' Convention: All transitions are triggered by the corresponding UC ID
'             as listed in docs/UC/README.md.
' ============================================================

title nasim — Evaluation Lifecycle

[*] --> IDLE : EVALUATIONSERVICE-01

state "IDLE" as IDLE #90A4AE
IDLE : No evaluation in progress.
IDLE : Default state.

state "CHECKING" as CHECKING #C5CAE9
CHECKING : Running task completion and success checks.
CHECKING : EVALUATIONSERVICE-02 CHECK Task Completion, EVALUATIONSERVICE-03 CHECK Success.

state "REVIEWING" as REVIEWING #AB47BC
REVIEWING : LLM-based code review and quality assessment.
REVIEWING : EVALUATIONSERVICE-04 VALIDATE With LLM.

state "TESTING" as TESTING #D4E157
TESTING : Running project test suites.
TESTING : EVALUATIONSERVICE-05 VALIDATE Test Suite.

state "SCORING" as SCORING #FF8A65
SCORING : Recording quality signal and scoring.
SCORING : EVALUATIONSERVICE-07 RECORD Quality Signal.

state "RETRYING" as RETRYING #C62828
RETRYING : Coordinating retry with backoff and escalation.
RETRYING : EVALUATIONSERVICE-06 COORDINATE Retry.

state "PASSED" as PASSED #689F38
PASSED : Evaluation passed all criteria.
PASSED : Terminal success state.

state "FAILED" as FAILED #AD1457
FAILED : Evaluation failed, retries exhausted.
FAILED : Terminal failure state.

IDLE --> CHECKING : EVALUATIONSERVICE-01
CHECKING --> REVIEWING : EVALUATIONSERVICE-04
CHECKING --> TESTING : EVALUATIONSERVICE-05
CHECKING --> SCORING : EVALUATIONSERVICE-07
CHECKING --> FAILED : EVALUATIONSERVICE-02
REVIEWING --> SCORING : EVALUATIONSERVICE-07
REVIEWING --> RETRYING : EVALUATIONSERVICE-06
TESTING --> SCORING : EVALUATIONSERVICE-07
TESTING --> RETRYING : EVALUATIONSERVICE-06
SCORING --> PASSED : EVALUATIONSERVICE-07
SCORING --> RETRYING : EVALUATIONSERVICE-06
RETRYING --> CHECKING : EVALUATIONSERVICE-06
RETRYING --> FAILED : EVALUATIONSERVICE-06

PASSED --> IDLE : EVALUATIONSERVICE-01
FAILED --> IDLE : EVALUATIONSERVICE-01

PASSED --> [*] : EVALUATIONSERVICE-01
FAILED --> [*] : EVALUATIONSERVICE-01

@enduml
