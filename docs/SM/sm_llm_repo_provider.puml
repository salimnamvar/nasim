@startuml sm_llm_repo_provider
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — LLM Repository: Provider Connection Lifecycle State Machine
' Boundary:  NASIM Application — Repository Layer
' Purpose:   Provider registration and backend selection lifecycle.
' Milestone: v1.0
' Version:   2.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0), docs/UC/uc_llm_repo.puml
' Review:    SM Architect extraction 2026-07-01 (C4+UC source of truth)
' Note:      Provider UCs are LLMREPOSITORY-01..04 per uc_llm_repo.puml.
' ============================================================

title nasim — LLM Repository: Provider Connection Lifecycle

[*] --> UNREGISTERED : LLMREPOSITORY-01

state "UNREGISTERED" as UNREGISTERED #455A64
UNREGISTERED : No provider registered.
UNREGISTERED : Default state.

state "REGISTERING" as REGISTERING #29B6F6
REGISTERING : Provider registration in progress.
REGISTERING : LLMREPOSITORY-01 REGISTER Provider.

state "ACTIVE" as ACTIVE #03A9F4
ACTIVE : Provider registered and ready for chat.
ACTIVE : LLMREPOSITORY-02 REQUEST Chat, LLMREPOSITORY-03 STREAM Chat.

state "SELECTING" as SELECTING #FBC02D
SELECTING : Backend selection in progress.
SELECTING : LLMREPOSITORY-04 SELECT Provider Backend.

state "ERROR" as ERROR #E64A19
ERROR : Registration or selection failed.
ERROR : Provider unavailable or invalid.

UNREGISTERED --> REGISTERING : LLMREPOSITORY-01
REGISTERING --> ACTIVE : LLMREPOSITORY-01
REGISTERING --> ERROR : LLMREPOSITORY-01
ACTIVE --> SELECTING : LLMREPOSITORY-04
SELECTING --> ACTIVE : LLMREPOSITORY-04
SELECTING --> ERROR : LLMREPOSITORY-04
ACTIVE --> UNREGISTERED : LLMREPOSITORY-01
ERROR --> UNREGISTERED : LLMREPOSITORY-01

UNREGISTERED --> [*] : LLMREPOSITORY-01

@enduml