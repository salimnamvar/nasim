@startuml sm_eval_svc_evaluation
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Evaluation Service: Evaluation Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Process lifecycle for Evaluation Service.
'            Orchestrates: checks, LLM review, test suites, scoring, retry.
' Milestone: v1.0
' Version:   3.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0), docs/UC/uc_eval_svc.puml
' Review:    SM Architect review 2026-07-01 (C4+UC source of truth)
' Convention: All transitions are triggered by the corresponding UC ID
'             as listed in docs/UC/README.md.
' Note:      PASSED and FAILED are terminal states — only [*] exits.
' ============================================================

title nasim — Evaluation Service: Evaluation Lifecycle

[*] --> IDLE : EVALSVC-01

state "IDLE" as IDLE #90A4AE
IDLE : No evaluation in progress.
IDLE : Default state.

state "CHECKING" as CHECKING #C5CAE9
CHECKING : Running task completion and success checks.
CHECKING : EVALSVC-02 CHECK Task Completion, EVALSVC-03 CHECK Success.

state "REVIEWING" as REVIEWING #AB47BC
REVIEWING : LLM-based code review and quality assessment.
REVIEWING : EVALSVC-04 VALIDATE With LLM.

state "TESTING" as TESTING #D4E157
TESTING : Running project test suites.
TESTING : EVALSVC-05 VALIDATE Test Suite.

state "SCORING" as SCORING #FF8A65
SCORING : Recording quality signal and scoring.
SCORING : EVALSVC-07 RECORD Quality Signal.

state "RETRYING" as RETRYING #C62828
RETRYING : Coordinating retry with backoff and escalation.
RETRYING : EVALSVC-06 COORDINATE Retry.

state "PASSED" as PASSED #689F38
PASSED : Evaluation passed all criteria.
PASSED : Terminal success state.

state "FAILED" as FAILED #AD1457
FAILED : Evaluation failed, retries exhausted.
FAILED : Terminal failure state.

IDLE --> CHECKING : EVALSVC-01
CHECKING --> REVIEWING : EVALSVC-04
CHECKING --> TESTING : EVALSVC-05
CHECKING --> SCORING : EVALSVC-07
CHECKING --> FAILED : EVALSVC-02
REVIEWING --> SCORING : EVALSVC-07
REVIEWING --> RETRYING : EVALSVC-06
TESTING --> SCORING : EVALSVC-07
TESTING --> RETRYING : EVALSVC-06
SCORING --> PASSED : EVALSVC-07
SCORING --> RETRYING : EVALSVC-06
RETRYING --> CHECKING : EVALSVC-06
RETRYING --> FAILED : EVALSVC-06

PASSED --> [*] : EVALSVC-07
FAILED --> [*] : EVALSVC-06

@enduml
