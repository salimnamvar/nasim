@startuml sm_persona_lifecycle
!include common/sm_common_lifecycle.puml
' ============================================================
' Title:     nasim — Persona Lifecycle State Machine
' Boundary:  nasim code agent
' Purpose:   Entity lifecycle for TaskService (Persona roles).
'            States: UNLOADED → LOADING → ACTIVE ↔ SWITCHING
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/UC/README.md (TASKSERVICE-11, TASKSERVICE-12, TASKSERVICE-13)
' Review:    CAR audit 2026-06-27
' Convention: All transitions are triggered by the corresponding UC ID
'             as listed in docs/UC/README.md.
' ============================================================

title nasim — Persona Lifecycle

[*] --> UNLOADED : TASKSERVICE-12

state "UNLOADED" as UNLOADED #9E9E9E
UNLOADED : No persona loaded.
UNLOADED : Default state.

state "LOADING" as LOADING #FFC107
LOADING : Persona configuration being loaded.
LOADING : TASKSERVICE-12 LOAD Persona.

state "ACTIVE" as ACTIVE #4DB6AC
ACTIVE : Persona active and available for delegation.
ACTIVE : TASKSERVICE-11 DELEGATE to Persona.

state "SWITCHING" as SWITCHING #FF9800
SWITCHING : Switching to different persona at runtime.
SWITCHING : TASKSERVICE-13 SWITCH Persona.

state "ERROR" as ERROR #F44336
ERROR : Persona load or switch failed.
ERROR : Load error or switch failure.

UNLOADED --> LOADING : TASKSERVICE-12
LOADING --> ACTIVE : TASKSERVICE-12
LOADING --> ERROR : TASKSERVICE-12
ACTIVE --> SWITCHING : TASKSERVICE-13
SWITCHING --> ACTIVE : TASKSERVICE-13
SWITCHING --> ERROR : TASKSERVICE-13
ACTIVE --> UNLOADED : TASKSERVICE-11
ERROR --> UNLOADED : TASKSERVICE-12

UNLOADED --> [*] : TASKSERVICE-12

@enduml
