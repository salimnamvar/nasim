@startuml uc_api

' ============================================================
' Title:     nasim — UC: API Group (Entry Gate)
' Group:     API (API Entry Gate)
' Boundary:  nasim code agent
' Purpose:   Core business operations exposed via API.
'            Sole entry point for all interface containers
'            (CLI, WebApp, DesktopApp, MobileApp).
'            ROD-compliant REST endpoints (AIP-136/193).
'            Entry chain: User → ServerRouter → downstream groups
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/ENTITIES.md, docs/UC/README.md
' Review:    CAR refinement loop 2026-06-27
' SQ:        sq_srv01..sq_srv11
' ============================================================

left to right direction

title nasim — API Use Cases (Entry Gate)

skinparam actorStyle awesome
skinparam packageStyle rectangle

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}

skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}

skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}

skinparam usecase<<extref>> {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontColor #5D4037
  BorderStyle dashed
}

' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------

actor "User" as User
actor "ServerRouter" as Router <<system>>
actor "AgentOrchestrator" as Agent <<system>>

note top of User
  Scope:          API-01..API-11 — Session CRUD, message dispatch, tool discovery, config management
  Preconditions:  ServerRouter initialized, downstream groups registered
  Contexts:       Called by interface containers (CLI, WebApp); sq_srv01..sq_srv11
  Excludes:       Direct core access (all requests route through API)
  Rollback:       API-06 dispatch is stateless; API-04/05/11 modify state and are reversible
  Design:         ServerRouter maps REST endpoints to downstream group operations; SSE for streaming
  Returns:
    - Success: JSON response or SSE stream
    - Failure: HTTP error with structured error body
end note

' ------------------------------------------------------------
' Cross-Group External References
' ------------------------------------------------------------

usecase "SSN-03\nLIST Sessions\n[uc_ssn]" as SSN03_ext <<extref>>
usecase "SSN-01\nPERSIST Session\n[uc_ssn]" as SSN01_ext <<extref>>
usecase "SSN-02\nREAD Session\n[uc_ssn]" as SSN02_ext <<extref>>
usecase "SSN-09\nDELETE Session\n[uc_ssn]" as SSN09_ext <<extref>>

usecase "AGT-01\nPROCESS User Task\n[uc_agt]" as AGT01_ext <<extref>>

usecase "CFG-01\nLOAD Config\n[uc_cfg]" as CFG01_ext <<extref>>
usecase "CFG-03\nAPPLY Layered Config\n[uc_cfg]" as CFG03_ext <<extref>>

usecase "TL-14\nLIST Registered Tools\n[uc_tl_advanced]" as TL14_ext <<extref>>

' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------

rectangle "nasim" {
  package "API Group (Entry Gate)" {
    usecase "**API-01 LIST Sessions**\n--\nList all sessions with pagination\nGET /v1/sessions" as API01
    usecase "**API-02 CREATE Session**\n--\nCreate a new session\nPOST /v1/sessions" as API02
    usecase "**API-03 GET Session**\n--\nGet session details by ID\nGET /v1/sessions/{id}" as API03
    usecase "**API-04 UPDATE Session**\n--\nUpdate session metadata\nPATCH /v1/sessions/{id}" as API04
    usecase "**API-05 DELETE Session**\n--\nDelete a session\nDELETE /v1/sessions/{id}" as API05
    usecase "**API-06 DISPATCH Message**\n--\nSend message, receive SSE stream\nPOST /v1/sessions/{id}:dispatch" as API06
    usecase "**API-07 LIST Messages**\n--\nList messages in a session\nGET /v1/sessions/{id}/messages" as API07
    usecase "**API-08 LIST Tools**\n--\nList registered tools\nGET /v1/tools" as API08
    usecase "**API-09 GET Tool**\n--\nGet tool definition\nGET /v1/tools/{name}" as API09
    usecase "**API-10 GET Config**\n--\nGet current configuration\nGET /v1/config" as API10
    usecase "**API-11 UPDATE Config**\n--\nUpdate configuration at runtime\nPATCH /v1/config" as API11
  }
}

' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------

User --> API01
User --> API02
User --> API03
User --> API04
User --> API05
User --> API06
User --> API07
User --> API08
User --> API09
User --> API10
User --> API11

Router --> API01 : dispatches
Router --> API02 : dispatches
Router --> API03 : dispatches
Router --> API04 : dispatches
Router --> API05 : dispatches
Router --> API06 : dispatches
Router --> API07 : dispatches
Router --> API08 : dispatches
Router --> API09 : dispatches
Router --> API10 : dispatches
Router --> API11 : dispatches

Agent --> API06 : delegates

' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------

API01 ..> SSN03_ext : <<include>>
API02 ..> SSN01_ext : <<include>>
API03 ..> SSN02_ext : <<include>>
API04 ..> SSN01_ext : <<include>>
API05 ..> SSN09_ext : <<include>>
API06 ..> AGT01_ext : <<include>>
API07 ..> SSN02_ext : <<include>>
API08 ..> TL14_ext : <<include>>
API09 ..> TL14_ext : <<include>>
API10 ..> CFG01_ext : <<include>>
API11 ..> CFG03_ext : <<include>>

note bottom of Agent
  Flow:   User request → ServerRouter routes → downstream group handler
  State:  API-01..API-11 — each returns JSON response or SSE stream
  Success: HTTP 200 with response body
  Failure: HTTP error (4xx/5xx) with structured error body
end note

@enduml
