@startuml uc_eval_svc

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Evaluation Service Group
' C4 ID:     eval_svc
' C4 Name:   Evaluation Service
' Boundary:  NASIM Application — Service Layer
' Purpose:   Task evaluation: success checks, LLM review, retry
'            coordination, repetition detection, turn budget.
'            C4 Rel: task_svc → eval_svc
' Entry:     Adapter → agent_ctrl → task_svc → eval_svc
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' SQ:        sq_evaluationservice01..sq_evaluationservice09
' ============================================================


title nasim — UC: Evaluation Service Group


actor "User" as User


rectangle "nasim" {
  package "Evaluation Service Group" {
    usecase "**EVALSVC-01 EVALUATE Task**\n--\nOrchestrate task evaluation:\nchecks, scores, retries" <<master>> as EV01
    usecase "**EVALSVC-02 CHECK Task Completion**\n--\nEvaluate against success criteria" <<include>> as EV02
    usecase "**EVALSVC-03 CHECK Success**\n--\nRun user-defined success checks" <<include>> as EV03
    usecase "**EVALSVC-04 VALIDATE With LLM**\n--\nLLM-based code review" <<include>> as EV04
    usecase "**EVALSVC-05 VALIDATE Test Suite**\n--\nRun project test suites" <<include>> as EV05
    usecase "**EVALSVC-06 COORDINATE Retry**\n--\nRetry with backoff and escalation" <<include>> as EV06
    usecase "**EVALSVC-07 RECORD Quality Signal**\n--\nProduce accept/reject with feedback" <<include>> as EV07
    usecase "**EVALSVC-08 DETECT Repetition**\n--\nDetect repeated failures or loops" <<include>> as EV08
    usecase "**EVALSVC-09 INJECT Turn Budget**\n--\nInject turn budget limits" <<include>> as EV09
  }
}


User --> EV01

EV01 ..> EV02 : <<include>>
EV01 ..> EV03 : <<include>>
EV01 ..> EV04 : <<include>>
EV01 ..> EV05 : <<include>>
EV01 ..> EV06 : <<include>>
EV01 ..> EV07 : <<include>>
EV01 ..> EV08 : <<include>>
EV01 ..> EV09 : <<include>>


@enduml