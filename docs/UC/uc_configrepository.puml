@startuml uc_config

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: ConfigService Group
' Group:     CONFIGSERVICE (ConfigService)
' Boundary:  NASIM Service
' Purpose:   Config loading, validation, layered overrides
'            (project YAML, env vars, CLI flags, defaults);
'            single source for all configuration access.
'            Entry chain: User → Interface → AgentController → ConfigService
' Milestone: v1.0
' Version:   13.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Review:    —
' SQ:        sq_configservice01..sq_configservice03
' ============================================================


left to right direction


title nasim — Config Use Cases


skinparam actorStyle awesome
skinparam packageStyle rectangle


skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}


skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}


skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User



' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------


rectangle "nasim" {
  package "Config Group (CFG)" {
    usecase "**CONFIGSERVICE-01 LOAD Config**\n--\nLoad global YAML, project YAML, env vars, CLI flags" <<master>> as CFG01
    usecase "**CONFIGSERVICE-02 VALIDATE Config**\n--\nValidate config schema at load time" <<include>> as CFG02
    usecase "**CONFIGSERVICE-03 APPLY Layered Config**\n--\nMerge layered config with precedence rules" <<include>> as CFG03
  }
}


' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------


User --> CFG01



' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------


CFG01 ..> CFG03 : <<include>>
CFG03 ..> CFG02 : <<include>>



@enduml