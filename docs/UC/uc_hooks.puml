@startuml uc_hooks

' ============================================================
' Title:     nasim — UC: Hooks Group
' Group:     HK (Hooks)
' Boundary:  nasim code agent
' Purpose:   Pre/post hooks for tool use and LLM calls
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/ENTITIES.md, docs/UC/README.md
' Review:    CAR refinement loop 2026-06-27
' SQ:        sq_hk01..sq_hk06
' ============================================================

left to right direction

title nasim — Hooks Use Cases

note top of User
  Scope:          HK-01..HK-06 — Register hooks, dispatch pre/post tool/LLM, validate results
  Preconditions:  HookManager initialized
  Contexts:       Called by AGT-02 (DISPATCH Tool Call), PRV-02 (REQUEST Chat); sq_hk01..sq_hk06
  Excludes:       Hook handler implementations (provided by plugins)
  Rollback:       N/A — hooks are fire-and-observe; validation result determines allow/deny
  Design:         HookManager maintains priority-ordered registry; dispatches before/after events
  Returns:
    - Success: HookResult(action=allow|deny|modify, data=...)
    - Failure: HookError logged; default allow unless critical
end note

skinparam actorStyle awesome
skinparam packageStyle rectangle

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}

skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}

skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}

' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------

actor "User" as User
actor "ServerRouter" as Router <<system>>
actor "AgentOrchestrator" as Agent <<system>>

' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------

rectangle "nasim" {
  package "Hooks Group (HK)" {
    usecase "**HK-01 REGISTER Hook**\n--\nRegister hook with name, event type, handler, priority" as HK01
    usecase "**HK-02 DISPATCH Pre-Tool Hook**\n--\nExecute hook before tool use" as HK02
    usecase "**HK-03 DISPATCH Post-Tool Hook**\n--\nExecute hook after tool use" as HK03
    usecase "**HK-04 DISPATCH Pre-LLM Hook**\n--\nExecute hook before LLM call" as HK04
    usecase "**HK-05 DISPATCH Post-LLM Hook**\n--\nExecute hook after LLM call" as HK05
    usecase "**HK-06 VALIDATE Hook Result**\n--\nValidate hook result: allow, deny, modify" as HK06
  }
}

' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------

User --> HK01
User --> HK02
User --> HK03
User --> HK04
User --> HK05
User --> HK06

Router --> HK01 : dispatches
Router --> HK02 : dispatches
Router --> HK03 : dispatches
Router --> HK04 : dispatches
Router --> HK05 : dispatches
Router --> HK06 : dispatches

Agent --> HK01 : calls
Agent --> HK02 : calls
Agent --> HK03 : calls
Agent --> HK04 : calls
Agent --> HK05 : calls
Agent --> HK06 : calls

' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------

HK02 ..> HK06 : <<include>>
HK03 ..> HK06 : <<include>>
HK04 ..> HK06 : <<include>>
HK05 ..> HK06 : <<include>>

note bottom of Agent
  Flow:   User request → ServerRouter dispatches → AgentOrchestrator calls HookManager
  State:  HK-01..HK-06 — each returns registration confirmation or hook verdict
  Success: Hook registered / dispatched / validated
  Failure: HookError logged; default allow policy applied
end note

@enduml
