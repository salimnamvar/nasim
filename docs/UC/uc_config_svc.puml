@startuml uc_config_svc

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Config Service Group
' C4 ID:     config_svc
' C4 Name:   Config Service
' Boundary:  NASIM Application — Service Layer
' Purpose:   Config loading, validation, layered overrides
'            (project YAML, env vars, CLI flags, defaults).
'            C4 Rel: agent_ctrl → config_svc; config_svc → config_repo
' Entry:     Adapter → agent_ctrl → config_svc
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' SQ:        sq_configservice01..sq_configservice03
' ============================================================


title nasim — UC: Config Service Group


actor "User" as User


usecase "CONFIGREPO-01\nREAD YAML\n[uc_config_repo]" as CR01_ext <<extref>>
usecase "CONFIGREPO-02\nREAD Environment\n[uc_config_repo]" as CR02_ext <<extref>>
usecase "CONFIGREPO-03\nWRITE Config\n[uc_config_repo]" as CR03_ext <<extref>>


rectangle "nasim" {
  package "Config Service Group" {
    usecase "**CONFIGSVC-01 LOAD Config**\n--\nLoad YAML, env vars, CLI flags" <<master>> as CS01
    usecase "**CONFIGSVC-02 VALIDATE Config**\n--\nValidate config schema at load time" <<include>> as CS02
    usecase "**CONFIGSVC-03 APPLY Layered Config**\n--\nMerge layered config with\nprecedence rules" <<include>> as CS03
  }
}


User --> CS01

CS01 ..> CR01_ext : <<include>>
CS01 ..> CR02_ext : <<include>>
CS01 ..> CS03 : <<include>>
CS03 ..> CS02 : <<include>>
CS03 ..> CR03_ext : <<include>>


@enduml