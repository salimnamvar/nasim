@startuml uc_mcp_adp

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: MCP Adapter Group
' C4 ID:     mcp_adp
' C4 Name:   MCP Adapter
' Boundary:  NASIM Application — Controller Layer
' Purpose:   MCP protocol: tool exposure, stdio/SSE transport.
'            C4 Rel: MCP Client → mcp_adp → agent_ctrl
' Entry:     MCP Client → mcp_adp → agent_ctrl → Services
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' SQ:        sq_mcp_adapter01..sq_mcp_adapter04
' ============================================================


title nasim — UC: MCP Adapter Group


actor "MCP Client" as MCPClient <<system>>


usecase "AGENTCTRL-01\nPROCESS Request\n[uc_agent_ctrl]" as AC01_ext <<extref>>
usecase "AGENTCTRL-04\nDISPATCH to Services\n[uc_agent_ctrl]" as AC04_ext <<extref>>


rectangle "nasim" {
  package "MCP Adapter Group" {
    usecase "**MCPADP-01 PROCESS MCP Request**\n--\nAccept and parse MCP request.\nDelegate to agent_ctrl." <<master>> as MCP01
    usecase "**MCPADP-02 LIST nasim Tools**\n--\nExpose tools via MCP tools/list" <<master>> as MCP02
    usecase "**MCPADP-03 INVOKE nasim Tool**\n--\nExecute tool via MCP tools/call" <<master>> as MCP03
    usecase "**MCPADP-04 STREAM Events**\n--\nStream agent events via MCP\nnotification (stdio/SSE)" <<include>> as MCP04
  }
}


MCPClient --> MCP01
MCPClient --> MCP02
MCPClient --> MCP03

MCP01 ..> AC01_ext : <<include>>
MCP01 ..> MCP04 : <<include>>
MCP02 ..> AC04_ext : <<include>>
MCP03 ..> AC01_ext : <<include>>
MCP03 ..> AC04_ext : <<include>>


@enduml