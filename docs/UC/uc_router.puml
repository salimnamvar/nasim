@startuml uc_router
' ============================================================
' Title:     nasim — UC: Model Router
' Boundary:  nasim code agent CLI + HTTP API
' Purpose:   Model selection, fallback, and routing strategies
' Milestone: v1.0
' Version:   3.0.0
' Source:    docs/audit/nasim-car-improvement-plan.md IMP-04
' Review:    —
' ============================================================

left to right direction
skinparam packageStyle rectangle

actor "AgentOrchestrator" as agent

rectangle "Model Router" {
    usecase "Select Model" as UC_RTG_01
    usecase "Apply Fallback" as UC_RTG_02
    usecase "Classify Task" as UC_RTG_03
    usecase "Switch Model Mid-Session" as UC_RTG_04
    usecase "CLASSIFY Task Type" as UC_RTG_05
    usecase "MATCH Capabilities" as UC_RTG_06
    usecase "OPTIMIZE Cost" as UC_RTG_07
}

rectangle "Provider Layer" {
    usecase "Select Provider Backend" as UC_PRV_04
}

rectangle "Config Layer" {
    usecase "Load Config" as UC_CFG_01
}

agent --> UC_RTG_01
agent --> UC_RTG_04
agent --> UC_RTG_05
agent --> UC_RTG_06
agent --> UC_RTG_07
UC_RTG_01 ..> UC_RTG_03 : <<include>>
UC_RTG_01 ..> UC_PRV_04 : <<include>>
UC_RTG_02 ..> UC_PRV_04 : <<include>>
UC_RTG_01 ..> UC_CFG_01 : <<include>>
UC_RTG_05 ..> UC_RTG_06 : <<include>>
UC_RTG_06 ..> UC_RTG_07 : <<include>>

@enduml
