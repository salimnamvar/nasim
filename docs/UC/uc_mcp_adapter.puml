@startuml uc_mcp_adapter

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: MCP Adapter Group (Interface Container)
' Group:     MCPADAPTER (MCP Adapter)
' Boundary:  NASIM Service
' Purpose:   MCP protocol: tool exposure, stdio/SSE transport.
'            External MCP clients connect here to discover and
'            invoke nasim tools via the Model Context Protocol.
'            ALL business operations delegate through Agent Controller.
'            Entry chain: MCP Client → MCP Adapter → Agent Controller → Services
' Milestone: v1.0
' Version:   13.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Review:    —
' SQ:        sq_mcp_adapter01..sq_mcp_adapter04
' ============================================================


left to right direction


title nasim — MCP Adapter Use Cases (Interface Container)


skinparam actorStyle awesome
skinparam packageStyle rectangle


skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}


skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}


skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}


skinparam usecase<<extref>> {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontColor #5D4037
  BorderStyle dashed
}


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "MCP Client" as MCPClient <<system>>


' ------------------------------------------------------------
' Cross-Group External References
' ------------------------------------------------------------


usecase "AGENTCONTROLLER-01\nPROCESS Request\n[uc_agent_controller]" as AC01_ext <<extref>>
usecase "AGENTCONTROLLER-04\nDISPATCH to Services\n[uc_agent_controller]" as AC04_ext <<extref>>


' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------


rectangle "nasim" {
  package "MCP Adapter Group (Interface Container)" {
    usecase "**MCPADAPTER-01 PROCESS MCP Request**\n--\nAccept and parse incoming\nMCP protocol request.\nDelegates to Agent Controller." <<master>> as MCP_ADP01
    usecase "**MCPADAPTER-02 LIST nasim Tools**\n--\nExpose available nasim tools\nvia MCP tools/list.\n<<include>> AGENTCONTROLLER-04" <<master>> as MCP_ADP02
    usecase "**MCPADAPTER-03 INVOKE nasim Tool**\n--\nExecute tool via MCP tools/call\nand return result.\n<<include>> AGENTCONTROLLER-01" <<master>> as MCP_ADP03
    usecase "**MCPADAPTER-04 STREAM Events**\n--\nStream agent events via\nMCP notification protocol\n(SSE/stdio)." <<include>> as MCP_ADP04
  }
}


' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------


MCPClient --> MCP_ADP01
MCPClient --> MCP_ADP02
MCPClient --> MCP_ADP03
MCPClient --> MCP_ADP04


' ------------------------------------------------------------
' Relationships (downward <<include>> only)
' ------------------------------------------------------------


MCP_ADP01 ..> AC01_ext : <<include>>
MCP_ADP03 ..> AC04_ext : <<include>>
MCP_ADP01 ..> MCP_ADP04 : <<include>>



@enduml
