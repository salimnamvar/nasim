@startuml uc_agent_controller

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Agent Controller (Convergence Point)
' Group:     AGENTCONTROLLER (Agent Controller)
' Boundary:  NASIM Service
' Purpose:   Single convergence point for all interface
'            containers (CLI, HTTP, MCP). Routes validated
'            requests to services. Protocol-agnostic.
'            Entry chain: User → Interface → Agent Controller → Services
' Milestone: v1.0
' Version:   13.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Review:    —
' SQ:        sq_agentcontroller01..sq_agentcontroller04
' ============================================================


left to right direction


title nasim — Agent Controller Use Cases (Convergence Point)


skinparam actorStyle awesome
skinparam packageStyle rectangle


skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}


skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}


skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}


skinparam usecase<<extref>> {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontColor #5D4037
  BorderStyle dashed
}


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User


' ------------------------------------------------------------
' Cross-Group External References
' ------------------------------------------------------------


usecase "TASKSERVICE-01\nPROCESS User Task\n[uc_agent]" as AGT01_ext <<extref>>
usecase "SESSIONSERVICE-01\nPERSIST Session\n[uc_session]" as SSN01_ext <<extref>>
usecase "SESSIONSERVICE-02\nREAD Session\n[uc_session]" as SSN02_ext <<extref>>
usecase "SESSIONSERVICE-03\nLIST Sessions\n[uc_session]" as SSN03_ext <<extref>>
usecase "SESSIONSERVICE-09\nDELETE Session\n[uc_session]" as SSN09_ext <<extref>>
usecase "CONFIGREPOSITORY-01\nLOAD Config\n[uc_config]" as CFG01_ext <<extref>>
usecase "CONFIGREPOSITORY-03\nAPPLY Layered Config\n[uc_config]" as CFG03_ext <<extref>>
usecase "TOOLSERVICE-14\nLIST Registered Tools\n[uc_tool_advanced]" as TL14_ext <<extref>>


' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------


rectangle "nasim" {
  package "Agent Controller (Convergence Point)" {
    usecase "**AGENTCONTROLLER-01 PROCESS Request**\n--\nRoute incoming request\nfrom any interface to services" <<master>> as AC01
    usecase "**AGENTCONTROLLER-02 VALIDATE Request**\n--\nValidate request format,\npermissions, and protocol" <<include>> as AC02
    usecase "**AGENTCONTROLLER-03 ADAPT Protocol**\n--\nAdapt between interface\nprotocols (CLI, HTTP, MCP)" <<include>> as AC03
    usecase "**AGENTCONTROLLER-04 DISPATCH to Services**\n--\nForward validated request\nto Task Service, Session Service, Config Service" <<include>> as AC04
  }
}


' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------


User --> AC01


' ------------------------------------------------------------
' Relationships (downward <<include>> only)
' ------------------------------------------------------------


AC01 ..> AC02 : <<include>>
AC01 ..> AC03 : <<include>>
AC01 ..> AC04 : <<include>>


AC04 ..> AGT01_ext : <<include>>



@enduml