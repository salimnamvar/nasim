@startuml uc_task_svc

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Task Service Group
' C4 ID:     task_svc
' C4 Name:   Task Service
' Boundary:  NASIM Application — Service Layer
' Purpose:   Agentic loop: LLM call, tool dispatch, context assembly,
'            subagent orchestration, error recovery, persona management.
'            C4 Rel: agent_ctrl → task_svc; task_svc → tool_svc,
'            safety_svc, context_svc, eval_svc, session_repo,
'            llm_repo, wire_log_repo
' Entry:     Adapter → agent_ctrl → task_svc
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' SQ:        sq_taskservice01..sq_taskservice15
' ============================================================


title nasim — UC: Task Service Group


actor "User" as User


usecase "SAFETYSVC-01\nCHECK Permission\n[uc_safety_svc]" as SAF01_ext <<extref>>
usecase "SAFETYSVC-03\nAPPLY Safety Mode\n[uc_safety_svc]" as SAF03_ext <<extref>>
usecase "CONTEXTSVC-01\nPROCESS Context\n[uc_context_svc]" as CTX01_ext <<extref>>
usecase "EVALSVC-01\nEVALUATE Task\n[uc_eval_svc]" as EVL01_ext <<extref>>
usecase "LLMREPO-02\nREQUEST Chat\n[uc_llm_repo]" as LLM02_ext <<extref>>
usecase "LLMREPO-03\nSTREAM Chat\n[uc_llm_repo]" as LLM03_ext <<extref>>
usecase "SESSIONREPO-01\nAPPEND Message\n[uc_session_repo]" as SR01_ext <<extref>>
usecase "WIRELOGREPO-01\nAPPEND Event\n[uc_wire_log_repo]" as WL01_ext <<extref>>


rectangle "nasim" {
  package "Task Service Group" {
    usecase "**TASKSVC-01 PROCESS User Task**\n--\nCore agentic loop: context,\nLLM call, tool dispatch" <<master>> as TS01
    usecase "**TASKSVC-02 DISPATCH Tool Call**\n--\nRoute tool call to tool_svc" <<include>> as TS02
    usecase "**TASKSVC-03 UPDATE Conversation**\n--\nAppend messages, track tokens" <<include>> as TS03
    usecase "**TASKSVC-04 DELETE History**\n--\nReset conversation history" <<include>> as TS04
    usecase "**TASKSVC-07 QUEUE Plan**\n--\nHold queued tool calls\nin plan mode" <<extend>> as TS07
    usecase "**TASKSVC-08 APPROVE Plan**\n--\nDrain queued plan calls" <<extend>> as TS08
    usecase "**TASKSVC-09 SPAWN Subagent**\n--\nCreate child agent with\nrestricted tools" <<extend>> as TS09
    usecase "**TASKSVC-10 COLLECT Subagent Result**\n--\nGather child agent results" <<include>> as TS10
    usecase "**TASKSVC-11 DELEGATE to Persona**\n--\nAssign tasks to persona roles" <<extend>> as TS11
    usecase "**TASKSVC-12 LOAD Persona**\n--\nLoad persona configuration" <<extend>> as TS12
    usecase "**TASKSVC-13 SWITCH Persona**\n--\nSwitch persona at runtime" <<extend>> as TS13
    usecase "**TASKSVC-14 HANDLE Error**\n--\nStructured error handling\nwith recovery" <<extend>> as TS14
    usecase "**TASKSVC-15 DISPATCH Safety Pipeline**\n--\nPermission, injection,\negress checks" <<include>> as TS15
  }
}


User --> TS01
User --> TS09

TS01 ..> TS02 : <<include>>
TS01 ..> TS03 : <<include>>
TS01 ..> TS04 : <<include>>
TS01 ..> TS07 : <<extend>>
TS01 ..> TS08 : <<extend>>
TS01 ..> TS09 : <<extend>>
TS01 ..> TS11 : <<extend>>
TS01 ..> TS12 : <<extend>>
TS01 ..> TS13 : <<extend>>
TS01 ..> TS14 : <<extend>>
TS01 ..> TS15 : <<include>>

TS02 ..> SAF01_ext : <<include>>
TS02 ..> LLM02_ext : <<include>>
TS02 ..> LLM03_ext : <<extend>>
TS03 ..> SR01_ext : <<include>>
TS03 ..> WL01_ext : <<include>>
TS01 ..> CTX01_ext : <<include>>
TS01 ..> EVL01_ext : <<extend>>
TS08 ..> TS02 : <<include>>
TS09 ..> TS10 : <<include>>
TS15 ..> SAF03_ext : <<include>>


@enduml