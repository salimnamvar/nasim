@startuml uc_edit_strategy

' ============================================================
' Title:     nasim — UC: Edit Strategy Group
' Group:     EDT (Edit Strategy)
' Boundary:  nasim code agent
' Purpose:   Polymorphic edit strategies with sandboxed diff staging
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/ENTITIES.md, docs/UC/README.md
' Review:    CAR refinement loop 2026-06-27
' SQ:        sq_edt01..sq_edt10
' ============================================================

left to right direction

title nasim — Edit Strategy Use Cases

note top of User
  Scope:          EDT-01..EDT-10 — Select edit strategy, apply various strategies, stage diff
  Preconditions:  StrategySelector initialized, edit strategies registered
  Contexts:       Called by AGT-01 (PROCESS User Task); sq_edt01..sq_edt10
  Excludes:       File I/O (see TL-02, TL-03)
  Rollback:       EDT-07/10 diff sandbox allows undo; EDT-02..06 applied directly (reversible via VCS-02)
  Design:         StrategySelector picks optimal strategy per model; each strategy implements EditCoder ABC
  Returns:
    - Success: EditResult(changes_applied, diff=...)
    - Failure: EditError with details
end note

skinparam actorStyle awesome
skinparam packageStyle rectangle

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}

skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}

skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}

' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------

actor "User" as User
actor "ServerRouter" as Router <<system>>
actor "AgentOrchestrator" as Agent <<system>>

' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------

rectangle "nasim" {
  package "Edit Strategy Group (EDT)" {
    usecase "**EDT-01 SELECT Strategy**\n--\nSelect optimal edit strategy for model" as EDT01
    usecase "**EDT-02 APPLY Search-Replace**\n--\nSearch-and-replace edit with fuzzy matching" as EDT02
    usecase "**EDT-03 APPLY Whole-File**\n--\nWhole file rewrite strategy" as EDT03
    usecase "**EDT-04 APPLY Unified Diff**\n--\nUnified diff format edit" as EDT04
    usecase "**EDT-05 APPLY Fenced Block**\n--\nFenced code block format edit" as EDT05
    usecase "**EDT-06 APPLY Function-Level**\n--\nAST-targeted function replacement" as EDT06
    usecase "**EDT-07 APPLY Diff Sandbox**\n--\nSandboxed diff with validation" as EDT07
    usecase "**EDT-08 APPLY Architect**\n--\nMulti-file architectural edit" as EDT08
    usecase "**EDT-09 APPLY Inline Patch**\n--\napply-patch format edit" as EDT09
    usecase "**EDT-10 STAGE Diff**\n--\nStage edits for review before apply" as EDT10
  }
}

' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------

User --> EDT01
User --> EDT02
User --> EDT03
User --> EDT04
User --> EDT05
User --> EDT06
User --> EDT07
User --> EDT08
User --> EDT09
User --> EDT10

Router --> EDT01 : dispatches
Router --> EDT02 : dispatches
Router --> EDT03 : dispatches
Router --> EDT04 : dispatches
Router --> EDT05 : dispatches
Router --> EDT06 : dispatches
Router --> EDT07 : dispatches
Router --> EDT08 : dispatches
Router --> EDT09 : dispatches
Router --> EDT10 : dispatches

Agent --> EDT01 : calls
Agent --> EDT02 : calls
Agent --> EDT03 : calls
Agent --> EDT04 : calls
Agent --> EDT05 : calls
Agent --> EDT06 : calls
Agent --> EDT07 : calls
Agent --> EDT08 : calls
Agent --> EDT09 : calls
Agent --> EDT10 : calls

' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------

EDT01 ..> EDT02 : <<include>>
EDT01 ..> EDT03 : <<include>>
EDT01 ..> EDT04 : <<include>>
EDT01 ..> EDT05 : <<include>>
EDT01 ..> EDT06 : <<include>>
EDT01 ..> EDT07 : <<include>>
EDT01 ..> EDT08 : <<include>>
EDT01 ..> EDT09 : <<include>>
EDT07 ..> EDT10 : <<include>>

note bottom of Agent
  Flow:   User request → ServerRouter dispatches → AgentOrchestrator calls StrategySelector
  State:  EDT-01..EDT-10 — each returns edit result or staged diff
  Success: Edit applied or staged for review
  Failure: EditError; strategy selector falls back to next strategy
end note

@enduml
