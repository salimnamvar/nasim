@startuml uc_mcp

' ============================================================
' Title:     nasim — UC: MCP Group
' Group:     MCP (Model Context Protocol)
' Boundary:  nasim code agent
' Purpose:   MCP as first-class subsystem: client/server runtime, tool adapter, discovery
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/ENTITIES.md, docs/UC/README.md
' Review:    CAR refinement loop 2026-06-27
' SQ:        sq_mcp01..sq_mcp04
' ============================================================

left to right direction

title nasim — MCP Use Cases

skinparam actorStyle awesome
skinparam packageStyle rectangle

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}

skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}

skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}

' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------

actor "User" as User
actor "ServerRouter" as Router <<system>>
actor "AgentOrchestrator" as Agent <<system>>
note top of User
  Scope:          MCP-01..MCP-04 — Connect MCP server, discover tools, adapt tools, expose nasim tools
  Preconditions:  MCPClientRuntime initialized
  Contexts:       Called by TL-12 (DISPATCH MCP Extension); sq_mcp01..sq_mcp04
  Excludes:       External MCP server implementations (outside scope)
  Rollback:       MCP-01 connection closes on disconnect; MCP-04 exposure is reversible
  Design:         MCPClientRuntime manages stdio/SSE connections; MCPToolAdapter wraps tools as MCP tools
  Returns:
    - Success: MCPConnection, ToolList, AdaptedTool, ExposureStatus
    - Failure: MCPError
end note

actor "MCP Client" as MCPClient <<system>>

' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------

rectangle "nasim" {
  package "MCP Group (MCP)" {
    usecase "**MCP-01 CONNECT MCP Server**\n--\nConnect to external MCP server via stdio/SSE" as MCP01
    usecase "**MCP-02 DISCOVER MCP Tools**\n--\nDiscover and register tools from MCP servers" as MCP02
    usecase "**MCP-03 ADAPT MCP Tool**\n--\nWrap MCP tools into nasim Tool ABC format" as MCP03
    usecase "**MCP-04 EXPOSE nasim Tools**\n--\nExpose nasim tools to external MCP clients" as MCP04
  }
}

' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------

User --> MCP01
User --> MCP02
User --> MCP03
User --> MCP04

MCPClient --> MCP04 : calls

Router --> MCP01 : dispatches
Router --> MCP02 : dispatches
Router --> MCP03 : dispatches
Router --> MCP04 : dispatches

Agent --> MCP01 : calls
Agent --> MCP02 : calls
Agent --> MCP03 : calls
Agent --> MCP04 : calls

' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------

MCP01 ..> MCP02 : <<include>>
MCP02 ..> MCP03 : <<include>>

note bottom of Agent
  Flow:   User request → ServerRouter dispatches → AgentOrchestrator calls MCP components
  State:  MCP-01..MCP-04 — each returns connection, tools, or exposure status
  Success: MCP server connected, tools discovered/adapted/exposed
  Failure: MCPError; upstream retries or falls back
end note

@enduml
