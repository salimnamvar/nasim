@startuml uc_evaluation

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Evaluation Group
' Group:     EVL (Evaluation)
' Boundary:  nasim code agent
' Purpose:   Task evaluation: success checks, LLM review, retry coordination
'            Entry chain: User → ServerRouter → AgentOrchestrator → EvaluationGroup
' Milestone: v1.0
' Version:   9.1.0
' Source:    .nasim/rules/ENTITIES.md, docs/UC/README.md
' Review:    CAR refinement loop 2026-06-27
' SQ:        sq_evaluation01..sq_evaluation09
' ============================================================


left to right direction


title nasim — Evaluation Use Cases


skinparam actorStyle awesome
skinparam packageStyle rectangle


skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}


skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}


skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User



' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------


rectangle "nasim" {
  package "Evaluation Group (EVL)" {
    usecase "**EVALUATION-01 EVALUATE Task**\n--\nOrchestrate task evaluation:\nchecks, scores, retries" <<master>> as EVL01
    usecase "**EVALUATION-02 CHECK Task Completion**\n--\nEvaluate task completion\nagainst success criteria" <<include>> as EVL02
    usecase "**EVALUATION-03 CHECK Success**\n--\nRun user-defined success checks" <<include>> as EVL03
    usecase "**EVALUATION-04 VALIDATE With LLM**\n--\nLLM-based code review\nand quality assessment" <<include>> as EVL04
    usecase "**EVALUATION-05 VALIDATE Test Suite**\n--\nRun project test suites" <<include>> as EVL05
    usecase "**EVALUATION-06 COORDINATE Retry**\n--\nCoordinate retry with\nbackoff and escalation" <<include>> as EVL06
    usecase "**EVALUATION-07 RECORD Quality Signal**\n--\nProduce accept/reject\nwith feedback" <<include>> as EVL07
    usecase "**EVALUATION-08 DETECT Repetition**\n--\nDetect repeated failures\nor loops" <<include>> as EVL08
    usecase "**EVALUATION-09 INJECT Turn Budget**\n--\nInject turn budget limits\ninto context" <<include>> as EVL09
  }
}


' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------


User --> EVL01


' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------


EVL01 ..> EVL02 : <<include>>
EVL01 ..> EVL03 : <<include>>
EVL01 ..> EVL04 : <<include>>
EVL01 ..> EVL05 : <<include>>
EVL01 ..> EVL06 : <<include>>
EVL01 ..> EVL07 : <<include>>
EVL01 ..> EVL08 : <<include>>
EVL01 ..> EVL09 : <<include>>




@enduml