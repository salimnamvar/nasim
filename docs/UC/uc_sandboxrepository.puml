@startuml uc_sandbox

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Sandbox Group
' Group:     SBX (Sandbox)
' Boundary:  nasim code agent
' Purpose:   OS-level process isolation for shell and edit operations
'            Entry chain: User → ServerRouter → AgentOrchestrator → SandboxGroup
' Milestone: v1.0
' Version:   9.1.0
' Source:    .nasim/rules/ENTITIES.md, docs/UC/README.md
' Review:    CAR refinement loop 2026-06-27
' SQ:        sq_sandbox01..sq_sandbox04
' ============================================================


left to right direction


title nasim — Sandbox Use Cases


skinparam actorStyle awesome
skinparam packageStyle rectangle


skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}


skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}


skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User



' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------


rectangle "nasim" {
  package "Sandbox Group (SBX)" {
    usecase "**SANDBOXREPOSITORY-01 ISOLATE Command**\n--\nExecute command in isolated OS environment" <<master>> as SBX01
    usecase "**SANDBOXREPOSITORY-02 APPLY Sandbox Policy**\n--\nEnforce network, filesystem, exec restrictions" <<include>> as SBX02
    usecase "**SANDBOXREPOSITORY-03 MONITOR Process**\n--\nMonitor process, enforce timeout and resource limits" <<include>> as SBX03
    usecase "**SANDBOXREPOSITORY-04 LIMIT Resources**\n--\nEnforce CPU, memory, and disk quotas" <<include>> as SBX04
  }
}


' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------


User --> SBX01

' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------


SBX01 ..> SBX02 : <<include>>
SBX01 ..> SBX03 : <<include>>
SBX01 ..> SBX04 : <<include>>




@enduml