@startuml uc_safety
' ============================================================
' Title:     nasim — UC: Safety and Permissions
' Boundary:  nasim code agent CLI
' Purpose:   Tool permission checks and user approval prompts
' Milestone: v1.0
' Version:   2.0.0
' Source:    docs/audit/audit_2026-06-20_capability-and-architecture.md
' Review:    —
' ============================================================

left to right direction
skinparam packageStyle rectangle

actor "Developer" as user
actor "AgentOrchestrator" as agent

rectangle "Safety Layer" {
    usecase "CHECK Tool Permission" as UC_SAF_01
    usecase "Prompt User Approval" as UC_SAF_02
    usecase "Apply Safety Mode" as UC_SAF_03
}

rectangle "Config Layer" {
    usecase "Load Config" as UC_CFG_01
}

agent --> UC_SAF_01
UC_SAF_01 ..> UC_SAF_03 : <<include>>
UC_SAF_01 ..> UC_SAF_02 : <<extend>>
UC_SAF_03 ..> UC_CFG_01 : <<include>>
UC_SAF_02 --> user : prompt [y/N]

@enduml
