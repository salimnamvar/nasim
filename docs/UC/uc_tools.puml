@startuml uc_tools

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Tools Group
' Group:     TL (Tool Layer)
' Boundary:  nasim code server
' Purpose:   Tools component — covers both uc_tool_core.puml
'            and uc_tool_advanced.puml. This stub exists for
'            cross-layer naming alignment with
'            c4_nasim_component_tools.
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/C4/c4_nasim_component_tools.puml,
'            docs/UC/uc_tool_core.puml,
'            docs/UC/uc_tool_advanced.puml
