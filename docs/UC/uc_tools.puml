' ============================================================


title Browse nasim — Tools Use Cases (see uc_tool_core / uc_tool_advanced)


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User


' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------


rectangle "nasim" {
  package "Tools Group (TL)" {
    usecase "**TOOL-01 LIST Core Tools**\n--\nFile operations, shell,\nsearch, web tools\nSee uc_tool_core.puml" <<extref>> as TL01
    usecase "**TOOL-02 LIST Advanced Tools**\n--\nGit, MCP, LSP, subagent,\ntodo, memory, plan\nSee uc_tool_advanced.puml" <<extref>> as TL02
  }
}

User --> TL01 : browse
User --> TL02 : browse

@enduml
