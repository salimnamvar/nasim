@startuml uc_context

' ============================================================
' Title:     nasim — UC: Context Graph Group
' Group:     CTX (Context Management)
' Boundary:  nasim code agent
' Purpose:   Context pipeline: graph construction, truncation, distillation, injection, compaction
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/ENTITIES.md, docs/UC/README.md
' Review:    CAR refinement loop 2026-06-27
' SQ:        sq_ctx01..sq_ctx06
' ============================================================

left to right direction

title nasim — Context Graph Use Cases

note top of User
  Scope:          CTX-01..CTX-06 — Process context pipeline: truncate, distill, inject, compact, track budget
  Preconditions:  PipelineOrchestrator initialized, context graph exists
  Contexts:       Called by AGT-01 (PROCESS User Task); sq_ctx01..sq_ctx06
  Excludes:       Memory retrieval (see MEM group) and repo-map injection (see RIM-04)
  Rollback:       N/A — context pipeline is per-turn; previous turn unaffected
  Design:         PipelineOrchestrator runs stages: truncate → distill → inject → compact; budget tracked
  Returns:
    - Success: ContextGraph (pruned, enriched)
    - Failure: ContextError
end note

skinparam actorStyle awesome
skinparam packageStyle rectangle

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}

skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}

skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}

' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------

actor "User" as User
actor "ServerRouter" as Router <<system>>
actor "AgentOrchestrator" as Agent <<system>>

' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------

rectangle "nasim" {
  package "Context Graph Group (CTX)" {
    usecase "**CTX-01 PROCESS Context**\n--\nOrchestrate context pipeline stages" as CTX01
    usecase "**CTX-02 TRUNCATE Nodes**\n--\nTruncate context nodes to fit token budget" as CTX02
    usecase "**CTX-03 DISTILL Nodes**\n--\nSummarize long context nodes via LLM" as CTX03
    usecase "**CTX-04 INJECT Context**\n--\nInject memory and repo-map into graph" as CTX04
    usecase "**CTX-05 COMPACT Nodes**\n--\nMerge redundant context nodes" as CTX05
    usecase "**CTX-06 TRACK Token Budget**\n--\nTrack cumulative token usage" as CTX06
  }
}

' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------

User --> CTX01

Router --> CTX01 : dispatches

Agent --> CTX01 : calls

' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------

CTX01 ..> CTX02 : <<include>>
CTX01 ..> CTX03 : <<include>>
CTX01 ..> CTX04 : <<include>>
CTX01 ..> CTX05 : <<include>>
CTX01 ..> CTX06 : <<include>>

note bottom of Agent
  Flow:   User request → ServerRouter dispatches → AgentOrchestrator calls PipelineOrchestrator
  State:  CTX-01..CTX-06 — pipeline stages return processed context graph
  Success: Context processed and ready for LLM
  Failure: ContextError; pipeline aborts, previous context preserved
end note

@enduml
