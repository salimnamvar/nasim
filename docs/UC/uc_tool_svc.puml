@startuml uc_tool_svc

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Tool Service Group
' C4 ID:     tool_svc
' C4 Name:   Tool Service
' Boundary:  NASIM Application — Service Layer
' Purpose:   Tool registry, parameter validation, execution dispatch;
'            hooks, plugins, and lifecycle hook dispatch.
'            C4 Rel: task_svc → tool_svc; tool_svc → fs_repo,
'            sandbox_repo, edit_strategy_repo, git_repo,
'            mcp_repo, web_repo
' Entry:     Adapter → agent_ctrl → task_svc → tool_svc
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' SQ:        sq_toolservice01..sq_toolservice22, hk01..06, plg01..06
' SIM-01:    Exceeds 15-UC visual limit (34 total). Organized into
'            11 sub-packages, each ≤15 UCs. Exception noted.
' ============================================================


title nasim — UC: Tool Service Group


actor "Task Service" as TaskSvc <<system>>


usecase "FSREPO-01\nREAD File\n[uc_fs_repo]" as FR01_ext <<extref>>
usecase "FSREPO-02\nWRITE File\n[uc_fs_repo]" as FR02_ext <<extref>>
usecase "SANDBOXREPO-01\nISOLATE Command\n[uc_sandbox_repo]" as SB01_ext <<extref>>
usecase "EDITSTRATEGYREPO-01\nSELECT Strategy\n[uc_edit_strategy_repo]" as ES01_ext <<extref>>
usecase "GITREPO-01\nREAD Git Status\n[uc_git_repo]" as GR01_ext <<extref>>
usecase "MCPREPO-03\nADAPT MCP Tool\n[uc_mcp_repo]" as MP03_ext <<extref>>
usecase "WEBREPO-01\nFETCH URL\n[uc_web_repo]" as WR01_ext <<extref>>
usecase "WEBREPO-02\nSEARCH Web\n[uc_web_repo]" as WR02_ext <<extref>>
rectangle "nasim" {
  package "Tool Service Group" {

    package "File Operations" {
      usecase "**TOOLSVC-01 READ File**\n--\nRead file with offset/limit" <<master>> as TL01
      usecase "**TOOLSVC-02 INSERT File**\n--\nCreate or overwrite files" <<master>> as TL02
      usecase "**TOOLSVC-03 UPDATE File**\n--\nReplace exact strings in files" <<master>> as TL03
      usecase "**TOOLSVC-04 LIST Directory**\n--\nList directory contents" <<master>> as TL04
    }

    package "Shell Execution" {
      usecase "**TOOLSVC-05 DISPATCH Shell Command**\n--\nExecute command via sandbox" <<master>> as TL05
    }

    package "Search Tools" {
      usecase "**TOOLSVC-06 SEARCH Grep**\n--\nSearch file contents by regex" <<master>> as TL06
      usecase "**TOOLSVC-07 SEARCH Glob**\n--\nFind files by glob pattern" <<master>> as TL07
      usecase "**TOOLSVC-08 SEARCH Find**\n--\nFind files by name pattern" <<master>> as TL08
    }

    package "Web Tools" {
      usecase "**TOOLSVC-09 FETCH Web Content**\n--\nFetch URL as markdown" <<master>> as TL09
      usecase "**TOOLSVC-10 SEARCH Web**\n--\nSearch the web" <<master>> as TL10
    }

    package "Integration Tools" {
      usecase "**TOOLSVC-11 READ Git Status**\n--\nGit status, diff, commit" <<master>> as TL11
      usecase "**TOOLSVC-12 DISPATCH MCP Extension**\n--\nInvoke MCP extension tools" <<master>> as TL12
      usecase "**TOOLSVC-13 READ LSP**\n--\nLSP hover, definition, references" <<master>> as TL13
      usecase "**TOOLSVC-14 LIST Registered Tools**\n--\nList all registered tools" <<master>> as TL14
    }

    package "Agent Tools" {
      usecase "**TOOLSVC-15 SPAWN Subagent**\n--\nSpawn child agent" <<master>> as TL15
    }

    package "Task Tracking" {
      usecase "**TOOLSVC-16 INSERT Todo**\n--\nCreate task entry" <<master>> as TL16
      usecase "**TOOLSVC-17 UPDATE Todo**\n--\nUpdate task entry" <<master>> as TL17
      usecase "**TOOLSVC-18 READ Todos**\n--\nList task entries" <<master>> as TL18
    }

    package "Memory" {
      usecase "**TOOLSVC-19 PERSIST Memory**\n--\nStore cross-session knowledge" <<master>> as TL19
      usecase "**TOOLSVC-20 RECALL Memory**\n--\nRetrieve cross-session knowledge" <<master>> as TL20
    }

    package "Planning" {
      usecase "**TOOLSVC-21 INSERT Plan**\n--\nCreate plan entry" <<master>> as TL21
      usecase "**TOOLSVC-22 UPDATE Plan**\n--\nUpdate plan entry" <<master>> as TL22
    }

    package "Hooks" {
      usecase "**TOOLSVC-HK01 REGISTER Hook**\n--\nRegister lifecycle hook" <<master>> as HK01
      usecase "**TOOLSVC-HK02 DISPATCH Pre-Tool Hook**\n--\nExecute pre-tool hook" <<master>> as HK02
      usecase "**TOOLSVC-HK03 DISPATCH Post-Tool Hook**\n--\nExecute post-tool hook" <<master>> as HK03
      usecase "**TOOLSVC-HK04 DISPATCH Pre-LLM Hook**\n--\nExecute pre-LLM hook" <<master>> as HK04
      usecase "**TOOLSVC-HK05 DISPATCH Post-LLM Hook**\n--\nExecute post-LLM hook" <<master>> as HK05
      usecase "**TOOLSVC-HK06 VALIDATE Hook Result**\n--\nValidate hook result" <<include>> as HK06
    }

    package "Plugins" {
      usecase "**TOOLSVC-PLG01 DISCOVER Plugins**\n--\nDiscover local plugins" <<master>> as PLG01
      usecase "**TOOLSVC-PLG02 LOAD Manifest**\n--\nParse plugin manifest" <<include>> as PLG02
      usecase "**TOOLSVC-PLG03 REGISTER Plugin Tools**\n--\nRegister plugin tools" <<include>> as PLG03
      usecase "**TOOLSVC-PLG04 REGISTER Plugin Hooks**\n--\nRegister plugin hooks" <<include>> as PLG04
      usecase "**TOOLSVC-PLG05 ENABLE Plugin**\n--\nEnable a plugin" <<master>> as PLG05
      usecase "**TOOLSVC-PLG06 DISABLE Plugin**\n--\nDisable a plugin" <<master>> as PLG06
    }
  }
}


TaskSvc --> TL14

TL01 ..> FR01_ext : <<include>>
TL02 ..> FR02_ext : <<include>>
TL03 ..> ES01_ext : <<include>>
TL03 ..> FR02_ext : <<include>>
TL04 ..> FR01_ext : <<include>>
TL05 ..> SB01_ext : <<include>>
TL06 ..> FR01_ext : <<include>>
TL09 ..> WR01_ext : <<include>>
TL10 ..> WR02_ext : <<include>>
TL11 ..> GR01_ext : <<include>>
TL12 ..> MP03_ext : <<include>>

HK02 ..> HK06 : <<include>>
HK03 ..> HK06 : <<include>>
HK04 ..> HK06 : <<include>>
HK05 ..> HK06 : <<include>>
PLG01 ..> PLG02 : <<include>>
PLG02 ..> PLG03 : <<include>>
PLG02 ..> PLG04 : <<include>>


@enduml