@startuml uc_tool_svc

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Tool Service Group
' Group:     TOOLSERVICE (Tool Service)
' Boundary:  NASIM Service
' Purpose:   Tool registry, parameter validation, execution dispatch;
'            subagent, todo, plan, review tools, dynamic plugin-loaded
'            tools, and lifecycle hook dispatch (PreToolUse, PostToolUse,
'            PreLLMCall, PostLLMCall).
'            Entry chain: User → Interface → Agent Controller → Task Service → Tool Service
' Milestone: v1.0
' Version:   13.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Review:    —
' SQ:        sq_toolservice01..sq_toolservice22
' ============================================================


left to right direction


title nasim — Tool Service Use Cases


skinparam actorStyle awesome
skinparam packageStyle rectangle


skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}


skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}


skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}


skinparam usecase<<extref>> {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontColor #5D4037
  BorderStyle dashed
}


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User



' ------------------------------------------------------------
' Cross-Group External References
' ------------------------------------------------------------


usecase "SAFETYSERVICE-01\nCHECK Permission\n[uc_safety_svc]" as SAF01_ext <<extref>>


' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------


rectangle "nasim" {
  package "Tool Service Group (TL)" {

    package "File Operations" as FILE_PKG {
      usecase "**TOOLSERVICE-01 READ File**\n--\nRead file contents with offset/limit" <<master>> as TL01
      usecase "**TOOLSERVICE-02 INSERT File**\n--\nCreate or overwrite files" <<master>> as TL02
      usecase "**TOOLSERVICE-03 UPDATE File**\n--\nReplace exact strings in files" <<master>> as TL03
      usecase "**TOOLSERVICE-04 LIST Directory**\n--\nList directory contents" <<master>> as TL04
    }

    package "Shell Execution" as SHL_PKG {
      usecase "**TOOLSERVICE-05 DISPATCH Shell Command**\n--\nExecute shell command via sandbox" <<master>> as TL05
    }

    package "Search Tools" as SRCH_PKG {
      usecase "**TOOLSERVICE-06 SEARCH Grep**\n--\nSearch file contents by regex" <<master>> as TL06
      usecase "**TOOLSERVICE-07 SEARCH Glob**\n--\nFind files by glob pattern" <<master>> as TL07
      usecase "**TOOLSERVICE-08 SEARCH Find**\n--\nFind files by name pattern" <<master>> as TL08
    }

    package "Web Tools" as WEB_PKG {
      usecase "**TOOLSERVICE-09 FETCH Web Content**\n--\nFetch URL content as markdown" <<master>> as TL09
      usecase "**TOOLSERVICE-10 SEARCH Web**\n--\nSearch the web for information" <<master>> as TL10
    }

    package "Integration Tools" as INT_PKG {
      usecase "**TOOLSERVICE-11 READ Git Status**\n--\nGit status, diff, commit operations" <<master>> as TL11
      usecase "**TOOLSERVICE-12 DISPATCH MCP Extension**\n--\nInvoke MCP extension tools" <<master>> as TL12
      usecase "**TOOLSERVICE-13 READ LSP**\n--\nLSP ops: hover, definition, references" <<master>> as TL13
      usecase "**TOOLSERVICE-14 LIST Registered Tools**\n--\nList all registered tools" <<master>> as TL14
    }

    package "Agent Tools" as AGT_PKG {
      usecase "**TOOLSERVICE-15 SPAWN Subagent**\n--\nSpawn child agent with restricted tools" <<master>> as TL15
    }

    package "Task Tracking" as TODO_PKG {
      usecase "**TOOLSERVICE-16 INSERT Todo**\n--\nCreate task tracking entry" <<master>> as TL16
      usecase "**TOOLSERVICE-17 UPDATE Todo**\n--\nUpdate task tracking entry" <<master>> as TL17
      usecase "**TOOLSERVICE-18 READ Todos**\n--\nList task tracking entries" <<master>> as TL18
    }

    package "Memory" as MEM_PKG {
      usecase "**TOOLSERVICE-19 PERSIST Memory**\n--\nStore cross-session knowledge" <<master>> as TL19
      usecase "**TOOLSERVICE-20 RECALL Memory**\n--\nRetrieve cross-session knowledge" <<master>> as TL20
    }

    package "Planning" as PLAN_PKG {
      usecase "**TOOLSERVICE-21 INSERT Plan**\n--\nCreate plan entry" <<master>> as TL21
      usecase "**TOOLSERVICE-22 UPDATE Plan**\n--\nUpdate plan entry" <<master>> as TL22
    }

    package "Hooks" as HOOK_PKG {
      usecase "**TOOLSERVICE-HK01 REGISTER Hook**\n--\nRegister hook with name, event type, handler, priority" <<master>> as HK01
      usecase "**TOOLSERVICE-HK02 DISPATCH Pre-Tool Hook**\n--\nExecute hook before tool use" <<master>> as HK02
      usecase "**TOOLSERVICE-HK03 DISPATCH Post-Tool Hook**\n--\nExecute hook after tool use" <<master>> as HK03
      usecase "**TOOLSERVICE-HK04 DISPATCH Pre-LLM Hook**\n--\nExecute hook before LLM call" <<master>> as HK04
      usecase "**TOOLSERVICE-HK05 DISPATCH Post-LLM Hook**\n--\nExecute hook after LLM call" <<master>> as HK05
      usecase "**TOOLSERVICE-HK06 VALIDATE Hook Result**\n--\nValidate hook result: allow, deny, modify" <<include>> as HK06
    }

    package "Plugins" as PLG_PKG {
      usecase "**TOOLSERVICE-PLG01 DISCOVER Plugins**\n--\nDiscover plugins from ~/.nasim/plugins/" <<master>> as PLG01
      usecase "**TOOLSERVICE-PLG02 LOAD Manifest**\n--\nParse plugin manifest metadata" <<include>> as PLG02
      usecase "**TOOLSERVICE-PLG03 REGISTER Plugin Tools**\n--\nRegister plugin tools with ToolRegistry" <<include>> as PLG03
      usecase "**TOOLSERVICE-PLG04 REGISTER Plugin Hooks**\n--\nRegister plugin hooks with HookManager" <<include>> as PLG04
      usecase "**TOOLSERVICE-PLG05 ENABLE Plugin**\n--\nEnable a plugin" <<master>> as PLG05
      usecase "**TOOLSERVICE-PLG06 DISABLE Plugin**\n--\nDisable a plugin" <<master>> as PLG06
    }
  }
}


