@startuml uc_http_adp

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: HTTP Adapter Group
' Group:     HTTPADP (HTTP Adapter)
' C4 ID:     http_adp
' Boundary:  NASIM Application
' Purpose:   Core business operations exposed via HTTP API.
'            Sole entry point for HTTP-based interface containers
'            (WebApp, DesktopApp, MobileApp).
'            ALL requests delegate through Agent Controller.
'            Entry chain: User → HTTP Adapter → Agent Controller → Services
' Milestone: v1.0
' Version:   13.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Review:    —
' SQ:        sq_httpadapter01..sq_httpadapter11
' ============================================================


title nasim — UC: HTTP Adapter Group


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User


' ------------------------------------------------------------
' Cross-Group External References
' ------------------------------------------------------------


usecase "AGENTCTRL-01\nPROCESS Request\n[uc_agent_ctrl]" as AC01_ext <<extref>>
usecase "AGENTCTRL-04\nDISPATCH to Services\n[uc_agent_ctrl]" as AC04_ext <<extref>>

usecase "SESSIONSVC-03\nLIST Sessions\n[uc_session_svc]" as SSN03_ext <<extref>>
usecase "SESSIONSVC-01\nPERSIST Session\n[uc_session_svc]" as SSN01_ext <<extref>>
usecase "SESSIONSVC-02\nREAD Session\n[uc_session_svc]" as SSN02_ext <<extref>>
usecase "SESSIONSVC-09\nDELETE Session\n[uc_session_svc]" as SSN09_ext <<extref>>

usecase "TASKSVC-01\nPROCESS User Task\n[uc_task_svc]" as TASK01_ext <<extref>>

usecase "CONFIGSVC-01\nLOAD Config\n[uc_config_svc]" as CFG01_ext <<extref>>
usecase "CONFIGSVC-03\nAPPLY Layered Config\n[uc_config_svc]" as CFG03_ext <<extref>>

usecase "TOOLSVC-14\nLIST Registered Tools\n[uc_tool_svc]" as TL14_ext <<extref>>


' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------


rectangle "nasim" {
  package "HTTP Adapter Group" {
    usecase "**HTTPADP-01 LIST Sessions**\n--\nList all sessions with pagination\nGET /v1/sessions" <<master>> as HTTP01
    usecase "**HTTPADP-02 CREATE Session**\n--\nCreate a new session\nPOST /v1/sessions" <<master>> as HTTP02
    usecase "**HTTPADP-03 GET Session**\n--\nGet session details by ID\nGET /v1/sessions/{id}" <<master>> as HTTP03
    usecase "**HTTPADP-04 UPDATE Session**\n--\nUpdate session metadata\nPATCH /v1/sessions/{id}" <<master>> as HTTP04
    usecase "**HTTPADP-05 DELETE Session**\n--\nDelete a session\nDELETE /v1/sessions/{id}" <<master>> as HTTP05
    usecase "**HTTPADP-06 DISPATCH Message**\n--\nSend message, receive SSE stream\nPOST /v1/sessions/{id}:dispatch" <<master>> as HTTP06
    usecase "**HTTPADP-07 LIST Messages**\n--\nList messages in a session\nGET /v1/sessions/{id}/messages" <<master>> as HTTP07
    usecase "**HTTPADP-08 LIST Tools**\n--\nList registered tools\nGET /v1/tools" <<master>> as HTTP08
    usecase "**HTTPADP-09 GET Tool**\n--\nGet tool definition\nGET /v1/tools/{name}" <<master>> as HTTP09
    usecase "**HTTPADP-10 GET Config**\n--\nGet current configuration\nGET /v1/config" <<master>> as HTTP10
    usecase "**HTTPADP-11 UPDATE Config**\n--\nUpdate configuration at runtime\nPATCH /v1/config" <<master>> as HTTP11
  }
}


' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------


User --> HTTP01
User --> HTTP02
User --> HTTP03
User --> HTTP04
User --> HTTP05
User --> HTTP06
User --> HTTP07
User --> HTTP08
User --> HTTP09
User --> HTTP10
User --> HTTP11


' ------------------------------------------------------------
' Relationships — all routes through Agent Controller
' ------------------------------------------------------------


HTTP01 ..> AC01_ext : <<include>>
HTTP02 ..> AC01_ext : <<include>>
HTTP03 ..> AC01_ext : <<include>>
HTTP04 ..> AC01_ext : <<include>>
HTTP05 ..> AC01_ext : <<include>>
HTTP06 ..> AC01_ext : <<include>>
HTTP07 ..> AC01_ext : <<include>>
HTTP08 ..> AC01_ext : <<include>>
HTTP09 ..> AC01_ext : <<include>>
HTTP10 ..> AC01_ext : <<include>>
HTTP11 ..> AC01_ext : <<include>>

HTTP01 ..> SSN03_ext : <<include>>
HTTP02 ..> SSN01_ext : <<include>>
HTTP03 ..> SSN02_ext : <<include>>
HTTP04 ..> SSN01_ext : <<include>>
HTTP05 ..> SSN09_ext : <<include>>
HTTP06 ..> TASK01_ext : <<include>>
HTTP07 ..> SSN02_ext : <<include>>
HTTP08 ..> TL14_ext : <<include>>
HTTP09 ..> TL14_ext : <<include>>
HTTP10 ..> CFG01_ext : <<include>>
HTTP11 ..> CFG03_ext : <<include>>


@enduml