@startuml uc_http_adp

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: HTTP Adapter Group
' C4 ID:     http_adp
' C4 Name:   HTTP Adapter
' Boundary:  NASIM Application — Controller Layer
' Purpose:   ASGI routes, middleware, SSE streaming.
'            C4 Rel: WebApp/DesktopApp/MobileApp → http_adp → agent_ctrl
' Entry:     User → HTTP client → http_adp → agent_ctrl → Services
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' SQ:        sq_httpadapter01..sq_httpadapter11
' ============================================================


title nasim — UC: HTTP Adapter Group


actor "User" as User


usecase "AGENTCTRL-01\nPROCESS Request\n[uc_agent_ctrl]" as AC01_ext <<extref>>


rectangle "nasim" {
  package "HTTP Adapter Group" {
    usecase "**HTTPADP-01 LIST Sessions**\n--\nGET /v1/sessions" <<master>> as HTTP01
    usecase "**HTTPADP-02 CREATE Session**\n--\nPOST /v1/sessions" <<master>> as HTTP02
    usecase "**HTTPADP-03 GET Session**\n--\nGET /v1/sessions/{id}" <<master>> as HTTP03
    usecase "**HTTPADP-04 UPDATE Session**\n--\nPATCH /v1/sessions/{id}" <<master>> as HTTP04
    usecase "**HTTPADP-05 DELETE Session**\n--\nDELETE /v1/sessions/{id}" <<master>> as HTTP05
    usecase "**HTTPADP-06 DISPATCH Message**\n--\nPOST /v1/sessions/{id}:dispatch\nSSE stream response" <<master>> as HTTP06
    usecase "**HTTPADP-07 LIST Messages**\n--\nGET /v1/sessions/{id}/messages" <<master>> as HTTP07
    usecase "**HTTPADP-08 LIST Tools**\n--\nGET /v1/tools" <<master>> as HTTP08
    usecase "**HTTPADP-09 GET Tool**\n--\nGET /v1/tools/{name}" <<master>> as HTTP09
    usecase "**HTTPADP-10 GET Config**\n--\nGET /v1/config" <<master>> as HTTP10
    usecase "**HTTPADP-11 UPDATE Config**\n--\nPATCH /v1/config" <<master>> as HTTP11
  }
}


User --> HTTP01
User --> HTTP02
User --> HTTP03
User --> HTTP04
User --> HTTP05
User --> HTTP06
User --> HTTP07
User --> HTTP08
User --> HTTP09
User --> HTTP10
User --> HTTP11

HTTP01 ..> AC01_ext : <<include>>
HTTP02 ..> AC01_ext : <<include>>
HTTP03 ..> AC01_ext : <<include>>
HTTP04 ..> AC01_ext : <<include>>
HTTP05 ..> AC01_ext : <<include>>
HTTP06 ..> AC01_ext : <<include>>
HTTP07 ..> AC01_ext : <<include>>
HTTP08 ..> AC01_ext : <<include>>
HTTP09 ..> AC01_ext : <<include>>
HTTP10 ..> AC01_ext : <<include>>
HTTP11 ..> AC01_ext : <<include>>


@enduml