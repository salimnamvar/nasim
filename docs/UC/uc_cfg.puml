@startuml uc_cfg

' ============================================================
' Title:     nasim — UC: Config Group
' Group:     CFG (Configuration)
' Boundary:  nasim code agent
' Purpose:   Config loading, validation, and layered overrides
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/ENTITIES.md, docs/UC/README.md
' Review:    CAR refinement loop 2026-06-27
' SQ:        sq_cfg01..sq_cfg03
' ============================================================

left to right direction

title nasim — Config Use Cases

skinparam actorStyle awesome
skinparam packageStyle rectangle

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}

skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}

skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}

' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------

actor "User" as User
actor "ServerRouter" as Router <<system>>
actor "AgentOrchestrator" as Agent <<system>>

note top of User
  Scope:          CFG-01..CFG-03 — Load, validate, and merge layered config
  Preconditions:  ConfigLoader initialized, config sources available
  Contexts:       Called by API-10, API-11; sq_cfg01..sq_cfg03
  Excludes:       Provider registration (see PRV-01)
  Rollback:       N/A — config applied atomically at load time
  Design:         Loads global YAML, project YAML, env vars, CLI flags with precedence
  Returns:
    - Success: Config object
    - Failure: ConfigError with details
end note

' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------

rectangle "nasim" {
  package "Config Group (CFG)" {
    usecase "**CFG-01 LOAD Config**\n--\nLoad global YAML, project YAML, env vars, CLI flags" as CFG01
    usecase "**CFG-02 VALIDATE Config**\n--\nValidate config schema at load time" as CFG02
    usecase "**CFG-03 APPLY Layered Config**\n--\nMerge layered config with precedence rules" as CFG03
  }
}

' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------

User --> CFG01
User --> CFG02
User --> CFG03

Router --> CFG01 : dispatches
Router --> CFG02 : dispatches
Router --> CFG03 : dispatches

Agent --> CFG01 : calls
Agent --> CFG02 : calls
Agent --> CFG03 : calls

' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------

CFG01 ..> CFG03 : <<include>>
CFG03 ..> CFG02 : <<include>>

note bottom of Agent
  Flow:   User request → ServerRouter dispatches → AgentOrchestrator calls ConfigLoader
  State:  CFG-01..CFG-03 — each returns loaded/validated/merged config
  Success: Config loaded, validated, and applied
  Failure: ConfigError with source location details
end note

@enduml
