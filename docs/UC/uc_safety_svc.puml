@startuml uc_safety_svc

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Safety Service Group
' C4 ID:     safety_svc
' C4 Name:   Safety Service
' Boundary:  NASIM Application — Service Layer
' Purpose:   Permission gating, injection scanning, egress inspection.
'            C4 Rel: task_svc → safety_svc
' Entry:     Adapter → agent_ctrl → task_svc → safety_svc
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' SQ:        sq_safetyservice01..sq_safetyservice03
' ============================================================


title nasim — UC: Safety Service Group


actor "Task Service" as TaskSvc <<system>>


rectangle "nasim" {
  package "Safety Service Group" {
    usecase "**SAFETYSVC-01 CHECK Permission**\n--\nCheck permission against\nsafety rules" <<include>> as SF01
    usecase "**SAFETYSVC-02 REQUEST Approval**\n--\nPrompt user for approval" <<master>> as SF02
    usecase "**SAFETYSVC-03 APPLY Safety Mode**\n--\nApply safety mode configuration" <<include>> as SF03
  }
}


TaskSvc --> SF02

SF02 ..> SF01 : <<include>>
SF03 ..> SF01 : <<include>>


@enduml