@startuml uc_agent
' ============================================================
' Title:     nasim — UC: Agent Core
' Boundary:  nasim code agent CLI + HTTP API
' Purpose:   Core agentic loop, permissions, context, plans, hooks
' Milestone: v1.0
' Version:   3.0.0
' Source:    docs/audit/nasim-car-improvement-plan.md
' Review:    —
' ============================================================

left to right direction
skinparam packageStyle rectangle

actor "Developer" as user
actor "HTTP Client" as client

rectangle "Agent Core" {
    usecase "PROCESS User Task" as UC_AGT_01
    usecase "DISPATCH Tool Call" as UC_AGT_02
    usecase "Manage Conversation" as UC_AGT_03
    usecase "Reset History" as UC_AGT_04
    usecase "CHECK Tool Permission" as UC_AGT_05
    usecase "COMPACT Context" as UC_AGT_06
    usecase "Queue Plan" as UC_AGT_07
    usecase "APPROVE Plan" as UC_AGT_08
    usecase "EVALUATE Task" as UC_AGT_09
    usecase "INJECT Turn Budget" as UC_AGT_10
    usecase "Execute Pre-Tool Hook" as UC_HK_02
    usecase "Execute Post-Tool Hook" as UC_HK_03
}

rectangle "Provider Layer" {
    usecase "Select Model" as UC_RTG_01
}

user --> UC_AGT_01
client --> UC_AGT_01
UC_AGT_01 ..> UC_AGT_02 : <<include>>
UC_AGT_01 ..> UC_AGT_03 : <<include>>
UC_AGT_02 ..> UC_AGT_05 : <<include>>
UC_AGT_02 ..> UC_HK_02 : <<include>>
UC_AGT_02 ..> UC_HK_03 : <<include>>
UC_AGT_01 ..> UC_AGT_06 : <<extend>>
UC_AGT_07 ..> UC_AGT_08 : <<extend>>
UC_AGT_01 ..> UC_RTG_01 : <<include>>
UC_AGT_01 ..> UC_AGT_09 : <<extend>>
UC_AGT_01 ..> UC_AGT_10 : <<include>>

@enduml
