@startuml uc_cli_adp

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: CLI Adapter Group
' C4 ID:     cli_adp
' C4 Name:   CLI Adapter
' Boundary:  NASIM Application — Controller Layer
' Purpose:   Terminal REPL session, arg parsing, slash commands.
'            C4 Rel: CLI → cli_adp → agent_ctrl
' Entry:     User → CLI (container) → cli_adp → agent_ctrl → Services
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' SQ:        sq_cli01..sq_cli08
' ============================================================


title nasim — UC: CLI Adapter Group


actor "User" as User


usecase "AGENTCTRL-01\nPROCESS Request\n[uc_agent_ctrl]" as AC01_ext <<extref>>


rectangle "nasim" {
  package "CLI Adapter Group" {
    usecase "**CLIADP-01 PROCESS User Input**\n--\nREPL loop and input handling.\nAll business ops via agent_ctrl." <<master>> as CLI01
    usecase "**CLIADP-02 DISPATCH Slash Command**\n--\nMap /cmd to agent_ctrl dispatch.\n/sessions, /plan, /model, etc." <<master>> as CLI02
    usecase "**CLIADP-03 STREAM Output**\n--\nRender AgentEvents from SSE\nto terminal" <<include>> as CLI03
    usecase "**CLIADP-04 READ CLI Arguments**\n--\nParse startup CLI arguments" <<master>> as CLI04
    usecase "**CLIADP-05 ENABLE Plan Mode**\n--\n/plan command via agent_ctrl" <<master>> as CLI05
    usecase "**CLIADP-06 REQUEST Approval**\n--\nSafety approval prompt\nvia agent_ctrl" <<master>> as CLI06
    usecase "**CLIADP-07 SWITCH Model**\n--\n/model command via agent_ctrl" <<master>> as CLI07
    usecase "**CLIADP-08 LIST Sessions**\n--\n/sessions command via agent_ctrl" <<master>> as CLI08
  }
}


User --> CLI01
User --> CLI02
User --> CLI04
User --> CLI05
User --> CLI06
User --> CLI07
User --> CLI08

CLI01 ..> CLI03 : <<include>>
CLI01 ..> AC01_ext : <<include>>
CLI02 ..> AC01_ext : <<include>>
CLI04 ..> AC01_ext : <<include>>
CLI05 ..> AC01_ext : <<include>>
CLI06 ..> AC01_ext : <<include>>
CLI07 ..> AC01_ext : <<include>>
CLI08 ..> AC01_ext : <<include>>


@enduml