@startuml uc_context_graph

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Context Service Group
' Group:     CONTEXTSERVICE (Context Service)
' Boundary:  NASIM Service
' Purpose:   Context pipeline: graph construction, truncation, distillation,
'            injection, and compaction.
'            Entry chain: User → Interface → Agent Controller → Task Service → Context Service
' Milestone: v1.0
' Version:   13.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Review:    —
' SQ:        sq_contextservice01..sq_contextservice06
' ============================================================


left to right direction


title nasim — Context Service Use Cases


skinparam actorStyle awesome
skinparam packageStyle rectangle


skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}


skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}


skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User



' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------


rectangle "nasim" {
  package "Context Service Group (CTX)" {
    usecase "**CONTEXTSERVICE-01 PROCESS Context**\n--\nOrchestrate context pipeline stages" <<master>> as CTX01
    usecase "**CONTEXTSERVICE-02 TRUNCATE Nodes**\n--\nTruncate context nodes to fit token budget" <<include>> as CTX02
    usecase "**CONTEXTSERVICE-03 DISTILL Nodes**\n--\nSummarize long context nodes via LLM" <<include>> as CTX03
    usecase "**CONTEXTSERVICE-04 INJECT Context**\n--\nInject memory and repo-map into graph" <<include>> as CTX04
    usecase "**CONTEXTSERVICE-05 COMPACT Nodes**\n--\nMerge redundant context nodes" <<include>> as CTX05
    usecase "**CONTEXTSERVICE-06 TRACK Token Budget**\n--\nTrack cumulative token usage" <<include>> as CTX06
  }
}


' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------


User --> CTX01




' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------


CTX01 ..> CTX02 : <<include>>
CTX01 ..> CTX03 : <<include>>
CTX01 ..> CTX04 : <<include>>
CTX01 ..> CTX05 : <<include>>
CTX01 ..> CTX06 : <<include>>



@enduml