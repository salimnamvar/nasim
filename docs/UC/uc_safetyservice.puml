@startuml uc_safety

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Safety Service Group
' Group:     SAFETYSERVICE (Safety Service)
' Boundary:  NASIM Service
' Purpose:   Permission gating, injection scanning, egress inspection.
'            Entry chain: User → Interface → Agent Controller → Task Service → Safety Service
' Milestone: v1.0
' Version:   13.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Review:    —
' SQ:        sq_safetyservice01..sq_safetyservice03
' ============================================================


left to right direction


title nasim — Safety Use Cases


skinparam actorStyle awesome
skinparam packageStyle rectangle


skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}


skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}


skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}


' ============================================================
' Actors
' ============================================================


actor "User" as User



' ============================================================
' System Boundary
' ============================================================


rectangle "nasim" {
  package "Safety Group (SAF)" {
    usecase "**SAFETYSERVICE-01 CHECK Permission**\n--\nCheck permission against safety rules" <<include>> as SAF01
    usecase "**SAFETYSERVICE-02 REQUEST Approval**\n--\nPrompt user for approval" <<master>> as SAF02
    usecase "**SAFETYSERVICE-03 APPLY Safety Mode**\n--\nApply safety mode configuration" <<master>> as SAF03
  }
}


' ============================================================
' Actor -> Use Case Associations
' ============================================================


User --> SAF02
User --> SAF03



' ============================================================
' Relationships
' ============================================================


SAF02 ..> SAF01 : <<include>>



@enduml