@startuml uc_context_svc

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Context Service Group
' C4 ID:     context_svc
' C4 Name:   Context Service
' Boundary:  NASIM Application — Service Layer
' Purpose:   Context pipeline: graph construction, truncation,
'            distillation, injection, and compaction.
'            C4 Rel: task_svc → context_svc; context_svc →
'            memory_repo, repo_intel_repo
' Entry:     Adapter → agent_ctrl → task_svc → context_svc
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' SQ:        sq_contextservice01..sq_contextservice06
' ============================================================


title nasim — UC: Context Service Group


actor "User" as User


usecase "MEMORYREPO-02\nRECALL Knowledge\n[uc_memory_repo]" as MR02_ext <<extref>>
usecase "REPOINTELREPO-04\nINJECT RepoMap\n[uc_repo_intel_repo]" as RI04_ext <<extref>>


rectangle "nasim" {
  package "Context Service Group" {
    usecase "**CONTEXTSVC-01 PROCESS Context**\n--\nOrchestrate context pipeline stages" <<master>> as CX01
    usecase "**CONTEXTSVC-02 TRUNCATE Nodes**\n--\nTruncate nodes to fit\ntoken budget" <<include>> as CX02
    usecase "**CONTEXTSVC-03 DISTILL Nodes**\n--\nSummarize long nodes via LLM" <<include>> as CX03
    usecase "**CONTEXTSVC-04 INJECT Context**\n--\nInject memory and repo-map" <<include>> as CX04
    usecase "**CONTEXTSVC-05 COMPACT Nodes**\n--\nMerge redundant context nodes" <<include>> as CX05
    usecase "**CONTEXTSVC-06 TRACK Token Budget**\n--\nTrack cumulative token usage" <<include>> as CX06
  }
}


User --> CX01

CX01 ..> CX02 : <<include>>
CX01 ..> CX03 : <<include>>
CX01 ..> CX04 : <<include>>
CX01 ..> CX05 : <<include>>
CX01 ..> CX06 : <<include>>
CX04 ..> MR02_ext : <<include>>
CX04 ..> RI04_ext : <<include>>


@enduml