@startuml uc_overview

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC Group Overview
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Purpose:   Navigation map — CSR delegation chain only.
'            No individual UC IDs shown.
' ============================================================


title nasim — UC Group Overview (C4 v13.0.0)


actor "User" as User
actor "MCP Client" as MCPClient <<system>>


rectangle "nasim" {

  ' Controller Layer
  usecase "**CLI Adapter**\n[cli_adp]" <<master>> as CLI_ADP
  usecase "**HTTP Adapter**\n[http_adp]" <<master>> as HTTP_ADP
  usecase "**MCP Adapter**\n[mcp_adp]" <<master>> as MCP_ADP
  usecase "**Agent Controller**\n[agent_ctrl]" <<master>> as AGENT_CTRL

  ' Service Layer
  usecase "**Task Service**\n[task_svc]" <<master>> as TASK_SVC
  usecase "**Session Service**\n[session_svc]" <<master>> as SESSION_SVC
  usecase "**Config Service**\n[config_svc]" <<master>> as CONFIG_SVC
  usecase "**Tool Service**\n[tool_svc]" <<master>> as TOOL_SVC
  usecase "**Safety Service**\n[safety_svc]" <<master>> as SAFETY_SVC
  usecase "**Context Service**\n[context_svc]" <<master>> as CONTEXT_SVC
  usecase "**Evaluation Service**\n[eval_svc]" <<master>> as EVAL_SVC

  ' Repository Layer
  usecase "**Session Repository**\n[session_repo]" <<master>> as SESSION_REPO
  usecase "**History Repository**\n[history_repo]" <<master>> as HISTORY_REPO
  usecase "**Config Repository**\n[config_repo]" <<master>> as CONFIG_REPO
  usecase "**LLM Repository**\n[llm_repo]" <<master>> as LLM_REPO
  usecase "**Filesystem Repository**\n[fs_repo]" <<master>> as FS_REPO
  usecase "**Sandbox Repository**\n[sandbox_repo]" <<master>> as SANDBOX_REPO
  usecase "**Edit Strategy Repository**\n[edit_strategy_repo]" <<master>> as EDIT_REPO
  usecase "**Git Repository**\n[git_repo]" <<master>> as GIT_REPO
  usecase "**MCP Repository**\n[mcp_repo]" <<master>> as MCP_REPO
  usecase "**Memory Repository**\n[memory_repo]" <<master>> as MEMORY_REPO
  usecase "**Repo Intelligence Repository**\n[repo_intel_repo]" <<master>> as REPO_INTEL
  usecase "**Web Repository**\n[web_repo]" <<master>> as WEB_REPO
  usecase "**Wire Log Repository**\n[wire_log_repo]" <<master>> as WIRE_LOG
}


' External clients → adapters (C4 Container_Ext → Component)
User --> CLI_ADP
User --> HTTP_ADP
MCPClient --> MCP_ADP

' Adapters → convergence point
CLI_ADP ..> AGENT_CTRL : <<include>>
HTTP_ADP ..> AGENT_CTRL : <<include>>
MCP_ADP ..> AGENT_CTRL : <<include>>

' Controller → services (C4 Rel)
AGENT_CTRL ..> TASK_SVC : <<include>>
AGENT_CTRL ..> SESSION_SVC : <<include>>
AGENT_CTRL ..> CONFIG_SVC : <<include>>

' Service orchestration (C4 Rel)
TASK_SVC ..> TOOL_SVC : <<include>>
TASK_SVC ..> SAFETY_SVC : <<include>>
TASK_SVC ..> CONTEXT_SVC : <<include>>
TASK_SVC ..> EVAL_SVC : <<extend>>

' Service → repository (C4 Rel)
TASK_SVC ..> SESSION_REPO : <<include>>
TASK_SVC ..> LLM_REPO : <<include>>
TASK_SVC ..> WIRE_LOG : <<include>>
SESSION_SVC ..> SESSION_REPO : <<include>>
SESSION_SVC ..> HISTORY_REPO : <<include>>
SESSION_SVC ..> WIRE_LOG : <<include>>
CONFIG_SVC ..> CONFIG_REPO : <<include>>
TOOL_SVC ..> FS_REPO : <<include>>
TOOL_SVC ..> SANDBOX_REPO : <<include>>
TOOL_SVC ..> EDIT_REPO : <<include>>
TOOL_SVC ..> GIT_REPO : <<include>>
TOOL_SVC ..> MCP_REPO : <<include>>
TOOL_SVC ..> WEB_REPO : <<include>>
CONTEXT_SVC ..> MEMORY_REPO : <<include>>
CONTEXT_SVC ..> REPO_INTEL : <<include>>

' Repository → repository (C4 Rel)
EDIT_REPO ..> SANDBOX_REPO : <<include>>
EDIT_REPO ..> FS_REPO : <<include>>


@enduml