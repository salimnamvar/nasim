@startuml uc_overview

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC Overview (Architecture Navigation Map)
' Group:     ALL (All Groups)
' Boundary:  NASIM Application
' Purpose:   High-level group overview showing all UC groups
'            and their actor interactions. Agent Controller
'            (agent_ctrl) is the central convergence point.
'            This is a NAVIGATION MAP — no individual UC IDs shown.
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Milestone: v1.0
' Version:   13.0.0
' Review:    —
' ============================================================


title nasim — UC Group Overview (Architecture Navigation)


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User


actor "MCP Client" as MCPClient <<system>>



' ------------------------------------------------------------
' System Boundary — UC Groups (C4 component ID traceability)
' ------------------------------------------------------------


rectangle "nasim" {

  usecase "**Agent Controller Group**\n[agent_ctrl]" <<master>> as AC_GROUP
  usecase "**HTTP Adapter Group**\n[http_adp]" <<master>> as HTTP_GROUP
  usecase "**CLI Adapter Group**\n[cli_adp]" <<master>> as CLI_GROUP
  usecase "**MCP Adapter Group**\n[mcp_adp]" <<master>> as MCP_ADP_GROUP

  usecase "**Task Service Group**\n[task_svc]" <<master>> as TASK_GROUP
  usecase "**Session Service Group**\n[session_svc]" <<master>> as SESSION_GROUP
  usecase "**Config Service Group**\n[config_svc]" <<master>> as CONFIG_GROUP
  usecase "**Tool Service Group**\n[tool_svc]" <<master>> as TOOL_GROUP

  usecase "**LLM Repository Group**\n[llm_repo]" <<master>> as LLM_GROUP
  usecase "**Context Service Group**\n[context_svc]" <<master>> as CTX_GROUP
  usecase "**Safety Service Group**\n[safety_svc]" <<master>> as SAFETY_GROUP
  usecase "**Sandbox Repository Group**\n[sandbox_repo]" <<master>> as SANDBOX_GROUP
  usecase "**Edit Strategy Repository Group**\n[edit_strategy_repo]" <<master>> as EDIT_GROUP
  usecase "**Evaluation Service Group**\n[eval_svc]" <<master>> as EVAL_GROUP
  usecase "**Git Repository Group**\n[git_repo]" <<master>> as GIT_GROUP
  usecase "**MCP Repository Group**\n[mcp_repo]" <<master>> as MCP_GROUP
  usecase "**Memory Repository Group**\n[memory_repo]" <<master>> as MEMORY_GROUP
  usecase "**Repo Intelligence Repository Group**\n[repo_intel_repo]" <<master>> as REPO_INTEL_GROUP
  usecase "**Wire Log Repository Group**\n[wire_log_repo]" <<master>> as WIRE_LOG_GROUP
  usecase "**Session Repository Group**\n[session_repo]" <<master>> as SESSION_REPO_GROUP
  usecase "**History Repository Group**\n[history_repo]" <<master>> as HISTORY_REPO_GROUP
  usecase "**Config Repository Group**\n[config_repo]" <<master>> as CONFIG_REPO_GROUP
  usecase "**Filesystem Repository Group**\n[fs_repo]" <<master>> as FS_REPO_GROUP
  usecase "**Web Repository Group**\n[web_repo]" <<master>> as WEB_REPO_GROUP
}


' ------------------------------------------------------------
' Actor -> Group Associations
' ------------------------------------------------------------


User --> AC_GROUP
User --> HTTP_GROUP
User --> CLI_GROUP

MCPClient --> MCP_ADP_GROUP



' ------------------------------------------------------------
' Group Relationships — Convergence Point Delegation Chain
' ------------------------------------------------------------

' All interface adapters route through Agent Controller
CLI_GROUP ..> AC_GROUP : <<include>>
HTTP_GROUP ..> AC_GROUP : <<include>>
MCP_ADP_GROUP ..> AC_GROUP : <<include>>

' Agent Controller -> downstream core groups (mandatory)
AC_GROUP ..> TASK_GROUP : <<include>>
AC_GROUP ..> SESSION_GROUP : <<include>>
AC_GROUP ..> CONFIG_GROUP : <<include>>
AC_GROUP ..> TOOL_GROUP : <<include>>

' Task Service -> execution groups (mandatory includes)
TASK_GROUP ..> LLM_GROUP : <<include>>
TASK_GROUP ..> CTX_GROUP : <<include>>
TASK_GROUP ..> SAFETY_GROUP : <<include>>
TASK_GROUP ..> SANDBOX_GROUP : <<include>>

' Service -> repository groups (data access)
SESSION_GROUP ..> SESSION_REPO_GROUP : <<include>>
SESSION_GROUP ..> HISTORY_REPO_GROUP : <<include>>
CONFIG_GROUP ..> CONFIG_REPO_GROUP : <<include>>
TOOL_GROUP ..> FS_REPO_GROUP : <<include>>
TOOL_GROUP ..> WEB_REPO_GROUP : <<include>>

' Task Service -> specialized/cross-cutting groups (optional extends)
TASK_GROUP ..> EDIT_GROUP : <<extend>>
TASK_GROUP ..> EVAL_GROUP : <<extend>>
TASK_GROUP ..> GIT_GROUP : <<extend>>
TASK_GROUP ..> MCP_GROUP : <<extend>>
TASK_GROUP ..> MEMORY_GROUP : <<extend>>
TASK_GROUP ..> REPO_INTEL_GROUP : <<extend>>
TASK_GROUP ..> WIRE_LOG_GROUP : <<extend>>
TASK_GROUP ..> SESSION_REPO_GROUP : <<include>>
EDIT_GROUP ..> FS_REPO_GROUP : <<include>>
EDIT_GROUP ..> SANDBOX_GROUP : <<include>>


@enduml