@startuml uc_overview

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC Overview (Architecture Navigation Map)
' Group:     ALL (All Groups)
' Boundary:  NASIM Service
' Purpose:   High-level group overview showing all UC groups
'            and their actor interactions. Agent Controller
'            (Convergence Point) is the central entry gate.
'            This is a NAVIGATION MAP — no individual UC IDs shown.
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Milestone: v1.0
' Version:   13.0.0
' Review:    —
' ============================================================


title nasim — UC Group Overview (Architecture Navigation)


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User


actor "MCP Client" as MCPClient <<system>>



' ------------------------------------------------------------
' System Boundary — UC Groups
' ------------------------------------------------------------


rectangle "nasim" {

  usecase "**Agent Controller (Convergence Point)**" <<master>> as AC_GROUP
  usecase "**HTTP Adapter Group (Entry Gate)**" <<master>> as API_GROUP
  usecase "**CLI Group (Interface Container)**" <<master>> as CLI_GROUP
  usecase "**MCP Adapter Group (Interface Container)**" <<master>> as MCP_ADP_GROUP

  usecase "**Task Service Group**" <<master>> as TASK_GROUP
  usecase "**Session Service Group**" <<master>> as SESSION_GROUP
  usecase "**Config Service Group**" <<master>> as CONFIG_GROUP
  usecase "**Tool Service Group**" <<master>> as TOOL_GROUP

  usecase "**LLM Repository Group**" <<master>> as LLM_GROUP
  usecase "**Context Service Group**" <<master>> as CTX_GROUP
  usecase "**Safety Service Group**" <<master>> as SAFETY_GROUP
  usecase "**Sandbox Repository Group**" <<master>> as SANDBOX_GROUP
  usecase "**Edit Strategy Repository Group**" <<master>> as EDIT_GROUP
  usecase "**Evaluation Service Group**" <<master>> as EVAL_GROUP
  usecase "**Git Repository Group**" <<master>> as GIT_GROUP
  usecase "**MCP Repository Group**" <<master>> as MCP_GROUP
  usecase "**Tool Service Hooks**" <<master>> as HOOKS_GROUP
  usecase "**Tool Service Plugins**" <<master>> as PLUGINS_GROUP
  usecase "**Memory Repository Group**" <<master>> as MEMORY_GROUP
  usecase "**Repo Intelligence Repository Group**" <<master>> as REPO_INTEL_GROUP
  usecase "**Wire Log Repository Group**" <<master>> as WIRE_LOG_GROUP
}


' ------------------------------------------------------------
' Actor -> Group Associations
' ------------------------------------------------------------


User --> AC_GROUP

MCPClient --> MCP_ADP_GROUP



' ------------------------------------------------------------
' Group Relationships — Convergence Point Delegation Chain
' ------------------------------------------------------------

' All interface containers route through Agent Controller
CLI_GROUP ..> AC_GROUP : <<include>>
API_GROUP ..> AC_GROUP : <<include>>
MCP_ADP_GROUP ..> AC_GROUP : <<include>>

' Agent Controller -> API Group (business operations)
AC_GROUP ..> API_GROUP : <<include>>

' API Group -> downstream core groups (mandatory)
API_GROUP ..> TASK_GROUP : <<include>>
API_GROUP ..> SESSION_GROUP : <<include>>
API_GROUP ..> CONFIG_GROUP : <<include>>
API_GROUP ..> TOOL_GROUP : <<include>>

' Task Service -> execution groups (mandatory includes)
TASK_GROUP ..> LLM_GROUP : <<include>>
TASK_GROUP ..> CTX_GROUP : <<include>>
TASK_GROUP ..> SAFETY_GROUP : <<include>>
TASK_GROUP ..> SANDBOX_GROUP : <<include>>

' Task Service -> specialized/cross-cutting groups (optional extends)
TASK_GROUP ..> EDIT_GROUP : <<extend>>
TASK_GROUP ..> EVAL_GROUP : <<extend>>
TASK_GROUP ..> GIT_GROUP : <<extend>>
TASK_GROUP ..> MCP_GROUP : <<extend>>
TASK_GROUP ..> HOOKS_GROUP : <<extend>>
TASK_GROUP ..> PLUGINS_GROUP : <<extend>>
TASK_GROUP ..> MEMORY_GROUP : <<extend>>
TASK_GROUP ..> REPO_INTEL_GROUP : <<extend>>
TASK_GROUP ..> WIRE_LOG_GROUP : <<extend>>


@enduml
