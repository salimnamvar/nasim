@startuml uc_server
' ============================================================
' Title:     nasim — UC: HTTP Server
' Boundary:  nasim code agent CLI + HTTP API
' Purpose:   REST API and SSE streaming for web/mobile/desktop clients
' Milestone: v1.0
' Version:   3.0.0
' Source:    docs/audit/nasim-car-improvement-plan.md CAR-11
' Review:    —
' ============================================================

left to right direction
skinparam packageStyle rectangle

actor "HTTP Client" as client

rectangle "HTTP Server" {
    usecase "Start Server" as UC_SRV_01
    usecase "Create Session" as UC_SRV_02
    usecase "Send Message" as UC_SRV_03
    usecase "Stream Response" as UC_SRV_04
    usecase "Get Message History" as UC_SRV_05
    usecase "List Tools" as UC_SRV_06
    usecase "Get Config" as UC_SRV_07
}

rectangle "Agent Layer" {
    usecase "PROCESS User Task" as UC_AGT_01
}

rectangle "Session Layer" {
    usecase "Save Session" as UC_SSN_01
    usecase "Load Session" as UC_SSN_02
    usecase "List Sessions" as UC_SSN_03
}

rectangle "Tool Layer" {
    usecase "List Registered Tools" as UC_TL_13
}

client --> UC_SRV_01
client --> UC_SRV_02
client --> UC_SRV_03
client --> UC_SRV_05
UC_SRV_03 ..> UC_SRV_04 : <<include>>
UC_SRV_03 ..> UC_AGT_01 : <<include>>
UC_SRV_02 ..> UC_SSN_01 : <<include>>
UC_SRV_04 ..> UC_SSN_01 : <<include>>
UC_SRV_05 ..> UC_SSN_02 : <<include>>
UC_SRV_06 ..> UC_TL_13 : <<include>>

@enduml
