@startuml uc_nasim_primary
' ============================================================
' Title:     NASIM Service — Primary Use Case Diagram
' Version:   13.0.0
' Phase:     C4 → UC (Use Case Extraction)
' Source:    C4 Component Diagram v13.0.0 (CSR 3-Layer)
' Purpose:   Derive actor goals from validated components.
'            Every C4 component has owning UC Group.
'            All domain entities have lifecycle coverage.
'            Strict traceability maintained for SQ/SM downstream.
' ============================================================

left to right direction
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor<<primary>> #E3F2FD
    BorderColor<<primary>> #1565C0
    FontColor<<primary>> #0D47A1
    BackgroundColor<<orchestration>> #FFF3E0
    BorderColor<<orchestration>> #E65100
    FontColor<<orchestration>> #BF360C
    BackgroundColor<<lifecycle>> #E8F5E9
    BorderColor<<lifecycle>> #2E7D32
    FontColor<<lifecycle>> #1B5E20
    BackgroundColor<<supporting>> #FFFDE7
    BorderColor<<supporting>> #F9A825
    FontColor<<supporting>> #F57F17
}
skinparam actor {
    BackgroundColor #FAFAFA
    BorderColor #616161
    FontColor #212121
}

actor "Developer" as Dev

rectangle "NASIM Service v13.0.0" {

    package "Request Handling & Entry Gate\n<< UC Group: CLI Adapter + HTTP Adapter + MCP Adapter + Agent Controller >>" as pkg_request {
        usecase "UC-001:\nSubmit Natural Language\nCoding Task" as UC001 <<primary>>
        usecase "UC-002:\nInvoke Tool Directly via\nMCP or Slash Command" as UC002 <<primary>>
    }

    package "Agentic Task Orchestration\n<< UC Group: Task Service + Safety Service +\nContext Service + Evaluation Service + Tool Service >>" as pkg_orchestrate {
        usecase "UC-003:\nExecute Agent-Orchestrated\nCoding Task\n(LLM + Tools + Safety + Eval)" as UC003 <<orchestration>>
    }

    package "Session Lifecycle Management\n<< UC Group: Session Service + History Repository +\nWire Log Repository >>" as pkg_session {
        usecase "UC-004:\nCreate New Session" as UC004 <<lifecycle>>
        usecase "UC-005:\nLoad Existing Session" as UC005 <<lifecycle>>
        usecase "UC-006:\nCreate Snapshot of\nCurrent State" as UC006 <<lifecycle>>
        usecase "UC-007:\nRevert Session to\nPrevious Snapshot" as UC007 <<lifecycle>>
        usecase "UC-008:\nFork Session from\nCheckpoint / WireLog" as UC008 <<lifecycle>>
    }

    package "Configuration Management\n<< UC Group: Config Service + Config Repository >>" as pkg_config {
        usecase "UC-009:\nLoad Effective Layered\nConfiguration" as UC009 <<supporting>>
        usecase "UC-010:\nUpdate Project-Level\nConfiguration Overrides" as UC010 <<supporting>>
    }

    package "Context & Knowledge Enrichment\n<< UC Group: Context Service + Memory Repository +\nRepo Intelligence Repository >>" as pkg_context {
        usecase "UC-011:\nEnrich Task Context with\nMemory + Codebase Intelligence" as UC011 <<supporting>>
    }

    package "Safe Tool Execution\n<< UC Group: Tool Service + Safety Service +\nFS/Sandbox/Edit Strategy/Git/MCP/Web/LLM Repositories >>" as pkg_tool {
        usecase "UC-012:\nRequest Safe Tool Action\n(Edit / Git / Sandbox /\nWeb / MCP / Repo Query)" as UC012 <<orchestration>>
    }
}

' === Connections (Developer initiates) ===
Dev --> UC001 : "via CLI REPL, WebApp,\nDesktop, Mobile, or MCP"
Dev --> UC002 : "power user / external tool"
Dev --> UC003 : "primary coding workflow"
Dev --> UC004
Dev --> UC005
Dev --> UC006
Dev --> UC007
Dev --> UC008
Dev --> UC009
Dev --> UC010
Dev --> UC011 : "implicit in task context"
Dev --> UC012 : "direct or via agent"

' === Includes / Extends for key orchestration (to be detailed in SQ) ===
UC003 ..> UC011 : <<include>>\n(context enrichment)
UC003 ..> UC012 : <<include>>\n(tool execution)
UC003 ..> UC009 : <<include>>\n(config)
UC001 ..> UC003 : <<include>>\n(orchestration)
UC012 ..> UC003 : <<extend>>\n(when agent delegates)

' === Traceability Notes ===
note right of UC003
  **Owns full agentic loop**:
  - LLM invocation (LLMRepository)
  - Context pipeline (ContextService)
  - Safety gating (SafetyService)
  - Tool dispatch + registry (ToolService)
  - Outcome eval + retry (EvaluationService)
  - Wire logging (WireLogRepository)
  
  All sub-flows use **ref** in SQ diagrams
  (no duplication across UCs).
end note

note right of pkg_session
  **Session entity lifecycle**:
  Create → Load → Mutate (turns) →
  Snapshot → Revert / Fork →
  (WireLog for replay & branching)
  
  All writes go through SessionService.
  No direct Repository calls from Controller.
end note

note right of pkg_tool
  **Safety & CSR enforced**:
  Every tool action passes SafetyService
  before Repository mutation.
  
  Sandbox validation for edits
  (EditStrategyRepository).
end note

legend right
  |= Color | UC Group Type |
  |<#E3F2FD> Primary Entry | Request Handling (UC-001,002) |
  |<#FFF3E0> Orchestration | Core Agent Loop + Tool Safety (UC-003,012) |
  |<#E8F5E9> Lifecycle | Session Management (UC-004..008) |
  |<#FFFDE7> Supporting | Config, Context, Knowledge (UC-009..011) |
  
  **Traceability Rule**:
  Every C4 v13.0.0 Component participates in ≥1 UC Group.
  No orphan components. No invented UCs.
  Flows respect CSR layering (Adapter/Controller → Service → Repository).
end legend

@enduml