@startuml uc_obs

' ============================================================
' Title:     nasim — UC: Observability Group
' Group:     OBS (Observability)
' Boundary:  nasim code agent
' Purpose:   Emit-only structured logging, metrics, trace correlation (tenas pattern)
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/ENTITIES.md, docs/UC/README.md
' Review:    CAR refinement loop 2026-06-27
' SQ:        sq_obs01..sq_obs06
' ============================================================

left to right direction

title nasim — Observability Use Cases

skinparam actorStyle awesome
skinparam packageStyle rectangle

skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}

skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}

skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}

' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------

actor "User" as User
actor "ServerRouter" as Router <<system>>
actor "AgentOrchestrator" as Agent <<system>>
note top of User
  Scope:          OBS-01..OBS-06 — Log, metrics, trace correlation, redact, /metrics endpoint, OTLP export
  Preconditions:  StructuredLogger initialized
  Contexts:       Called by all system components; sq_obs01..sq_obs06
  Excludes:       Log storage/rotation (outside scope)
  Rollback:       N/A — emit-only; no side effects to roll back
  Design:         StructuredLogger writes JSON to stdout; MetricsCollector serves /metrics; OTel export optional
  Returns:
    - Success: LogEntry written or metric recorded
    - Failure: LogError (non-fatal, logged internally)
end note

actor "Observability Platform" as Platform <<system>>

' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------

rectangle "nasim" {
  package "Observability Group (OBS)" {
    usecase "**OBS-01 STREAM Structured Log**\n--\nWrite structured JSON records to stdout" as OBS01
    usecase "**OBS-02 RECORD Metrics**\n--\nIncrement counters and observe histograms" as OBS02
    usecase "**OBS-03 CORRELATE Trace**\n--\nGenerate and bind trace/span ids per entrypoint" as OBS03
    usecase "**OBS-04 REDACT Sensitive**\n--\nStrip secrets before any emission" as OBS04
    usecase "**OBS-05 EXPOSE /metrics**\n--\nServe /metrics endpoint for pull scrape" as OBS05
    usecase "**OBS-06 EXPORT OTLP**\n--\nExport traces/metrics via OTLP (optional)" as OBS06
  }
}

' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------

User --> OBS05
Platform --> OBS05 : scrapes

Router --> OBS05 : dispatches
Router --> OBS01 : dispatches
Router --> OBS02 : dispatches
Router --> OBS03 : dispatches
Router --> OBS04 : dispatches
Router --> OBS06 : dispatches

Agent --> OBS01 : calls
Agent --> OBS02 : calls
Agent --> OBS03 : calls
Agent --> OBS04 : calls
Agent --> OBS05 : calls
Agent --> OBS06 : calls

' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------

OBS02 ..> OBS03 : <<include>>
OBS04 ..> OBS01 : <<extend>>
OBS04 ..> OBS02 : <<extend>>

note bottom of Agent
  Flow:   User request → ServerRouter dispatches → AgentOrchestrator calls Observability components
  State:  OBS-01..OBS-06 — each returns emission confirmation or metric data
  Success: Log written, metric recorded, trace correlated, /metrics served, OTLP exported
  Failure: LogError (non-fatal); system continues
end note

@enduml
