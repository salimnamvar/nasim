@startuml uc_edit_strategy_repo

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Edit Strategy Repository Group
' Group:     EDITSTRATEGYREPOSITORY (Edit Strategy Repository)
' C4 ID:     edit_strategy_repo
' Boundary:  NASIM Application — Repository Layer
' Purpose:   Diff staging, computation, and safe application:
'            staged edits, sandboxed validation.
'            Entry chain: User → Interface → Agent Controller → Task Service → Tool Service → Edit Strategy Repository
' Milestone: v1.0
' Version:   13.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Review:    —
' SQ:        sq_editstrategyrepository01..sq_editstrategyrepository10
' ============================================================


left to right direction


title nasim — Edit Strategy Use Cases


skinparam actorStyle awesome
skinparam packageStyle rectangle


skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}


skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}


skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User



' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------


rectangle "nasim" {
  package "Edit Strategy Group (EDT)" {
    usecase "**EDITSTRATEGYREPOSITORY-01 SELECT Strategy**\n--\nSelect optimal edit strategy for model" <<master>> as EDT01
    usecase "**EDITSTRATEGYREPOSITORY-02 APPLY Search-Replace**\n--\nSearch-and-replace edit with fuzzy matching" <<include>> as EDT02
    usecase "**EDITSTRATEGYREPOSITORY-03 APPLY Whole-File**\n--\nWhole file rewrite strategy" <<include>> as EDT03
    usecase "**EDITSTRATEGYREPOSITORY-04 APPLY Unified Diff**\n--\nUnified diff format edit" <<include>> as EDT04
    usecase "**EDITSTRATEGYREPOSITORY-05 APPLY Fenced Block**\n--\nFenced code block format edit" <<include>> as EDT05
    usecase "**EDITSTRATEGYREPOSITORY-06 APPLY Function-Level**\n--\nAST-targeted function replacement" <<include>> as EDT06
    usecase "**EDITSTRATEGYREPOSITORY-07 APPLY Diff Sandbox**\n--\nSandboxed diff with validation" <<include>> as EDT07
    usecase "**EDITSTRATEGYREPOSITORY-08 APPLY Architect**\n--\nMulti-file architectural edit" <<include>> as EDT08
    usecase "**EDITSTRATEGYREPOSITORY-09 APPLY Inline Patch**\n--\napply-patch format edit" <<include>> as EDT09
    usecase "**EDITSTRATEGYREPOSITORY-10 STAGE Diff**\n--\nStage edits for review before apply" <<include>> as EDT10
  }
}


' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------


User --> EDT01



' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------


EDT01 ..> EDT02 : <<include>>
EDT01 ..> EDT03 : <<include>>
EDT01 ..> EDT04 : <<include>>
EDT01 ..> EDT05 : <<include>>
EDT01 ..> EDT06 : <<include>>
EDT01 ..> EDT07 : <<include>>
EDT01 ..> EDT08 : <<include>>
EDT01 ..> EDT09 : <<include>>
EDT07 ..> EDT10 : <<include>>



@enduml