@startuml uc_memory

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: MemoryRepository Group
' Group:     MEMORYREPOSITORY (MemoryRepository)
' Boundary:  NASIM Service
' Purpose:   Cross-session knowledge persistence
'            Entry chain: User → Interface → AgentController → TaskService → ContextService → MemoryRepository
' Milestone: v1.0
' Version:   13.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Review:    —
' SQ:        sq_memoryrepository01..sq_memoryrepository04
' ============================================================


left to right direction


title nasim — Memory Use Cases


skinparam actorStyle awesome
skinparam packageStyle rectangle


skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}


skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}


skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User



' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------


rectangle "nasim" {
  package "Memory Group (MEM)" {
    usecase "**MEMORYREPOSITORY-01 PERSIST Knowledge**\n--\nStore knowledge entries with scope, key, content" <<master>> as MEM01
    usecase "**MEMORYREPOSITORY-02 RECALL Knowledge**\n--\nRetrieve knowledge from memory stores" <<master>> as MEM02
    usecase "**MEMORYREPOSITORY-03 SEARCH Knowledge**\n--\nFTS5 search across stored knowledge" <<include>> as MEM03
    usecase "**MEMORYREPOSITORY-04 SCOPE Knowledge**\n--\nIsolate knowledge by global, project, session scope" <<include>> as MEM04
  }
}


' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------


User --> MEM01
User --> MEM02

' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------


MEM01 ..> MEM04 : <<include>>
MEM02 ..> MEM03 : <<include>>




@enduml