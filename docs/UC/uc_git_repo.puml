@startuml uc_git_repo

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Git Repository Group
' Group:     GITREPOSITORY (Git Repository)
' Boundary:  NASIM Service
' Purpose:   Git operations: status, diff, commit, branch
'            Entry chain: User → Interface → Agent Controller → Task Service → Tool Service → Git Repository
' Milestone: v1.0
' Version:   13.0.0
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' Review:    —
' SQ:        sq_gitrepository01..sq_gitrepository04
' ============================================================


left to right direction


title nasim — Git Use Cases


skinparam actorStyle awesome
skinparam packageStyle rectangle


skinparam usecase {
  BackgroundColor #FFFFFF
  BorderColor #424242
  FontColor #000000
  ArrowColor #424242
  FontSize 12
}


skinparam actor {
  BackgroundColor #E8EAF6
  BorderColor #3949AB
  FontColor #1A237E
  FontSize 12
}


skinparam actor<<system>> {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontColor #0D47A1
}


' ------------------------------------------------------------
' Actors
' ------------------------------------------------------------


actor "User" as User



' ------------------------------------------------------------
' System Boundary
' ------------------------------------------------------------


rectangle "nasim" {
  package "Git Group (VCS)" {
    usecase "**GITREPOSITORY-01 READ Git Status**\n--\nRead working tree status and staged changes" <<master>> as VCS01
    usecase "**GITREPOSITORY-02 INSERT Commit**\n--\nCreate commits with conventional messages" <<include>> as VCS02
    usecase "**GITREPOSITORY-03 READ Diff**\n--\nRead diff between working tree and HEAD" <<include>> as VCS03
    usecase "**GITREPOSITORY-04 AUTO-COMMIT**\n--\nAuto-commit after file edits" <<master>> as VCS04
  }
}


' ------------------------------------------------------------
' Actor -> Use Case Associations
' ------------------------------------------------------------


User --> VCS01
User --> VCS04




' ------------------------------------------------------------
' Relationships
' ------------------------------------------------------------


VCS04 ..> VCS02 : <<include>>
VCS04 ..> VCS03 : <<include>>



@enduml