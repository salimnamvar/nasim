@startuml uc_repo_intelligence
' ============================================================
' Title:     nasim — UC: Repo Intelligence Management
' Boundary:  nasim code agent CLI + HTTP API
' Purpose:   AST indexing, symbol ranking, semantic search, context injection
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/audit/audit.2026.06.20.deep.domain.audit.md
' Review:    —
' ============================================================

left to right direction
skinparam packageStyle rectangle

actor "AgentOrchestrator" as agent
actor "ContextGraph" as ctx

rectangle "Repo Intelligence" {
    usecase "INDEX Repository" as UC_RIM_01
    usecase "RANK Symbols" as UC_RIM_02
    usecase "SEARCH Semantic" as UC_RIM_03
    usecase "INJECT RepoMap" as UC_RIM_04
    usecase "INVALIDATE Index" as UC_RIM_05
    usecase "EXTRACT AST Tags" as UC_RIM_06
}

rectangle "External" {
    component "Tree-sitter" as treesitter
    component "Embedding Model" as embedding
}

agent --> UC_RIM_01
agent --> UC_RIM_03
agent --> UC_RIM_04
agent --> UC_RIM_05
ctx --> UC_RIM_04
UC_RIM_01 ..> UC_RIM_06 : <<include>>
UC_RIM_03 ..> embedding : <<include>>
UC_RIM_06 ..> treesitter : <<include>>
UC_RIM_01 ..> UC_RIM_02 : <<include>>

@enduml
