@startuml uc_session_svc

!include common/uc_styles.puml


' ============================================================
' Title:     nasim — UC: Session Service Group
' C4 ID:     session_svc
' C4 Name:   Session Service
' Boundary:  NASIM Application — Service Layer
' Purpose:   Session lifecycle: create, load, save, snapshot, revert.
'            C4 Rel: agent_ctrl → session_svc; session_svc →
'            session_repo, history_repo, wire_log_repo
' Entry:     Adapter → agent_ctrl → session_svc
' Source:    docs/C4/c4_nasim_component.puml (v13.0.0)
' SQ:        sq_sessionservice01..sq_sessionservice09
' ============================================================


title nasim — UC: Session Service Group


actor "Agent Controller" as AgentCtrl <<system>>


usecase "SESSIONREPO-01\nAPPEND Message\n[uc_session_repo]" as SR01_ext <<extref>>
usecase "SESSIONREPO-02\nREAD Messages\n[uc_session_repo]" as SR02_ext <<extref>>
usecase "HISTORYREPO-01\nSNAPSHOT State\n[uc_history_repo]" as HR01_ext <<extref>>
usecase "HISTORYREPO-03\nREVERT Turn\n[uc_history_repo]" as HR03_ext <<extref>>
usecase "WIRELOGREPO-04\nFORK Session\n[uc_wire_log_repo]" as WL04_ext <<extref>>
usecase "WIRELOGREPO-05\nCHECKPOINT Turn\n[uc_wire_log_repo]" as WL05_ext <<extref>>


rectangle "nasim" {
  package "Session Service Group" {
    usecase "**SESSIONSVC-01 PERSIST Session**\n--\nSave session to storage" <<include>> as SS01
    usecase "**SESSIONSVC-02 READ Session**\n--\nLoad session from storage" <<include>> as SS02
    usecase "**SESSIONSVC-03 LIST Sessions**\n--\nList all saved sessions" <<master>> as SS03
    usecase "**SESSIONSVC-04 RESTORE Session**\n--\nResume a previously saved session" <<master>> as SS04
    usecase "**SESSIONSVC-05 SNAPSHOT Session**\n--\nCreate session state snapshot" <<master>> as SS05
    usecase "**SESSIONSVC-06 REVERT Turn**\n--\nUndo last turn in session" <<master>> as SS06
    usecase "**SESSIONSVC-07 SEARCH Sessions**\n--\nCross-session search via FTS5" <<master>> as SS07
    usecase "**SESSIONSVC-08 BRANCH Session**\n--\nFork conversation from any point" <<master>> as SS08
    usecase "**SESSIONSVC-09 DELETE Session**\n--\nDelete session from storage" <<master>> as SS09
  }
}


AgentCtrl --> SS03
AgentCtrl --> SS04
AgentCtrl --> SS05
AgentCtrl --> SS06
AgentCtrl --> SS07
AgentCtrl --> SS08
AgentCtrl --> SS09

SS01 ..> SR01_ext : <<include>>
SS02 ..> SR02_ext : <<include>>
SS04 ..> SS02 : <<include>>
SS05 ..> SS01 : <<include>>
SS05 ..> HR01_ext : <<include>>
SS06 ..> SS02 : <<include>>
SS06 ..> HR03_ext : <<include>>
SS08 ..> SS01 : <<include>>
SS08 ..> WL04_ext : <<include>>
SS05 ..> WL05_ext : <<include>>


@enduml