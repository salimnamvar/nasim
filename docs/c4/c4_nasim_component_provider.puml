title nasim — Provider Component Diagram

Container_Boundary(provider_boundary, "Provider Layer") {
    Component(provider_proto, "Provider", "nasim/provider/base.py", "Protocol: chat(), chat_stream(), model_name")
    Component(provider_factory, "ProviderFactory", "nasim/provider/base.py", "Reads config, instantiates correct provider class")
    Component(ollama_provider, "OllamaProvider", "nasim/provider/ollama.py", "Ollama /api/chat: sync + streaming")
    Component(openai_provider, "OpenAIProvider", "nasim/provider/openai.py", "OpenAI Chat Completions API (Phase 2)")
    Component(anthropic_provider, "AnthropicProvider", "nasim/provider/anthropic.py", "Anthropic Messages API (Phase 2)")
}

System_Ext(ollama_api, "Ollama Server", "HTTP/JSON")
System_Ext(openai_api, "OpenAI API", "HTTP/JSON")
System_Ext(anthropic_api, "Anthropic API", "HTTP/JSON")

Rel(provider_factory, provider_proto, "creates instance")
Rel(ollama_provider, provider_proto, "implements")
Rel(openai_provider, provider_proto, "implements")
Rel(anthropic_provider, provider_proto, "implements")
Rel(ollama_provider, ollama_api, "HTTP POST /api/chat", "JSON")
Rel(openai_provider, openai_api, "HTTP POST /v1/chat/completions", "JSON")
Rel(anthropic_provider, anthropic_api, "HTTP POST /v1/messages", "JSON")

SHOW_LEGEND()
