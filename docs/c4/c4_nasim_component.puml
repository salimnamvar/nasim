title nasim — Component Overview (cross-container)

Container_Boundary(cli_boundary, "CLI Layer") {
    Component(arg_parser, "ArgParser", "", "")
    Component(repl_session, "REPLSession", "", "")
    Component(renderer, "Renderer", "", "")
}

Container_Boundary(agent_boundary, "Agent Layer") {
    Component(agent_orch, "AgentOrchestrator", "", "")
    Component(conv_history, "ConversationHistory", "", "")
    Component(compactor, "ContextCompactor", "", "")
    Component(perm_gate, "PermissionGate", "", "")
}

Container_Boundary(provider_boundary, "Provider Layer") {
    Component(provider, "Provider", "", "")
}

Container_Boundary(tool_boundary, "Tool Layer") {
    Component(tool_registry, "ToolRegistry", "", "")
    Component(search_tools, "SearchTools", "", "")
    Component(web_tools, "WebTools", "", "")
}

Container_Boundary(config_boundary, "Config Layer") {
    Component(config_loader, "ConfigLoader", "", "")
}

Container_Boundary(session_boundary, "Session Layer") {
    Component(session_store, "SessionStore", "", "")
}

Rel(repl_session, agent_orch, "user input -> events")
Rel(agent_orch, provider, "chat / stream")
Rel(agent_orch, tool_registry, "execute tools")
Rel(agent_orch, conv_history, "messages")
Rel(agent_orch, perm_gate, "permission check")
Rel(conv_history, compactor, "compact")
Rel(agent_orch, session_store, "save/load")
Rel(config_loader, agent_orch, "settings")

SHOW_LEGEND()
