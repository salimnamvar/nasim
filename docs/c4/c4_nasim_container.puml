title nasim — Container Diagram

Person(dev, "Developer", "Terminal user")
Person(http_client, "HTTP Client", "Web/mobile/desktop apps")

System_Boundary(nasim, "nasim") {
    Container(cli, "CLI", "Python click + rich", "Interactive terminal: REPL, slash commands, rich rendering")
    Container(agent, "Agent Core", "Python", "Orchestrator, conversation history, context compaction, permissions, plan mode")
    Container(provider, "Provider Layer", "Python httpx", "Provider abstraction: Ollama, OpenAI, Anthropic + model routing")
    Container(tools, "Tool Layer", "Python", "Tool registry: file, search, shell, web, git, MCP, LSP tools")
    Container(config, "Config", "Python pydantic", "Layered config: global YAML + project YAML + env + CLI flags")
    Container(session, "Session Store", "Python JSON", "Persists conversation history to ~/.nasim/sessions/")
    Container(server, "HTTP API Server", "Python starlette", "RESTful API + SSE streaming for web/mobile/desktop clients")
    Container(hooks, "Hook System", "Python", "Pre/post hooks for tool use and LLM calls")
    Container(plugins, "Plugin System", "Python", "Plugin discovery, loading, dynamic tool/hook registration")
}

System_Ext(llm_provider, "LLM Provider", "Ollama / OpenAI / Anthropic API")
System_Ext(host_fs, "Host Filesystem", "Project code files")
System_Ext(host_shell, "Host Shell", "subprocess execution")
System_Ext(web_ext, "Web", "Documentation and search")
System_Ext(mcp_server, "MCP Server", "Extension tools")
System_Ext(mcp_client, "MCP Client", "External tool consumers")

Rel(dev, cli, "types input, reads output")
Rel(http_client, server, "sends requests, receives SSE", "HTTP/JSON")
Rel(cli, agent, "sends user input, receives events")
Rel(server, agent, "sends user input, receives events")
Rel(agent, provider, "calls provider chat/stream")
Rel(agent, tools, "dispatches tool calls")
Rel(agent, session, "loads/saves conversation history")
Rel(agent, hooks, "triggers pre/post hooks")
Rel(hooks, plugins, "loads plugin hooks")
Rel(plugins, tools, "registers plugin tools")
Rel(provider, llm_provider, "HTTP POST", "JSON streaming")
Rel(tools, host_fs, "read/write/search files")
Rel(tools, host_shell, "execute commands")
Rel(tools, web_ext, "fetch/search")
Rel(tools, mcp_server, "invoke extension tools")
Rel(server, mcp_client, "serves MCP protocol", "stdio/SSE")
Rel(config, agent, "provides settings")
Rel(config, provider, "provides provider config")
Rel(config, tools, "provides tool config")

SHOW_LEGEND()
