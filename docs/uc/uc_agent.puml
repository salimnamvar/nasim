@startuml uc_agent
' ============================================================
' Title:     nasim — UC: Agent Core
' Boundary:  nasim code agent CLI
' Purpose:   Core agentic loop operations and new capabilities
' Milestone: v1.0
' Version:   2.0.0
' Source:    docs/audit/audit_2026-06-20_capability-and-architecture.md
' Review:    —
' ============================================================

left to right direction
skinparam packageStyle rectangle

actor "Developer" as user

rectangle "Agent Core" {
    usecase "PROCESS User Task" as UC_AGT_01
    usecase "DISPATCH Tool Call" as UC_AGT_02
    usecase "Manage Conversation" as UC_AGT_03
    usecase "Reset History" as UC_AGT_04
    usecase "CHECK Tool Permission" as UC_AGT_05
    usecase "COMPACT Context" as UC_AGT_06
    usecase "Queue Plan" as UC_AGT_07
    usecase "APPROVE Plan" as UC_AGT_08
}

user --> UC_AGT_01
UC_AGT_01 ..> UC_AGT_02 : <<include>>
UC_AGT_01 ..> UC_AGT_03 : <<include>>
UC_AGT_02 ..> UC_AGT_05 : <<include>>
UC_AGT_01 ..> UC_AGT_06 : <<extend>>
UC_AGT_07 ..> UC_AGT_08 : <<extend>>

@enduml
