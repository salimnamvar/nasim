@startuml er_observability
' ============================================================
' Title:     nasim — Observability ERD
' Boundary:  nasim code agent CLI
' Purpose:   Physical schema for structured logs, metrics, and trace context
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/audit/audit.2026.06.20.logging.observability.car.md
' Review:    —
' Note:      Emit-only per tenas pattern. Logs go to stdout.
'            Metrics exposed via /metrics pull endpoint.
'            OTel export is optional (behind feature flag).
' ============================================================

title nasim — Observability ERD

entity "log_record" as lr {
    * record_id : TEXT (UUID) <<PK>>
    --
    * timestamp : TEXT (ISO 8601)
    * level : TEXT {TRACE|DEBUG|INFO|WARNING|ERROR|CRITICAL}
    * logger_name : TEXT
    * message : TEXT
    * trace_id : TEXT (UUID)
    * span_id : TEXT (hex)
    * parent_span_id : TEXT (hex) <<nullable>>
    * session_id : TEXT (UUID) <<nullable>>
    * turn_number : INTEGER <<nullable>>
    * extra : TEXT (JSON)
    * redacted : BOOLEAN
}

entity "metric_point" as mp {
    * point_id : TEXT (UUID) <<PK>>
    --
    * name : TEXT
    * type : TEXT {counter|gauge|histogram|summary}
    * value : REAL
    * labels : TEXT (JSON)
    * timestamp : REAL
    * trace_id : TEXT (UUID) <<nullable>>
}

entity "trace_context" as tc {
    * span_id : TEXT (hex) <<PK>>
    --
    * trace_id : TEXT (UUID)
    * parent_span_id : TEXT (hex) <<nullable>>
    * session_id : TEXT (UUID) <<nullable>>
    * turn_number : INTEGER <<nullable>>
    * operation_name : TEXT
    * start_time : REAL
    * end_time : REAL <<nullable>>
    * status : TEXT {ok|error|unset}
}

entity "observability_config" as oc {
    * config_id : TEXT <<PK>> {global|project}
    --
    * log_level : TEXT {TRACE|DEBUG|INFO|WARNING|ERROR|CRITICAL}
    * log_format : TEXT {json|text}
    * structured_enabled : BOOLEAN
    * wire_enabled : BOOLEAN
    * redact_enabled : BOOLEAN
    * redact_patterns : TEXT (JSON)
    * metrics_enabled : BOOLEAN
    * otel_enabled : BOOLEAN
    * otel_endpoint : TEXT <<nullable>>
    * sampling_rate : REAL
}

entity "redaction_rule" as rr {
    * rule_id : TEXT (UUID) <<PK>>
    --
    * scope : TEXT {global|project}
    * pattern : TEXT
    * replacement : TEXT
    * enabled : BOOLEAN
    * description : TEXT <<nullable>>
}

lr }|--|| tc : "correlates via trace_id"
mp }|--o| tc : "optional trace link"
tc ||--o{ lr : "produces"
tc ||--o{ mp : "records metrics"

note bottom of lr
  Emitted to stdout as one JSON line per record.
  StructuredLogger writes here conceptually.
  Redaction applied before emission (redacted=true).
  trace_id enables cross-reference with wire events.
  extra holds domain-specific key-value pairs.
end note

note bottom of mp
  Prometheus-compatible metric points.
  name follows convention: nasim_<metric>[_<unit>]
  labels are low-cardinality (model, provider, tool, success).
  Optional trace_id links metric to distributed trace.
end note

note bottom of tc
  Request-scoped trace context.
  trace_id is root (per CLI turn or HTTP request).
  span_id is current operation.
  Shared with OTel when otel feature enabled.
  end_time filled on span completion.
end note

note right of oc
  Loaded from layered config:
  global ~/.nasim/config.yaml →
  project .nasim/config.yaml →
  env vars NASIM_* → CLI flags.
  Wire log has separate enabled flag.
end note

note right of rr
  Regex-based secret stripping.
  Global rules: env vars, API keys, .env.
  Per-project: custom patterns.
  Applied by LogRedactor before any emission.
  Always on — cannot be disabled.
end note

@enduml
