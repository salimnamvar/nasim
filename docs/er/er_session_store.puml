@startuml er_session_store
' ============================================================
' Title:     nasim — Session Store ERD
' Boundary:  nasim code agent CLI
' Purpose:   Physical schema for session JSON Lines store
' Milestone: v1.0
' Version:   2.0.0
' Source:    docs/audit/audit_2026-06-20_capability-and-architecture.md
' Review:    —
' Note:      Minimal ERD — nasim uses JSON Lines files, not a
'            relational database. This documents the logical schema.
' ============================================================

entity "session" as sess {
    * id : TEXT (UUID) <<PK>>
    --
    * created_at : TEXT (ISO 8601)
    * model : TEXT
    * provider : TEXT
    message_count : INTEGER
}

entity "message" as msg {
    * session_id : TEXT <<FK>>
    * sequence : INTEGER
    --
    * role : TEXT {system|user|assistant|tool}
    content : TEXT
    tool_calls : TEXT (JSON)
    tool_call_id : TEXT
    timestamp : TEXT (ISO 8601)
}

sess ||--o{ msg : "contains"

note bottom of sess
  Physical storage: ~/.nasim/sessions/<id>/session.jsonl
  Each line is a JSON object: session metadata or a message.
  One file per session ID.
end note

@enduml
