@startuml c4_nasim_component_server
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!include common/c4_styles.puml
!theme plain

' ============================================================
' Title:     NASIM Application — API Component Diagram
' Boundary:  NASIM Application (container) — API Group
' Purpose:   API component group inside nasim. Shows how
'            interface containers connect to ServerRouter.
'            API is a component, not a container.
'            CSR Layer: Controller
' Milestone: v1.0
' Version:   9.0.0
' Source:    CAR refinement loop — C4 correction
' Review:    —
' Date:      2026-06-25
' ============================================================

LAYOUT_WITH_LEGEND()
title NASIM Application — API Component Diagram

Boundary(nasim_application, "NASIM Application") {
    Boundary(api_group, "API Group") <<controller>> {
        Component(server_app, "ServerApp", "FastAPI", "ASGI application factory with lifespan, middleware, route mounts")
        Component(server_router, "ServerRouter", "FastAPI Router", "ROD-compliant REST endpoints. Sole entry gate for all interface containers.")
        Component(sse_handler, "SSEHandler", "SSE", "Converts AgentEvent stream to SSE format for all interface clients")
        Component(api_schema, "APISchema", "Pydantic", "Request/response models with AIP-193 error format")
    }
}

Component_Ext(agent_orch, "AgentOrchestrator", "Agent Group")
Component_Ext(core_engine, "Core Engine", "Core Engine Container")

Container_Ext(webapp, "WebApp", "JavaScript SPA", "Browser-based interface")
Container_Ext(desktop_app, "DesktopApp", "Electron / Tauri", "Desktop application")
Container_Ext(mobile_app, "MobileApp", "React Native / Flutter", "Mobile application")
System_Ext(mcp_client_ext, "MCP Client", "External tool or IDE connecting via MCP")

Rel(webapp, server_router, "submits coding tasks and streams AI responses", "HTTP/JSON + SSE")
Rel(desktop_app, server_router, "submits coding tasks and streams AI responses", "HTTP/JSON + SSE")
Rel(mobile_app, server_router, "submits coding tasks and streams AI responses", "HTTP/JSON + SSE")
Rel(mcp_client_ext, core_engine, "invokes NASIM Application tools via MCP protocol", "stdio / SSE")

Rel(server_app, server_router, "mounts routes")
Rel(server_router, api_schema, "validates requests/responses")
Rel(server_router, agent_orch, "delegates to agent orchestrator")
Rel(server_router, sse_handler, "converts agent events to streaming format")
Rel(sse_handler, agent_orch, "consumes AgentEvents")

@enduml
