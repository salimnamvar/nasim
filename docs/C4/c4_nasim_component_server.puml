@startuml c4_nasim_component_server
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
skinparam linetype polyline

' ============================================================
' Title:     nasim — Server Component Diagram
' Boundary:  nasim code agent HTTP API
' Purpose:   Server Layer components for HTTP interface
' Milestone: v1.0
' Version:   4.0.0
' Source:    docs/audit/audit.2026.06.20.comprehensive.reference.audit.md
' Review:    docs/audit/audit.2026.06.20.comprehensive.reference.audit.md
' ============================================================

title nasim — Server Component Diagram

Container_Boundary(server_boundary, "Server Layer") {
    Component(server_app, "ServerApp", "FastAPI", "ASGI application factory with lifespan, middleware, route mounts")
    Component(server_router, "ServerRouter", "FastAPI Router", "ROD-compliant REST endpoints mapped to AgentOrchestrator")
    Component(sse_handler, "SSEHandler", "SSE", "Converts AgentEvent stream to SSE format for HTTP clients")
    Component(api_schema, "APISchema", "Pydantic", "Request/response models: SessionCreate, MessageCreate, responses")
}

System_Ext(agent_orch, "Agent Orchestrator", "Core agentic loop")
System_Ext(session_store, "Session Store", "Message history persistence")
System_Ext(tool_registry, "Tool Registry", "Instance-based tool registry")

Rel(server_app, server_router, "mounts routes")
Rel(server_router, agent_orch, "delegates to")
Rel(server_router, session_store, "manages sessions")
Rel(server_router, tool_registry, "lists tools")
Rel(server_router, sse_handler, "streams via")
Rel(sse_handler, agent_orch, "consumes AgentEvents")

SHOW_LEGEND()

@enduml
