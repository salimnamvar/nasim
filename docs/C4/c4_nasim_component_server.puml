@startuml c4_nasim_component_server
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
skinparam linetype polyline

' ============================================================
' Title:     nasim — Server Component Diagram
' Boundary:  nasim HTTP API Server process
' Purpose:   Server Layer components for HTTP interface
' Milestone: v1.0
' Version:   5.0.0
' Source:    docs/prompt/p1.md — corrective architecture review
' Review:    docs/audit/audit.2026.06.20.comprehensive.reference.audit.md
' ============================================================

title nasim — Server Component Diagram

Container_Boundary(server_boundary, "HTTP API Server Process") {
    Component(server_app, "ServerApp", "FastAPI", "ASGI application factory with lifespan, middleware, route mounts")
    Component(server_router, "ServerRouter", "FastAPI Router", "ROD-compliant REST endpoints mapped to agent orchestrator")
    Component(sse_handler, "SSEHandler", "SSE", "Converts AgentEvent stream to SSE format for HTTP clients")
    Component(api_schema, "APISchema", "Pydantic", "Request/response models with AIP-193 error format")
}

Container_Ext(core_library, "Core Library")

Rel(server_app, server_router, "mounts routes")
Rel(server_router, core_library, "delegates to agent orchestrator")
Rel(server_router, sse_handler, "streams via")
Rel(sse_handler, core_library, "consumes AgentEvents")

SHOW_LEGEND()

@enduml
