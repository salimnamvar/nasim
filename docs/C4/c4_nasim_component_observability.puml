@startuml c4_nasim_component_observability
' ============================================================
' Title:     NASIM Application — Observability Component Diagram
' Boundary:  NASIM Application (container) — Observability Group
' Purpose:   Application-side logging and metrics emission (emit only)
'            CSR Layer: Infrastructure
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/audit/audit.2026.06.20.logging.observability.car.md
' Review:    CAR audit 2026-06-26
' Date:      2026-06-26
' ============================================================
' SIM-01 EXCEPTION: 18 elements — single-group component diagram showing all 9 observability sub-components + 9 external dependencies; splitting would break the emit-path chain visibility
' ============================================================

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
!include common/c4_styles.puml

title NASIM Application — Track Observability Component Diagram

Container_Boundary(nasim_application, "NASIM Application") {
    Boundary(observability_group, "Observability Group") <<infrastructure>> {
        Component(structured_logger, "StructuredLogger", "structlog + JSON formatter", "Writes structured JSON records to stdout only. Includes trace_id, span_id, session_id, turn_number. Never ships to Loki or log agent.")
        Component(metrics_collector, "MetricsCollector", "prometheus-client", "Owns application metrics: token usage, latency histograms, tool call counters, error rates. Exposes /metrics for pull scrape only.")
        Component(trace_correlator, "TraceCorrelator", "contextvars", "Generates root trace/span per top-level task. Binds trace_id, span_id, parent_span_id to context.")
        Component(context_propagator, "ContextPropagator", "contextvars + threading", "Propagates trace context across Provider calls, tool dispatch, hook execution, subagent spawn, MCP calls.")
        Component(log_redactor, "LogRedactor", "regex patterns", "Strips secrets before any emission to structured logs or wire events. Always on. Configurable redaction rules.")
        Component(dual_output_adapter, "DualOutputAdapter", "tty detection", "CLI adapter: writes JSON to stdout + delegates to Renderer when isatty. HTTP/MCP: direct structured emission.")
        Component(instrumentation_mw, "InstrumentationMiddleware", "ASGI middleware", "Outermost HTTP request handler. Extracts/generates request_id; binds to contextvars.")
        Component(otel_exporter, "OTelExporter", "opentelemetry-sdk (optional)", "Behind otel feature flag. Bridges TraceCorrelator spans to OTel SDK. Zero dep when disabled.")
    }
}

System_Ext(agent_orch, "AgentOrchestrator", "Agent Group")
System_Ext(provider, "Provider", "Provider Group")
System_Ext(tool_registry, "ToolRegistry", "Tool Group")
System_Ext(wire_log, "WireLog", "Wire Log Group")
System_Ext(config_loader, "ConfigLoader", "Config Group")
System_Ext(renderer, "Renderer", "CLI Group")

System_Ext(stdout, "stdout", "Standard output stream")
System_Ext(otel_collector, "OTel Collector", "OTLP/gRPC endpoint for optional trace and metric export")
System_Ext(prometheus, "Prometheus", "Metrics collection and storage")

Rel(agent_orch, structured_logger, "emits agent lifecycle events to structured log (activate log / deactivate log)")
Rel(agent_orch, metrics_collector, "records token usage, latency, and tool call metrics")
Rel(agent_orch, context_propagator, "obtains trace context for event correlation")
Rel(agent_orch, wire_log, "appends domain events to wire log")

Rel(provider, structured_logger, "emits LLM request/response metadata to log")
Rel(provider, metrics_collector, "records LLM latency and token consumption metrics")
Rel(provider, context_propagator, "propagates trace context across LLM calls")

Rel(tool_registry, structured_logger, "emits tool execution events to log")
Rel(tool_registry, metrics_collector, "records tool call counts and duration metrics")
Rel(tool_registry, context_propagator, "propagates trace context across tool dispatch")

Rel(trace_correlator, context_propagator, "provides root trace and span context")
Rel(context_propagator, structured_logger, "injects trace_id and span_id into log records")
Rel(context_propagator, wire_log, "injects correlation IDs into wire events")
Rel(log_redactor, structured_logger, "sanitizes log records before emission")
Rel(log_redactor, wire_log, "sanitizes wire events before append")
Rel(dual_output_adapter, structured_logger, "delegates structured JSON emission to logger")
Rel(dual_output_adapter, stdout, "writes JSON to stdout", "stdout only — emit path ends here")
Rel(dual_output_adapter, renderer, "delegates human-readable output when isatty")
Rel(instrumentation_mw, context_propagator, "generates and binds request_id to context")
Rel(instrumentation_mw, metrics_collector, "records HTTP request duration and status")
Rel(instrumentation_mw, structured_logger, "emits HTTP request lifecycle events")
Rel(config_loader, structured_logger, "configures log level and format")
Rel(config_loader, metrics_collector, "enables or disables metrics emission")
Rel(config_loader, log_redactor, "configures redaction rules")
Rel(config_loader, otel_exporter, "enables or disables OTel feature")

Rel(structured_logger, stdout, "writes structured JSON logs to stdout", "stdout — emit path ends here")
Rel(metrics_collector, prometheus, "exposes /metrics for pull scrape", "HTTP GET — pull model only")
Rel(otel_exporter, otel_collector, "exports traces and metrics", "OTLP/gRPC — only when otel enabled")
Rel(trace_correlator, otel_exporter, "bridges spans to OTel SDK (optional)")
Rel(metrics_collector, otel_exporter, "bridges metrics to OTel SDK (optional)")
Rel(wire_log, structured_logger, "optionally projects domain events as structured log records")

legend right
    |<#E3F2FD>  **Controller** | CLI Group, API Group |
    |<#FFF3E0>  **Service**    | Agent, Router, Provider, Safety, Context Graph, Edit Strategy, Evaluation |
    |<#E8F5E9>  **Repository** | Session, Tool, Memory, Config, Git, Repo Intelligence |
    |<#F3E5F5>  **Infrastructure** | MCP, Sandbox, Observability, Wire Log, Hooks, Plugins |
end legend

!define CSR_CTRL participant "ServerRouter" as ctrl
!define CSR_SVC participant "StructuredLogger" as svc

' CSR lint markers
!define CSR_ACTOR actor "User" as user
!define CSR_CTRL participant "ServerRouter" as ctrl
!define CSR_SVC participant "AgentService" as svc
!define CSR_REPO participant "DataStore" as repo
@enduml
