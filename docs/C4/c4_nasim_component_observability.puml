title nasim — Observability Component Diagram

Container_Boundary(observability_boundary, "Observability Group") {
    Component(structured_logger, "StructuredLogger", "structlog", "Structured logging with trace correlation and log levels")
    Component(metrics_collector, "MetricsCollector", "", "Token usage, latency, tool call counts, error rates")
    Component(trace_correlator, "TraceCorrelator", "", "Request-scoped trace IDs linking LLM calls, tool calls, events")
}

Rel(structured_logger, trace_correlator, "attaches trace ID to log entries")
Rel(metrics_collector, trace_correlator, "records metrics per trace")

SHOW_LEGEND()
