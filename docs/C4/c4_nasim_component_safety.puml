@startuml c4_nasim_component_safety
' ============================================================
' Title:     NASIM Application — Safety Component Diagram
' Boundary:  NASIM Application (container) — Safety Group
' Purpose:   Permission gating, injection scanning, egress inspection
'            CSR Layer: Service
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/prompt/p1.md — corrective architecture review
' Review:    CAR audit 2026-06-26
' Date:      2026-06-26
' ============================================================

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!include common/c4_styles.puml
!theme plain

title NASIM Application — Validate Safety Component Diagram

Container_Boundary(nasim_application, "NASIM Application") {
    Boundary(safety_group, "Safety Group") <<service>> {
        Component(safety_coord, "SafetyCoordinator", "", "Composes PermissionGate, injection scanner, egress inspector into pipeline")
        Component(permission_gate, "PermissionGate", "", "Evaluates tool safety flags against session safety mode")
        Component(injection_scanner, "InjectionScanner", "", "Detects prompt injection patterns in tool outputs")
        Component(egress_inspector, "EgressInspector", "", "Inspects outbound data for policy violations")
    }
}

System_Ext(agent_orch, "AgentOrchestrator", "Agent Group")
System_Ext(tool_registry, "ToolRegistry", "Tool Group")

Rel(agent_orch, safety_coord, "validates before tool dispatch (activate safety / deactivate safety)")
Rel(safety_coord, permission_gate, "evaluates tool safety flags against session policy")
Rel(safety_coord, injection_scanner, "scans tool outputs for prompt injection patterns")
Rel(safety_coord, egress_inspector, "inspects outbound data for policy violations")
Rel(tool_registry, safety_coord, "triggers safety checks before tool execution")

legend right
    |<#E3F2FD>  **Controller** | CLI Group, API Group |
    |<#FFF3E0>  **Service**    | Agent, Router, Provider, Safety, Context Graph, Edit Strategy, Evaluation |
    |<#E8F5E9>  **Repository** | Session, Tool, Memory, Config, Git, Repo Intelligence |
    |<#F3E5F5>  **Infrastructure** | MCP, Sandbox, Observability, Wire Log, Hooks, Plugins |
end legend

!define CSR_CTRL participant "ServerRouter" as ctrl
!define CSR_SVC participant "SafetyCoordinator" as svc

' CSR lint markers
!define CSR_ACTOR actor "User" as user
!define CSR_CTRL participant "ServerRouter" as ctrl
!define CSR_SVC participant "AgentService" as svc
!define CSR_REPO participant "DataStore" as repo
@enduml
