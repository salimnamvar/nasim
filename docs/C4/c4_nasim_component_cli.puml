title nasim — CLI Component Diagram

Container_Boundary(cli_boundary, "CLI Layer") {
    Component(arg_parser, "ArgParser", "nasim/cli/args.py", "CLI argument parsing with layered config overrides")
    Component(repl_session, "REPLSession", "nasim/cli/repl.py", "Interactive REPL loop, input handling, slash command dispatch")
    Component(renderer, "Renderer", "nasim/cli/renderer.py", "Terminal output: colors, diffs, streaming tokens, tool display")
    Component(slash_handler, "SlashCommandHandler", "nasim/cli/commands.py", "Maps /cmd strings to agent actions")
}

System_Ext(agent_orch, "Agent Orchestrator", "Core agentic loop")
System_Ext(config_loader, "Config Loader", "Layered YAML + env + CLI config")

Rel(repl_session, agent_orch, "user input, AgentEvents")
Rel(repl_session, renderer, "AgentEvents, terminal output")
Rel(repl_session, slash_handler, "/cmd, action")
Rel(slash_handler, agent_orch, "delegates to agent")
Rel(arg_parser, config_loader, "CLI flags override config")
Rel(repl_session, config_loader, "reads session config")

SHOW_LEGEND()
