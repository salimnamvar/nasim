@startuml c4_nasim_component_cli
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!include common/c4_styles.puml
!theme plain

' ============================================================
' Title:     NASIM Application — CLI Component Diagram
' Boundary:  NASIM Application (container) — CLI Group
' Purpose:   CLI Group: Controller layer for terminal users.
'            REPLSession is the entry point; it delegates to
'            AgentOrchestrator (Service layer) and renders
'            AgentEvents to terminal via Renderer.
'            CSR Layer: Controller
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/entities.md
' Review:    CAR audit 2026-06-26
' Date:      2026-06-26
' ============================================================

title NASIM Application — CLI Component Diagram

Person(user, "User", "Developer using NASIM Application")

Boundary(nasim_application, "NASIM Application") {
    Boundary(cli_group, "CLI Group") <<controller>> {
        Component(arg_parser, "ArgParser", "", "CLI argument parsing with layered config overrides")
        Component(repl_session, "REPLSession", "", "Interactive REPL loop, input handling, slash command dispatch")
        Component(renderer, "Renderer", "", "Terminal output: colors, diffs, streaming tokens, tool display")
        Component(slash_handler, "SlashCommandHandler", "", "Maps /cmd strings to agent actions")
    }
}

Component_Ext(agent_orch, "AgentOrchestrator", "Agent Group")
Component_Ext(config_loader, "ConfigLoader", "Config Group")

Rel(user, repl_session, "types commands", "terminal REPL")
Rel(repl_session, agent_orch, "delegates agent tasks to orchestrator")
Rel(repl_session, renderer, "converts AgentEvents to terminal output")
Rel(repl_session, slash_handler, "forwards parsed /cmd to dispatch handler")
Rel(slash_handler, agent_orch, "dispatches slash command as agent task")
Rel(arg_parser, config_loader, "CLI flags override config")

legend right
    |<#E3F2FD>  **Controller** | CLI Group, API Group |
    |<#FFF3E0>  **Service**    | Agent, Router, Provider, Safety, Context Graph, Edit Strategy, Evaluation |
    |<#E8F5E9>  **Repository** | Session, Tool, Memory, Config, Git, Repo Intelligence |
    |<#F3E5F5>  **Infrastructure** | MCP, Sandbox, Observability, Wire Log, Hooks, Plugins |
end legend

@enduml
