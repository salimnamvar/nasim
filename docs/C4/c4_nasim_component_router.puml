@startuml c4_nasim_component_router
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
!include common/c4_styles.puml

' ============================================================
' Title:     NASIM APPLICATION — Router Component Diagram
' Boundary:  NASIM APPLICATION (container) — Router Group
' Purpose:   Model selection, fallback chains, capability queries
'            CSR Layer: Service
' Milestone: v1.0
' Version:   9.0.0
' Source:    docs/prompt/p1.md — corrective architecture review
' Review:    —
' ============================================================

LAYOUT_WITH_LEGEND()
title NASIM APPLICATION — Router Component Diagram

Boundary(nasim_application, "NASIM APPLICATION") {
    Boundary(router_group, "Router Group") <<service>> {
        Component(model_router, "ModelRouter", "", "Model selection, fallback chains, task classification, routing strategies")
        Component(fallback_chain, "FallbackChain", "", "Ordered provider failover chain with retry and exponential backoff")
    }
}

Component_Ext(agent_orch, "AgentOrchestrator", "Agent Group")
Component_Ext(provider, "Provider", "Provider Group")

Rel(agent_orch, model_router, "route model selection")
Rel(model_router, provider, "route to provider")
Rel(model_router, fallback_chain, "trigger failover")
Rel(fallback_chain, provider, "failover to next provider")

@enduml
