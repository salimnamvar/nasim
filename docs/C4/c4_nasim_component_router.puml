' ============================================================
' Title:     NASIM Application — Router Component Diagram
' Boundary:  NASIM Application (container) — Router Group
' Purpose:   Model selection, fallback chains, capability queries
'            CSR Layer: Service
'            Cross-boundary callers shown as System_Ext (opaque references).
'            Component_Ext is not a standard C4-PlantUML macro and is
'            forbidden per AU-01. Callers/targets are internal components
'            in other groups — see their dedicated component diagrams.
' Milestone: v1.0
' Version:   9.2.0
' Source:    docs/entities.md, .nasim/agents/c4_architect.md
' Review:    AU-01 fix — 2026-06-27
' Date:      2026-06-27
' ============================================================

@startuml c4_nasim_component_router
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
!include common/c4_styles.puml


title NASIM Application — Router Component Diagram

System_Ext(agent_sys, "Agent Group", "Caller — AgentOrchestrator dispatches model selection; see c4_nasim_component_agent.puml")
System_Ext(provider_sys, "Provider Group", "Target — LiteLLMProxy executes the selected model; see c4_nasim_component_provider.puml")

Container_Boundary(nasim_application, "NASIM Application") {
    Boundary(router_group, "Router Group") <<service>> {
        Component(model_router, "ModelRouter", "", "Model selection, fallback chains, task classification, routing strategies")
        Component(fallback_chain, "FallbackChain", "", "Ordered provider failover chain with retry and exponential backoff")
    }
}

Rel(agent_sys, model_router, "route model selection")
Rel(model_router, provider_sys, "route to provider")
Rel(model_router, fallback_chain, "trigger failover")
Rel(fallback_chain, provider_sys, "failover to next provider")

legend right
    |<#E3F2FD>  **Controller** | CLI Group, API Group |
    |<#FFF3E0>  **Service**    | Agent, Router, Provider, Safety, Context Graph, Edit Strategy, Evaluation |
    |<#E8F5E9>  **Repository** | Session, Tool, Memory, Config, Git, Repo Intelligence |
    |<#F3E5F5>  **Infrastructure** | MCP, Sandbox, Observability, Wire Log, Hooks, Plugins |
end legend

@enduml
