@startuml nasim_component_provider
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain

' ============================================================
' Title: nasim — Provider Component Diagram
' Boundary: nasim core library — Provider group
' Purpose: Universal LLM provider abstraction via litellm proxy (100+ providers)
' Milestone: v1.0
' Version: 6.0.0
' Source: docs/audit/audit.2026.06.20.deep.domain.audit.md
' Review: —
' ============================================================

LAYOUT_LEFT_RIGHT()
LAYOUT_WITH_LEGEND()

title nasim — Provider Components

' ============================================================
' Provider Group
' ============================================================

Container_Boundary(provider_boundary, "Provider Group") {

    Component(provider, "Provider", "Protocol", "Unified interface: chat(), chat_stream(), model_name. All providers route through litellm.")

    Component(litellm_proxy, "LiteLLM Proxy", "litellm library", "Universal LLM proxy: 100+ providers via model string prefix (anthropic/, openai/, gemini/, deepseek/, ollama/, etc.)")
}

' ============================================================
' External: LLM Backends (consolidated — litellm routes to 100+)
' ============================================================

System_Ext(all_llm_backends, "100+ LLM Backends", "Unified via litellm. Includes cloud (OpenAI, Anthropic, Google, DeepSeek, Mistral, Groq, Cohere, etc.) and local (Ollama, vLLM, LM Studio)")

' ============================================================
' Provider Relationships
' ============================================================

Rel(provider, litellm_proxy, "delegates all LLM calls")
Rel(litellm_proxy, all_llm_backends, "routes via model string prefix", "HTTP/JSON")

@enduml
