title nasim — Provider Component Diagram

Container_Boundary(provider_boundary, "Provider Group") {
    Component(provider_proto, "Provider", "Protocol", "LLM provider interface: chat, chat_stream, model_name")
    Component(provider_factory, "ProviderFactory", "", "Reads config, instantiates correct provider class")
    Component(model_router, "ModelRouter", "", "Model selection, fallback chains, task classification")
    Component(provider_caps, "ProviderCapabilities", "", "Capability declaration: streaming, tools, max_tokens, vision")
    Component(fallback_chain, "FallbackChain", "", "Circuit breaker + retry + provider failover")
    Component(ollama_provider, "OllamaProvider", "", "Ollama /api/chat: sync + streaming")
    Component(openai_provider, "OpenAIProvider", "", "OpenAI Chat Completions API")
    Component(anthropic_provider, "AnthropicProvider", "", "Anthropic Messages API")
}

System_Ext(ollama_api, "Ollama Server", "HTTP/JSON")
System_Ext(openai_api, "OpenAI API", "HTTP/JSON")
System_Ext(anthropic_api, "Anthropic API", "HTTP/JSON")

Rel(provider_factory, provider_proto, "creates instance")
Rel(model_router, provider_proto, "routes to provider")
Rel(model_router, provider_caps, "queries capabilities")
Rel(model_router, fallback_chain, "triggers failover")
Rel(ollama_provider, provider_proto, "implements")
Rel(openai_provider, provider_proto, "implements")
Rel(anthropic_provider, provider_proto, "implements")
Rel(ollama_provider, ollama_api, "HTTP POST /api/chat", "JSON")
Rel(openai_provider, openai_api, "HTTP POST /v1/chat/completions", "JSON")
Rel(anthropic_provider, anthropic_api, "HTTP POST /v1/messages", "JSON")

SHOW_LEGEND()
