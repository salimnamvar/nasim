@startuml c4_nasim_component_provider
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
!include common/c4_styles.puml

' ============================================================
' Title:     NASIM Application — Provider Component Diagram
' Boundary:  NASIM Application (container) — Provider Group
' Purpose:   Provider Group: universal LLM abstraction via litellm.
'            Provider is a Protocol — all LLM calls route through
'            LiteLLM Proxy to 100+ backends without per-provider code.
'            CSR Layer: Service
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/entities.md
' Review:    CAR audit 2026-06-26
' Date:      2026-06-26
' ============================================================

title NASIM Application — Provider Component Diagram

Boundary(nasim_application, "NASIM Application") {
    Boundary(provider_group, "Provider Group") <<service>> {
        Component(provider, "Provider", "Protocol", "Unified interface: chat(), chat_stream(), model_name, capabilities. All providers route through litellm.")
        Component(litellm_proxy, "LiteLLM Proxy", "litellm library", "Universal LLM proxy: 100+ providers via model string prefix (anthropic/, openai/, gemini/, deepseek/, ollama/, etc.)")
        Component(provider_caps, "ProviderCapabilities", "", "Per-model capability metadata: supports_tools, supports_vision, supports_streaming, max_context, supports_prompt_caching.")
    }
}

Component_Ext(agent_orch, "AgentOrchestrator", "Agent Group")
Component_Ext(model_router, "ModelRouter", "Router Group")
System_Ext(all_llm_backends, "LLM Backends", "Unified via litellm: OpenAI, Anthropic, Google, DeepSeek, Ollama, vLLM, and 100+ providers via model string prefix")

Rel(agent_orch, provider, "invokes LLM inference via provider protocol")
Rel(model_router, provider_caps, "queries capabilities for model selection")
Rel(provider, litellm_proxy, "delegates all LLM calls to universal proxy")
Rel(provider, provider_caps, "exposes capability metadata to callers")
Rel(litellm_proxy, all_llm_backends, "routes via model string prefix", "HTTP/JSON")

legend right
    |<#E3F2FD>  **Controller** | CLI Group, API Group |
    |<#FFF3E0>  **Service**    | Agent, Router, Provider, Safety, Context Graph, Edit Strategy, Evaluation |
    |<#E8F5E9>  **Repository** | Session, Tool, Memory, Config, Git, Repo Intelligence |
    |<#F3E5F5>  **Infrastructure** | MCP, Sandbox, Observability, Wire Log, Hooks, Plugins |
end legend

@enduml
