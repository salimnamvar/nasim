@startuml c4_nasim_component_tools
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain


' ============================================================
' Title:     nasim — Tools Component Diagram
' Boundary:  nasim core library — Tool group
' Purpose:   Tool layer internal components including repo intelligence and review tools
' Milestone: v1.0
' Version:   6.0.0
' Source:    docs/audit/audit.2026.06.20.deep.domain.audit.md
' Review:    —
