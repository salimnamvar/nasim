title nasim — Tools Component Diagram

Container_Boundary(tool_boundary, "Tool Group") {
    Component(tool_abc, "Tool", "ABC", "Base tool: name, description, parameters, safe, execute")
    Component(tool_registry, "ToolRegistry", "", "Instance-based registry, dynamic registration for MCP")
    Component(file_tools, "FileTools", "", "ReadFileTool, WriteFileTool, EditFileTool")
    Component(search_tools, "SearchTools", "", "GrepTool, GlobTool, FindFileTool")
    Component(shell_tool, "ShellTool", "", "Shell command execution via sandbox with timeout")
    Component(dir_tool, "DirTool", "", "List directory contents")
    Component(web_tools, "WebTools", "", "WebFetchTool, WebSearchTool")
    Component(git_tool, "GitTool", "", "Git status, diff, commit operations")
    Component(lsp_tool, "LspTool", "", "LSP operations: hover, definition, references, symbols")
    Component(subagent_tool, "SubagentTool", "", "Spawns child agents via SubagentCoordinator")
    Component(todo_tool, "TodoTool", "", "Task tracking within session")
    Component(memory_tool, "MemoryTool", "", "Persist and retrieve cross-session knowledge")
    Component(plan_tool, "PlanTool", "", "Plan creation and management")
    Component(repo_map_tool, "RepoMapTool", "", "Generates and queries repository map summaries")
    Component(semantic_search_tool, "SemanticSearchTool", "", "Embedding-based semantic code search")
    Component(review_tool, "ReviewTool", "", "LLM-driven code review and quality assessment")
}

Container_Ext(sandbox_group, "Sandbox Group")
Container_Ext(repo_intelligence_group, "Repo Intelligence Group")
Container_Ext(provider_group, "Provider Group")
System_Ext(host_fs, "Host Filesystem")
System_Ext(web, "Web")
System_Ext(mcp_server, "MCP Server")
System_Ext(git_repo, "Git Repository")
System_Ext(lsp_server, "LSP Server")

Rel(tool_registry, tool_abc, "manages instances")
Rel(file_tools, tool_abc, "extends")
Rel(search_tools, tool_abc, "extends")
Rel(shell_tool, tool_abc, "extends")
Rel(dir_tool, tool_abc, "extends")
Rel(web_tools, tool_abc, "extends")
Rel(git_tool, tool_abc, "extends")
Rel(lsp_tool, tool_abc, "extends")
Rel(subagent_tool, tool_abc, "extends")
Rel(todo_tool, tool_abc, "extends")
Rel(memory_tool, tool_abc, "extends")
Rel(plan_tool, tool_abc, "extends")
Rel(repo_map_tool, tool_abc, "extends")
Rel(semantic_search_tool, tool_abc, "extends")
Rel(review_tool, tool_abc, "extends")
Rel(shell_tool, sandbox_group, "executes via sandbox")
Rel(file_tools, host_fs, "path I/O")
Rel(search_tools, host_fs, "search files")
Rel(dir_tool, host_fs, "directory listing")
Rel(web_tools, web, "HTTP")
Rel(git_tool, git_repo, "git CLI")
Rel(lsp_tool, lsp_server, "LSP protocol")
Rel(repo_map_tool, repo_intelligence_group, "queries repo map")
Rel(semantic_search_tool, repo_intelligence_group, "vector search")
Rel(review_tool, provider_group, "LLM review call")
Rel(tool_registry, mcp_server, "discovers and registers MCP tools")

@enduml
