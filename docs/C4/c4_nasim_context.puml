@startuml c4_nasim_context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Context.puml
!theme plain

' ============================================================
' Title:     NASIM Application — System Context
' Boundary:  NASIM Application
' Purpose:   Show NASIM Application as a code-agent system with one User actor
'            and all external systems it depends on or is consumed by.
'
'            ABSTRACTION LEVEL NOTES:
'            This is Level 1 (Context). It shows what the system IS and
'            what it INTERACTS with — not how it works internally.
'            Internal implementation details (tree_sitter, embedding_model,
'            vector_store, CLI vs HTTP entry points) belong in Container
'            or Component diagrams and are intentionally omitted here.
'
' Milestone: v1.0
' Version:   9.0.0
' Source:    docs/entities.md
' Review:    —
' ============================================================

LAYOUT_LEFT_RIGHT()
LAYOUT_WITH_LEGEND()

title NASIM Application — System Context

Person(user, "User", "Developer using NASIM Application as an AI coding assistant")

System(nasim_application, "NASIM Application", "AI-powered coding assistant that understands codebases, executes tasks, and delivers production-ready changes across files, tests, and documentation.")

System_Ext(llm_backend, "LLM Backend", "Multi-provider inference: Ollama, OpenAI, Anthropic, and 100+ providers via litellm")
System_Ext(host_fs, "Host Filesystem", "Project source code, configuration, and documentation files")
System_Ext(sandbox, "Sandbox Runtime", "OS-level process isolation (landlock, seccomp, bubblewrap) — untrusted commands execute here, not on the bare host")
System_Ext(web, "Web", "Documentation, package APIs, and search engines for live context retrieval")
System_Ext(mcp_server, "MCP Server", "Extension tools provided to NASIM Application via Model Context Protocol")
System_Ext(mcp_client, "MCP Client", "External tools and IDEs that consume NASIM Application's exposed capabilities via MCP")
System_Ext(git_repo, "Git Repository", "Version-controlled project files — branch state, history, and commits")
System_Ext(lsp_server, "LSP Server", "Language server providing code intelligence (definitions, references, diagnostics)")
System_Ext(plugin_dir, "Plugin Directory", "Community plugins installed at ~/.nasim/plugins/")
System_Ext(otel_collector, "OTel Collector", "OTLP/gRPC endpoint for optional trace and metric export")
System_Ext(obs_platform, "Observability Platform", "Log agent, Prometheus, Grafana — NASIM Application emits; platform owns collection, storage, and visualization")

Rel(user, nasim_application, "submits coding tasks and receives AI-generated changes, suggestions, and answers")
Rel(nasim_application, llm_backend, "sends context and receives code completions", "HTTP/JSON")
Rel(nasim_application, host_fs, "reads, writes, and searches project files", "path operations")
Rel(nasim_application, sandbox, "executes untrusted shell commands within OS-level isolation boundaries", "subprocess + OS primitives")
Rel(nasim_application, web, "fetches documentation and search results for task context", "HTTP")
Rel(nasim_application, mcp_server, "discovers and invokes extension tools", "stdio / SSE")
Rel(mcp_client, nasim_application, "invokes NASIM Application tools via MCP protocol", "stdio / SSE")
Rel(nasim_application, git_repo, "reads repository state and creates atomic commits", "git CLI")
Rel(nasim_application, lsp_server, "queries code intelligence for definitions and references", "LSP protocol")
Rel(nasim_application, plugin_dir, "discovers and loads community plugins at startup", "filesystem")
Rel(nasim_application, obs_platform, "emits structured logs to stdout; exposes /metrics for pull-scrape", "stdout + HTTP")
Rel(nasim_application, otel_collector, "exports traces and metrics (optional)", "OTLP/gRPC")

@enduml
