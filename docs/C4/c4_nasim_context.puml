@startuml c4_nasim_context
' ============================================================
' Title:     NASIM Service System — Context Diagram
' Boundary:  NASIM Service System
' Purpose:   Show NASIM Application with users and external systems
' Milestone: v1.0
' Version:   11.0.0
' Source:    docs/C4/README.md
' Review:    —
' ============================================================

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Context.puml
!theme plain

LAYOUT_LEFT_RIGHT()

title NASIM Service System — Context Diagram

Person(user, "Developer", "Uses NASIM as an AI coding assistant")

System(nasim, "NASIM Application", "AI coding agent that translates natural language into file changes")

System_Ext(llm, "LLM Backend", "Multi-provider inference via litellm")
System_Ext(host_fs, "Host Filesystem", "Project source code and configuration")
System_Ext(sandbox, "Sandbox Runtime", "OS-level process isolation")
System_Ext(web, "Web", "Documentation and search engines")
System_Ext(mcp_server, "MCP Server", "Extension tools via MCP protocol")
System_Ext(mcp_client, "MCP Client", "External tools consuming NASIM via MCP")
System_Ext(git, "Git Repository", "Version-controlled project files")
System_Ext(repo_intel, "Repo Intelligence Backend", "Tree-sitter, LSP, embeddings, vector store")
System_Ext(obs, "Observability Platform", "Logs, metrics, dashboards")

Rel(user, nasim, "submits coding tasks, receives AI-generated changes")
Rel(nasim, llm, "sends context, receives completions")
Rel(nasim, host_fs, "reads and writes project files")
Rel(nasim, sandbox, "runs commands in isolation")
Rel(nasim, web, "fetches documentation")
Rel(nasim, mcp_server, "invokes extension tools")
Rel(mcp_client, nasim, "consumes NASIM tools via MCP")
Rel(nasim, git, "reads state, creates commits")
Rel(nasim, repo_intel, "parses code, queries intelligence")
Rel(nasim, obs, "emits logs and metrics")

legend right
    |= Symbol |= Meaning |
    | Person | Human actor |
    | System | System of interest |
    | System_Ext | External system |
end legend

@enduml