@startuml c4_nasim_context
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Context.puml
!theme plain

' ============================================================
' Title:     NASIM Application — System Context
' Boundary:  NASIM Application
' Purpose:   Show NASIM Application as a code-agent system with one User actor
'            and all external systems it depends on or is consumed by.
'
'            ABSTRACTION LEVEL NOTES:
'            This is Level 1 (Context). It shows what the system IS and
'            what it INTERACTS with — not how it works internally.
'            No containers, no components, no protocols.
'
'            GROUPING DECISIONS:
'            - Plugin Directory is grouped under Host Filesystem because
'              plugins are accessed via filesystem reads at startup.
'            - Tree-sitter, Embedding Model, and Vector Store are grouped
'              as Code Intelligence services because they are all used by
'              the Repo Intelligence subsystem for code understanding.
'            - OTel Collector is grouped under Observability Platform
'              because it is part of the platform's collection pipeline.
'
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/entities.md, docs/C4/README.md
' Review:    —
' ============================================================

LAYOUT_LEFT_RIGHT()
LAYOUT_WITH_LEGEND()

title NASIM Application — System Context

Person(user, "User", "Developer using NASIM Application as an AI coding assistant")

System(nasim_application, "NASIM Application", "AI coding agent that interprets natural language tasks, orchestrates tools and LLM providers, and produces file-level changes with safety validation")

System_Ext(llm_backend, "LLM Backend", "Multi-provider inference: Ollama, OpenAI, Anthropic, and 100+ providers via litellm")
System_Ext(host_fs, "Host Filesystem", "Project source code, configuration, documentation, and community plugin files")
System_Ext(host_shell, "Host Shell", "OS-level subprocess execution for shell commands")
System_Ext(sandbox, "Sandbox Runtime", "OS-level process isolation: landlock, seccomp, bubblewrap for untrusted commands")
System_Ext(web, "Web", "Documentation, package APIs, and search engines for live context retrieval")
System_Ext(mcp_server, "MCP Server", "Extension tools provided to NASIM Application via Model Context Protocol")
System_Ext(mcp_client, "MCP Client", "External tools and IDEs that consume NASIM Application's exposed capabilities via MCP")
System_Ext(git_repo, "Git Repository", "Version-controlled project files: branch state, history, and commits")
System_Ext(lsp_server, "LSP Server", "Language server providing code intelligence: definitions, references, diagnostics")
System_Ext(code_intel, "Code Intelligence Services", "Tree-sitter (AST parsing), Embedding Model (vector generation), Vector Store (similarity search)")
System_Ext(obs_platform, "Observability Platform", "Log agent, Prometheus, Grafana, OTel Collector: NASIM Application emits; platform owns collection, storage, visualization")

Rel(user, nasim_application, "submits coding tasks and receives AI-generated changes, suggestions, and answers")
Rel(nasim_application, llm_backend, "sends context and receives code completions")
Rel(nasim_application, host_fs, "reads, writes, and searches project files and plugins")
Rel(nasim_application, host_shell, "executes shell commands via sandbox isolation")
Rel(nasim_application, sandbox, "runs untrusted commands within OS-level isolation boundaries")
Rel(nasim_application, web, "fetches documentation and search results for task context")
Rel(nasim_application, mcp_server, "discovers and invokes extension tools")
Rel(mcp_client, nasim_application, "invokes NASIM Application tools via MCP protocol")
Rel(nasim_application, git_repo, "reads repository state and creates atomic commits")
Rel(nasim_application, lsp_server, "queries code intelligence for definitions and references")
Rel(nasim_application, code_intel, "parses ASTs, generates embeddings, and performs similarity search")
Rel(nasim_application, obs_platform, "emits structured logs, traces, and metrics for collection")

@enduml
