@startuml c4_nasim_context
' ============================================================
' Title:     NASIM Service System — Context Diagram
' Boundary:  NASIM Service System
' Purpose:   Show NASIM Service with users and external systems
' Milestone: v1.0
' Version:   13.0.0
' Source:    docs/C4/README.md
' ============================================================
' REVIEW CHANGES:
'   - Added trust/security boundary via $tags (trusted/untrusted)
'   - Added direction arrows (→ / ⟷) in labels to disambiguate flow
'   - Added (R/O) or (R/W) to system descriptions for access semantics
'   - Replaced !theme plain with common/c4_styles.puml for consistent styling
' ============================================================

' TODO: Pin to a specific commit hash for reproducibility
' e.g., replace v2.10.0 with <COMMIT_HASH> after verifying desired SHA
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Context.puml
!include common/c4_styles.puml
skinparam linetype polyline

LAYOUT_LEFT_RIGHT()

title NASIM Service System — Context Diagram

Person(user, "Developer", "Uses NASIM as an AI coding assistant")

System(nasim_service, "NASIM Service", "AI coding agent service: translates natural language into file changes, manages tool orchestration and safety")

' ── Trusted External Systems (internal/controlled) ──
' (R/W) = read-write, (R/O) = read-only
System_Ext(llm, "LLM Backend", "Multi-provider inference via litellm (R/O)", $tags="trusted")
System_Ext(host_fs, "Host Filesystem", "Project source code and configuration (R/W)", $tags="trusted")
System_Ext(sandbox, "Sandbox Runtime", "OS-level process isolation (R/W)", $tags="trusted")
System_Ext(git, "Git Repository", "Version-controlled project files (R/W)", $tags="trusted")
System_Ext(repo_intel, "Repo Intelligence Backend", "Tree-sitter, LSP, embeddings, vector store (R/W)", $tags="trusted")

' ── Untrusted External Systems (external/uncontrolled) ──
System_Ext(web, "Web", "Documentation and search engines (R/O)", $tags="untrusted")
System_Ext(mcp_server, "MCP Server", "Extension tools via MCP protocol (R/W)", $tags="untrusted")
System_Ext(mcp_client, "MCP Client", "External tools consuming NASIM via MCP (R/O)", $tags="untrusted")


' Relationships — direction arrow in label: → one-way, ⟷ bidirectional
Rel(user, nasim_service, "⟷ submits coding tasks, receives changes")
Rel(nasim_service, llm, "→ sends context, receives completions")
Rel(nasim_service, host_fs, "⟷ reads and writes project files")
Rel(nasim_service, sandbox, "→ runs commands in isolation")
Rel(nasim_service, web, "→ fetches documentation")
Rel(nasim_service, mcp_server, "⟷ invokes extension tools")
Rel(mcp_client, nasim_service, "→ consumes NASIM tools via MCP")
Rel(nasim_service, git, "⟷ reads state, creates commits")
Rel(nasim_service, repo_intel, "⟷ parses code, queries intelligence")

legend right
    |= <color:#000000>Symbol |= <color:#000000>Meaning |
    | <color:#000000>Person | <color:#000000>Human actor |
    | <color:#000000>System | <color:#000000>System of interest |
    | <color:#000000>System_Ext | <color:#000000>External system |
    |<#E8F5E9> <color:#1B5E20>**Trusted**</color> | <color:#000000>Internal/controlled external system</color> |
    |<#FFEBEE> <color:#B71C1C>**Untrusted**</color> | <color:#000000>External/uncontrolled system</color> |
end legend

@enduml
