@startuml c4_nasim_component_hooks
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
!include common/c4_styles.puml


' ============================================================
' Title:     NASIM Application — Hooks Component Diagram
' Boundary:  NASIM Application (container) — Hooks Group
' Purpose:   Pre/post hooks for tool use and LLM calls
'            CSR Layer: Infrastructure
' Milestone: v1.0
' Version:   9.0.0
' Source:    docs/prompt/p1.md — corrective architecture review
' Review:    docs/audit/audit.2026.06.20.comprehensive.reference.audit.md
' Date:      2026-06-25
' ============================================================

LAYOUT_WITH_LEGEND()
title NASIM Application — Hooks Component Diagram

Boundary(nasim_application, "NASIM Application") {
    Boundary(hooks_group, "Hooks Group") <<infrastructure>> {
        Component(hook_manager, "HookManager", "nasim/hooks/manager.py", "Registers, discovers, and executes hooks in priority order")
    }
}

Component_Ext(agent_orch, "AgentOrchestrator", "Agent Group")
Component_Ext(tool_registry, "ToolRegistry", "Tool Group")
Component_Ext(plugin_loader, "PluginLoader", "Plugins Group")

Rel(agent_orch, hook_manager, "triggers PreToolUse, PostToolUse, PreLLMCall, PostLLMCall")
Rel(plugin_loader, hook_manager, "registers plugin hooks")
Rel(hook_manager, tool_registry, "queries tool metadata for hook dispatch")

@enduml
