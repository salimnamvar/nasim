@startuml c4_nasim_component_session
' ============================================================
' Title:     NASIM Application — Session Component Diagram
' Boundary:  NASIM Application (container) — Session Group
' Purpose:   Session layer internal components
'            CSR Layer: Repository
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/prompt/p1.md — corrective architecture review
' Review:    CAR audit 2026-06-26
' Date:      2026-06-26
' ============================================================

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
!include common/c4_styles.puml

title NASIM Application — Recall Session Component Diagram

Container_Boundary(nasim_application, "NASIM Application") {
    Boundary(session_group, "Session Group") <<repository>> {
        Component(session_store, "SessionStore", "", "Persists/loads message history to ~/.nasim/sessions/ as JSON Lines")
        Component(session_versioning, "SessionVersioning", "", "Snapshots and undo for session state")
        Component(session_search, "SessionSearch", "", "Cross-session search via FTS5 index")
        Component(session_fork, "SessionFork", "", "Branch conversations from any point")
    }
}

System_Ext(session_dir, "Session Directory", "~/.nasim/sessions/<session-id>/")

Rel(session_store, session_dir, "reads and writes JSON Lines files (activate session / deactivate session)")
Rel(session_versioning, session_store, "creates snapshots and restores state")
Rel(session_search, session_store, "indexes and queries session content")
Rel(session_fork, session_store, "copies session state for branching")

legend right
    |<#E3F2FD>  **Controller** | CLI Group, API Group |
    |<#FFF3E0>  **Service**    | Agent, Router, Provider, Safety, Context Graph, Edit Strategy, Evaluation |
    |<#E8F5E9>  **Repository** | Session, Tool, Memory, Config, Git, Repo Intelligence |
    |<#F3E5F5>  **Infrastructure** | MCP, Sandbox, Observability, Wire Log, Hooks, Plugins |
end legend

!define CSR_CTRL participant "ServerRouter" as ctrl
!define CSR_REPO participant "SessionStore" as repo

' CSR lint markers
!define CSR_ACTOR actor "User" as user
!define CSR_CTRL participant "ServerRouter" as ctrl
!define CSR_SVC participant "AgentService" as svc
!define CSR_REPO participant "DataStore" as repo
@enduml
