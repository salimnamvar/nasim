title nasim — MCP Component Diagram

Container_Boundary(mcp_boundary, "MCP Group") {
    Component(mcp_client_rt, "MCPClientRuntime", "nasim/mcp/client.py", "Connects to external MCP servers via stdio/SSE transport")
    Component(mcp_server_rt, "MCPServerRuntime", "nasim/mcp/server.py", "Exposes nasim tools to external MCP clients via stdio/SSE")
    Component(mcp_tool_adapter, "MCPToolAdapter", "nasim/mcp/adapter.py", "Wraps MCP server tools into nasim Tool ABC format")
    Component(mcp_discovery, "MCPDiscovery", "nasim/mcp/discovery.py", "Discovers and registers MCP server tools at startup from config")
}

System_Ext(mcp_server, "MCP Server", "External extension tools")
System_Ext(mcp_client, "MCP Client", "External tool consumers")
System_Ext(tool_registry, "Tool Registry", "Instance-based tool registry")

Rel(mcp_client_rt, mcp_server, "connects via stdio/SSE")
Rel(mcp_client_rt, mcp_discovery, "discovers tools")
Rel(mcp_discovery, mcp_tool_adapter, "registers discovered tools")
Rel(mcp_tool_adapter, tool_registry, "registers as nasim tools")
Rel(mcp_server_rt, tool_registry, "exposes nasim tools to external clients")
Rel(mcp_server_rt, mcp_client, "serves MCP protocol via stdio/SSE")

@enduml
