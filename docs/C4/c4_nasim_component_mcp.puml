@startuml c4_nasim_component_mcp
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
!include common/c4_styles.puml

' ============================================================
' Title:     NASIM Application — MCP Component Diagram
' Boundary:  NASIM Application (container) — MCP Group
' Purpose:   Model Context Protocol as first-class subsystem
'            CSR Layer: Infrastructure
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/prompt/p1.md — corrective architecture review
' Review:    CAR audit 2026-06-26
' Date:      2026-06-26
' ============================================================

title NASIM Application — MCP Component Diagram

Boundary(nasim_application, "NASIM Application") {
    Boundary(mcp_group, "MCP Group") <<infrastructure>> {
        Component(mcp_client_rt, "MCPClientRuntime", "nasim/mcp/client.py", "Connects to external MCP servers via stdio/SSE transport")
        Component(mcp_server_rt, "MCPServerRuntime", "nasim/mcp/server.py", "Exposes NASIM Application tools to external MCP clients via stdio/SSE")
        Component(mcp_tool_adapter, "MCPToolAdapter", "nasim/mcp/adapter.py", "Wraps MCP server tools into NASIM Application Tool ABC format")
        Component(mcp_discovery, "MCPDiscovery", "nasim/mcp/discovery.py", "Discovers and registers MCP server tools at startup from config")
    }
}

System_Ext(mcp_server, "MCP Server", "External extension tools")
System_Ext(mcp_client, "MCP Client", "External tool consumers")
Component_Ext(tool_registry, "ToolRegistry", "Tool Group")

Rel(mcp_client_rt, mcp_server, "invokes extension tool operations on external MCP servers")
Rel(mcp_client_rt, mcp_discovery, "discovers available tools at startup")
Rel(mcp_discovery, mcp_tool_adapter, "registers discovered tools for adaptation")
Rel(mcp_tool_adapter, tool_registry, "registers adapted tools into Tool Registry")
Rel(mcp_server_rt, tool_registry, "exposes NASIM tools to external MCP clients")
Rel(mcp_server_rt, mcp_client, "serves NASIM capabilities to external consumers")

legend right
    |<#E3F2FD>  **Controller** | CLI Group, API Group |
    |<#FFF3E0>  **Service**    | Agent, Router, Provider, Safety, Context Graph, Edit Strategy, Evaluation |
    |<#E8F5E9>  **Repository** | Session, Tool, Memory, Config, Git, Repo Intelligence |
    |<#F3E5F5>  **Infrastructure** | MCP, Sandbox, Observability, Wire Log, Hooks, Plugins |
end legend

@enduml
