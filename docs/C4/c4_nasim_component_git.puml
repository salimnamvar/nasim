title nasim — Git Component Diagram

Container_Boundary(git_boundary, "Git Layer") {
    Component(git_integration, "GitIntegration", "nasim/git/integration.py", "Auto-commit after file edits, branch awareness, diff tracking")
    Component(git_status, "GitStatus", "nasim/git/status.py", "Read working tree status, staged changes, branch info")
    Component(git_commit, "GitCommit", "nasim/git/commit.py", "Create commits with conventional commit messages")
}

System_Ext(git_repo, "Git Repository", "Version control for project files")

Rel(git_integration, git_status, "reads current state")
Rel(git_integration, git_commit, "creates commits")
Rel(git_status, git_repo, "git status, git diff")
Rel(git_commit, git_repo, "git commit, git add")

SHOW_LEGEND()
