!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
!theme plain
LAYOUT_LEFT_RIGHT()
LAYOUT_WITH_LEGEND()


' ============================================================
' Title:     nasim — Plugins Component Diagram
' Boundary:  nasim core library — Plugins group
' Purpose:   Plugin discovery, loading, dynamic tool/hook registration
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/prompt/p1.md — corrective architecture review
' Review:    docs/audit/audit.2026.06.20.comprehensive.reference.audit.md
' ============================================================

title nasim — Plugins Component Diagram

Container_Boundary(plugins_boundary, "Plugins Group") {
    Component(plugin_loader, "PluginLoader", "nasim/plugins/loader.py", "Discovers and loads plugins from ~/.nasim/plugins/")
    Component(plugin_manifest, "PluginManifest", "nasim/plugins/manifest.py", "Plugin metadata: name, version, tools, hooks, dependencies")
}

System_Ext(plugin_dir, "Plugin Directory", "~/.nasim/plugins/")
System_Ext(tool_registry, "Tool Registry", "Instance-based tool registry")
System_Ext(hook_manager, "Hook Manager", "Hook registration")

Rel(plugin_loader, plugin_dir, "discovers plugin manifests")
Rel(plugin_loader, plugin_manifest, "parses manifest")
Rel(plugin_loader, tool_registry, "registers plugin tools")
Rel(plugin_loader, hook_manager, "registers plugin hooks")

@enduml
