@startuml c4_nasim_component_repo_intelligence
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
!include common/c4_styles.puml


' ============================================================
' Title:     NASIM Application — Repo Intelligence Component Diagram
' Boundary:  NASIM Application (container) — Repo Intelligence Group
' Purpose:   Codebase intelligence: AST indexing, symbol graph, semantic search, repo mapping
'            CSR Layer: Repository
'
'            CONTEXT-LEVEL NOTE:
'            At Context level (c4_nasim_context.puml), Tree-sitter,
'            Embedding Model, Vector Store, and LSP Server are grouped
'            under "Repo Intelligence Backend" for visual simplicity.
'            This Component diagram shows their distinct responsibilities
'            and the internal components that consume them.
' Milestone: v1.0
' Version:   9.0.0
' Source:    docs/audit/audit.2026.06.20.deep.domain.audit.md
' Review:    —
' ============================================================

LAYOUT_WITH_LEGEND()
title NASIM Application — Repo Intelligence Component Diagram

Boundary(nasim_application, "NASIM Application") {
    Boundary(repo_intel_group, "Repo Intelligence Group") <<repository>> {
        Component(repo_intel_mgr, "RepoIntelligenceManager", "", "Orchestrates codebase intelligence: indexing, search, ranking, repo mapping")
        Component(ast_index_adapter, "ASTIndexAdapter", "", "Tree-sitter based AST indexing for symbol extraction")
        Component(symbol_graph, "SymbolGraph", "", "Cross-file symbol reference graph: definitions, usages, imports")
        Component(embedding_adapter, "EmbeddingAdapter", "", "Wraps embedding model API for vector generation")
        Component(semantic_search_svc, "SemanticSearchService", "", "Vector similarity search over code embeddings with relevance ranking")
        Component(repo_map_builder, "RepoMapBuilder", "", "Generates hierarchical repo map summaries for context injection")
    }
}

System_Ext(tree_sitter, "Tree-sitter", "Incremental parser for source code AST")
System_Ext(embedding_model, "Embedding Model", "Code embedding model (local or API)")
System_Ext(vector_store, "Vector Store", "Persistent vector storage for code embeddings")
System_Ext(host_fs, "Host Filesystem", "Source code files to index")

Rel(repo_intel_mgr, ast_index_adapter, "indexes source files")
Rel(repo_intel_mgr, symbol_graph, "builds reference graph")
Rel(repo_intel_mgr, embedding_adapter, "generates embeddings")
Rel(repo_intel_mgr, semantic_search_svc, "performs vector search with ranking")
Rel(repo_intel_mgr, repo_map_builder, "builds repo map")
Rel(ast_index_adapter, tree_sitter, "parses AST")
Rel(ast_index_adapter, symbol_graph, "feeds symbol data")
Rel(ast_index_adapter, host_fs, "reads source files")
Rel(embedding_adapter, embedding_model, "API call for vectors")
Rel(embedding_adapter, vector_store, "stores vectors")
Rel(semantic_search_svc, vector_store, "query vectors")
Rel(semantic_search_svc, symbol_graph, "ranks by relevance and recency")
Rel(repo_map_builder, symbol_graph, "reads structure")
Rel(repo_map_builder, host_fs, "traverses directories")

@enduml
