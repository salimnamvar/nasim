Rel(agent_orch, subagent_coord, "spawn, collect")
Rel(agent_orch, error_boundary, "handle errors")
Rel(agent_orch, persona_mgr, "load persona")
Rel(agent_orch, structured_logger, "emit logs")
Rel(agent_orch, metrics_collector, "record metrics")
Rel(agent_orch, memory_store, "persist, retrieve")
Rel(agent_orch, session_store, "save, load")
Rel(agent_orch, agent_events, "yield events")
Rel(conv_history, compactor, "compact when exceeded")
Rel(compactor, provider, "secondary LLM call")
Rel(model_router, provider, "route to provider")
Rel(model_router, provider_caps, "query capabilities")
Rel(model_router, fallback_chain, "trigger failover")
Rel(provider_factory, provider, "instantiates")
Rel(tool_registry, sandbox_executor, "sandboxed execution")
Rel(tool_registry, mcp_tool_adapter, "MCP tools")
Rel(mcp_client_rt, mcp_discovery, "discover tools")
Rel(mcp_discovery, mcp_tool_adapter, "register tools")
Rel(mcp_server_rt, tool_registry, "expose tools")
Rel(hook_manager, hook_types, "manages hooks")
Rel(plugin_loader, plugin_manifest, "loads manifest")
Rel(plugin_loader, hook_manager, "registers hooks")
Rel(plugin_loader, tool_registry, "registers tools")
Rel(session_versioning, session_store, "snapshots")
Rel(session_search, session_store, "searches")
Rel(session_fork, session_store, "forks")
Rel(memory_store, memory_index, "indexes")
Rel(memory_store, memory_scope, "filters")
Rel(git_integration, git_status, "reads state")
Rel(git_integration, git_commit, "creates commits")
Rel(config_loader, config_schema, "produces config")

@enduml

