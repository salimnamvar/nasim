title nasim — Component Diagram

Container_Boundary(cli_boundary, "CLI (cli.py)") {
    Component(cli_main, "main", "cli.py", "Entry point, argument parsing, REPL loop")
}

Container_Boundary(agent_boundary, "Agent Core (agent.py)") {
    Component(agent, "Agent", "agent.py", "Orchestrates LLM + tool loop, holds messages, enforces max iterations")
}

Container_Boundary(llm_boundary, "LLM (llm.py)") {
    Component(ollama_client, "OllamaClient", "llm.py", "Ollama /api/chat client, sync + streaming, response parsing")
}

Container_Boundary(tool_boundary, "Tools (tools.py)") {
    Component(tool_registry, "TOOL_REGISTRY", "tools.py", "Decorator-based tool registration, OpenAI-compatible definitions")
    Component(execute_tool, "execute_tool()", "tools.py", "Dispatches tool calls by name")
    Component(file_tools, "FileTools", "tools.py", "read_file, write_file, edit_file")
    Component(shell_tool, "ShellTool", "tools.py", "shell_exec with timeout")
    Component(dir_tool, "DirTool", "tools.py", "list_dir")
}

System_Ext(ollama, "Ollama Server", "HTTP API")
System_Ext(host_fs, "Host Filesystem")
System_Ext(host_shell, "Host Shell")

Rel(cli_main, agent, "user input -> response")
Rel(agent, ollama_client, "chat(messages, tools)")
Rel(agent, execute_tool, "execute_tool(name, args)")
Rel(ollama_client, ollama, "HTTP POST", "JSON")
Rel(execute_tool, tool_registry, "lookup handler")
Rel(execute_tool, file_tools, "read/write/edit")
Rel(execute_tool, shell_tool, "subprocess")
Rel(execute_tool, dir_tool, "pathlib")
Rel(file_tools, host_fs, "path I/O")
Rel(shell_tool, host_shell, "subprocess")
Rel(dir_tool, host_fs, "directory listing")

SHOW_LEGEND()
