@startuml c4_nasim_component_overview
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
skinparam linetype polyline

' ============================================================
' Title:     nasim — Component Overview (cross-container)
' Boundary:  nasim code agent
' Purpose:   High-level view of all containers and their primary interactions
' Milestone: v1.0
' Version:   4.0.0
' Source:    docs/audit/audit.2026.06.20.comprehensive.reference.audit.md
' Review:    docs/audit/audit.2026.06.20.comprehensive.reference.audit.md
' ============================================================

title nasim — Component Overview (cross-container)

Container_Boundary(cli_boundary, "CLI Layer") {
    Component(arg_parser, "ArgParser", "click", "CLI argument parsing with layered overrides")
    Component(repl_session, "REPLSession", "click + rich", "Interactive REPL loop, input handling, slash command dispatch")
    Component(renderer, "Renderer", "rich", "Terminal output: streaming tokens, diffs, colors, tool display")
    Component(slash_handler, "SlashCommandHandler", "click", "Maps /cmd strings to actions")
}

Container_Boundary(agent_boundary, "Agent Layer") {
    Component(agent_orch, "AgentOrchestrator", "", "Core agentic loop: Provider call, tool dispatch, repeat. Yields AgentEvent objects")
    Component(conv_history, "ConversationHistory", "", "Owns message list + token count. Triggers compaction when budget exceeded")
    Component(compactor, "ContextCompactor", "", "Summarizes oldest exchanges via secondary LLM call")
    Component(perm_gate, "PermissionGate", "", "Per-tool safety check: ask, auto, off modes")
    Component(plan_session, "PlanSession", "", "Holds queued tool calls in plan mode. /approve drains the queue")
    Component(agent_events, "AgentEvent", "", "Event types: TextChunk, ToolStart, ToolResult, Error, Done")
    Component(subagent_mgr, "SubagentManager", "", "Parent-child agent orchestration with nesting limit of 5")
    Component(task_dispatcher, "TaskDispatcher", "", "Role-based task delegation: planner, architect, coder, reviewer")
    Component(error_boundary, "ErrorBoundary", "", "Structured error handling with recovery actions")
    Component(safety_pipeline, "SafetyPipeline", "", "Multi-stage safety: permission gate, injection scanner, egress inspector")
    Component(persona_loader, "PersonaLoader", "", "Runtime persona switching for specialized agent roles")
}

Container_Boundary(provider_boundary, "Provider Layer") {
    Component(provider, "Provider", "Protocol", "LLM provider interface: chat, chat_stream, model_name")
    Component(provider_factory, "ProviderFactory", "", "Reads config, instantiates correct provider backend")
    Component(model_router, "ModelRouter", "", "Model selection, fallback chains, task classification")
    Component(provider_caps, "ProviderCapabilities", "", "Capability declaration per provider: streaming, tools, max tokens")
    Component(fallback_chain, "FallbackChain", "", "Circuit breaker + retry + provider failover")
}

Container_Boundary(tool_boundary, "Tool Layer") {
    Component(tool_registry, "ToolRegistry", "", "Instance-based tool registry. find(name) returns Tool. Dynamic registration for MCP")
    Component(file_tools, "FileTools", "ABC", "ReadFileTool, WriteFileTool, EditFileTool")
    Component(search_tools, "SearchTools", "ABC", "GrepTool, GlobTool, FindFileTool")
    Component(shell_tool, "ShellTool", "ABC", "Shell command execution via sandbox with timeout")
    Component(web_tools, "WebTools", "ABC", "WebFetchTool, WebSearchTool")
    Component(git_tool, "GitTool", "ABC", "Git status, diff, commit operations")
    Component(mcp_adapter, "MCPToolAdapter", "", "Wraps MCP server tools into nasim Tool format")
    Component(lsp_tool, "LspTool", "ABC", "LSP operations: hover, definition, references, symbols")
    Component(subagent_tool, "SubagentTool", "ABC", "Spawns child agents as tool calls")
    Component(todo_tool, "TodoTool", "ABC", "Task tracking within session")
    Component(memory_tool, "MemoryTool", "ABC", "Persist and retrieve cross-session knowledge")
    Component(plan_tool, "PlanTool", "ABC", "Plan creation and management")
}

Container_Boundary(config_boundary, "Config Layer") {
    Component(config_loader, "ConfigLoader", "pydantic", "Loads global YAML, project YAML, env vars, CLI flags. Returns typed Config")
}

Container_Boundary(session_boundary, "Session Layer") {
    Component(session_store, "SessionStore", "pathlib + json", "Persists/loads message history to ~/.nasim/sessions/<id>/")
    Component(session_versioning, "SessionVersioning", "", "Snapshots and undo for session state")
    Component(session_search, "SessionSearch", "", "Cross-session search via FTS5")
    Component(session_fork, "SessionFork", "", "Branch conversations from any point")
}

Container_Boundary(server_boundary, "Server Layer") {
    Component(server_app, "ServerApp", "FastAPI", "ASGI application factory with middleware and route mounts")
    Component(server_router, "ServerRouter", "FastAPI Router", "ROD-compliant REST endpoints for sessions, messages, tools, config")
    Component(sse_handler, "SSEHandler", "SSE", "Server-Sent Events streaming for agent responses")
    Component(api_schema, "APISchema", "Pydantic", "Request/response models with AIP-193 error format")
}

Container_Boundary(sandbox_boundary, "Sandbox Layer") {
    Component(sandbox_executor, "SandboxExecutor", "", "OS-level process isolation: landlock, seccomp, bubblewrap")
}

Container_Boundary(observability_boundary, "Observability Layer") {
    Component(structured_logger, "StructuredLogger", "structlog", "Structured logging with trace correlation")
    Component(metrics_collector, "MetricsCollector", "", "Token usage, latency, tool call metrics")
}

Container_Boundary(memory_boundary, "Memory Layer") {
    Component(memory_store, "MemoryStore", "", "Cross-session knowledge persistence and retrieval")
}

Container_Boundary(git_boundary, "Git Layer") {
    Component(git_integration, "GitIntegration", "", "Auto-commit, branch awareness, diff tracking")
}

Rel(repl_session, agent_orch, "user input, AgentEvents")
Rel(repl_session, renderer, "AgentEvents, terminal output")
Rel(repl_session, slash_handler, "/cmd, action")

Rel(agent_orch, provider, "chat, stream")
Rel(agent_orch, tool_registry, "execute tools")
Rel(agent_orch, conv_history, "messages, token tracking")
Rel(agent_orch, perm_gate, "permission check before tool exec")
Rel(agent_orch, plan_session, "queue, drain in plan mode")
Rel(agent_orch, subagent_mgr, "spawn child agents")
Rel(agent_orch, task_dispatcher, "delegate role-based tasks")
Rel(agent_orch, error_boundary, "handle structured errors")
Rel(agent_orch, safety_pipeline, "multi-stage safety checks")
Rel(agent_orch, persona_loader, "switch agent persona")
Rel(conv_history, compactor, "compact when budget exceeded")

Rel(model_router, provider, "route to selected provider")
Rel(model_router, provider_caps, "query provider capabilities")
Rel(model_router, fallback_chain, "failover on provider error")
Rel(provider_factory, provider, "instantiates")

Rel(tool_registry, sandbox_executor, "sandboxed shell execution")
Rel(sandbox_executor, shell_tool, "wraps shell commands")

Rel(agent_orch, structured_logger, "emit structured logs")
Rel(agent_orch, metrics_collector, "record metrics")

Rel(agent_orch, memory_store, "persist, retrieve knowledge")

Rel(git_tool, git_integration, "git operations")

Rel(session_store, agent_orch, "save, load sessions")
Rel(session_versioning, session_store, "snapshots, undo")
Rel(session_search, session_store, "cross-session search")
Rel(session_fork, session_store, "branch conversations")

Rel(config_loader, agent_orch, "settings")
Rel(config_loader, provider, "provider config")
Rel(config_loader, tool_registry, "tool config")
Rel(config_loader, model_router, "routing config")

SHOW_LEGEND()

@enduml
