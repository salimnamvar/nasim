@startuml c4_nasim_component_overview
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
!theme plain


' ============================================================
' Title:     nasim — Component Overview
' Boundary:  nasim core library
' Purpose:   Cross-container view of all component groups and their interactions
' Milestone: v1.0
' Version:   5.0.0
' Source:    docs/prompt/p1.md — corrective architecture review
' Review:    docs/audit/audit.2026.06.20.comprehensive.reference.audit.md
' ============================================================

title nasim — Component Overview

System_Boundary(agent_group, "Agent Group") {
    Component(agent_orch, "AgentOrchestrator", "", "Core agentic loop: Provider call, tool dispatch, repeat. Yields AgentEvent objects")
    Component(conv_history, "ConversationHistory", "", "Owns message list and token count. Triggers compaction when budget exceeded")
    Component(compactor, "ContextCompactor", "", "Summarizes oldest exchanges via secondary LLM call")
    Component(safety_coord, "SafetyCoordinator", "", "Composes PermissionGate, injection scanner, egress inspector")
    Component(plan_session, "PlanSession", "", "Holds queued tool calls in plan mode. /approve drains the queue")
    Component(agent_events, "AgentEvent", "", "Event types: TextChunk, ToolStart, ToolResult, Error, Done")
    Component(subagent_coord, "SubagentCoordinator", "", "Parent-child agent orchestration with nesting limit 5")
    Component(error_boundary, "ErrorBoundary", "", "Structured error handling with recovery actions")
    Component(persona_mgr, "PersonaManager", "", "Runtime persona switching for specialized agent roles")
}

System_Boundary(provider_group, "Provider Group") {
    Component(provider, "Provider", "Protocol", "LLM provider interface: chat, chat_stream, model_name")
    Component(provider_factory, "ProviderFactory", "", "Reads config, instantiates correct provider backend")
    Component(model_router, "ModelRouter", "", "Model selection, fallback chains, task classification")
    Component(provider_caps, "ProviderCapabilities", "", "Capability declaration: streaming, tools, max_tokens")
    Component(fallback_chain, "FallbackChain", "", "Circuit breaker + retry + provider failover")
}

System_Boundary(tool_group, "Tool Group") {
    Component(tool_registry, "ToolRegistry", "", "Instance-based tool registry. find(name) returns Tool")
    Component(file_tools, "FileTools", "ABC", "ReadFileTool, WriteFileTool, EditFileTool")
    Component(search_tools, "SearchTools", "ABC", "GrepTool, GlobTool, FindFileTool")
    Component(shell_tool, "ShellTool", "ABC", "Shell command execution via sandbox")
    Component(web_tools, "WebTools", "ABC", "WebFetchTool, WebSearchTool")
    Component(git_tool, "GitTool", "ABC", "Git status, diff, commit operations")
    Component(lsp_tool, "LspTool", "ABC", "LSP operations: hover, definition, references")
    Component(subagent_tool, "SubagentTool", "ABC", "Spawns child agents via SubagentCoordinator")
    Component(todo_tool, "TodoTool", "ABC", "Task tracking within session")
    Component(memory_tool, "MemoryTool", "ABC", "Persist and retrieve cross-session knowledge")
    Component(plan_tool, "PlanTool", "ABC", "Plan creation and management")
}

System_Boundary(mcp_group, "MCP Group") {
    Component(mcp_client_rt, "MCPClientRuntime", "", "Connects to external MCP servers via stdio/SSE")
    Component(mcp_server_rt, "MCPServerRuntime", "", "Exposes nasim tools to external MCP clients")
    Component(mcp_tool_adapter, "MCPToolAdapter", "", "Wraps MCP server tools into nasim Tool format")
    Component(mcp_discovery, "MCPDiscovery", "", "Discovers and registers MCP server tools at startup")
}

System_Boundary(config_group, "Config Group") {
    Component(config_loader, "ConfigLoader", "pydantic", "Loads global YAML, project YAML, env vars, CLI flags")
    Component(config_schema, "Config", "dataclass", "Typed configuration: provider, model, safety, budget, mcp")
}

System_Boundary(session_group, "Session Group") {
    Component(session_store, "SessionStore", "", "Persists/loads message history to ~/.nasim/sessions/")
    Component(session_versioning, "SessionVersioning", "", "Snapshots and undo for session state")
    Component(session_search, "SessionSearch", "", "Cross-session search via FTS5 index")
    Component(session_fork, "SessionFork", "", "Branch conversations from any point")
}

System_Boundary(hooks_group, "Hooks Group") {
    Component(hook_manager, "HookManager", "", "Registers, discovers, and executes hooks")
    Component(hook_types, "Hook", "", "Hook types: PreToolUse, PostToolUse, PreLLMCall, PostLLMCall")
    Component(hook_result, "HookResult", "", "Hook execution result: allow, deny, modify")
}

System_Boundary(plugins_group, "Plugins Group") {
    Component(plugin_loader, "PluginLoader", "", "Discovers and loads plugins from ~/.nasim/plugins/")
    Component(plugin_manifest, "PluginManifest", "", "Plugin metadata: name, version, tools, hooks")
}

System_Boundary(sandbox_group, "Sandbox Group") {
    Component(sandbox_executor, "SandboxExecutor", "", "OS-level process isolation: landlock, seccomp, bubblewrap")
    Component(sandbox_policy, "SandboxPolicy", "", "Network domain allowlists, filesystem mount rules")
    Component(sandbox_monitor, "SandboxMonitor", "", "Process monitoring, timeout enforcement")
}

System_Boundary(observability_group, "Observability Group") {
    Component(structured_logger, "StructuredLogger", "structlog", "Structured logging with trace correlation")
    Component(metrics_collector, "MetricsCollector", "", "Token usage, latency, tool call metrics")
}

System_Boundary(memory_group, "Memory Group") {
    Component(memory_store, "MemoryStore", "", "Cross-session knowledge persistence and retrieval")
    Component(memory_index, "MemoryIndex", "", "FTS5 index for semantic search")
    Component(memory_scope, "MemoryScope", "", "Scope isolation: global, project, session")
}

System_Boundary(git_group, "Git Group") {
    Component(git_integration, "GitIntegration", "", "Auto-commit, branch awareness, diff tracking")
    Component(git_status, "GitStatus", "", "Read working tree status, staged changes")
    Component(git_commit, "GitCommit", "", "Create commits with conventional messages")
}

Rel(agent_orch, provider, "chat, stream")
Rel(agent_orch, tool_registry, "execute tools")
Rel(agent_orch, conv_history, "messages, token tracking")
