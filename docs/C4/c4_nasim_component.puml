@startuml c4_nasim_component
' ============================================================
' Title:     NASIM Application — Component Diagram
' Boundary:  NASIM Application
' Purpose:   Container-to-Component traceability with strict 3-layer CSR.
'            External clients from Container diagram connect to internal
'            adapters, which converge at AgentController (single entry).
'            Consistent naming: Adapter/Controller, Service, Repository.
' Milestone: v1.0
' Version:   11.2.0
' Source:    docs/C4/c4_nasim_container.puml (v11.0.1)
' Review:    —
' Date:      2026-06-29
' Note:      v11.0.1 — Absorbed agent.puml gaps: SubagentCoordinator,
'            ErrorBoundary, PersonaManager into TaskService.
'            v11.0.2 — Absorbed tools.puml gaps: SubagentTool, TodoTool,
'            PlanTool, ReviewTool into ToolService.
'            v11.1.0 — Added WireLogRepository for interaction recording,
'            replay, session forking, and checkpointing.
'            v11.2.0 — Added EditStrategyRepository for diff staging,
'            computation, and safe application of file edits.
' ============================================================

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
!include common/c4_styles.puml

LAYOUT_TOP_DOWN()

title NASIM Application — Component Diagram (CSR 3-Layer)

' ── External Clients (from Container diagram) ──
Container_Ext(cli, "CLI", "Python 3.10+", "Terminal interface: REPL, arg parsing, slash commands")
Container_Ext(webapp, "WebApp", "JavaScript SPA", "Browser-based interface")
Container_Ext(desktop, "DesktopApp", "Electron / Tauri", "Desktop application")
Container_Ext(mobile, "MobileApp", "React Native / Flutter", "Mobile application")
Container_Ext(mcp_client, "MCP Client", "External tools consuming NASIM via MCP")

' ── NASIM Application Boundary ──
Container_Boundary(nasim_application, "NASIM Application") {

    ' ── Controller Layer (single convergence point) ──
    Boundary(controller_layer, "Controller Layer") <<controller>> {
        Component(cli_adapter, "CLIAdapter", "argparse + REPL", "Terminal REPL session, arg parsing, slash commands")
        Component(http_adapter, "HTTPAdapter", "FastAPI", "ASGI routes, middleware, SSE streaming")
        Component(mcp_adapter, "MCPAdapter", "mcp.server", "MCP protocol: tool exposure, stdio/SSE transport")
        Component(agent_ctrl, "AgentController", "", "Central entry gate. All adapters converge here. Delegates to services.")
    }

    ' ── Service Layer ──
    Boundary(service_layer, "Service Layer") <<service>> {
        Component(task_svc, "TaskService", "", "Agentic loop: LLM call, tool dispatch, context assembly, subagent orchestration, error recovery, persona management")
        Component(tool_svc, "ToolService", "", "Tool registry, parameter validation, execution dispatch; includes subagent, todo, plan, review tools")
        Component(session_svc, "SessionService", "", "Session lifecycle: create, load, save, snapshot, revert")
        Component(safety_svc, "SafetyService", "", "Permission gating, injection scanning, egress inspection")
        Component(context_svc, "ContextService", "", "Context pipeline: graph, truncation, distillation, injection")
    }

    ' ── Repository Layer (includes external adapters) ──
    Boundary(repository_layer, "Repository Layer") <<repository>> {
        Component(session_repo, "SessionRepository", "", "Message persistence: JSON Lines, turn management")
        Component(history_repo, "HistoryRepository", "", "Snapshots, revert index, search index")
        Component(config_repo, "ConfigRepository", "", "YAML, env vars, CLI flags, project overrides")
        Component(memory_repo, "MemoryRepository", "", "Cross-session knowledge persistence")
        Component(llm_repo, "LLMRepository", "litellm", "LLM API calls + model routing: streaming, fallback chains, capability-based model selection, task classification")
        Component(fs_repo, "FilesystemRepository", "pathlib", "Host filesystem I/O: read, write, edit, glob, grep")
        Component(sandbox_repo, "SandboxRepository", "subprocess", "Sandboxed command execution: timeout, isolation")
        Component(edit_strategy_repo, "EditStrategyRepository", "", "Diff staging, computation, and safe application: staged edits, sandboxed validation")
        Component(git_repo, "GitRepository", "gitpython", "Git operations: status, diff, commit, branch")
        Component(mcp_repo, "MCPRepository", "mcp.client", "MCP extension tools: discovery, invocation")
        Component(repo_intel_repo, "RepoIntelligenceRepository", "tree-sitter + API", "Codebase intelligence: AST indexing, symbol graph, embedding generation, semantic search, repo map building")
        Component(web_repo, "WebRepository", "httpx", "Web fetch: documentation, search results")
        Component(wire_log_repo, "WireLogRepository", "", "Append-only event store: interaction recording, replay, session forking, checkpointing")
    }

    ' ── Data Stores (internal persistence) ──
    Boundary(datastore_layer, "Data Stores") <<datastore>> {
        ComponentDb(session_store, "Session Store", "JSONL", "Conversation history: ~/.nasim/sessions/")
        ComponentDb(memory_store, "Memory Store", "JSON + embeddings", "Cross-session knowledge: ~/.nasim/memory/")
        ComponentDb(wire_log_store, "Wire Log Store", "JSONL", "Append-only interaction log: ~/.nasim/sessions/<id>/wire.jsonl")
        ComponentDb(config_store, "Config Store", "YAML", "Configuration: project overrides, env vars")
    }
}

' ── External Systems ──
System_Ext(llm, "LLM Backend", "Multi-provider inference via litellm")
System_Ext(host_fs, "Host Filesystem", "Project source code and configuration")
System_Ext(sandbox, "Sandbox Runtime", "OS-level process isolation")
System_Ext(web, "Web", "Documentation and search engines")
System_Ext(mcp_server, "MCP Server", "Extension tools via MCP protocol")
System_Ext(git, "Git Repository", "Version-controlled project files")
System_Ext(repo_intel, "Repo Intelligence Backend", "Tree-sitter, LSP, embeddings, vector store")

' ══════════════════════════════════════════════════════════════
' ── External Clients → Adapters (Container → Component traceability) ──
' ══════════════════════════════════════════════════════════════

Rel(cli, cli_adapter, "submits tasks", "HTTP/JSON + SSE")
Rel(webapp, http_adapter, "submits tasks", "HTTP/JSON + SSE")
Rel(desktop, http_adapter, "submits tasks", "HTTP/JSON + SSE")
Rel(mobile, http_adapter, "submits tasks", "HTTPS + SSE")
Rel(mcp_client, mcp_adapter, "invokes tools", "stdio / SSE")

' ══════════════════════════════════════════════════════════════
' ── Adapters → Controller (single convergence point) ──
' ══════════════════════════════════════════════════════════════

Rel(cli_adapter, agent_ctrl, "delegates validated request")
Rel(http_adapter, agent_ctrl, "delegates validated request")
Rel(mcp_adapter, agent_ctrl, "delegates validated request")

' ══════════════════════════════════════════════════════════════
' ── Controller → Services (CSR: Controller → Service) ──
' ══════════════════════════════════════════════════════════════

Rel(agent_ctrl, task_svc, "dispatches task orchestration")
Rel(agent_ctrl, session_svc, "manages session lifecycle")
Rel(agent_ctrl, config_repo, "loads configuration")

' ══════════════════════════════════════════════════════════════
' ── Services → Services (orchestration) ──
' ══════════════════════════════════════════════════════════════

Rel(task_svc, tool_svc, "dispatches tool execution")
Rel(task_svc, safety_svc, "validates actions before dispatch")
Rel(task_svc, context_svc, "assembles context for LLM call")

' ══════════════════════════════════════════════════════════════
' ── Services → Repositories (CSR: Service → Repository) ──
' ══════════════════════════════════════════════════════════════

Rel(task_svc, session_repo, "persists conversation turns")
Rel(task_svc, llm_repo, "invokes LLM inference")
Rel(session_svc, session_repo, "loads and saves sessions")
Rel(session_svc, history_repo, "manages snapshots and revert index")
Rel(tool_svc, fs_repo, "reads and writes project files")
Rel(tool_svc, sandbox_repo, "executes commands in sandbox")
Rel(tool_svc, edit_strategy_repo, "stages and applies file diffs safely")
Rel(tool_svc, git_repo, "queries git state, creates commits")
Rel(tool_svc, mcp_repo, "invokes extension tools")
Rel(tool_svc, web_repo, "fetches documentation")
Rel(context_svc, memory_repo, "injects memory context")
Rel(context_svc, repo_intel_repo, "queries codebase intelligence")
Rel(task_svc, wire_log_repo, "records agent-provider-tool interactions")
Rel(session_svc, wire_log_repo, "forks sessions, checkpoints turns")

' ══════════════════════════════════════════════════════════════
' ── Repository → Repository (internal dependencies) ──
' ══════════════════════════════════════════════════════════════

Rel(edit_strategy_repo, sandbox_repo, "validates diffs in sandboxed environment")
Rel(edit_strategy_repo, fs_repo, "reads original files, writes staged edits")

' ══════════════════════════════════════════════════════════════
' ── Repository → Data Stores (internal persistence) ──
' ══════════════════════════════════════════════════════════════

Rel(session_repo, session_store, "reads and writes conversations", "JSONL")
Rel(memory_repo, memory_store, "reads and writes knowledge", "JSON + vectors")
Rel(wire_log_repo, wire_log_store, "reads and writes event logs", "JSONL")
Rel(config_repo, config_store, "reads and writes configuration", "YAML")

' ══════════════════════════════════════════════════════════════
' ── Repository → External Systems ──
' ══════════════════════════════════════════════════════════════

Rel(llm_repo, llm, "routes LLM API calls", "HTTP/JSON streaming")
Rel(fs_repo, host_fs, "reads and writes files", "path I/O")
Rel(edit_strategy_repo, host_fs, "reads originals, writes staged edits", "path I/O")
Rel(sandbox_repo, sandbox, "executes commands", "subprocess")
Rel(git_repo, git, "version control operations", "git CLI")
Rel(mcp_repo, mcp_server, "invokes extension tools", "stdio / SSE")
Rel(repo_intel_repo, repo_intel, "parses code, queries intelligence", "in-process / HTTP")
Rel(web_repo, web, "fetches documentation", "HTTPS")

legend right
    |<#E3F2FD>  **Controller** | CLIAdapter, HTTPAdapter, MCPAdapter, AgentController |
    |<#FFF3E0>  **Service**    | TaskService, ToolService, SessionService, SafetyService, ContextService |
    |<#E8F5E9>  **Repository** | SessionRepository, HistoryRepository, ConfigRepository, MemoryRepository, LLMRepository, FilesystemRepository, SandboxRepository, EditStrategyRepository, GitRepository, MCPRepository, RepoIntelligenceRepository, WebRepository, WireLogRepository |
    |<#FFFDE7>  **Data Store** | SessionStore, MemoryStore, WireLogStore, ConfigStore |
    |<#FAFAFA>  **Container_Ext** | External clients from Container diagram |
end legend

@enduml
