Rel(agent_orch, memory_store, "persist, retrieve")
Rel(agent_orch, session_store, "save, load")
Rel(agent_orch, repo_intel_mgr, "INDEX, RANK, INJECT")
Rel(agent_orch, edit_strategy_mgr, "SELECT, APPLY")
