@startuml c4_nasim_component
' ============================================================
' Title:     NASIM Application — Component Diagram
' Boundary:  NASIM Application
' Purpose:   Single convergence point: AgentController receives
'            all requests from CLIAdapter, HTTPAdapter, MCPAdapter.
'            Strict CSR layering: Controller → Service → Repository.
'            External adapters handle system boundary interactions.
' Milestone: v1.0
' Version:   1.0.0
' Source:    docs/C4/c4_nasim_container.puml (v11.0.1)
' Review:    —
' Date:      2026-06-29
' ============================================================

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
!include common/c4_styles.puml

LAYOUT_TOP_DOWN()

title NASIM Application — Component Diagram (CSR)

' ── External Clients ──
Person(user, "Developer", "Uses NASIM as an AI coding assistant")

Container_Ext(cli, "CLI", "Python 3.10+", "Terminal interface: REPL, arg parsing, slash commands")
Container_Ext(webapp, "WebApp", "JavaScript SPA", "Browser-based interface")
Container_Ext(desktop, "DesktopApp", "Electron / Tauri", "Desktop application")
Container_Ext(mobile, "MobileApp", "React Native / Flutter", "Mobile application")
Container_Ext(mcp_client_ext, "MCP Client", "External tools consuming NASIM via MCP")

' ── NASIM Application Boundary ──
Container_Boundary(nasim_application, "NASIM Application") {

    ' ── Interface Adapters (entry handlers) ──
    Boundary(adapter_layer, "Adapter Layer") <<controller>> {
        Component(cli_adapter, "CLIAdapter", "argparse + REPL", "Handles terminal REPL session, arg parsing, slash command dispatch")
        Component(http_adapter, "HTTPAdapter", "FastAPI", "ASGI application: routes, middleware, lifespan, SSE streaming")
        Component(mcp_adapter, "MCPAdapter", "mcp.server", "MCP protocol handler: tool exposure, stdio/SSE transport")
    }

    ' ── Controller Layer (single convergence point) ──
    Boundary(controller_layer, "Controller Layer") <<controller>> {
        Component(agent_ctrl, "AgentController", "", "Central entry gate. Receives all requests from adapters. Delegates to TaskService. Enforces auth, validation, error shaping.")
    }

    ' ── Service Layer ──
    Boundary(service_layer, "Service Layer") <<service>> {
        Component(task_svc, "TaskService", "", "Orchestrates agentic loop: LLM call, tool dispatch, context assembly, retry")
        Component(tool_svc, "ToolService", "", "Tool registry lookup, parameter validation, execution dispatch, result formatting")
        Component(session_svc, "SessionService", "", "Session lifecycle: create, load, save, snapshot, revert, search")
        Component(safety_svc, "SafetyService", "", "Permission gating, injection scanning, egress inspection, content filtering")
        Component(context_svc, "ContextService", "", "Context pipeline: graph construction, truncation, distillation, injection")
        Component(eval_svc, "EvaluationService", "", "Task evaluation, success checks, retry coordination")
    }

    ' ── Repository Layer ──
    Boundary(repository_layer, "Repository Layer") <<repository>> {
        Component(session_repo, "SessionRepository", "", "Message persistence: JSON Lines read/write, turn management")
        Component(history_repo, "HistoryRepository", "", "Cross-session history: snapshot storage, revert index, search index")
        Component(config_repo, "ConfigRepository", "", "Configuration loading: YAML, env vars, CLI flags, project overrides")
        Component(memory_repo, "MemoryRepository", "", "Cross-session knowledge: persist, retrieve, relevance ranking")
    }

    ' ── External Adapters (system boundary) ──
    Boundary(external_adapter_layer, "External Adapter Layer") <<infrastructure>> {
        Component(llm_client, "LLMClient", "litellm", "Routes LLM API calls via litellm: streaming, fallback, capability matching")
        Component(fs_adapter, "FilesystemAdapter", "pathlib", "Host filesystem I/O: read, write, edit, glob, grep")
        Component(sandbox_adapter, "SandboxAdapter", "subprocess", "Sandboxed command execution: timeout, isolation, output capture")
        Component(git_adapter, "GitAdapter", "gitpython", "Git operations: status, diff, commit, branch, log")
        Component(mcp_client_adapter, "MCPClientAdapter", "mcp.client", "MCP extension tools: discovery, invocation, response handling")
        Component(repo_intel_adapter, "RepoIntelligenceAdapter", "tree-sitter + API", "Codebase intelligence: AST indexing, symbol graph, semantic search")
        Component(web_adapter, "WebAdapter", "httpx", "Web fetch: documentation retrieval, search results, URL resolution")
    }
}

' ── External Systems ──
System_Ext(llm, "LLM Backend", "Multi-provider inference via litellm")
System_Ext(host_fs, "Host Filesystem", "Project source code and configuration")
System_Ext(sandbox, "Sandbox Runtime", "OS-level process isolation")
System_Ext(web, "Web", "Documentation and search engines")
System_Ext(mcp_server, "MCP Server", "Extension tools via MCP protocol")
System_Ext(git, "Git Repository", "Version-controlled project files")
System_Ext(repo_intel, "Repo Intelligence Backend", "Tree-sitter, LSP, embeddings, vector store")

' ══════════════════════════════════════════════════════════════
' ── External Clients → Adapters ──
' ══════════════════════════════════════════════════════════════

Rel(user, cli, "runs coding tasks", "terminal REPL")
Rel(user, webapp, "interacts via browser", "HTTPS")
Rel(user, desktop, "interacts via desktop app", "local")
Rel(user, mobile, "interacts via mobile app", "HTTPS")

Rel(cli, cli_adapter, "submits tasks", "HTTP/JSON + SSE")
Rel(webapp, http_adapter, "submits tasks", "HTTP/JSON + SSE")
Rel(desktop, http_adapter, "submits tasks", "HTTP/JSON + SSE")
Rel(mobile, http_adapter, "submits tasks", "HTTPS + SSE")
Rel(mcp_client_ext, mcp_adapter, "invokes tools", "stdio / SSE")

' ══════════════════════════════════════════════════════════════
' ── Adapters → Controller (single convergence point) ──
' ══════════════════════════════════════════════════════════════

Rel(cli_adapter, agent_ctrl, "delegates validated request")
Rel(http_adapter, agent_ctrl, "delegates validated request")
Rel(mcp_adapter, agent_ctrl, "delegates validated request")

' ══════════════════════════════════════════════════════════════
' ── Controller → Services (CSR: Controller → Service) ──
' ══════════════════════════════════════════════════════════════

Rel(agent_ctrl, task_svc, "dispatches task orchestration")
Rel(agent_ctrl, session_svc, "manages session lifecycle")

' ══════════════════════════════════════════════════════════════
' ── Services → Services (orchestration) ──
' ══════════════════════════════════════════════════════════════

Rel(task_svc, tool_svc, "dispatches tool execution")
Rel(task_svc, safety_svc, "validates actions before dispatch")
Rel(task_svc, context_svc, "assembles context for LLM call")
Rel(task_svc, eval_svc, "triggers evaluation after completion")

' ══════════════════════════════════════════════════════════════
' ── Services → Repositories (CSR: Service → Repository) ──
' ══════════════════════════════════════════════════════════════

Rel(task_svc, session_repo, "persists conversation turns")
Rel(session_svc, session_repo, "loads and saves sessions")
Rel(session_svc, history_repo, "manages snapshots and revert index")
Rel(context_svc, memory_repo, "injects memory context")
Rel(agent_ctrl, config_repo, "loads configuration")

' ══════════════════════════════════════════════════════════════
' ── Services / Repositories → External Adapters ──
' ══════════════════════════════════════════════════════════════

Rel(task_svc, llm_client, "invokes LLM inference")
Rel(tool_svc, fs_adapter, "reads and writes project files")
Rel(tool_svc, sandbox_adapter, "executes commands in sandbox")
Rel(tool_svc, git_adapter, "queries git state, creates commits")
Rel(tool_svc, mcp_client_adapter, "invokes extension tools")
Rel(tool_svc, web_adapter, "fetches documentation")
Rel(context_svc, repo_intel_adapter, "queries codebase intelligence")

' ══════════════════════════════════════════════════════════════
' ── External Adapters → External Systems ──
' ══════════════════════════════════════════════════════════════

Rel(llm_client, llm, "routes LLM API calls", "HTTP/JSON streaming")
Rel(fs_adapter, host_fs, "reads and writes files", "path I/O")
Rel(sandbox_adapter, sandbox, "executes commands", "subprocess")
Rel(git_adapter, git, "version control operations", "git CLI")
Rel(mcp_client_adapter, mcp_server, "invokes extension tools", "stdio / SSE")
Rel(repo_intel_adapter, repo_intel, "parses code, queries intelligence", "in-process / HTTP")
Rel(web_adapter, web, "fetches documentation", "HTTPS")

legend right
    |<#E3F2FD>  **Controller** | Adapter Layer, Controller Layer |
    |<#FFF3E0>  **Service**    | Task, Tool, Session, Safety, Context, Evaluation |
    |<#E8F5E9>  **Repository** | Session, History, Config, Memory |
    |<#F3E5F5>  **Infrastructure** | LLM, Filesystem, Sandbox, Git, MCP, Repo Intelligence, Web |
end legend

@enduml
