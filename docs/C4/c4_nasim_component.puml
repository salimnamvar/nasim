@startuml c4_nasim_component
' ============================================================
' Title:     NASIM Application — Component Diagram
' Boundary:  NASIM Application
' Purpose:   Container-to-Component traceability with strict 3-layer CSR.
'            External clients connect to adapters → Agent Controller (single entry)
'            → services → repositories → data stores → external systems.
' Milestone: v1.0
' Version:   13.0.0
' Source:    docs/C4/c4_nasim_container.puml (v13.0.0)
' ============================================================

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
!include common/c4_styles.puml
skinparam linetype polyline

LAYOUT_TOP_DOWN()

title NASIM Application — Component Diagram (CSR 3-Layer)

' ── External Clients (from Container diagram) ──
Container_Ext(cli, "CLI", "Python 3.10+", "Terminal interface: REPL, arg parsing, slash commands", $tags="external_container")
Container_Ext(webapp, "WebApp", "JavaScript SPA", "Browser-based interface", $tags="external_container")
Container_Ext(desktop, "DesktopApp", "Electron / Tauri", "Desktop application", $tags="external_container")
Container_Ext(mobile, "MobileApp", "React Native / Flutter", "Mobile application", $tags="external_container")
Container_Ext(mcp_client, "MCP Client", "External tools consuming NASIM via MCP", $tags="external_container")

' ── NASIM Application Boundary ──
Container_Boundary(nasim_app, "NASIM Application") {

    ' ── Controller Layer (single convergence point) ──
    Boundary(controller_layer, "Controller Layer") <<controller>> {
        Component(cli_adp, "CLI Adapter", "argparse + REPL", "Terminal REPL session, arg parsing, slash commands", $tags="controller")
        Component(http_adp, "HTTP Adapter", "FastAPI", "ASGI routes, middleware, SSE streaming", $tags="controller")
        Component(mcp_adp, "MCP Adapter", "mcp.server", "MCP protocol: tool exposure, stdio/SSE transport", $tags="controller")
        Component(agent_ctrl, "Agent Controller", "asyncio", "Central entry gate. All adapters converge here. Delegates to services.", $tags="controller")
    }

    ' ── Service Layer ──
    Boundary(service_layer, "Service Layer") <<service>> {
        Component(task_svc, "Task Service", "asyncio", "Agentic loop: LLM call, tool dispatch, context assembly, subagent orchestration, error recovery, persona management", $tags="service")
        Component(tool_svc, "Tool Service", "registry", "Tool registry, parameter validation, execution dispatch; includes subagent, todo, plan, review tools, dynamic plugin-loaded tools, and lifecycle hook dispatch (PreToolUse, PostToolUse, PreLLMCall, PostLLMCall)", $tags="service")
        Component(session_svc, "Session Service", "asyncio", "Session lifecycle: create, load, save, snapshot, revert", $tags="service")
        Component(config_svc, "Config Service", "pydantic + PyYAML", "Config loading, validation, layered overrides (project YAML, env vars, CLI flags, defaults); single source for all configuration access", $tags="service")
        Component(safety_svc, "Safety Service", "policy pipeline", "Permission gating, injection scanning, egress inspection", $tags="service")
        Component(context_svc, "Context Service", "graph", "Context pipeline: graph construction, truncation, distillation, injection, and compaction", $tags="service")
        Component(eval_svc, "Evaluation Service", "litellm + heuristics", "Task evaluation: success checks, LLM review, retry coordination, repetition detection, turn budget management", $tags="service")
    }

    ' ── Repository Layer ──
    Boundary(repository_layer, "Repository Layer") <<repository>> {
        Component(session_repo, "Session Repository", "JSONL + pathlib", "Message persistence: JSON Lines, turn management", $tags="repository")
        Component(history_repo, "History Repository", "JSONL + SQLite FTS5", "Snapshots, revert index, search index", $tags="repository")
        Component(config_repo, "Config Repository", "PyYAML + os.environ", "YAML, env vars, CLI flags, project overrides", $tags="repository")
        Component(memory_repo, "Memory Repository", "JSON + embeddings", "Cross-session knowledge persistence", $tags="repository")
        Component(llm_repo, "LLM Repository", "litellm", "LLM API calls + model routing: streaming, fallback chains, capability-based model selection, task classification", $tags="repository")
        Component(fs_repo, "Filesystem Repository", "pathlib", "Host filesystem I/O: read, write, edit, glob, grep", $tags="repository")
        Component(sandbox_repo, "Sandbox Repository", "subprocess", "Sandboxed command execution: timeout, isolation", $tags="repository")
        Component(edit_strategy_repo, "Edit Strategy Repository", "pathlib + unified_diff", "Diff staging, computation, and safe application: staged edits, sandboxed validation", $tags="repository")
        Component(git_repo, "Git Repository", "gitpython", "Git operations: status, diff, commit, branch", $tags="repository")
        Component(mcp_repo, "MCP Repository", "mcp.client", "MCP extension tools: discovery, invocation", $tags="repository")
        Component(repo_intel_repo, "Repo Intelligence Repository", "tree-sitter + API", "Codebase intelligence: AST indexing, symbol graph, embedding generation, semantic search, repo map building", $tags="repository")
        Component(web_repo, "Web Repository", "httpx", "Web fetch: documentation, search results", $tags="repository")
        Component(wire_log_repo, "Wire Log Repository", "JSONL append-only", "Append-only event store: interaction recording, replay, session forking, checkpointing", $tags="repository")
    }

    ' ── Data Stores (internal persistence) ──
    Boundary(datastore_layer, "Data Stores") <<datastore>> {
        ComponentDb(session_store, "Session Store", "JSONL", "Conversation history: ~/.nasim/sessions/", $tags="datastore")
        ComponentDb(memory_store, "Memory Store", "JSON + embeddings", "Cross-session knowledge: ~/.nasim/memory/", $tags="datastore")
        ComponentDb(wire_log_store, "Wire Log Store", "JSONL", "Append-only interaction log: ~/.nasim/sessions/<id>/wire.jsonl", $tags="datastore")
        ComponentDb(config_store, "Config Store", "YAML", "Configuration: project overrides, env vars", $tags="datastore")
    }
}

' ── External Systems ──
System_Ext(llm, "LLM Backend", "Multi-provider inference via litellm")
System_Ext(host_fs, "Host Filesystem", "Project source code and configuration")
System_Ext(sandbox, "Sandbox Runtime", "OS-level process isolation")
System_Ext(web, "Web", "Documentation and search engines")
System_Ext(mcp_server, "MCP Server", "Extension tools via MCP protocol")
System_Ext(git, "Git Repository", "Version-controlled project files")
System_Ext(repo_intel, "Repo Intelligence Backend", "Tree-sitter, LSP, embeddings, vector store")

' ══════════════════════════════════════════════════════════════
' ── External Clients → Adapters (Container → Component traceability) ──
' ══════════════════════════════════════════════════════════════

Rel(cli, cli_adp, "submits tasks", "HTTP/JSON + SSE")
Rel(webapp, http_adp, "submits tasks", "HTTP/JSON + SSE")
Rel(desktop, http_adp, "submits tasks", "HTTP/JSON + SSE")
Rel(mobile, http_adp, "submits tasks", "HTTPS + SSE")
Rel(mcp_client, mcp_adp, "invokes tools", "stdio / SSE")

' ══════════════════════════════════════════════════════════════
' ── Adapters → Controller (single convergence point) ──
' ══════════════════════════════════════════════════════════════

Rel(cli_adp, agent_ctrl, "delegates validated request")
Rel(http_adp, agent_ctrl, "delegates validated request")
Rel(mcp_adp, agent_ctrl, "delegates validated request")

' ══════════════════════════════════════════════════════════════
' ── Controller → Services (CSR: Controller → Service) ──
' ══════════════════════════════════════════════════════════════

Rel(agent_ctrl, task_svc, "dispatches task orchestration")
Rel(agent_ctrl, session_svc, "manages session lifecycle")
Rel(agent_ctrl, config_svc, "loads and validates configuration")

' ══════════════════════════════════════════════════════════════
' ── Services → Services (orchestration) ──
' ══════════════════════════════════════════════════════════════

Rel(task_svc, tool_svc, "dispatches tool execution")
Rel(task_svc, safety_svc, "validates actions before dispatch")
Rel(task_svc, context_svc, "assembles context for LLM call")
Rel(task_svc, eval_svc, "evaluates task completion, manages retries and quality checks")

' ══════════════════════════════════════════════════════════════
' ── Services → Repositories (CSR: Service → Repository) ──
' ══════════════════════════════════════════════════════════════

Rel(task_svc, session_repo, "persists conversation turns")
Rel(task_svc, llm_repo, "invokes LLM inference")
Rel(session_svc, session_repo, "loads and saves sessions")
Rel(session_svc, history_repo, "manages snapshots and revert index")
Rel(config_svc, config_repo, "reads and validates configuration; applies layered overrides")
Rel(tool_svc, fs_repo, "reads and writes project files")
Rel(tool_svc, sandbox_repo, "executes commands in sandbox")
Rel(tool_svc, edit_strategy_repo, "stages and applies file diffs safely")
Rel(tool_svc, git_repo, "queries git state, creates commits")
Rel(tool_svc, mcp_repo, "invokes extension tools")
Rel(tool_svc, web_repo, "fetches documentation")
Rel(context_svc, memory_repo, "injects memory context")
Rel(context_svc, repo_intel_repo, "queries codebase intelligence")
Rel(task_svc, wire_log_repo, "records agent-provider-tool interactions")
Rel(session_svc, wire_log_repo, "forks sessions, checkpoints turns")

' ══════════════════════════════════════════════════════════════
' ── Repository → Repository (internal dependencies) ──
' ══════════════════════════════════════════════════════════════

Rel(edit_strategy_repo, sandbox_repo, "validates diffs in sandboxed environment")
Rel(edit_strategy_repo, fs_repo, "reads original files, writes staged edits")

' ══════════════════════════════════════════════════════════════
' ── Repository → Data Stores (internal persistence) ──
' ══════════════════════════════════════════════════════════════

Rel(session_repo, session_store, "reads and writes conversations", "JSONL")
Rel(memory_repo, memory_store, "reads and writes knowledge", "JSON + vectors")
Rel(wire_log_repo, wire_log_store, "reads and writes event logs", "JSONL")
Rel(config_repo, config_store, "reads and writes configuration", "YAML")

' ══════════════════════════════════════════════════════════════
' ── Repository → External Systems ──
' ══════════════════════════════════════════════════════════════

Rel(llm_repo, llm, "sends context, receives completions", "HTTP/JSON streaming")
Rel(fs_repo, host_fs, "reads and writes project files", "path I/O")
Rel(edit_strategy_repo, host_fs, "reads and writes project files", "path I/O")
Rel(sandbox_repo, sandbox, "runs commands in isolation", "subprocess")
Rel(git_repo, git, "reads state, creates commits", "git CLI")
Rel(mcp_repo, mcp_server, "invokes extension tools", "stdio / SSE")
Rel(repo_intel_repo, repo_intel, "parses code, queries intelligence", "in-process / HTTP")
Rel(web_repo, web, "fetches documentation", "HTTPS")

legend right
    |<#E3F2FD>  **Controller** | CLI Adapter, HTTP Adapter, MCP Adapter, Agent Controller |
    |<#FFF3E0>  **Service**    | Task Service, Tool Service, Session Service, Config Service, Safety Service, Context Service, Evaluation Service |
    |<#E8F5E9>  **Repository** | Session Repository, History Repository, Config Repository, Memory Repository, LLM Repository, Filesystem Repository, Sandbox Repository, Edit Strategy Repository, Git Repository, MCP Repository, Repo Intelligence Repository, Web Repository, Wire Log Repository |
    |<#FFFDE7>  **Data Store** | SessionStore, MemoryStore, WireLogStore, ConfigStore |
    |<#FAFAFA>  **External Client** | CLI, WebApp, DesktopApp, MobileApp, MCP Client |
end legend

@enduml