title nasim — Sandbox Component Diagram

Container_Boundary(sandbox_boundary, "Sandbox Group") {
    Component(sandbox_executor, "SandboxExecutor", "", "OS-level process isolation: landlock, seccomp, bubblewrap")
    Component(sandbox_policy, "SandboxPolicy", "", "Network domain allowlists, filesystem mount rules, exec restrictions")
    Component(sandbox_monitor, "SandboxMonitor", "", "Process monitoring, timeout enforcement, resource limits")
}

System_Ext(host_shell, "Host Shell", "subprocess execution")
System_Ext(host_fs, "Host Filesystem", "restricted mount points")

Rel(sandbox_executor, sandbox_policy, "applies policy before exec")
Rel(sandbox_executor, sandbox_monitor, "monitors running process")
Rel(sandbox_executor, host_shell, "runs isolated subprocess")
Rel(sandbox_executor, host_fs, "restricted file access")

SHOW_LEGEND()
