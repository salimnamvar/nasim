@startuml c4_nasim_component_sandbox
' ============================================================
' Title:     NASIM Application — Sandbox Component Diagram
' Boundary:  NASIM Application (container) — Sandbox Group
' Purpose:   OS-level process isolation and diff staging for shell and edit operations
'            CSR Layer: Infrastructure
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/audit/audit.2026.06.20.deep.domain.audit.md
' Review:    CAR audit 2026-06-26
' Date:      2026-06-26
' ============================================================

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!include common/c4_styles.puml
!theme plain

title NASIM Application — Isolate Sandbox Component Diagram

Container_Boundary(nasim_application, "NASIM Application") {
    Boundary(sandbox_group, "Sandbox Group") <<infrastructure>> {
        Component(sandbox_executor, "SandboxExecutor", "", "OS-level process isolation: landlock, seccomp, bubblewrap")
        Component(sandbox_policy, "SandboxPolicy", "", "Network domain allowlists, filesystem mount rules, exec restrictions")
        Component(sandbox_monitor, "SandboxMonitor", "", "Process monitoring, timeout enforcement, resource limits")
        Component(resource_limiter, "ResourceLimiter", "", "Enforces CPU, memory, and disk quotas per sandbox instance")
        Component(diff_sandbox_mgr, "DiffSandboxManager", "", "Manages sandboxed diff staging, presentation, and application")
        Component(edit_staging_area, "EditStagingArea", "", "Stages file edits before sandbox-validated application")
        Component(diff_computer, "DiffComputer", "", "Computes diffs between original and staged content")
        Component(staged_applicator, "StagedApplicator", "", "Applies approved staged diffs to filesystem")
    }
}

System_Ext(host_shell, "Host Shell", "subprocess execution")
System_Ext(host_fs, "Host Filesystem", "restricted mount points")

Rel(sandbox_executor, sandbox_policy, "applies policy constraints before execution (activate sandbox / deactivate sandbox)")
Rel(sandbox_executor, sandbox_monitor, "monitors running process for timeout and resources")
Rel(sandbox_executor, resource_limiter, "configures resource limits before execution")
Rel(sandbox_policy, resource_limiter, "defines quota rules for resource enforcement")
Rel(resource_limiter, host_fs, "enforces disk quotas on filesystem access")
Rel(resource_limiter, host_shell, "enforces CPU and memory limits via cgroups/rlimits")
Rel(sandbox_executor, host_shell, "runs isolated subprocess in sandbox")
Rel(sandbox_executor, host_fs, "provides restricted file access within sandbox")
Rel(diff_sandbox_mgr, edit_staging_area, "stages edits for sandbox validation")
Rel(diff_sandbox_mgr, sandbox_executor, "validates diffs within sandboxed environment")
Rel(edit_staging_area, diff_computer, "computes diff between original and staged content")
Rel(diff_computer, host_fs, "reads original files for diff computation")
Rel(staged_applicator, edit_staging_area, "reads approved edits for application")
Rel(staged_applicator, sandbox_executor, "applies diffs within sandboxed environment")
Rel(staged_applicator, host_fs, "writes final files to filesystem")
Rel(diff_sandbox_mgr, staged_applicator, "applies approved diffs to filesystem")

legend right
    |<#E3F2FD>  **Controller** | CLI Group, API Group |
    |<#FFF3E0>  **Service**    | Agent, Router, Provider, Safety, Context Graph, Edit Strategy, Evaluation |
    |<#E8F5E9>  **Repository** | Session, Tool, Memory, Config, Git, Repo Intelligence |
    |<#F3E5F5>  **Infrastructure** | MCP, Sandbox, Observability, Wire Log, Hooks, Plugins |
end legend

!define CSR_CTRL participant "ServerRouter" as ctrl
!define CSR_SVC participant "SandboxExecutor" as svc

' CSR lint markers
!define CSR_ACTOR actor "User" as user
!define CSR_CTRL participant "ServerRouter" as ctrl
!define CSR_SVC participant "AgentService" as svc
!define CSR_REPO participant "DataStore" as repo
@enduml
