@startuml c4_styles
title Apply C4 Shared Styles
' ============================================================
' Title:     NASIM C4 — Apply Shared Styles
' Purpose:   Common color palette, skinparam, and macros
'            for all nasim C4 diagrams.
' Version:   9.0.0
' Source:    docs/C4/common/c4_styles.puml
' ============================================================

' --- Color Palette (CSR Layers) ---
' Controller Layer (CLI, API)
skinparam rectangle<<controller>> {
    BackgroundColor<<controller>> #E3F2FD
    BorderColor<<controller>> #1565C0
    FontColor<<controller>> #0D47A1
}

' Service Layer (Agent, Router, Safety, Context Graph, Edit Strategy, Evaluation)
skinparam rectangle<<service>> {
    BackgroundColor<<service>> #FFF3E0
    BorderColor<<service>> #E65100
    FontColor<<service>> #BF360C
}

' Repository Layer (Session, Tool, Memory, Config, Git, Repo Intelligence)
skinparam rectangle<<repository>> {
    BackgroundColor<<repository>> #E8F5E9
    BorderColor<<repository>> #2E7D32
    FontColor<<repository>> #1B5E20
}

' Infrastructure Layer (MCP, Sandbox, Observability, Wire Log, Hooks, Plugins)
skinparam rectangle<<infrastructure>> {
    BackgroundColor<<infrastructure>> #F3E5F5
    BorderColor<<infrastructure>> #7B1FA2
    FontColor<<infrastructure>> #4A148C
}

' Data Store (persistence: JSONL, YAML, embeddings)
skinparam database<<datastore>> {
    BackgroundColor<<datastore>> #FFFDE7
    BorderColor<<datastore>> #F9A825
    FontColor<<datastore>> #F57F17
}

' External Container (WebApp, DesktopApp, MobileApp)
skinparam rectangle<<external_container>> {
    BackgroundColor<<external_container>> #FAFAFA
    BorderColor<<external_container>> #616161
    FontColor<<external_container>> #212121
}

' Deployable Container (CLI Process, API Server Process, Core Engine)
skinparam rectangle<<deployable>> {
    BackgroundColor<<deployable>> #E8EAF6
    BorderColor<<deployable>> #283593
    FontColor<<deployable>> #1A237E
}

' --- Usage ---
' !include common/c4_styles.puml
' Provides CSR layer color palette via stereotypes:
'   <<controller>>   — blue (#E3F2FD)   — CLI Group, API Group
'   <<service>>      — orange (#FFF3E0)  — Agent, Router, Safety, Context Graph,
'                                          Edit Strategy, Evaluation, Provider
'   <<repository>>   — green (#E8F5E9)   — Session, Tool, Memory, Config, Git,
'                                          Repo Intelligence
'   <<infrastructure>> — purple (#F3E5F5) — MCP, Sandbox, Observability,
'                                          Wire Log, Hooks, Plugins
'
' Each diagram should include a standalone 'legend' block explaining
' these colors. Do NOT use LAYOUT_WITH_LEGEND() with this file — it
' produces an empty auto-generated legend when no AddElementTag calls
' are present. Use a manual 'legend right' block instead.

' CSR lint markers (reserved for cross-layer linting — do not remove)
!define CSR_ACTOR actor "User" as user
!define CSR_CTRL participant "ServerRouter" as ctrl
!define CSR_SVC participant "AgentOrchestrator" as svc
!define CSR_REPO participant "SessionStore" as repo
!define CSR_ACT activate actorUser
!define CSR_DEACT deactivate actorUser

@enduml
