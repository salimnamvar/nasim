@startuml c4_styles
title Apply C4 Shared Styles
' ============================================================
' Title:     NASIM C4 — Apply Shared Styles
' Purpose:   CSR layer colour palette, AddElementTag definitions,
'            and skinparam stereotypes for all NASIM C4 diagrams.
' Version:   10.0.0
' Source:    docs/C4/common/c4_styles.puml
' ============================================================
'
' INCLUDE ORDER (required for AddElementTag to resolve):
'   1. !include C4_Context.puml  OR  C4_Container.puml  OR  C4_Component.puml
'   2. !include common/c4_styles.puml
'
' LAYERED COMPONENT DIAGRAM USAGE:
'   - Apply $tags on every Component/ComponentDb inside a Boundary.
'   - Boundary(...) <<stereotype>> labels the group; $tags colours each element.
'   - Valid tags: controller | service | repository | datastore
'   - Example:
'       Boundary(ctrl_layer, "Controller Layer") {
'           Component(agent_ctrl, "Agent Controller", "asyncio", "...", $tags="controller")
'       }
'   - Do NOT put Sequence Diagram defines here — use docs/SQ/common/sq_styles.puml.
'   - Do NOT use LAYOUT_WITH_LEGEND() — use a manual 'legend right' block instead.

' --- AddElementTag (primary — colours individual components) ---
AddElementTag("controller", $bgColor="#E3F2FD", $borderColor="#1565C0", $fontColor="#0D47A1", $legendText="Controller")
AddElementTag("service", $bgColor="#FFF3E0", $borderColor="#E65100", $fontColor="#BF360C", $legendText="Service")
AddElementTag("repository", $bgColor="#E8F5E9", $borderColor="#2E7D32", $fontColor="#1B5E20", $legendText="Repository")
AddElementTag("datastore", $bgColor="#FFFDE7", $borderColor="#F9A825", $fontColor="#F57F17", $legendText="Data Store")
AddElementTag("infrastructure", $bgColor="#F3E5F5", $borderColor="#7B1FA2", $fontColor="#4A148C", $legendText="Infrastructure")
AddElementTag("external_container", $bgColor="#FAFAFA", $borderColor="#616161", $fontColor="#212121", $legendText="External Client")
AddElementTag("deployable", $bgColor="#E8EAF6", $borderColor="#283593", $fontColor="#1A237E", $legendText="Deployable")
AddElementTag("trusted", $bgColor="#E8F5E9", $borderColor="#2E7D32", $fontColor="#1B5E20", $legendText="Trusted")
AddElementTag("untrusted", $bgColor="#FFEBEE", $borderColor="#C62828", $fontColor="#B71C1C", $legendText="Untrusted")
AddElementTag("machine_client", $bgColor="#F3E5F5", $borderColor="#7B1FA2", $fontColor="#4A148C", $legendText="Machine Client")

' --- Legend styling (no !theme plain; need explicit colors) ---
skinparam legendFontColor #000000
skinparam legendBackgroundColor #FFFFFF

' --- Skinparam stereotypes (fallback for Boundary wrappers) ---
skinparam rectangle<<controller>> {
    BackgroundColor<<controller>> #E3F2FD
    BorderColor<<controller>> #1565C0
    FontColor<<controller>> #0D47A1
}

skinparam rectangle<<service>> {
    BackgroundColor<<service>> #FFF3E0
    BorderColor<<service>> #E65100
    FontColor<<service>> #BF360C
}

skinparam rectangle<<repository>> {
    BackgroundColor<<repository>> #E8F5E9
    BorderColor<<repository>> #2E7D32
    FontColor<<repository>> #1B5E20
}

skinparam rectangle<<infrastructure>> {
    BackgroundColor<<infrastructure>> #F3E5F5
    BorderColor<<infrastructure>> #7B1FA2
    FontColor<<infrastructure>> #4A148C
}

skinparam database<<datastore>> {
    BackgroundColor<<datastore>> #FFFDE7
    BorderColor<<datastore>> #F9A825
    FontColor<<datastore>> #F57F17
}

skinparam rectangle<<external_container>> {
    BackgroundColor<<external_container>> #FAFAFA
    BorderColor<<external_container>> #616161
    FontColor<<external_container>> #212121
}

skinparam rectangle<<deployable>> {
    BackgroundColor<<deployable>> #E8EAF6
    BorderColor<<deployable>> #283593
    FontColor<<deployable>> #1A237E
}

skinparam rectangle<<trusted>> {
    BackgroundColor<<trusted>> #E8F5E9
    BorderColor<<trusted>> #2E7D32
    FontColor<<trusted>> #1B5E20
}

skinparam rectangle<<untrusted>> {
    BackgroundColor<<untrusted>> #FFEBEE
    BorderColor<<untrusted>> #C62828
    FontColor<<untrusted>> #B71C1C
}

skinparam rectangle<<machine_client>> {
    BackgroundColor<<machine_client>> #F3E5F5
    BorderColor<<machine_client>> #7B1FA2
    FontColor<<machine_client>> #4A148C
}

' --- Legend Procedures ---
' Each diagram calls the appropriate procedure at the end of its body.
' Entries use <color:#RRGGBB> to ensure readability without !theme plain.

!procedure $nasim_legend_context()
legend right
    |= <color:#000000>Symbol |= <color:#000000>Meaning |
    |<#08427B> <color:#FFFFFF>**Person**</color> | <color:#000000>Human actor</color> |
    |<#1168BD> <color:#FFFFFF>**System**</color> | <color:#000000>System of interest</color> |
    |<#999999> <color:#FFFFFF>**System_Ext**</color> | <color:#000000>External system</color> |
    |<#E8F5E9> <color:#1B5E20>**Trusted**</color> | <color:#000000>Internal / controlled external system</color> |
    |<#FFEBEE> <color:#B71C1C>**Untrusted**</color> | <color:#000000>External / uncontrolled system</color> |
end legend
!endprocedure

!procedure $nasim_legend_container()
legend right
    |= <color:#000000>Symbol |= <color:#000000>Meaning |
    |<#08427B> <color:#FFFFFF>**Person**</color> | <color:#000000>Human actor</color> |
    |<#1168BD> <color:#FFFFFF>**System**</color> | <color:#000000>System of interest</color> |
    |<#999999> <color:#FFFFFF>**System_Ext**</color> | <color:#000000>External system</color> |
    |<#438DD5> <color:#FFFFFF>**Container**</color> | <color:#000000>Internal deployable</color> |
    |<#FAFAFA> <color:#212121>**External Client**</color> | <color:#000000>CLI, WebApp, DesktopApp, MobileApp (human-facing)</color> |
    |<#F3E5F5> <color:#4A148C>**Machine Client**</color> | <color:#000000>MCP Client (API / machine)</color> |
    | <color:#000000>System_Boundary | <color:#000000>Service boundary |
end legend
!endprocedure

!procedure $nasim_legend_component()
legend right
    |= <color:#000000>Symbol |= <color:#000000>Meaning |
    |<#E3F2FD> <color:#0D47A1>**Controller**</color> | <color:#000000>CLI Adapter, HTTP Adapter, MCP Adapter, Agent Controller</color> |
    |<#FFF3E0> <color:#BF360C>**Service**</color> | <color:#000000>Task, Tool, Session, Config, Safety, Context, Evaluation</color> |
    |<#E8F5E9> <color:#1B5E20>**Repository**</color> | <color:#000000>Grouped: Persistence, Intelligence, Integration, Execution</color> |
    |<#FFFDE7> <color:#F57F17>**Data Store**</color> | <color:#000000>SessionStore, MemoryStore, WireLogStore, ConfigStore</color> |
    |<#FAFAFA> <color:#212121>**External Client**</color> | <color:#000000>CLI, WebApp, DesktopApp, MobileApp</color> |
    |<#F3E5F5> <color:#4A148C>**Machine Client**</color> | <color:#000000>MCP Client</color> |
end legend
!endprocedure

@enduml