@startuml c4_nasim_component_evaluation
' ============================================================
' Title:     NASIM Application — Evaluation Component Diagram
' Boundary:  NASIM Application (container) — Evaluation Group
' Purpose:   Task evaluation: success checks, LLM review, testing, retry coordination
'            CSR Layer: Service
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/audit/audit.2026.06.20.deep.domain.audit.md
' Review:    CAR audit 2026-06-26
' Date:      2026-06-26
' ============================================================

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!theme plain
!include common/c4_styles.puml


title NASIM Application — Evaluation Component Diagram

Container_Boundary(nasim_application, "NASIM Application") {
    Boundary(evaluation_group, "Evaluation Group") <<service>> {
        Component(eval_engine, "EvaluationEngine", "", "Orchestrates task evaluation: runs checks, scores, retries, records quality metrics")
        Component(task_evaluator, "TaskEvaluator", "", "Evaluates task completion against success criteria")
        Component(success_check_runner, "SuccessCheckRunner", "", "Runs user-defined success checks and assertions")
        Component(llm_reviewer, "LLMReviewer", "", "LLM-based code review and quality assessment")
        Component(test_runner, "TestRunner", "", "Runs project test suites to validate changes")
        Component(retry_coordinator, "RetryCoordinator", "", "Coordinates retry attempts with backoff and escalation")
        Component(repetition_detector, "RepetitionDetector", "", "Detects repeated failures or loops, triggers escalation")
        Component(turn_budget_injector, "TurnBudgetInjector", "", "Injects turn budget limits and progress signals into context")
    }
}

System_Ext(provider, "Provider", "Provider Group")
System_Ext(tool_registry, "ToolRegistry", "Tool Group")

Rel(eval_engine, task_evaluator, "evaluates task completion against success criteria")
Rel(eval_engine, success_check_runner, "runs user-defined success checks")
Rel(eval_engine, llm_reviewer, "invokes LLM for code review and quality assessment")
Rel(eval_engine, test_runner, "runs project test suites to validate changes")
Rel(eval_engine, retry_coordinator, "coordinates retry attempts with backoff")
Rel(eval_engine, repetition_detector, "detects repeated failures and loops")
Rel(eval_engine, turn_budget_injector, "injects turn budget limits into context")
Rel(llm_reviewer, provider, "invokes LLM for code review and quality assessment")
Rel(test_runner, tool_registry, "executes project test suites via tool dispatch")

legend right
    |<#E3F2FD>  **Controller** | CLI Group, API Group |
    |<#FFF3E0>  **Service**    | Agent, Router, Provider, Safety, Context Graph, Edit Strategy, Evaluation |
    |<#E8F5E9>  **Repository** | Session, Tool, Memory, Config, Git, Repo Intelligence |
    |<#F3E5F5>  **Infrastructure** | MCP, Sandbox, Observability, Wire Log, Hooks, Plugins |
end legend

@enduml
