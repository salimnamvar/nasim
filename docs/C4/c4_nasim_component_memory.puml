title nasim — Memory Component Diagram

Container_Boundary(memory_boundary, "Memory Layer") {
    Component(memory_store, "MemoryStore", "nasim/memory/store.py", "Persists knowledge entries with scope, key, content, timestamps")
    Component(memory_index, "MemoryIndex", "nasim/memory/index.py", "FTS5 index for semantic search across stored knowledge")
    Component(memory_scope, "MemoryScope", "nasim/memory/scope.py", "Scope isolation: global, project, session-level knowledge")
}

System_Ext(memory_backend, "Memory Backend", "Persistent storage for knowledge entries")

Rel(memory_store, memory_index, "indexes new entries")
Rel(memory_store, memory_backend, "read/write persistence")
Rel(memory_scope, memory_store, "filters by scope")

SHOW_LEGEND()
