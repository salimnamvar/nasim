@startuml nasim_container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Container.puml
!theme plain

' ============================================================
' Title: nasim — Container Diagram (API-First)
' Boundary: nasim
' Purpose: Show deployable units. nasim is one container; CLI,
'          WebApp, DesktopApp, MobileApp are interface containers
'          that connect to nasim. API is a component inside nasim,
'          not a separate container.
' Milestone: v1.0
' Version:   8.0.0
' Source:    CAR refinement loop — C4 correction
' Review:    —
' ============================================================

LAYOUT_LEFT_RIGHT()
LAYOUT_WITH_LEGEND()

title nasim — Container Diagram (API-First)

Person(user, "User", "Interacts via CLI, WebApp, DesktopApp, or MobileApp")

Container_Boundary(interfaces, "Interface Containers") {
    Container(cli, "CLI", "Python click + rich", "Terminal interface: REPL, slash commands, rich rendering")
    Container(webapp, "WebApp", "JavaScript SPA", "Browser-based interface")
    Container(desktop_app, "DesktopApp", "Electron / Tauri", "Desktop application")
    Container(mobile_app, "MobileApp", "React Native / Flutter", "Mobile application")
}

Container(nasim, "nasim", "Python", "API-First code agent: API component is the sole entry gate. No interface may bypass the API to call internal services directly.")

System_Ext(llm_backend, "LLM Backend", "Multi-provider inference: 100+ providers via litellm")
System_Ext(host_fs, "Host Filesystem", "Project code files")
System_Ext(host_shell, "Host Shell", "subprocess execution")
System_Ext(web_ext, "Web", "Documentation and search")
System_Ext(mcp_server, "MCP Server", "Extension tools via Model Context Protocol")
System_Ext(mcp_client, "MCP Client", "External tools connecting to nasim MCP server")
System_Ext(git_repo, "Git Repository", "Version control")
System_Ext(sandbox_rt, "Sandbox Runtime", "OS-level isolation")
System_Ext(lsp_server, "LSP Server", "Code intelligence")
System_Ext(plugin_dir, "Plugin Directory", "Community extensions")
System_Ext(tree_sitter, "Tree-sitter", "Incremental AST parser for source code")
System_Ext(embedding_model, "Embedding Model", "Code embedding generation (local or API)")
System_Ext(vector_store, "Vector Store", "Persistent vector storage for similarity search")
System_Ext(otel_collector, "OTel Collector", "OTLP/gRPC endpoint for optional trace/metric export")
System_Ext(obs_platform, "Observability Platform", "Agent-based collection, Loki logs, Prometheus metrics, Grafana dashboards. nasim emits only.")

Rel(user, cli, "types input, reads output", "terminal")
Rel(user, webapp, "interacts via browser", "HTTPS")
Rel(user, desktop_app, "interacts via desktop app", "HTTPS")
Rel(user, mobile_app, "interacts via mobile app", "HTTPS")

Rel(cli, nasim, "routes all calls through API component", "in-process / HTTP")
Rel(webapp, nasim, "routes all calls through API component", "HTTP/JSON + SSE")
Rel(desktop_app, nasim, "routes all calls through API component", "HTTP/JSON + SSE")
Rel(mobile_app, nasim, "routes all calls through API component", "HTTP/JSON + SSE")

Rel(mcp_client, nasim, "invokes nasim tools via MCP protocol", "stdio/SSE")

Rel(nasim, llm_backend, "HTTP POST", "JSON streaming")
Rel(nasim, host_fs, "read/write/search files")
Rel(nasim, host_shell, "execute commands via sandbox")
Rel(nasim, web_ext, "fetch/search")
Rel(nasim, mcp_server, "invoke extension tools")
Rel(nasim, git_repo, "git operations")
Rel(nasim, sandbox_rt, "isolated execution")
Rel(nasim, lsp_server, "code intelligence")
Rel(nasim, plugin_dir, "plugin discovery")
Rel(nasim, tree_sitter, "parses AST")
Rel(nasim, embedding_model, "generates embeddings")
Rel(nasim, vector_store, "vector CRUD")
Rel(nasim, otel_collector, "exports traces/metrics (optional)", "OTLP/gRPC")
Rel(nasim, obs_platform, "writes structured logs to stdout", "stdout")
Rel(obs_platform, nasim, "pull-scrapes /metrics endpoint", "HTTP GET")

@enduml
