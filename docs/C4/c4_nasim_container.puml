@startuml c4_nasim_container
' ============================================================
' Title:     NASIM Service System — Container Diagram
' Boundary:  NASIM Service System
' Purpose:   Show NASIM Application with interface containers
' Milestone: v1.0
' Version:   11.0.0
' Source:    docs/C4/c4_nasim_context.puml (v11.0.0)
' Review:    —
' ============================================================
' SIM-01 EXCEPTION: 22 elements — single-system-boundary view
' of all containers and external systems; splitting breaks the
' Container-level abstraction.
' ============================================================

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Container.puml
!theme plain
!include common/c4_styles.puml

LAYOUT_TOP_DOWN()

title NASIM Service System — Container Diagram

Person(user, "Developer", "Uses NASIM as an AI coding assistant")

System_Boundary(nasim_service, "NASIM Service System") {
    Container(nasim_app, "NASIM Application", "Python 3.10+", "AI coding agent: agentic loop, tool orchestration, safety, context management")
    Container(cli, "CLI", "Python 3.10+", "Terminal interface: REPL, arg parsing, slash commands")
    Container(webapp, "WebApp", "JavaScript SPA", "Browser-based interface")
    Container(desktop, "DesktopApp", "Electron / Tauri", "Desktop application")
    Container(mobile, "MobileApp", "React Native / Flutter", "Mobile application")
}

System_Ext(llm, "LLM Backend", "Multi-provider inference via litellm")
System_Ext(host_fs, "Host Filesystem", "Project source code and configuration")
System_Ext(sandbox, "Sandbox Runtime", "OS-level process isolation")
System_Ext(web, "Web", "Documentation and search engines")
System_Ext(mcp_server, "MCP Server", "Extension tools via MCP protocol")
System_Ext(mcp_client, "MCP Client", "External tools consuming NASIM via MCP")
System_Ext(git, "Git Repository", "Version-controlled project files")
System_Ext(tree_sitter, "Tree-sitter", "AST parsing for code understanding")
System_Ext(lsp_server, "LSP Server", "Code intelligence: completions, diagnostics, references")
System_Ext(embedding_model, "Embedding Model", "Vector generation for semantic search")
System_Ext(vector_store, "Vector Store", "Similarity search over code embeddings")
System_Ext(log_agent, "Log Agent", "Fluent Bit / Vector: tails stdout, parses, pushes to Loki")
System_Ext(prometheus, "Prometheus", "Pull-scrapes /metrics endpoint")
System_Ext(grafana, "Grafana", "Read-only visualization and alerting dashboard")

Rel(user, cli, "runs coding tasks", "terminal REPL")
Rel(user, webapp, "interacts via browser", "HTTPS")
Rel(user, desktop, "interacts via desktop app", "local")
Rel(user, mobile, "interacts via mobile app", "HTTPS")
Rel(mcp_client, nasim_app, "invokes NASIM tools via MCP", "stdio / SSE")

Rel(cli, nasim_app, "delegates tasks", "in-process call")
Rel(webapp, nasim_app, "delegates tasks", "HTTP/JSON + SSE")
Rel(desktop, nasim_app, "delegates tasks", "HTTP/JSON + SSE")
Rel(mobile, nasim_app, "delegates tasks", "HTTPS + SSE")

Rel(nasim_app, llm, "sends context, receives completions", "HTTP/JSON streaming")
Rel(nasim_app, host_fs, "reads and writes project files", "path I/O")
Rel(nasim_app, sandbox, "runs commands in isolation", "subprocess")
Rel(nasim_app, web, "fetches documentation", "HTTPS")
Rel(nasim_app, mcp_server, "invokes extension tools", "stdio / SSE")
Rel(nasim_app, git, "reads state, creates commits", "git CLI")
Rel(nasim_app, tree_sitter, "parses source code into AST", "in-process / FFI")
Rel(nasim_app, lsp_server, "queries code intelligence", "LSP protocol")
Rel(nasim_app, embedding_model, "generates code embeddings", "HTTP/JSON")
Rel(nasim_app, vector_store, "performs similarity search", "HTTP/JSON")
Rel(nasim_app, log_agent, "emits structured logs to stdout", "stdout only")
Rel(nasim_app, prometheus, "exposes /metrics endpoint", "HTTP GET — pull model")
Rel(grafana, prometheus, "queries metrics", "PromQL")

legend right
    |= Symbol |= Meaning |
    | Person | Human actor |
    | Container | Runtime unit within NASIM Service System |
    | System_Ext | External system |
end legend

@enduml