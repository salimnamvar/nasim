title nasim — Container Diagram

Person(dev, "Developer", "Terminal user")
Person(http_client, "HTTP Client", "Web/mobile/desktop apps")

System_Boundary(nasim, "nasim") {
    Container(cli, "CLI", "Python click + rich", "Terminal interface: REPL, slash commands, rich rendering")
    Container(server, "HTTP API Server", "Python FastAPI", "RESTful API + SSE streaming for web/mobile/desktop clients")
    Container(core, "Core Library", "Python", "Agent orchestration, provider abstraction, tools, sessions, config, hooks, plugins, sandbox, observability, memory, git, MCP")
}

System_Ext(llm_backend, "LLM Backend", "Multi-provider inference: Ollama, OpenAI, Anthropic")
System_Ext(host_fs, "Host Filesystem", "Project code files")
System_Ext(host_shell, "Host Shell", "subprocess execution")
System_Ext(web_ext, "Web", "Documentation and search")
System_Ext(mcp_server, "MCP Server", "Extension tools")
System_Ext(mcp_client, "MCP Client", "External tool consumers")
System_Ext(git_repo, "Git Repository", "Version control")
System_Ext(sandbox_rt, "Sandbox Runtime", "OS-level isolation")
System_Ext(memory_ext, "Memory Backend", "Knowledge store")
System_Ext(lsp_server, "LSP Server", "Code intelligence")
System_Ext(plugin_dir, "Plugin Directory", "Community extensions")

Rel(dev, cli, "types input, reads output")
Rel(http_client, server, "sends requests, receives SSE", "HTTP/JSON")
Rel(cli, core, "delegates to core library")
Rel(server, core, "delegates to core library")
Rel(core, llm_backend, "HTTP POST", "JSON streaming")
Rel(core, host_fs, "read/write/search files")
Rel(core, host_shell, "execute commands via sandbox")
Rel(core, web_ext, "fetch/search")
Rel(core, mcp_server, "invoke extension tools")
Rel(server, mcp_client, "serves MCP protocol", "stdio/SSE")
Rel(core, git_repo, "git operations")
Rel(core, sandbox_rt, "isolated execution")
Rel(core, memory_ext, "knowledge persistence")
Rel(core, lsp_server, "code intelligence")
Rel(core, plugin_dir, "plugin discovery")

SHOW_LEGEND()
