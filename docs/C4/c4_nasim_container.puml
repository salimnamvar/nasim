@startuml nasim_container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Container.puml
!theme plain

' ============================================================
' Title: nasim — Container Diagram
' Boundary: nasim code agent
' Purpose: Show deployable units, technology choices, and observability pipeline
' Milestone: v1.0
' Version: 6.0.0
' Source: docs/audit/audit.2026.06.20.deep.domain.audit.md
' Review: —
' ============================================================

LAYOUT_LEFT_RIGHT()
LAYOUT_WITH_LEGEND()

title nasim — Container Diagram

' ============================================================
' Tags & Styling
' ============================================================

AddElementTag("future", $bgColor="#F0F0F0", $fontColor="#666666", $borderColor="#999999", $borderStyle=DashedLine(), $legendText="Future scope (inactive)")
AddRelTag("future_rel", $textColor="#666666", $lineColor="#999999", $lineStyle=DashedLine(), $legendText="Future relationship")

' ============================================================
' Actors
' ============================================================

Person(dev, "Developer", "Terminal user")
Person(http_client, "HTTP Client", "Web/mobile/desktop apps")

' ============================================================
' nasim Boundary
' ============================================================

System_Boundary(nasim, "nasim") {
    Container(cli, "CLI", "Python click + rich", "Terminal interface: REPL, slash commands, rich rendering")
    Container(server, "HTTP API Server", "Python FastAPI", "RESTful API + SSE streaming for web/mobile/desktop clients")
    Container(core, "Core Library", "Python", "Agent orchestration, provider abstraction, tools, sessions, config, hooks, plugins, sandbox, observability, memory, git, MCP")
}

' ============================================================
' External Systems
' ============================================================

System_Ext(llm_backend, "LLM Backend", "Multi-provider inference: 100+ providers via litellm")
System_Ext(host_fs, "Host Filesystem", "Project code files")
System_Ext(host_shell, "Host Shell", "subprocess execution")
System_Ext(web_ext, "Web", "Documentation and search")
System_Ext(mcp_server, "MCP Server", "Extension tools")
System_Ext(mcp_client, "MCP Client", "External tool consumers")
System_Ext(git_repo, "Git Repository", "Version control")
System_Ext(sandbox_rt, "Sandbox Runtime", "OS-level isolation")
System_Ext(lsp_server, "LSP Server", "Code intelligence")
System_Ext(plugin_dir, "Plugin Directory", "Community extensions")
System_Ext(tree_sitter, "Tree-sitter", "Incremental AST parser for source code")
System_Ext(embedding_model, "Embedding Model", "Code embedding generation (local or API)")
System_Ext(vector_store, "Vector Store", "Persistent vector storage for similarity search")

' ============================================================
' Observability Platform (tenas pattern)
' ============================================================

System_Boundary(obs_platform, "Observability Platform") {
    Container(log_agent, "Log Agent", "Fluent Bit / Vector", "Tails stdout/stderr from Core/CLI/Server processes, parses, enriches with labels, buffers, retries, pushes to Loki")
    Container(loki, "Loki", "Log storage", "Log ingestion, storage, LogQL queries. Low-cardinality label indexing")
    Container(prometheus, "Prometheus", "Metrics store", "Pull-scrapes /metrics endpoint. Time-series store, PromQL")
    Container(grafana, "Grafana", "Dashboard UI", "Read-only visualization + alerting. LogQL and PromQL dashboards")
}

' ============================================================
' Relationships
' ============================================================

Rel(dev, cli, "types input, reads output")
Rel(http_client, server, "sends requests, receives SSE", "HTTP/JSON")
Rel(cli, core, "delegates to core library")
Rel(server, core, "delegates to core library")
Rel(core, llm_backend, "HTTP POST", "JSON streaming")
Rel(core, host_fs, "read/write/search files")
Rel(core, host_shell, "execute commands via sandbox")
Rel(core, web_ext, "fetch/search")
Rel(core, mcp_server, "invoke extension tools")
Rel(server, mcp_client, "serves MCP protocol", "stdio/SSE")
Rel(core, git_repo, "git operations")
Rel(core, sandbox_rt, "isolated execution")
Rel(core, lsp_server, "code intelligence")
Rel(core, plugin_dir, "plugin discovery")
Rel(core, tree_sitter, "parses AST")
Rel(core, embedding_model, "generates embeddings")
Rel(core, vector_store, "vector CRUD")

' ============================================================
' Observability Pipeline (tenas pattern: emit-only app, platform-owned collection)
' ============================================================

Rel(core, log_agent, "writes structured logs to stdout", "stdout only — emit path ends here")
Rel(log_agent, loki, "pushes parsed and enriched logs", "POST /loki/api/v1/push")
Rel(prometheus, core, "pull-scrapes /metrics endpoint", "HTTP GET — pull model only")
Rel(grafana, loki, "queries logs", "LogQL")
Rel(grafana, prometheus, "queries metrics", "PromQL")

@enduml
