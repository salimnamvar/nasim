@startuml c4_nasim_container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Container.puml
!include common/c4_styles.puml
!theme plain

' ============================================================
' Title:     NASIM Application — Container Diagram
' Boundary:  NASIM Application
' Purpose:   Show the 3 runtime entry points (CLI Process, HTTP
'            API Server, Core Engine) and architecturally
'            significant external systems they depend on.
'            CLI and HTTP are separate entry points within a
'            single Python process.
' Milestone: v1.0
' Version:   9.0.0
' Source:    docs/entities.md
' Review:    —
' Date:      2026-06-25
' ============================================================

LAYOUT_TOP_DOWN()
LAYOUT_WITH_LEGEND()

title NASIM Application — Container Diagram

Person(user, "User", "Developer using NASIM Application as an AI coding assistant")

System_Boundary(nasim_application, "NASIM Application") {
    Container(cli_process, "CLI Process", "Python 3.10+", "Terminal interface: REPL, arg parsing, rendering. Delegates to Core Engine.")
    Container(api_server, "HTTP API Server", "FastAPI + SSE", "REST API with Server-Sent Events streaming. Entry gate for all interface containers.")
    Container(core_engine, "Core Engine", "Python 3.10+", "Unified agent engine: agentic loop, tool orchestration, safety, context management, business logic")
}

Container_Ext(webapp, "WebApp", "JavaScript SPA", "Browser-based interface connecting to API Server via HTTP")
Container_Ext(desktop_app, "DesktopApp", "Electron / Tauri", "Desktop application connecting to API Server via HTTP")
Container_Ext(mobile_app, "MobileApp", "React Native / Flutter", "Mobile application connecting to API Server via HTTP")

System_Ext(mcp_client, "MCP Client", "External tools and IDEs that consume NASIM Application's exposed capabilities via MCP")
System_Ext(llm_backend, "LLM Backend", "Multi-provider inference: Ollama, OpenAI, Anthropic, and 100+ via litellm")
System_Ext(host_fs, "Host Filesystem", "Project source code, configuration, documentation, and community plugin files")
System_Ext(host_shell, "Host Shell", "OS-level subprocess execution for shell commands")
System_Ext(mcp_server, "MCP Server", "Extension tools provided to NASIM Application via Model Context Protocol")

Rel(user, cli_process, "runs coding tasks", "terminal REPL")
Rel(user, webapp, "interacts via browser", "HTTPS")
Rel(user, desktop_app, "interacts via desktop app", "local")
Rel(user, mobile_app, "interacts via mobile app", "HTTPS")

Rel(cli_process, core_engine, "delegates tasks", "in-process call")
Rel(webapp, api_server, "submits coding tasks and streams AI responses", "HTTP/JSON + SSE")
Rel(desktop_app, api_server, "submits coding tasks and streams AI responses", "HTTP/JSON + SSE")
Rel(mobile_app, api_server, "submits coding tasks and streams AI responses", "HTTP/JSON + SSE")
Rel(mcp_client, core_engine, "invokes NASIM Application tools via MCP protocol", "stdio / SSE")
Rel(api_server, core_engine, "delegates to core agent engine", "in-process call")

Rel(core_engine, llm_backend, "sends context and receives code completions", "HTTP/JSON streaming")
Rel(core_engine, host_fs, "reads, writes, and searches project files", "path I/O")
Rel(core_engine, host_shell, "executes shell commands", "subprocess")
Rel(core_engine, mcp_server, "discovers and invokes extension tools", "stdio / SSE")

@enduml
