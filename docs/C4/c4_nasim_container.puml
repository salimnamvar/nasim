@startuml c4_nasim_container
' ============================================================
' Title:     NASIM Service — Container Diagram
' Boundary:  NASIM Service
' Purpose:   NASIM Application is the single deployable container.
'            All interfaces (CLI, WebApp, DesktopApp, MobileApp,
'            MCP Client) are external clients connecting to it.
' Milestone: v1.0
' Version:   13.1.0
' Source:    docs/C4/c4_nasim_context.puml (v13.0.0)
' ============================================================

!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Container.puml
!include common/c4_styles.puml

LAYOUT_TOP_DOWN()

title NASIM Service — Container Diagram

' ── Actors ──────────────────────────────────────────────────
Person(user, "Developer", "Uses NASIM as an AI coding assistant", $sprite="person")

' ── External Clients ────────────────────────────────────────
Container_Ext(cli, "CLI", "Python 3.10+", "Terminal interface: REPL, arg parsing, slash commands", $tags="external_container")
Container_Ext(webapp, "WebApp", "JavaScript SPA", "Browser-based interface", $tags="external_container")
Container_Ext(desktop, "DesktopApp", "Electron / Tauri", "Desktop application", $tags="external_container")
Container_Ext(mobile, "MobileApp", "React Native / Flutter", "Mobile application", $tags="external_container")
Container_Ext(mcp_client, "MCP Client", "External tools consuming NASIM via MCP", $tags="machine_client")

' ── NASIM Service Boundary ──────────────────────────────────
System_Boundary(nasim_service, "NASIM Service") {
    Container(nasim_app, "NASIM Application", "Python 3.10+", "AI coding agent: agentic loop, tool orchestration, safety, context management")
}

' ── External Systems ────────────────────────────────────────
System_Ext(llm, "LLM Backend", "Multi-provider inference via litellm")
System_Ext(host_fs, "Host Filesystem", "Project source code and configuration")
System_Ext(sandbox, "Sandbox Runtime", "OS-level process isolation")
System_Ext(web, "Web", "Documentation and search engines")
System_Ext(mcp_server, "MCP Server", "Extension tools via MCP protocol")
System_Ext(git, "Git Repository", "Version-controlled project files")
System_Ext(repo_intel, "Repo Intelligence Backend", "Tree-sitter, LSP, embeddings, vector store")



' ── User → External Clients ─────────────────────────────────
Rel(user, cli, "runs coding tasks", "terminal REPL")
Rel(user, webapp, "interacts via browser", "HTTPS")
Rel(user, desktop, "interacts via desktop app", "local")
Rel(user, mobile, "interacts via mobile app", "HTTPS")

' ── External Clients → NASIM Application ────────────────────
' Changed: CLI uses stdio (local process IPC), not HTTP/JSON + SSE
Rel(cli, nasim_app, "delegates tasks", "stdio")
Rel(webapp, nasim_app, "delegates tasks", "HTTP/JSON + SSE")
Rel(desktop, nasim_app, "delegates tasks", "HTTP/JSON + SSE")
Rel(mobile, nasim_app, "delegates tasks", "HTTPS + SSE")
Rel(mcp_client, nasim_app, "invokes NASIM tools via MCP", "stdio / SSE")

' ── NASIM Application → External Systems ────────────────────
Rel(nasim_app, llm, "sends context, receives completions", "HTTP/JSON streaming")
Rel(nasim_app, host_fs, "reads and writes project files", "path I/O")
Rel(nasim_app, sandbox, "runs commands in isolation", "subprocess")
Rel(nasim_app, web, "fetches documentation", "HTTPS")
Rel(nasim_app, mcp_server, "invokes extension tools", "stdio / SSE")
Rel(nasim_app, git, "reads state, creates commits", "git CLI")
Rel(nasim_app, repo_intel, "parses code, queries intelligence", "in-process / HTTP")

$nasim_legend_container()

@enduml
