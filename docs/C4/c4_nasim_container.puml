@startuml c4_nasim_container
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Container.puml
!theme plain

' ============================================================
' Title:     NASIM Application — Container Diagram
' Boundary:  NASIM Application
' Purpose:   Show the 3 runtime entry points within NASIM Application:
'            1. CLI Process (terminal interface)
'            2. HTTP API Server (FastAPI + SSE)
'            3. Core Engine (agent loop, tools, business logic)
'
'            WHY CLI AND HTTP ARE SEPARATE CONTAINERS:
'            NASIM Application runs as a single Python process. However,
'            CLI Process and HTTP API Server are modeled as separate
'            Containers because they are distinct RUNTIME ENTRY POINTS —
'            each with its own initialization, argument parsing, request
'            handling, and lifecycle. In C4, a Container represents a
'            separately runnable/deployable unit OR a distinct runtime
'            responsibility. Here, the "responsibility" interpretation
'            applies: they share a process boundary but serve different
'            interaction models (terminal REPL vs HTTP+SSE).
'
'            WHY WEBAPP/DESKTOP/MOBILE ARE Container_Ext:
'            WebApp, DesktopApp, and MobileApp are genuinely separate
'            deployable units (browser SPA, Electron app, mobile app)
'            with their own processes, codebases, and deployment pipelines.
'            They are NOT part of NASIM Application — they are clients
'            that communicate with it over HTTP. In C4, a Container_Ext
'            represents a container outside the system boundary that
'            interacts with it. This is the correct model for external
'            client applications.
'
'            CONTAINER vs COMPONENT distinction:
'            - Container: represents a separately runnable unit OR a
'              distinct runtime entry point (CLI Process, HTTP API Server)
'              OR the main application shell (Core Engine).
'            - Component: represents an internal module/class within a
'              Container (e.g., AgentOrchestrator, SafetyCoordinator).
'            The HTTP API Server is NOT a Component because it is a
'            distinct entry point with its own lifecycle, not an internal
'            module of the Core Engine.
' Milestone: v1.0
' Version:   9.0.0
' Source:    docs/entities.md
' Review:    —
' ============================================================

LAYOUT_LEFT_RIGHT()
LAYOUT_WITH_LEGEND()

title NASIM Application — Container Diagram

Person(user, "User", "Developer using NASIM Application as an AI coding assistant")

System_Boundary(nasim_application, "NASIM Application") {
    Container(cli_process, "CLI Process", "Python 3.10+", "Terminal interface: REPL, arg parsing, rendering. Delegates to Core Engine.")
    Container(api_server, "HTTP API Server", "FastAPI + SSE", "REST API with Server-Sent Events streaming. Entry gate for all interface containers.")
    Container(core_engine, "Core Engine", "Python 3.10+", "Unified agent engine: agentic loop, tool orchestration, safety, context management, business logic")
}

Container_Ext(webapp, "WebApp", "JavaScript SPA", "Browser-based interface connecting to API Server via HTTP")
Container_Ext(desktop_app, "DesktopApp", "Electron / Tauri", "Desktop application connecting to API Server via HTTP")
Container_Ext(mobile_app, "MobileApp", "React Native / Flutter", "Mobile application connecting to API Server via HTTP")

System_Ext(mcp_client, "MCP Client", "External tool or IDE that invokes NASIM Application via MCP protocol")
System_Ext(llm_backend, "LLM Backend", "Multi-provider inference: Ollama, OpenAI, Anthropic, and 100+ via litellm")
System_Ext(host_fs, "Host Filesystem", "Project code files and directories")
System_Ext(host_shell, "Host Shell", "Shell execution via OS subprocess")
System_Ext(web_ext, "Web", "Documentation pages and search engines")
System_Ext(mcp_server, "MCP Server", "Extension tools provided to NASIM Application via Model Context Protocol")
System_Ext(git_repo, "Git Repository", "Version-controlled project files")
System_Ext(sandbox_rt, "Sandbox Runtime", "OS-level process isolation (landlock, seccomp, bubblewrap)")
System_Ext(lsp_server, "LSP Server", "Language server providing code intelligence")
System_Ext(plugin_dir, "Plugin Directory", "Community plugins at ~/.nasim/plugins/")
System_Ext(tree_sitter, "Tree-sitter", "Incremental AST parser for source code indexing")
System_Ext(embedding_model, "Embedding Model", "Code embedding generation (local or API-based)")
System_Ext(vector_store, "Vector Store", "Persistent vector storage for semantic code search")
System_Ext(otel_collector, "OTel Collector", "OTLP/gRPC endpoint for optional trace and metric export")
System_Ext(obs_platform, "Observability Platform", "Log agent, Prometheus, Grafana. NASIM Application emits only — platform owns collection, storage, and visualization.")

Rel(user, cli_process, "runs coding tasks (CLI mode)", "terminal REPL")
Rel(user, webapp, "interacts via browser", "HTTPS")
Rel(user, desktop_app, "interacts via desktop app", "local")
Rel(user, mobile_app, "interacts via mobile app", "HTTPS")

Rel(cli_process, core_engine, "delegates tasks", "Internal Call")
Rel(webapp, api_server, "submits coding tasks and streams AI responses", "HTTP/JSON + SSE")
Rel(desktop_app, api_server, "submits coding tasks and streams AI responses", "HTTP/JSON + SSE")
Rel(mobile_app, api_server, "submits coding tasks and streams AI responses", "HTTP/JSON + SSE")
Rel(mcp_client, api_server, "invokes tools via MCP protocol", "stdio / SSE")
Rel(api_server, core_engine, "delegates to core agent engine", "Internal Call")

Rel(core_engine, llm_backend, "sends chat requests, receives completions", "HTTP/JSON streaming")
Rel(core_engine, host_fs, "reads, writes, and searches project files")
Rel(core_engine, host_shell, "executes shell commands via sandbox")
Rel(core_engine, web_ext, "fetches documentation and search results", "HTTP")
Rel(core_engine, mcp_server, "discovers and invokes extension tools", "stdio / SSE")
Rel(core_engine, git_repo, "reads status and creates commits", "git CLI")
Rel(core_engine, sandbox_rt, "executes commands in isolated environment")
Rel(core_engine, lsp_server, "queries code intelligence", "LSP protocol")
Rel(core_engine, plugin_dir, "discovers and loads plugins at startup")
Rel(core_engine, tree_sitter, "parses source code AST for indexing")
Rel(core_engine, embedding_model, "generates code embeddings")
Rel(core_engine, vector_store, "stores and retrieves code embeddings")
Rel(core_engine, otel_collector, "exports traces and metrics (optional)", "OTLP/gRPC")
Rel(core_engine, obs_platform, "emits structured logs to stdout; exposes /metrics for pull-scrape", "stdout + HTTP")

' ============================================================
' Note for Readers:
' ============================================================
' NASIM Application runs as a SINGLE Python process.
' CLI Process and HTTP API Server are NOT separate deployments —
' they are separate RUNTIME ENTRY POINTS within the same process.
'
' In C4, a Container models a unit with a distinct runtime
' responsibility. CLI Process handles terminal interaction (REPL,
' arg parsing, rendering). HTTP API Server handles HTTP requests
' and SSE streaming. Both delegate to the shared Core Engine.
'
' WebApp, DesktopApp, and MobileApp are modeled as Container_Ext
' because they are truly separate deployable units (browser SPA,
' Electron app, mobile app) with their own processes. They are
' clients of NASIM Application, not part of it.
' ============================================================

@enduml
