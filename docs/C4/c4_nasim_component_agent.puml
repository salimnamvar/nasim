@startuml c4_nasim_component_agent
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/v2.10.0/C4_Component.puml
!include common/c4_styles.puml
!theme plain

' ============================================================
' Title:     NASIM Application — Agent Component Diagram
' Boundary:  NASIM Application (container) — Agent Group
' Purpose:   Agent Group: core agentic loop (Service layer).
'            AgentOrchestrator is the single orchestrating
'            component for the nasim Service layer.
'            CSR Layer: Service
' Milestone: v1.0
' Version:   9.1.0
' Source:    docs/entities.md
' Review:    CAR audit 2026-06-26
' Date:      2026-06-26
' ============================================================

title NASIM Application — Agent Component Diagram

Boundary(nasim_application, "NASIM Application") {
    Boundary(agent_group, "Agent Group") <<service>> {
        Component(agent_orch, "AgentOrchestrator", "", "Core agentic loop: Provider call, tool dispatch, repeat. Yields structured events")
        Component(conv_history, "ConversationHistory", "", "Owns messages list and token count. Triggers compaction when budget exceeded")
        Component(compactor, "ContextCompactor", "", "Summarizes old exchanges via secondary LLM call when budget exceeded")
        Component(plan_session, "PlanSession", "", "Holds queued tool calls in plan mode. /approve drains the queue")
        Component(subagent_coord, "SubagentCoordinator", "", "Parent-child orchestration, nesting limit 5, result aggregation")
        Component(error_boundary, "ErrorBoundary", "", "Structured error handling with recovery actions and error hierarchy")
        Component(persona_mgr, "PersonaManager", "", "Runtime persona switching for specialized agent roles")
    }
}

Component_Ext(provider, "Provider", "Provider Group")
Component_Ext(tool_registry, "ToolRegistry", "Tool Group")
Component_Ext(session_store, "SessionStore", "Session Group")
Component_Ext(memory_store, "MemoryStore", "Memory Group")
Component_Ext(structured_logger, "StructuredLogger", "Observability Group")
Component_Ext(safety_coord, "SafetyCoordinator", "Safety Group")

Rel(agent_orch, provider, "invokes LLM inference for task completion")
Rel(agent_orch, tool_registry, "dispatches tool calls for execution")
Rel(agent_orch, conv_history, "persists and retrieves conversation messages")
Rel(agent_orch, safety_coord, "validates before tool dispatch")
Rel(agent_orch, subagent_coord, "spawns and aggregates child agent results")
Rel(agent_orch, error_boundary, "delegates structured error handling with recovery")
Rel(agent_orch, persona_mgr, "loads and switches agent persona at runtime")
Rel(agent_orch, memory_store, "persists and retrieves cross-session knowledge")
Rel(agent_orch, session_store, "saves and loads session state")
Rel(agent_orch, structured_logger, "emits structured logs and metrics")
Rel(agent_orch, plan_session, "queues tool calls in plan mode for batch approval")
Rel(conv_history, compactor, "triggers compaction when token budget exceeded")
Rel(compactor, provider, "invokes secondary LLM for context summarization")
Rel(subagent_coord, agent_orch, "child agent inherits core orchestration loop")

legend right
    |<#E3F2FD>  **Controller** | CLI Group, API Group |
    |<#FFF3E0>  **Service**    | Agent, Router, Provider, Safety, Context Graph, Edit Strategy, Evaluation |
    |<#E8F5E9>  **Repository** | Session, Tool, Memory, Config, Git, Repo Intelligence |
    |<#F3E5F5>  **Infrastructure** | MCP, Sandbox, Observability, Wire Log, Hooks, Plugins |
end legend

@enduml
