#!/usr/bin/env bash
# nasim — selector + launcher for all remote Ollama solutions on "black" + frontier terminal agents on laptop.
# Primary UX: `nasim select` (interactive) or `nasim launch --access ... --agent ...`
# Thin glue only. Real power from native Ollama (Anthropic compat), Tailscale/SSH, LiteLLM, claude/aider/opencode.
# Every feature (transport x agent) is exercised by tests/nasim-features.sh + .github/workflows/ci.yml matrix.
# Live testable on salim-hp against real black via SSH.

set -euo pipefail

# Allow sourcing for tests (harness does NASIM_TEST_MODE + source or just calls the bin).
if [[ "${NASIM_INTERNAL:-}" == "1" && "${BASH_SOURCE[0]}" != "${0}" ]]; then
    # When sourced, just define functions and return; do not parse args.
    :
fi

NASIM_VERSION="2026-06-16-v2-select"
BLACK_HOST="${NASIM_BLACK_HOST:-black}"
DEFAULT_MODEL="${NASIM_MODEL:-${NASIM_DEFAULT_MODEL:-qwen2.5-coder:14b}}"
DEFAULT_LOCAL_PORT=11435
LITELLM_PORT=4000

# --- Utilities ---

die() { echo "nasim: $*" >&2; exit 1; }
log() { echo "nasim: $*" >&2; }
have() { command -v "$1" >/dev/null 2>&1; }

free_port() {
    # Find a free local port starting from base.
    local base="${1:-$DEFAULT_LOCAL_PORT}"
    local p=$base
    while ss -ltn 2>/dev/null | grep -q ":$p " || netstat -ltn 2>/dev/null | grep -q ":$p "; do
        p=$((p+1))
        [[ $p -gt $((base+100)) ]] && die "no free port found near $base"
    done
    echo "$p"
}

cleanup_tunnel() {
    local pidfile="${1:-}"
    if [[ -n "$pidfile" && -f "$pidfile" ]]; then
        local pid
        pid=$(cat "$pidfile" 2>/dev/null || true)
        if [[ -n "$pid" ]]; then
            kill "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
        fi
        rm -f "$pidfile"
    fi
}

probe_url() {
    local url="$1"
    curl -sf --max-time 6 --connect-timeout 3 "$url/api/tags" >/dev/null
}

probe_and_show() {
    local url="$1"
    log "probing $url ..."
    if probe_url "$url"; then
        log "OK: endpoint reachable"
        # Print model list to stderr so dry-run capture of stdout (the URL) stays clean
        curl -s --max-time 5 "$url/api/tags" | python3 -c '
import sys, json
try:
    d=json.load(sys.stdin)
    names=[m.get("name","?") for m in d.get("models",[])][:6]
    print("  models:", " ".join(names), file=sys.stderr)
except: print("  (could not parse model list)", file=sys.stderr)
' 2>/dev/null || true
        return 0
    else
        log "FAIL: $url not reachable"
        return 1
    fi
}

# --- Transport setup (return the effective base URL on success) ---

setup_ssh_tunnel() {
    if is_dry; then
        echo "http://127.0.0.1:11435"
        return 0
    fi
    local lport
    lport=$(free_port "$DEFAULT_LOCAL_PORT")
    local pidfile="/tmp/nasim-ssh-tunnel-$$.pid"
    log "starting SSH tunnel: $lport -> $BLACK_HOST:11434"
    # Use -f to background immediately; -N no command; keepalives.
    ssh -o ConnectTimeout=8 -o ServerAliveInterval=20 -o ServerAliveCountMax=3 \
        -o ExitOnForwardFailure=yes -f -N -L "${lport}:localhost:11434" "$BLACK_HOST"
    local ssh_pid
    # Best effort: the -f ssh writes its pid to the controlling; we poll briefly.
    sleep 0.6
    # Record a best-effort pid (pgrep the forward for cleanup).
    pgrep -f "ssh.*${lport}.*${BLACK_HOST}" | head -1 > "$pidfile" || true
    local url="http://127.0.0.1:${lport}"
    # Register cleanup for this shell
    trap "cleanup_tunnel '$pidfile'" EXIT INT TERM
    if ! probe_and_show "$url"; then
        cleanup_tunnel "$pidfile"
        die "SSH tunnel came up but probe failed. Is ollama running on black?"
    fi
    echo "$url"
}

setup_tailscale() {
    if is_dry; then
        echo "http://black:11434"
        return 0
    fi
    if ! have tailscale || ! tailscale status >/dev/null 2>&1; then
        log "Tailscale not running or not installed on this machine. Falling back or choose another access."
        return 1
    fi
    # Prefer MagicDNS name "black" if it resolves in tailnet; else try to get black's ts ip (requires ssh or known).
    local url="http://black:11434"
    if probe_and_show "$url"; then
        echo "$url"
        return 0
    fi
    # Fallback: ask black its tailscale ip (via the ssh we know works) and use the 100.x address.
    if have ssh; then
        local tsip
        tsip=$(ssh -o ConnectTimeout=5 "$BLACK_HOST" 'tailscale ip -4 2>/dev/null | head -1' || true)
        if [[ -n "$tsip" ]]; then
            url="http://${tsip}:11434"
            if probe_and_show "$url"; then
                echo "$url"
                return 0
            fi
        fi
    fi
    log "Tailscale present but could not reach black:11434. Is black in the same tailnet and ollama listening?"
    return 1
}

setup_litellm() {
    local inner_url="$1"   # the real ollama base we already verified (ssh or ts)
    if is_dry; then
        echo "http://127.0.0.1:${LITELLM_PORT}"
        return 0
    fi
    local cfg="/tmp/nasim-litellm-$$.yaml"
    local pidfile="/tmp/nasim-litellm-$$.pid"
    cat > "$cfg" <<EOF
model_list:
  - model_name: black-default
    litellm_params:
      model: ollama/${DEFAULT_MODEL}
      api_base: ${inner_url}
  - model_name: black-fast
    litellm_params:
      model: ollama/llama3.1:8b
      api_base: ${inner_url}
EOF
    log "litellm config: $cfg (inner: $inner_url)"
    if ! have litellm; then
        log "litellm not installed. pip install 'litellm[proxy]' then re-run, or use direct transport."
        # Still return a would-be url for dry runs / tests
        echo "http://127.0.0.1:${LITELLM_PORT}"
        return 0
    fi
    # Start in background
    litellm --config "$cfg" --port "$LITELLM_PORT" --num_workers 1 >/tmp/nasim-litellm-$$.log 2>&1 &
    local lpid=$!
    echo "$lpid" > "$pidfile"
    sleep 1.2
    trap "cleanup_tunnel '$pidfile'; rm -f '$cfg' /tmp/nasim-litellm-$$.log 2>/dev/null || true" EXIT INT TERM
    local url="http://127.0.0.1:${LITELLM_PORT}"
    if probe_and_show "$url"; then
        echo "$url"
        return 0
    fi
    # Non-fatal for some agents; return anyway
    echo "$url"
}

# --- Agent launchers (set envs then exec). In dry mode they print instead of exec. ---

is_dry() { [[ "${NASIM_TEST_MODE:-}${1:-}" == *dry* || "${NASIM_DRY_RUN:-}" == "1" ]]; }

launch_claude() {
    local url="$1" model="$2"
    log "launching claude -> $url model=$model (native Anthropic compat)"
    if is_dry; then
        echo "DRY: ANTHROPIC_AUTH_TOKEN=ollama ANTHROPIC_BASE_URL=$url ANTHROPIC_API_KEY= CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 claude --model $model"
        return 0
    fi
    ANTHROPIC_AUTH_TOKEN=ollama \
    ANTHROPIC_BASE_URL="$url" \
    ANTHROPIC_API_KEY="" \
    CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1 \
    exec claude --model "$model" "${@:3}"
}

launch_aider() {
    local url="$1" model="$2"
    local m="ollama/${model}"
    log "launching aider -> $url model=$m"
    if is_dry; then
        echo "DRY: OLLAMA_API_BASE=$url aider --model $m"
        return 0
    fi
    export OLLAMA_API_BASE="$url"
    exec aider --model "$m" "${@:3}"
}

launch_opencode() {
    local url="$1" model="$2"
    # 2026: opencode (from research) accepts OpenAI compat or ollama provider. We prefer OpenAI-style base for broadest compat.
    log "launching opencode -> $url model=$model (OpenAI compat base)"
    if is_dry; then
        echo "DRY: OPENAI_BASE_URL=$url OPENAI_API_KEY=ollama opencode (or ollama launch opencode) model=$model"
        return 0
    fi
    # Try the common pattern; user can adjust per OD-01.
    OPENAI_BASE_URL="$url" OPENAI_API_KEY="ollama" \
    exec opencode --model "$model" "${@:3}" 2>/dev/null || \
    OPENAI_BASE_URL="$url" exec opencode "${@:3}"
}

launch_terminal() {
    local url="$1" model="$2"
    log "dropping into configured shell (all envs set). Run your agents manually."
    if is_dry; then
        echo "DRY: export ANTHROPIC_BASE_URL=$url OLLAMA_API_BASE=$url NASIM_REMOTE_URL=$url"
        echo "DRY: PS1=\"nasim[black:${model}] $ \" ; exec \$SHELL -i"
        return 0
    fi
    export ANTHROPIC_AUTH_TOKEN=ollama
    export ANTHROPIC_BASE_URL="$url"
    export ANTHROPIC_API_KEY=""
    export OLLAMA_API_BASE="$url"
    export NASIM_REMOTE_URL="$url"
    export NASIM_MODEL="$model"
    export PS1="nasim[black:${model}] \$ "
    exec "${SHELL:-/bin/bash}" -i
}

# --- High level: choose transport then agent ---

choose_and_launch() {
    local access="${1:-ssh-tunnel}"
    local agent="${2:-claude}"
    local model="${3:-$DEFAULT_MODEL}"
    local url

    if is_dry; then
        # Dry: never touch network or ssh. Return a deterministic fake URL so launchers can emit clean DRY lines.
        url="http://127.0.0.1:11435"
        log "(dry) would setup access=$access (no real tunnel)"
    else
        case "$access" in
            ssh-tunnel|ssh)
                url=$(setup_ssh_tunnel) ;;
            tailscale|ts)
                url=$(setup_tailscale) || { log "Tailscale unavailable — try ssh-tunnel"; url=$(setup_ssh_tunnel); } ;;
            litellm|llm)
                local inner
                inner=$(setup_ssh_tunnel)
                url=$(setup_litellm "$inner") ;;
            *)
                die "unknown access: $access (ssh-tunnel | tailscale | litellm)" ;;
        esac
    fi

    # Final probe (defensive) — skipped in dry
    if ! is_dry && ! probe_url "$url"; then
        die "final probe failed for $url"
    fi

    case "$agent" in
        claude|code)      launch_claude "$url" "$model" "${@:4}" ;;
        aider)            launch_aider  "$url" "$model" "${@:4}" ;;
        opencode|open)    launch_opencode "$url" "$model" "${@:4}" ;;
        terminal|shell)   launch_terminal "$url" "$model" ;;
        *)
            log "unknown agent '$agent' — falling back to terminal shell"
            launch_terminal "$url" "$model" ;;
    esac
}

# --- Interactive select ---

do_select() {
    log "nasim select — choose access to black + frontier agent (Ctrl-C aborts)"
    echo

    # Access
    local accesses=("ssh-tunnel (recommended, always works here)" "tailscale (if up)" "litellm (proxy on top)")
    local access_keys=("ssh-tunnel" "tailscale" "litellm")
    PS3="Access method (1-3): "
    select a in "${accesses[@]}"; do
        if [[ -n "$a" ]]; then
            ACCESS="${access_keys[$((REPLY-1))]}"
            break
        fi
    done
    echo "Selected access: $ACCESS"
    echo

    # Agent
    local agents=("claude (native Anthropic compat — full frontier agent)" "aider (git-centric, excellent local)" "opencode (open Claude Code alt)" "terminal (branded shell — manual any agent)")
    local agent_keys=("claude" "aider" "opencode" "terminal")
    PS3="Agent / terminal (1-4): "
    select ag in "${agents[@]}"; do
        if [[ -n "$ag" ]]; then
            AGENT="${agent_keys[$((REPLY-1))]}"
            break
        fi
    done
    echo "Selected agent: $AGENT"
    echo

    # Model (simple prompt; could read from probe later)
    read -r -p "Model tag on black [${DEFAULT_MODEL}]: " m
    MODEL="${m:-$DEFAULT_MODEL}"

    echo
    log "Bringing up $ACCESS + $AGENT + $MODEL ..."
    choose_and_launch "$ACCESS" "$AGENT" "$MODEL"
}

# --- CLI surface + legacy compat ---

cmd="${1:-help}"
shift || true

case "$cmd" in
    select)
        do_select "$@"
        ;;
    launch)
        # nasim launch --access X --agent Y --model Z [extra args to agent]
        access="ssh-tunnel"; agent="claude"; model="$DEFAULT_MODEL"
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --access) access="$2"; shift 2 ;;
                --agent)  agent="$2"; shift 2 ;;
                --model)  model="$2"; shift 2 ;;
                --dry-run) export NASIM_DRY_RUN=1; shift ;;
                *) break ;;
            esac
        done
        choose_and_launch "$access" "$agent" "$model" "$@"
        ;;
    claude|code)
        # Legacy thin path (still useful). Assumes a tunnel or NASIM_REMOTE_URL already set, or auto ssh.
        url="${NASIM_REMOTE_URL:-http://127.0.0.1:11435}"
        model="${NASIM_MODEL:-$DEFAULT_MODEL}"
        if [[ -z "${NASIM_REMOTE_URL:-}" ]]; then
            log "no NASIM_REMOTE_URL; starting ad-hoc ssh tunnel for legacy claude..."
            url=$(setup_ssh_tunnel)
        fi
        launch_claude "$url" "$model" "$@"
        ;;
    aider)
        url="${NASIM_REMOTE_URL:-http://127.0.0.1:11435}"
        model="${NASIM_MODEL:-ollama/${DEFAULT_MODEL}}"
        if [[ -z "${NASIM_REMOTE_URL:-}" ]]; then
            log "no NASIM_REMOTE_URL; starting ad-hoc ssh tunnel for legacy aider..."
            url=$(setup_ssh_tunnel)
        fi
        launch_aider "$url" "$model" "$@"
        ;;
    doctor|probe|status)
        url="${NASIM_REMOTE_URL:-http://127.0.0.1:11435}"
        if [[ $# -gt 0 && "$1" == "--url" ]]; then url="$2"; fi
        log "nasim doctor (version $NASIM_VERSION)"
        echo "  effective url: $url"
        echo "  black host:    $BLACK_HOST"
        probe_and_show "$url" || true
        # Also try to show GPU state on black (best effort)
        if have ssh; then
            echo "  black ollama ps (via ssh):"
            ssh -o ConnectTimeout=4 "$BLACK_HOST" 'ollama ps 2>/dev/null || curl -s http://localhost:11434/api/ps | head -c 300' 2>/dev/null || echo "    (ssh to black for ps failed)"
        fi
        ;;
    tunnel)
        sub="${1:-help}"; shift || true
        case "$sub" in
            ssh|start)
                setup_ssh_tunnel >/dev/null
                log "tunnel running (cleanup on this shell exit)"
                # Keep the shell alive so trap works if user wants
                echo "Press Ctrl-C or exit shell to tear down."
                sleep 99999 || true
                ;;
            status)
                pgrep -af "ssh.*${BLACK_HOST}" | grep -E 'L .*1143' || echo "no obvious nasim ssh tunnel"
                ;;
            *)
                echo "nasim tunnel ssh|status"
                ;;
        esac
        ;;
    help|*)
        cat <<EOF
nasim $NASIM_VERSION — all solutions for remote Ollama on black + terminal frontier agents on laptop.

Primary:
  nasim select                     Interactive chooser (access + agent + model) then launch
  nasim launch --access ssh-tunnel --agent claude --model qwen2.5-coder:14b
                                   Non-interactive. Access: ssh-tunnel | tailscale | litellm
                                   Agent:   claude | aider | opencode | terminal

Legacy (still work, auto-tunnel if no NASIM_REMOTE_URL):
  nasim claude [args...]
  nasim aider  [args...]

Utility:
  nasim doctor [--url URL]         Probe reachability, list models, black GPU state
  nasim status                     Alias for doctor
  nasim tunnel ssh                 Start a persistent-for-shell SSH forward (cleanup on exit)
  nasim tunnel status

Env overrides:
  NASIM_REMOTE_URL=http://...      Force a base (skips tunnel setup in some paths)
  NASIM_MODEL=...                  Default model
  NASIM_BLACK_HOST=black
  NASIM_TEST_MODE=1 or --dry-run   Print instead of exec (for CI/tests)

See:
  .grok/research/2026-06-16-frontier-agents-with-local-remote-ollama.md
  .grok/recipes/ (tunnel, remote-claude-code, etc.)
  tests/nasim-features.sh + .github/workflows/ci.yml (every combo is CI-tested)

All solutions implemented + tested before "go ahead".
EOF
        ;;
esac
